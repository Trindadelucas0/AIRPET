# ==============================================
# AIRPET — Configuracoes do Ambiente
# Copie este arquivo para .env e preencha os valores
# NUNCA commite o .env no repositorio
# ==============================================

# Banco de Dados PostgreSQL + PostGIS
DB_HOST=localhost
DB_PORT=5432
DB_USER=
DB_PASSWORD=
DB_DATABASE=airpet

# JWT (JSON Web Token)
JWT_SECRET=
JWT_EXPIRES_IN=7d

# Sessao Express
SESSION_SECRET=

# Servidor
PORT=3000
NODE_ENV=development

# URL base do sistema (para gerar QR Codes, links de tags NFC, redefinir senha, compartilhar)
# Em producao use o dominio real com https. Ex.: https://airpet.seuregistroonline.com.br
BASE_URL=http://localhost:3000

# Web Push (VAPID keys) — gere com: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:admin@airpet.com

# Limite de cadastros: total máximo de usuários permitidos no sistema.
# O app verifica automaticamente no registro (Usuario.contarTotal() >= MAX_USUARIOS = bloqueia).
# Use 0 ou deixe vazio = sem limite. Ex.: 50 = após 50 usuários ninguém pode se cadastrar.
MAX_USUARIOS=10

# Credenciais do Admin (acesso ao painel administrativo)
ADMIN_EMAIL=admin@airpet.com
ADMIN_PASSWORD=12345
