{
  "name": "airpet",
  "version": "1.0.0",
  "description": "Sistema de identificacao e recuperacao de pets via NFC — PWA com mapas, chat moderado e dashboard admin",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "prestart": "npm run css:build",
    "predev": "npm run css:build",
    "postinstall": "npm run css:build",
    "start:prod": "npm run css:build && node server.js",
    "css:build": "node node_modules/tailwindcss/lib/cli.js -i ./src/public/css/input.css -o ./src/public/css/output.css --minify",
    "css:watch": "node node_modules/tailwindcss/lib/cli.js -i ./src/public/css/input.css -o ./src/public/css/output.css --watch",
    "send:test-emails": "node scripts/debug/send-test-emails-once.js --to=lucasrodrigues4@live.com",
    "db:migrate": "node scripts/run-pgm.cjs up",
    "db:migrate:down": "node scripts/run-pgm.cjs down",
    "db:migrate:create": "node scripts/run-pgm.cjs create",
    "db:health": "node scripts/db-health.cjs",
    "migrate:r2": "node scripts/migrate-local-images-to-r2.cjs",
    "test:r2": "node scripts/test-r2-put.cjs",
    "metrics:reconcile": "node scripts/reconcile-r2-metrics.cjs",
    "lint": "eslint \"src/controllers\" \"src/services\" \"src/routes\"",
    "test": "node --test tests/smoke-app.test.js tests/smoke-utils.test.js tests/smoke-admin-path.test.js tests/csrf-origin-guard.test.js tests/explorar-post-validators.test.js",
    "calibrate": "node scripts/calibrate.cjs",
    "admin:url": "node scripts/print-admin-urls.cjs",
    "mapa:debug-tag": "node scripts/print-tag-scan-map-debug.cjs"
  },
  "keywords": [
    "pet",
    "nfc",
    "pwa",
    "leaflet",
    "postgresql"
  ],
  "license": "ISC",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1023.0",
    "bcrypt": "^6.0.0",
    "connect-pg-simple": "^10.0.0",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.3.1",
    "ejs": "^5.0.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "express-session": "^1.19.0",
    "express-validator": "^7.3.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "method-override": "^3.0.0",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "pg": "^8.20.0",
    "resend": "^4.8.0",
    "socket.io": "^4.8.3",
    "tailwindcss": "^3.4.17",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.27",
    "eslint": "^9.39.4",
    "node-pg-migrate": "^8.0.4",
    "nodemon": "^3.1.14",
    "postcss": "^8.5.8"
  }
}
