<%- include('../partials/header') %>
<%- include('../partials/flash') %>
<%
  function brl(cents) {
    return `R$ ${(Number(cents || 0) / 100).toFixed(2).replace('.', ',')}`;
  }
%>
<main class="container mx-auto px-4 py-8 space-y-8">
  <section class="relative overflow-hidden rounded-3xl border border-slate-200 bg-white p-6 md:p-8">
    <div class="pointer-events-none absolute right-0 top-0 h-28 w-28 rounded-full bg-primary-100 blur-2xl"></div>
    <div class="flex flex-col gap-4 md:flex-row md:items-center md:justify-between relative">
      <div>
        <p class="text-xs font-semibold uppercase tracking-wide text-primary-600">TAG NFC AIRPET</p>
        <h1 class="mt-1 text-3xl font-extrabold text-slate-900">Compre uma vez a tag e mantenha tudo ativo com assinatura.</h1>
        <p class="mt-3 max-w-2xl text-sm text-slate-600">
          Na compra, cada tag precisa ser vinculada a um pet já cadastrado. Se comprar outra tag para o mesmo pet,
          a anterior será desativada após ativação da nova.
        </p>
        <div class="mt-4 flex flex-wrap gap-2">
          <span class="rounded-full bg-emerald-100 px-3 py-1 text-xs font-semibold text-emerald-700">Pagamento seguro</span>
          <span class="rounded-full bg-blue-100 px-3 py-1 text-xs font-semibold text-blue-700">Renovação soma +30 dias</span>
          <span class="rounded-full bg-amber-100 px-3 py-1 text-xs font-semibold text-amber-700">Até 10 pets por conta</span>
        </div>
      </div>
      <a href="/tags/pedidos" class="rounded-xl bg-slate-900 px-4 py-2 text-sm font-semibold text-white hover:bg-slate-700">
        Ver meus pedidos
      </a>
    </div>
  </section>

  <section class="grid gap-4 md:grid-cols-3">
    <% (planos || []).forEach(function(plano) { %>
      <article class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
        <h2 class="text-lg font-bold text-slate-900"><%= plano.nome_exibicao %></h2>
        <p class="mt-1 text-2xl font-extrabold text-primary-700">
          <%= brl(plano.mensalidade_centavos) %>
          <span class="text-xs font-medium text-slate-500">/ 30 dias</span>
        </p>
        <p class="mt-2 text-xs text-slate-500">Renovação adiciona +30 dias ao saldo atual.</p>
        <ul class="mt-4 space-y-1 text-xs text-slate-600">
          <% Object.entries(plano.features_json || {}).slice(0, 4).forEach(function(entry) { %>
            <% if (entry[1]) { %>
              <li><i class="fa-solid fa-circle-check text-emerald-600 mr-1"></i><%= entry[0] %></li>
            <% } %>
          <% }) %>
        </ul>
      </article>
    <% }) %>
  </section>

  <% if (typeof usuario !== 'undefined' && usuario) { %>
    <section class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
      <h3 class="text-lg font-bold text-slate-900">Criar pedido</h3>
      <p class="mt-1 text-sm text-slate-600">Escolha plano, quantidade e informe os dados para emissão da nota fiscal.</p>

      <form action="/tags/pedidos" method="POST" class="mt-5 space-y-5" id="form-tag-order">
        <div class="grid gap-4 md:grid-cols-3">
          <label class="text-sm">
            <span class="mb-1 block font-semibold text-slate-700">Plano</span>
            <select name="plan_slug" class="w-full rounded-xl border border-slate-300 px-3 py-2">
              <% (planos || []).forEach(function(plano) { %>
                <option value="<%= plano.slug %>"><%= plano.nome_exibicao %></option>
              <% }) %>
            </select>
          </label>

          <label class="text-sm">
            <span class="mb-1 block font-semibold text-slate-700">Tipo de pedido</span>
            <select name="order_type" id="order_type" class="w-full rounded-xl border border-slate-300 px-3 py-2">
              <option value="compra_tag">Primeira compra / comprar nova tag</option>
              <option value="assinatura_recorrente">Somente renovação da assinatura</option>
            </select>
          </label>
          <label class="text-sm">
            <span class="mb-1 block font-semibold text-slate-700">Quantidade de tags</span>
            <input type="number" min="1" max="10" value="1" id="quantidade_tags" name="quantidade_tags" class="w-full rounded-xl border border-slate-300 px-3 py-2">
          </label>
        </div>

        <div class="rounded-xl border border-slate-200 bg-slate-50 p-4">
          <div class="flex items-start justify-between gap-3">
            <div>
              <p class="text-sm font-semibold text-slate-700">Pets por unidade da compra</p>
              <p class="text-xs text-slate-500">A quantidade de seletores abaixo acompanha a quantidade de tags.</p>
            </div>
            <a href="/pets" class="text-xs font-semibold text-primary-700 hover:text-primary-900">Cadastrar pet</a>
          </div>
          <div class="mt-3 grid gap-3 md:grid-cols-2" id="pet-selectors" data-has-pets="<%= (pets || []).length ? '1' : '0' %>">
            <!-- preenchido por JS -->
          </div>
        </div>

        <div class="rounded-xl border border-slate-200 bg-white p-4">
          <h4 class="text-sm font-bold text-slate-900">Dados para nota fiscal</h4>
          <p class="mt-1 text-xs text-slate-500">Preencha os dados reais para emissão fiscal do pedido.</p>
          <div class="mt-3 grid gap-4 md:grid-cols-2">
            <label class="text-sm">
              <span class="mb-1 block font-semibold text-slate-700">Nome completo / Razão social</span>
              <input type="text" name="billing_name" required maxlength="150" class="w-full rounded-xl border border-slate-300 px-3 py-2">
            </label>
            <label class="text-sm">
              <span class="mb-1 block font-semibold text-slate-700">CPF ou CNPJ</span>
              <input type="text" name="billing_cpf_cnpj" required maxlength="18" class="w-full rounded-xl border border-slate-300 px-3 py-2" placeholder="Somente números ou formatado">
            </label>
            <label class="text-sm">
              <span class="mb-1 block font-semibold text-slate-700">Telefone</span>
              <input type="text" name="billing_phone" required maxlength="30" class="w-full rounded-xl border border-slate-300 px-3 py-2">
            </label>
            <label class="text-sm">
              <span class="mb-1 block font-semibold text-slate-700">CEP</span>
              <input type="text" name="billing_cep" required maxlength="9" class="w-full rounded-xl border border-slate-300 px-3 py-2">
            </label>
            <label class="text-sm md:col-span-2">
              <span class="mb-1 block font-semibold text-slate-700">Logradouro</span>
              <input type="text" name="billing_logradouro" required maxlength="160" class="w-full rounded-xl border border-slate-300 px-3 py-2">
            </label>
            <label class="text-sm">
              <span class="mb-1 block font-semibold text-slate-700">Número</span>
              <input type="text" name="billing_numero" required maxlength="20" class="w-full rounded-xl border border-slate-300 px-3 py-2">
            </label>
            <label class="text-sm">
              <span class="mb-1 block font-semibold text-slate-700">Complemento (opcional)</span>
              <input type="text" name="billing_complemento" maxlength="100" class="w-full rounded-xl border border-slate-300 px-3 py-2">
            </label>
            <label class="text-sm">
              <span class="mb-1 block font-semibold text-slate-700">Bairro</span>
              <input type="text" name="billing_bairro" required maxlength="100" class="w-full rounded-xl border border-slate-300 px-3 py-2">
            </label>
            <label class="text-sm">
              <span class="mb-1 block font-semibold text-slate-700">Cidade</span>
              <input type="text" name="billing_cidade" required maxlength="100" class="w-full rounded-xl border border-slate-300 px-3 py-2">
            </label>
            <label class="text-sm">
              <span class="mb-1 block font-semibold text-slate-700">UF</span>
              <input type="text" name="billing_uf" required maxlength="2" class="w-full rounded-xl border border-slate-300 px-3 py-2 uppercase">
            </label>
          </div>
        </div>

        <div class="grid gap-4 md:grid-cols-2">
          <label class="text-sm">
            <span class="mb-1 block font-semibold text-slate-700">Cupom (opcional)</span>
            <input type="text" name="promo_code" placeholder="EX: AIRPET10" class="w-full rounded-xl border border-slate-300 px-3 py-2 uppercase">
          </label>
          <label class="text-sm">
            <span class="mb-1 block font-semibold text-slate-700">Código de indicação (opcional)</span>
            <input type="text" name="referral_code" class="w-full rounded-xl border border-slate-300 px-3 py-2 uppercase">
          </label>
        </div>

        <div class="rounded-xl border border-primary-100 bg-primary-50 p-4 text-xs text-primary-800">
          Você será redirecionado para o checkout seguro. O pedido só muda para <strong>pago</strong> após confirmação do webhook.
        </div>

        <div class="flex justify-end">
          <button type="submit" class="rounded-xl bg-primary-600 px-5 py-2.5 text-sm font-semibold text-white hover:bg-primary-700">
            Ir para pagamento
          </button>
        </div>
      </form>
    </section>
  <% } else { %>
    <section class="rounded-2xl border border-primary-200 bg-primary-50 p-5 text-sm text-primary-800">
      Faça login para comprar e vincular suas tags aos pets.
    </section>
  <% } %>
</main>
<script>
  (function () {
    const pets = <%- JSON.stringify((pets || []).map(function (p) { return { id: p.id, nome: p.nome }; })) %>;
    const qtdInput = document.getElementById('quantidade_tags');
    const orderTypeSelect = document.getElementById('order_type');
    const selectorsRoot = document.getElementById('pet-selectors');

    if (!qtdInput || !orderTypeSelect || !selectorsRoot) return;

    function buildOption(pet, selectedId) {
      const selectedAttr = Number(selectedId) === Number(pet.id) ? 'selected' : '';
      return '<option value="' + pet.id + '" ' + selectedAttr + '>' + pet.nome + '</option>';
    }

    function renderSelectors() {
      const isAssinatura = orderTypeSelect.value === 'assinatura_recorrente';
      const qtd = isAssinatura ? 0 : Math.min(10, Math.max(1, Number(qtdInput.value || 1)));
      qtdInput.disabled = isAssinatura;
      if (isAssinatura) qtdInput.value = 1;

      const selected = Array.from(selectorsRoot.querySelectorAll('select[name="pet_ids"]')).map(function (el) {
        return el.value;
      });

      if (!pets.length && !isAssinatura) {
        selectorsRoot.innerHTML = '<p class="text-sm text-red-600">Você precisa cadastrar ao menos 1 pet para continuar.</p>';
        return;
      }

      let html = '';
      for (let i = 0; i < qtd; i += 1) {
        const options = pets.map(function (pet) { return buildOption(pet, selected[i]); }).join('');
        html += '<label class="text-sm">' +
          '<span class="mb-1 block font-semibold text-slate-700">Tag #' + (i + 1) + '</span>' +
          '<select name="pet_ids" required class="w-full rounded-xl border border-slate-300 px-3 py-2">' +
          options +
          '</select>' +
          '</label>';
      }
      if (isAssinatura) {
        html = '<p class="text-sm text-slate-600">Renovação sem compra de hardware. Nenhum pet precisa ser selecionado.</p>';
      }
      selectorsRoot.innerHTML = html;
    }

    qtdInput.addEventListener('change', renderSelectors);
    orderTypeSelect.addEventListener('change', renderSelectors);
    renderSelectors();
  })();
</script>
<%- include('../partials/footer') %>
