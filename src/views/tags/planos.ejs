<%- include('../partials/header') %>
<%
  function brl(cents) {
    return `R$ ${(Number(cents || 0) / 100).toFixed(2).replace('.', ',')}`;
  }
  function custoDia(cents) {
    return `~R$ ${(Number(cents || 0) / 3000).toFixed(2).replace('.', ',')}/dia`;
  }
  var planoUi = planCopyMap || {};
  var comparativo = [
    { label: 'Contato rapido no scan (ligar, localizacao, encontrei)', key: 'scan_publico_basico' },
    { label: 'Alerta de pet perdido com mapa e contexto', key: 'pet_perdido_mapa' },
    { label: 'Petshop parceiro sugerido no resgate', key: 'petshop_proximo' },
    { label: 'Notificacoes em mais canais', key: 'notificacoes_multicanal' }
  ];
%>
<main class="tc-wrap">
  <section class="tc-hero">
    <div class="tc-eyebrow">Planos Tag AIRPET</div>
    <h1 class="tc-title">Nao e so uma tag. E um plano de protecao para quando cada minuto importa.</h1>
    <p class="tc-sub">A tag identifica seu pet. O plano define o alcance da ajuda quando alguem escaneia ou quando seu pet se perde.</p>
    <div class="tc-badges">
      <span class="tc-badge tc-badge-green">Sem fidelidade</span>
      <span class="tc-badge tc-badge-blue">Renovacao soma +30 dias</span>
      <span class="tc-badge tc-badge-purple">Checkout seguro</span>
    </div>
    <% if (upgradeResumo && upgradeResumo.elegivel) { %>
      <p class="tc-sub"><strong>Cliente ativo:</strong> upgrade com <%= upgradeResumo.descontoLabel %> de desconto automatico.</p>
    <% } %>
  </section>

  <section class="tc-section tc-grid3">
    <% (planos || []).forEach(function(plano) { %>
      <% var ui = planoUi[plano.slug] || { titulo: plano.nome || 'Plano', subtitulo: 'Plano AIRPET', cta: 'Quero esse plano', badge: '', destaque: false, bullets: [] }; %>
      <article class="tc-card <%= ui.destaque ? 'featured' : '' %>">
        <div class="tc-tier"><%= plano.nome_exibicao || ui.titulo %></div>
        <div class="tc-card-head">
          <h2 class="tc-name"><%= ui.titulo %></h2>
          <% if (ui.badge) { %><span class="tc-badge tc-badge-purple"><%= ui.badge %></span><% } %>
        </div>
        <p class="tc-price"><%= brl(plano.mensalidade_centavos) %> <small>/30 dias</small></p>
        <p class="tc-sub"><%= ui.subtitulo %> · <%= custoDia(plano.mensalidade_centavos) %></p>
        <ul class="tc-list">
          <% ui.bullets.forEach(function(item){ %>
            <li><i class="fa-solid fa-circle-check"></i><%= item %></li>
          <% }) %>
        </ul>
        <div class="tc-section">
          <%- include('../partials/ui/button', {
            href: '/tags/loja-tag?plan=' + encodeURIComponent(plano.slug) + '#comprar',
            label: ui.cta,
            variant: ui.destaque ? 'primary' : 'secondary',
            className: '!rounded-xl !px-4 !py-2.5 !text-sm !font-semibold w-full'
          }) %>
        </div>
      </article>
    <% }) %>
  </section>

  <section class="tc-card tc-section">
    <h3 class="text-lg font-black text-slate-900">Comparativo de recursos</h3>
    <div class="tc-table-wrap">
      <table class="tc-table">
        <thead>
          <tr>
            <th>Recurso</th><th>Essencial</th><th>Protecao</th><th>Rede</th>
          </tr>
        </thead>
        <tbody>
          <% comparativo.forEach(function(item){ %>
            <tr>
              <td><%= item.label %></td>
              <% (planos || []).forEach(function(plano){ %>
                <td>
                  <% if (plano.features_json && plano.features_json[item.key]) { %>
                    <span class="font-semibold text-emerald-600"><i class="fa-solid fa-check"></i></span>
                  <% } else { %>
                    <span class="text-slate-400">-</span>
                  <% } %>
                </td>
              <% }) %>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </section>

  <section class="tc-section tc-kpi-grid">
    <article class="tc-kpi"><strong>12k+</strong><span>Pets protegidos</span></article>
    <article class="tc-kpi"><strong>98%</strong><span>Taxa de resgate</span></article>
    <article class="tc-kpi"><strong>340+</strong><span>Cidades atendidas</span></article>
    <article class="tc-kpi"><strong>4.9</strong><span>Avaliação média</span></article>
  </section>

  <section class="tc-card tc-section">
    <h3 class="text-lg font-black text-slate-900">Perguntas frequentes</h3>
    <div class="tc-row2 tc-section">
      <article><strong>Posso trocar de plano depois?</strong><p class="tc-sub">Sim. Upgrades recebem desconto automático quando elegíveis.</p></article>
      <article><strong>Preciso comprar tag em toda renovação?</strong><p class="tc-sub">Não. Você pode renovar somente a assinatura.</p></article>
    </div>
    <div class="mt-5 flex flex-wrap gap-3">
      <a href="/tags/loja-tag" class="btn-primary-inline !rounded-xl !px-5 !py-2.5 !text-sm">Ir para compra</a>
      <a href="/tags/pedidos" class="btn-ghost !rounded-xl !px-5 !py-2.5 !text-sm">Ver meus pedidos</a>
    </div>
  </section>
</main>
<%- include('../partials/footer') %>
