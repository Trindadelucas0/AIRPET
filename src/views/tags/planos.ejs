<%- include('../partials/header') %>
<%
  function brl(cents) {
    return `R$ ${(Number(cents || 0) / 100).toFixed(2).replace('.', ',')}`;
  }
  function custoDia(cents) {
    return `~R$ ${(Number(cents || 0) / 3000).toFixed(2).replace('.', ',')}/dia`;
  }
  var planoUi = planCopyMap || {};
  var comparativo = [
    { label: 'Contato rapido no scan (ligar, localizacao, encontrei)', key: 'scan_publico_basico' },
    { label: 'Alerta de pet perdido com mapa e contexto', key: 'pet_perdido_mapa' },
    { label: 'Petshop parceiro sugerido no resgate', key: 'petshop_proximo' },
    { label: 'Notificacoes em mais canais', key: 'notificacoes_multicanal' }
  ];
%>
<main class="container mx-auto max-w-7xl px-4 py-8 space-y-8">
  <section class="relative overflow-hidden rounded-3xl border border-slate-200 bg-white p-6 md:p-8 shadow-sm">
    <div class="pointer-events-none absolute -right-8 -top-10 h-40 w-40 rounded-full bg-primary-100 blur-3xl"></div>
    <div class="pointer-events-none absolute -left-8 -bottom-12 h-32 w-32 rounded-full bg-blue-100 blur-3xl"></div>

    <div class="relative">
      <p class="text-xs font-bold uppercase tracking-[0.1em] text-primary-600">PLANOS TAG AIRPET</p>
      <h1 class="mt-2 max-w-4xl text-3xl font-black tracking-tight text-slate-900 md:text-4xl">
        Não é só uma tag. É um plano de proteção para o momento em que cada minuto importa.
      </h1>
      <p class="mt-3 max-w-3xl text-sm leading-relaxed text-slate-600">
        A tag identifica seu pet. O plano define o alcance da ajuda quando alguém escaneia ou quando seu pet se perde.
        Escolha o nível de proteção ideal e avance para a compra com tudo pronto.
      </p>
      <div class="mt-4 flex flex-wrap gap-2">
        <span class="rounded-full border border-emerald-200 bg-emerald-50 px-3 py-1 text-xs font-semibold text-emerald-700">Sem fidelidade</span>
        <span class="rounded-full border border-blue-200 bg-blue-50 px-3 py-1 text-xs font-semibold text-blue-700">Renovação soma +30 dias</span>
        <span class="rounded-full border border-purple-200 bg-purple-50 px-3 py-1 text-xs font-semibold text-purple-700">Checkout seguro</span>
      </div>
      <% if (typeof upgradeResumo !== 'undefined' && upgradeResumo && upgradeResumo.elegivel) { %>
        <div class="mt-4 rounded-xl border border-emerald-200 bg-emerald-50 p-3 text-sm text-emerald-800">
          Você já é cliente TAG: em upgrades de plano, recebe <strong><%= upgradeResumo.descontoLabel %></strong> de desconto automático na mensalidade.
        </div>
      <% } %>
    </div>
  </section>

  <section class="grid gap-4 md:grid-cols-3">
    <% (planos || []).forEach(function(plano) { %>
      <% var ui = planoUi[plano.slug] || { titulo: plano.nome || 'Plano', subtitulo: 'Plano AIRPET', cta: 'Quero esse plano', badge: '', destaque: false, bullets: [] }; %>
      <article class="relative overflow-hidden rounded-2xl border bg-white p-5 shadow-sm transition-all hover:-translate-y-0.5 hover:shadow-md <%= ui.destaque ? 'border-primary-300 ring-2 ring-primary-100' : 'border-slate-200' %>">
        <div class="flex items-center justify-between gap-2">
          <h2 class="text-xl font-black text-slate-900"><%= ui.titulo %></h2>
          <% if (ui.badge) { %>
            <span class="rounded-full bg-primary-100 px-3 py-1 text-xs font-semibold text-primary-700"><%= ui.badge %></span>
          <% } else { %>
            <span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold text-slate-600">30 dias</span>
          <% } %>
        </div>

        <p class="mt-3 text-3xl font-black text-primary-700">
          <%= brl(plano.mensalidade_centavos) %>
          <span class="text-xs font-semibold text-slate-500">/30 dias</span>
        </p>
        <p class="text-xs font-semibold text-slate-500"><%= custoDia(plano.mensalidade_centavos) %></p>

        <p class="mt-3 text-sm text-slate-600"><%= ui.subtitulo %></p>
        <ul class="mt-4 space-y-2 text-sm text-slate-600">
          <% ui.bullets.forEach(function(item){ %>
            <li class="flex items-start gap-2">
              <i class="fa-solid fa-circle-check mt-0.5 text-emerald-600"></i>
              <span><%= item %></span>
            </li>
          <% }) %>
        </ul>

        <div class="mt-5">
          <%- include('../partials/ui/button', {
            href: '/tags/loja-tag?plan=' + encodeURIComponent(plano.slug) + '#comprar',
            label: ui.cta,
            variant: ui.destaque ? 'primary' : 'secondary',
            className: '!rounded-xl !px-4 !py-2.5 !text-sm !font-semibold w-full'
          }) %>
        </div>
      </article>
    <% }) %>
  </section>

  <section class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
    <h3 class="text-lg font-black text-slate-900">O que muda em cada plano na prática</h3>
    <p class="mt-1 text-sm text-slate-600">Compare rapidamente os recursos liberados no scan da tag e no fluxo de resgate.</p>
    <div class="mt-4 overflow-x-auto">
      <table class="min-w-full text-sm">
        <thead>
          <tr class="border-b border-slate-200 text-left text-slate-500">
            <th class="py-2 pr-4 font-semibold">Recurso</th>
            <th class="py-2 px-3 font-semibold">Essencial</th>
            <th class="py-2 px-3 font-semibold text-primary-700">Proteção</th>
            <th class="py-2 px-3 font-semibold">Rede</th>
          </tr>
        </thead>
        <tbody>
          <% comparativo.forEach(function(item){ %>
            <tr class="border-b border-slate-100">
              <td class="py-2 pr-4 text-slate-700"><%= item.label %></td>
              <% (planos || []).forEach(function(plano){ %>
                <td class="py-2 px-3">
                  <% if (plano.features_json && plano.features_json[item.key]) { %>
                    <span class="font-semibold text-emerald-600"><i class="fa-solid fa-check"></i> Sim</span>
                  <% } else { %>
                    <span class="text-slate-400"><i class="fa-solid fa-minus"></i> Não</span>
                  <% } %>
                </td>
              <% }) %>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </section>

  <section class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
    <h3 class="text-lg font-black text-slate-900">Perguntas frequentes</h3>
    <div class="mt-4 grid gap-3 md:grid-cols-2">
      <article class="rounded-xl border border-slate-200 bg-slate-50 p-4">
        <p class="text-sm font-bold text-slate-900">Posso trocar de plano depois?</p>
        <p class="mt-1 text-sm text-slate-600">Sim. Você pode ajustar seu nível de proteção nos próximos ciclos.</p>
      </article>
      <article class="rounded-xl border border-slate-200 bg-slate-50 p-4">
        <p class="text-sm font-bold text-slate-900">Preciso comprar tag em toda renovação?</p>
        <p class="mt-1 text-sm text-slate-600">Não. Existe opção de renovação sem compra de novo hardware.</p>
      </article>
    </div>
    <div class="mt-5 flex flex-wrap gap-3">
      <a href="/tags/loja-tag" class="btn-primary-inline !rounded-xl !px-5 !py-2.5 !text-sm">Ir para compra</a>
      <a href="/tags/pedidos" class="btn-ghost !rounded-xl !px-5 !py-2.5 !text-sm">Ver meus pedidos</a>
    </div>
  </section>
</main>
<%- include('../partials/footer') %>
