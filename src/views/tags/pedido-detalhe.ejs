<%- include('../partials/header') %>
<%- include('../partials/flash') %>
<%
  function brl(cents) {
    return `R$ ${(Number(cents || 0) / 100).toFixed(2).replace('.', ',')}`;
  }
%>
<main class="tc-wrap">
  <header class="tc-hero">
    <div>
      <p class="tc-eyebrow">Pedido detalhado</p>
      <h1 class="tc-title">Pedido #<%= pedido.id %></h1>
      <p class="tc-sub">Plano <strong><%= pedido.plan_slug %></strong> · Status <strong><%= pedido.status %></strong></p>
    </div>
    <a href="/tags/pedidos" class="text-sm font-semibold text-primary-700 hover:text-primary-900">Voltar</a>
  </header>

  <section class="tc-card tc-section">
    <div class="tc-detail-grid text-sm">
      <div><span class="text-slate-500">Tipo</span><div class="font-semibold"><%= pedido.order_type %></div></div>
      <div><span class="text-slate-500">Quantidade de tags</span><div class="font-semibold"><%= pedido.quantidade_tags %></div></div>
      <div><span class="text-slate-500">Total</span><div class="font-semibold"><%= brl(pedido.total_centavos) %></div></div>
    </div>
    <div class="mt-4 rounded-xl bg-slate-50 p-3 text-xs text-slate-600">
      Atualização de status é automática após confirmação do pagamento no webhook. Se já pagou e ainda está pendente,
      aguarde alguns minutos e atualize a página.
    </div>
  </section>

  <section class="tc-card">
    <h2 class="text-base font-bold text-slate-900">Dados fiscais do pedido</h2>
    <div class="tc-row2 tc-section text-sm">
      <p><span class="text-slate-500">Nome:</span> <span class="font-semibold text-slate-900"><%= pedido.billing_name || '-' %></span></p>
      <p><span class="text-slate-500">CPF/CNPJ:</span> <span class="font-semibold text-slate-900"><%= pedido.billing_cpf_cnpj || '-' %></span></p>
      <p><span class="text-slate-500">Telefone:</span> <span class="font-semibold text-slate-900"><%= pedido.billing_phone || '-' %></span></p>
      <p><span class="text-slate-500">CEP:</span> <span class="font-semibold text-slate-900"><%= pedido.billing_cep || '-' %></span></p>
    </div>
  </section>

  <% if (pedido.order_type !== 'assinatura_recorrente') { %>
    <section class="tc-section">
      <h2 class="text-lg font-bold text-slate-900">Unidades da tag</h2>
      <% (unidades || []).forEach(function(u) { %>
        <article class="tc-card tc-section">
          <div class="mb-3 flex items-center justify-between">
            <h3 class="font-semibold text-slate-900">Tag #<%= u.sequencia %></h3>
            <span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold text-slate-700"><%= u.personalization_status %></span>
          </div>

          <form action="/tags/pedidos/<%= pedido.id %>/unidades/<%= u.id %>/personalizar" method="POST" enctype="multipart/form-data" class="tc-row3">
            <label class="text-sm md:col-span-1">
              <span class="mb-1 block font-semibold text-slate-700">Pet vinculado</span>
              <select name="pet_id" class="tc-select">
                <% (pets || []).forEach(function(p) { %>
                  <option value="<%= p.id %>" <%= Number(u.pet_id) === Number(p.id) ? 'selected' : '' %>><%= p.nome %></option>
                <% }) %>
              </select>
            </label>

            <label class="text-sm md:col-span-1">
              <span class="mb-1 block font-semibold text-slate-700">Foto para impressão</span>
              <input type="file" name="foto_tag" accept="image/*" class="tc-input">
            </label>

            <div class="md:col-span-1 flex items-end">
              <button type="submit" class="w-full rounded-xl bg-primary-600 px-4 py-2.5 text-sm font-semibold text-white hover:bg-primary-700">
                Salvar personalização
              </button>
            </div>
          </form>

          <% if (u.print_photo_url) { %>
            <div class="mt-3 flex items-center gap-3 rounded-xl bg-slate-50 p-3">
              <img src="<%= u.print_photo_url %>" alt="Foto da tag" class="h-14 w-14 rounded-lg object-cover">
              <p class="text-xs text-slate-600">Foto de impressão salva para esta unidade.</p>
            </div>
          <% } %>

          <% if (u.tag_code) { %>
            <p class="mt-3 text-xs text-slate-500">Tag física alocada: <strong><%= u.tag_code %></strong> (<%= u.nfc_status %>)</p>
          <% } %>
        </article>
      <% }) %>
    </section>
  <% } %>
</main>
<%- include('../partials/footer') %>
