<%- include('../partials/header') %>
<%- include('../partials/flash') %>
<main class="tc-wrap">
  <header class="tc-hero">
    <div>
      <p class="tc-eyebrow">Historico</p>
      <h1 class="tc-title">Meus pedidos TAG</h1>
      <% if (estadoPlano) { %>
        <p class="tc-sub">
          Plano atual: <strong><%= estadoPlano.planSlug %></strong>
          <% if (estadoPlano.validUntil) { %>
            • válido até <%= new Date(estadoPlano.validUntil).toLocaleDateString('pt-BR') %>
          <% } %>
          <% if (estadoPlano.emGrace) { %>
            • em período de graça
          <% } %>
        </p>
      <% } %>
    </div>
    <a href="/tags/planos" class="btn-primary-inline !rounded-xl !px-4 !py-2.5 !text-sm">
      Nova compra / renovação
    </a>
  </header>

  <% if (!pedidos || pedidos.length === 0) { %>
    <section class="tc-card">
      Nenhum pedido encontrado ainda.
    </section>
  <% } %>

  <section class="tc-section">
    <% (pedidos || []).forEach(function(p) { %>
      <article class="tc-order-card">
        <div class="tc-order-main">
          <div>
            <h2 class="text-lg font-bold text-slate-900">Pedido #<%= p.id %></h2>
            <p class="tc-sub">
              <%= p.order_type === 'assinatura_recorrente' ? 'Renovação de assinatura' : 'Compra de tag' %>
              • Plano <%= p.plan_slug %>
            </p>
          </div>
          <span class="tc-pill <%= p.status === 'pago' ? 'ok' : 'warn' %>">
            <%= p.status %>
          </span>
        </div>
        <div class="px-4 pb-4 flex items-center justify-between text-sm">
          <span class="text-slate-500">Total</span>
          <strong class="text-slate-900">R$ <%= (Number(p.total_centavos || 0) / 100).toFixed(2).replace('.', ',') %></strong>
        </div>
        <div class="px-4 pb-4">
          <a href="/tags/pedidos/<%= p.id %>" class="text-sm font-semibold text-primary-700 hover:text-primary-900">Ver detalhes</a>
        </div>
      </article>
    <% }) %>
  </section>
</main>
<%- include('../partials/footer') %>
