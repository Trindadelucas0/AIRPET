<% locals.titulo = 'Agenda' %>
<%- include('../partials/header') %>
<%- include('../partials/flash') %>

<main class="flex-1 container mx-auto px-4 py-6 max-w-2xl">

  <h1 class="text-2xl font-bold text-gray-900 mb-6">
    <i class="fa-solid fa-calendar-days mr-2 text-[#ec5a1c]"></i>Agenda
  </h1>

  <!-- Botao agendar -->
  <% if (typeof petshops !== 'undefined' && petshops && petshops.length > 0) { %>
    <div class="card mb-6">
      <h2 class="text-lg font-bold text-gray-800 mb-4">Novo agendamento</h2>
      <form action="/agenda" method="POST" class="space-y-3">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Petshop</label>
          <select name="petshop_id" required class="input-field">
            <option value="">Selecione...</option>
            <% petshops.forEach(function(ps) { %>
              <option value="<%= ps.id %>"><%= ps.nome %></option>
            <% }) %>
          </select>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Servico</label>
          <select name="servico" required class="input-field">
            <option value="banho">Banho</option>
            <option value="tosa">Tosa</option>
            <option value="banho_tosa">Banho + Tosa</option>
            <option value="consulta">Consulta</option>
            <option value="vacinacao">Vacinacao</option>
            <option value="outro">Outro</option>
          </select>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Data e hora</label>
          <input type="datetime-local" name="data" required class="input-field">
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Pet</label>
          <select name="pet_id" class="input-field">
            <option value="">Nenhum pet especifico</option>
            <% if (typeof pets !== 'undefined' && pets) { pets.forEach(function(p) { %>
              <option value="<%= p.id %>"><%= p.nome %></option>
            <% }) } %>
          </select>
        </div>
        <button type="submit" class="btn-primary w-full">
          <i class="fa-solid fa-plus mr-2"></i>Agendar
        </button>
      </form>
    </div>
  <% } %>

  <!-- Lista de agendamentos -->
  <% if (typeof agendamentos !== 'undefined' && agendamentos && agendamentos.length > 0) { %>
    <div class="space-y-3">
      <% agendamentos.forEach(function(ag) { %>
        <div class="card flex items-center gap-3">
          <div class="w-10 h-10 rounded-full flex items-center justify-center flex-shrink-0
            <% if (ag.status === 'agendado') { %>bg-blue-100 text-blue-500
            <% } else if (ag.status === 'concluido') { %>bg-green-100 text-green-500
            <% } else { %>bg-gray-100 text-gray-500<% } %>">
            <i class="fa-solid fa-calendar-check"></i>
          </div>
          <div class="flex-1 min-w-0">
            <p class="text-sm font-semibold text-gray-800 capitalize"><%= ag.servico %></p>
            <p class="text-xs text-gray-500"><%= ag.petshop_nome || 'Petshop' %></p>
            <p class="text-xs text-gray-400">
              <%= new Date(ag.data).toLocaleDateString('pt-BR') %> as
              <%= new Date(ag.data).toLocaleTimeString('pt-BR', { hour: '2-digit', minute: '2-digit' }) %>
            </p>
          </div>
          <span class="text-xs font-medium px-2 py-1 rounded-full
            <% if (ag.status === 'agendado') { %>bg-blue-100 text-blue-600
            <% } else if (ag.status === 'concluido') { %>bg-green-100 text-green-600
            <% } else { %>bg-gray-100 text-gray-600<% } %>">
            <%= ag.status %>
          </span>
        </div>
      <% }) %>
    </div>
  <% } else { %>
    <div class="card text-center py-12">
      <i class="fa-solid fa-calendar-xmark text-4xl text-gray-300 mb-3"></i>
      <p class="text-gray-500">Nenhum agendamento ainda.</p>
      <p class="text-sm text-gray-400 mt-1">Agende banho, tosa ou consultas nos petshops parceiros.</p>
    </div>
  <% } %>

</main>

<%- include('../partials/footer') %>
