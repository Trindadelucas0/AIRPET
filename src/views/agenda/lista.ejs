<% locals.titulo = 'Agenda' %>
<%
  const statusLabel = {
    pendente: 'Pendente',
    aceito: 'Confirmado',
    recusado: 'Recusado',
    expirado: 'Expirado',
    cancelado: 'Cancelado',
    concluido: 'Concluído',
  };
%>
<%- include('../partials/header') %>
<%- include('../partials/flash') %>

<main class="flex-1 container mx-auto px-4 py-8 max-w-5xl space-y-6">
  <section class="card">
    <div id="agendaWizardRoot" data-wizard-root>
      <%- include('../partials/wizard-shell', {
        shellId: 'agendaWizardShell',
        badge: 'Agendamento guiado',
        title: 'Agendar serviço',
        subtitle: 'Escolha parceiro, serviço, pet e dia para ver os horários livres.',
        totalSteps: 5,
        currentStep: 1,
        stepLabelId: 'agendaStepLabel',
        stepPercentId: 'agendaStepPercent',
        progressBarId: 'agendaProgressBar'
      }) %>

      <form action="/agenda" method="GET" id="agendaWizardSearch">
        <section class="air-wizard-step-card" data-wizard-step data-step="1">
          <div class="air-wizard-step-grid">
            <h3 class="air-wizard-step-title">1) Qual petshop?</h3>
            <select name="petshop_id" class="input-field w-full" required>
              <option value="">Selecione...</option>
              <% (petshops || []).forEach(function(ps) { %>
                <option value="<%= ps.id %>" <%= Number(petshopSelecionado) === Number(ps.id) ? 'selected' : '' %>><%= ps.nome %></option>
              <% }) %>
            </select>
          </div>
          <div class="air-wizard-nav">
            <button type="button" class="btn-primary" data-wizard-next>Continuar</button>
          </div>
        </section>

        <section class="air-wizard-step-card hidden" data-wizard-step data-step="2">
          <div class="air-wizard-step-grid">
            <h3 class="air-wizard-step-title">2) Qual serviço?</h3>
            <select name="service_id" class="input-field w-full" required>
              <option value="">Selecione...</option>
              <% (petshops || []).forEach(function(ps) { %>
                <% (servicosPorPetshop && servicosPorPetshop[ps.id] ? servicosPorPetshop[ps.id] : []).forEach(function(s) { %>
                  <option value="<%= s.id %>" data-petshop="<%= ps.id %>" <%= Number(serviceSelecionado) === Number(s.id) ? 'selected' : '' %>>
                    <%= ps.nome %> • <%= s.nome %>
                  </option>
                <% }) %>
              <% }) %>
            </select>
          </div>
          <div class="air-wizard-nav">
            <button type="button" class="btn-primary" data-wizard-next>Continuar</button>
            <button type="button" class="btn-ghost" data-wizard-prev>Voltar</button>
          </div>
        </section>

        <section class="air-wizard-step-card hidden" data-wizard-step data-step="3">
          <div class="air-wizard-step-grid">
            <h3 class="air-wizard-step-title">3) Qual pet?</h3>
            <select name="pet_id" class="input-field w-full" required>
              <option value="">Selecione...</option>
              <% (pets || []).forEach(function(p) { %>
                <option value="<%= p.id %>" <%= Number(petSelecionado) === Number(p.id) ? 'selected' : '' %>><%= p.nome %></option>
              <% }) %>
            </select>
          </div>
          <div class="air-wizard-nav">
            <button type="button" class="btn-primary" data-wizard-next>Continuar</button>
            <button type="button" class="btn-ghost" data-wizard-prev>Voltar</button>
          </div>
        </section>

        <section class="air-wizard-step-card hidden" data-wizard-step data-step="4">
          <div class="air-wizard-step-grid">
            <h3 class="air-wizard-step-title">4) Em qual dia?</h3>
            <input type="date" name="dia" value="<%= diaSelecionado || '' %>" class="input-field w-full" required>
          </div>
          <div class="air-wizard-nav">
            <button type="button" class="btn-primary" data-wizard-next>Ir para horários</button>
            <button type="button" class="btn-ghost" data-wizard-prev>Voltar</button>
          </div>
        </section>

        <section class="air-wizard-step-card hidden" data-wizard-step data-step="5">
          <div class="air-wizard-step-grid">
            <h3 class="air-wizard-step-title">5) Horários disponíveis</h3>
            <p class="air-wizard-step-helper">Busque os horários do dia e toque em um horário para enviar a solicitação.</p>
            <button type="submit" class="btn-primary w-full">Buscar horários</button>
          </div>
          <div class="air-wizard-nav">
            <button type="button" class="btn-ghost" data-wizard-prev>Voltar</button>
          </div>
        </section>
      </form>
    </div>

    <div class="mt-4">
      <% if (!(slotsDisponiveis || []).length) { %>
        <% if (petshopSelecionado && serviceSelecionado && diaSelecionado) { %>
          <p class="text-sm text-gray-500">Não encontramos horários livres para este dia. Tente outra data.</p>
        <% } else { %>
          <p class="text-sm text-gray-500">Avance até o passo 5 e clique em “Buscar horários”.</p>
        <% } %>
      <% } else { %>
        <div class="flex flex-wrap gap-2">
          <% (slotsDisponiveis || []).forEach(function(slot) { %>
            <form action="/agenda" method="POST" class="inline-flex">
              <input type="hidden" name="petshop_id" value="<%= petshopSelecionado %>">
              <input type="hidden" name="service_id" value="<%= serviceSelecionado %>">
              <input type="hidden" name="dia" value="<%= diaSelecionado || '' %>">
              <input type="hidden" name="data_agendada" value="<%= slot.inicio %>">
              <input type="hidden" name="pet_id" value="<%= petSelecionado || '' %>">
              <button class="agenda-slot-btn px-3 py-2 rounded-xl border border-gray-200 text-sm hover:bg-orange-50 transition-colors">
                <%= new Date(slot.inicio).toLocaleTimeString('pt-BR', { hour: '2-digit', minute: '2-digit' }) %>
              </button>
            </form>
          <% }) %>
        </div>
      <% } %>
    </div>
  </section>

  <section class="card">
    <h2 class="text-lg font-bold text-gray-900 mb-3">Meus agendamentos</h2>
    <% if (!(agendamentos || []).length) { %>
      <p class="text-sm text-gray-500">Nenhum agendamento ainda.</p>
    <% } else { %>
      <div class="space-y-3">
        <% (agendamentos || []).forEach(function(ag) { %>
          <article class="rounded-2xl border border-gray-200 p-4 bg-white">
            <div class="flex flex-wrap items-start justify-between gap-3">
              <div>
                <p class="font-semibold text-gray-900"><%= ag.servico_nome || 'Serviço' %> • <%= ag.pet_nome %></p>
                <p class="text-sm text-gray-600"><%= ag.petshop_nome %></p>
                <p class="text-xs text-gray-500 mt-1">
                  <%= new Date(ag.data_agendada).toLocaleDateString('pt-BR') %> às
                  <%= new Date(ag.data_agendada).toLocaleTimeString('pt-BR', { hour: '2-digit', minute: '2-digit' }) %>
                </p>
                <% if (ag.petshop_endereco) { %>
                  <p class="text-xs text-gray-500 mt-1"><i class="fa-solid fa-location-dot mr-1"></i><%= ag.petshop_endereco %></p>
                <% } %>
              </div>
              <div class="flex flex-wrap items-center gap-2">
                <span class="px-2 py-1 rounded-full text-xs font-semibold bg-gray-100 text-gray-700">
                  <%= statusLabel[ag.status] || ag.status %>
                </span>
                <% if (ag.status === 'pendente' || ag.status === 'aceito') { %>
                  <form action="/agenda/<%= ag.id %>/cancelar" method="POST">
                    <button class="px-3 py-1.5 rounded-lg border border-red-200 bg-red-50 text-red-600 text-xs font-semibold">Cancelar</button>
                  </form>
                <% } %>
                <% if (ag.petshop_latitude && ag.petshop_longitude) { %>
                  <a href="https://maps.google.com/?q=<%= ag.petshop_latitude %>,<%= ag.petshop_longitude %>" target="_blank" rel="noopener" class="px-3 py-1.5 rounded-lg border border-orange-200 bg-orange-50 text-orange-700 text-xs font-semibold">
                    Como chegar
                  </a>
                <% } %>
              </div>
            </div>
          </article>
        <% }) %>
      </div>
    <% } %>
  </section>
</main>

<script src="/js/airpet-wizard.js"></script>
<script>
  (function () {
    var root = document.getElementById('agendaWizardRoot')
    var petshopSelect = document.querySelector('#agendaWizardSearch select[name="petshop_id"]')
    var serviceSelect = document.querySelector('#agendaWizardSearch select[name="service_id"]')
    var petSelect = document.querySelector('#agendaWizardSearch select[name="pet_id"]')
    var slotButtons = document.querySelectorAll('.agenda-slot-btn')
    if (!root || !petshopSelect || !serviceSelect) return

    function filterServices() {
      var petshopId = petshopSelect.value
      Array.prototype.forEach.call(serviceSelect.options, function (opt) {
        if (!opt.value) return
        var allowed = !petshopId || String(opt.getAttribute('data-petshop')) === String(petshopId)
        opt.hidden = !allowed
      })
      var selected = serviceSelect.options[serviceSelect.selectedIndex]
      if (selected && selected.hidden) serviceSelect.value = ''
    }

    function toggleSubmitByPet() {
      if (!petSelect || !slotButtons.length) return
      var hasPet = !!petSelect.value
      Array.prototype.forEach.call(slotButtons, function (btn) {
        btn.disabled = !hasPet
        btn.title = hasPet ? '' : 'Selecione um pet antes de agendar'
      })
    }

    var wizard = new window.AirpetWizard(root, {
      stepLabel: document.getElementById('agendaStepLabel'),
      stepPercent: document.getElementById('agendaStepPercent'),
      progressBar: document.getElementById('agendaProgressBar')
    })

    var temPesquisa = Boolean(petshopSelect.value && serviceSelect.value && document.querySelector('#agendaWizardSearch input[name="dia"]').value)
    wizard.goTo(temPesquisa ? 5 : 1)

    petshopSelect.addEventListener('change', function () {
      filterServices()
      wizard.goTo(2)
    })

    if (petSelect) petSelect.addEventListener('change', toggleSubmitByPet)
    filterServices()
    toggleSubmitByPet()
  })()
</script>

<%- include('../partials/footer') %>
