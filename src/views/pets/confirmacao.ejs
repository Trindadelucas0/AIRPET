<% locals.titulo = pet.nome + ' cadastrado!' %>
<%- include('../partials/header') %>

<main class="flex-1 flex items-center justify-center px-4 py-12">
  <div class="text-center max-w-md w-full">

    <div class="mb-6">
      <div class="w-24 h-24 mx-auto rounded-full bg-green-100 flex items-center justify-center mb-4 animate-bounce">
        <i class="fa-solid fa-check text-4xl text-green-500"></i>
      </div>
      <% if (pet.foto) { %>
        <img src="<%= pet.foto %>" alt="<%= pet.nome %>"
             class="w-28 h-28 rounded-full object-cover mx-auto border-4 border-white shadow-lg -mt-14 relative z-10">
      <% } %>
    </div>

    <h1 class="text-3xl font-extrabold text-gray-900 mb-2">
      <%= pet.nome %> esta protegido!
    </h1>
    <p class="text-gray-500 mb-8">
      O perfil do seu pet foi criado com sucesso. Agora voce pode vincular uma tag NFC,
      registrar vacinas e muito mais.
    </p>

    <div class="space-y-3">
      <a href="/pets/<%= pet.id %>"
         class="btn-primary w-full inline-flex items-center justify-center">
        <i class="fa-solid fa-eye mr-2"></i>Ver perfil de <%= pet.nome %>
      </a>

      <a href="/pets/<%= pet.id %>/saude"
         class="btn-outline w-full inline-flex items-center justify-center">
        <i class="fa-solid fa-notes-medical mr-2"></i>Carteira de saude
      </a>

      <a href="/diario/<%= pet.id %>"
         class="btn-outline w-full inline-flex items-center justify-center">
        <i class="fa-solid fa-book mr-2"></i>Iniciar diario
      </a>

      <a href="/pets/cadastro"
         class="text-sm text-gray-500 hover:text-[#ec5a1c] transition-colors inline-block mt-4">
        <i class="fa-solid fa-plus mr-1"></i>Cadastrar outro pet
      </a>
    </div>

  </div>
</main>

<%- include('../partials/footer') %>
