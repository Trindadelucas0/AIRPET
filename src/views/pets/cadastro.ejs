<% locals.titulo = 'Cadastrar Pet' %>
<% locals.extraHead = `
<link href="https://fonts.googleapis.com/css2?family=Rubik+Doodle+Shadow&family=Syne:wght@700;800&family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
  /* Layout do fluxo de pets deve seguir o design system (tema claro no PC). */
  body { font-family:'DM Sans',sans-serif; }

  .wizard-wrap { max-width:520px; margin:0 auto; padding:24px 20px 80px; }

  /* ── TOPBAR ── */
  .wizard-topbar {
    position:sticky; top:56px; z-index:40;
    background:rgba(255,255,255,0.88); backdrop-filter:blur(20px);
    border-bottom:1px solid var(--border); padding:12px 0;
  }
  .wizard-topbar-inner {
    max-width:520px; margin:0 auto; padding:0 20px;
    display:flex; align-items:center; gap:14px;
  }
  .wizard-topbar-back {
    color:var(--text-dim); font-size:13px; text-decoration:none;
    display:flex; align-items:center; gap:6px; transition:color 0.15s;
  }
  .wizard-topbar-back:hover { color:var(--accent); text-decoration:none; }
  .wizard-topbar h1 { font-family:var(--font-display); font-size:17px; font-weight:800; color:var(--text); }

  /* ── PROGRESS ── */
  .progress-section { margin-bottom:28px; }
  .progress-meta { display:flex; justify-content:space-between; font-size:12px; color:var(--text-dim); font-weight:600; margin-bottom:8px; }
  .progress-track {
    width:100%; height:3px; background:var(--ink-3); border-radius:2px; overflow:hidden;
  }
  .progress-fill {
    height:100%; background:var(--accent); border-radius:2px;
    transition:width 0.4s cubic-bezier(0.4,0,0.2,1);
  }

  /* ── STEP CARD ── */
  .wizard-step {
    background:var(--ink-2); border:1px solid var(--border); border-radius:20px; padding:32px 28px;
    animation:step-in 0.3s ease-out both;
  }
  @keyframes step-in { from { opacity:0; transform:translateX(20px); } to { opacity:1; transform:none; } }
  .step-icon-wrap {
    width:64px; height:64px; border-radius:20px; margin:0 auto 20px;
    background:var(--accent-glow); border:1px solid rgba(242,96,32,0.2);
    display:flex; align-items:center; justify-content:center;
    font-size:26px; color:var(--accent);
  }
  .step-title {
    font-family:var(--font-display);
    font-size:22px; font-weight:800; color:var(--text);
    text-align:center; margin-bottom:6px;
  }
  .step-sub { font-size:13px; color:var(--text-dim); text-align:center; margin-bottom:24px; }

  /* ── INPUT ── */
  .ds-input {
    width:100%; background:var(--ink-3); border:1px solid var(--border);
    border-radius:12px; padding:13px 16px; color:var(--text);
    font-family:'DM Sans',sans-serif; font-size:15px; outline:none;
    transition:border-color 0.2s, box-shadow 0.2s;
  }
  .ds-input::placeholder { color:var(--text-muted); }
  .ds-input:focus { border-color:rgba(242,96,32,0.5); box-shadow:0 0 0 3px rgba(242,96,32,0.06); }
  .ds-input.center { text-align:center; font-size:18px; font-weight:700; }
  .ds-select { appearance:none; cursor:pointer; }

  /* ── TIPO BUTTONS ── */
  .tipo-grid { display:grid; grid-template-columns:1fr 1fr; gap:10px; }
  .tipo-btn {
    display:flex; flex-direction:column; align-items:center; gap:8px;
    padding:20px 12px; border-radius:14px;
    border:2px solid var(--border); background:var(--ink-3);
    cursor:pointer; transition:all 0.15s;
    color:var(--text-dim); font-family:'DM Sans',sans-serif;
    font-size:14px; font-weight:600;
  }
  .tipo-btn:hover { border-color:var(--accent); color:var(--text); background:var(--ink-4); }
  .tipo-btn.selected { border-color:var(--accent); background:var(--accent-glow); color:var(--accent-light); }
  .tipo-btn-icon { font-size:32px; }

  /* ── PORTE BUTTONS ── */
  .porte-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:8px; }
  .porte-btn {
    padding:14px 8px; border-radius:12px;
    border:2px solid var(--border); background:var(--ink-3);
    cursor:pointer; transition:all 0.15s;
    color:var(--text-dim); font-family:'DM Sans',sans-serif;
    font-size:13px; font-weight:600; text-align:center;
  }
  .porte-btn:hover { border-color:var(--accent); color:var(--text); }
  .porte-btn.selected { border-color:var(--accent); background:var(--accent-glow); color:var(--accent-light); }

  /* ── SEXO BUTTONS ── */
  .sexo-grid { display:grid; grid-template-columns:1fr 1fr; gap:10px; }
  .sexo-btn {
    display:flex; flex-direction:column; align-items:center; gap:8px;
    padding:18px; border-radius:14px;
    border:2px solid var(--border); background:var(--ink-3);
    cursor:pointer; transition:all 0.15s;
    color:var(--text-dim); font-family:'DM Sans',sans-serif; font-size:14px; font-weight:600;
  }
  .sexo-btn:hover { border-color:var(--accent); color:var(--text); }
  .sexo-btn.selected { border-color:var(--accent); background:var(--accent-glow); color:var(--accent-light); }
  .sexo-btn i { font-size:24px; }

  /* ── FOTO UPLOAD ── */
  .foto-label {
    display:block; cursor:pointer;
    border:2px dashed var(--border); border-radius:16px; overflow:hidden;
    transition:border-color 0.2s; position:relative;
  }
  .foto-label:hover { border-color:rgba(242,96,32,0.4); }
  .foto-preview {
    width:100%; height:200px; object-fit:cover; display:block;
    background:var(--ink-3);
  }
  .foto-placeholder {
    width:100%; height:200px; display:flex; flex-direction:column; align-items:center; justify-content:center;
    gap:10px; color:var(--text-dim); background:var(--ink-3);
  }
  .foto-placeholder i { font-size:32px; color:var(--text-muted); }
  .foto-placeholder span { font-size:13px; font-weight:600; }
  .foto-overlay {
    position:absolute; inset:0; background:rgba(13,13,15,0.5); backdrop-filter:blur(2px);
    display:flex; align-items:center; justify-content:center;
    color:#fff; font-size:14px; font-weight:700; opacity:0; transition:opacity 0.2s;
  }
  .foto-label:hover .foto-overlay { opacity:1; }

  /* ── BUTTONS ── */
  .btn-next {
    width:100%; padding:14px; margin-top:20px;
    background:var(--accent); color:#fff; border:none; border-radius:12px;
    font-family:'DM Sans',sans-serif; font-size:16px; font-weight:700;
    cursor:pointer; transition:all 0.2s; display:flex; align-items:center; justify-content:center; gap:10px;
  }
  .btn-next:hover { background:var(--accent-light); transform:translateY(-1px); }
  .btn-next:disabled { opacity:0.5; cursor:not-allowed; transform:none; }

  .btn-back-step {
    width:100%; padding:12px; margin-top:10px;
    background:transparent; color:var(--text-dim); border:1px solid var(--border); border-radius:12px;
    font-family:'DM Sans',sans-serif; font-size:14px; font-weight:600;
    cursor:pointer; transition:all 0.15s;
  }
  .btn-back-step:hover { border-color:var(--border-hover); color:var(--text); }

  /* ── LABEL ── */
  .ds-label { display:block; font-size:11px; font-weight:700; color:var(--text-dim); letter-spacing:0.08em; text-transform:uppercase; margin-bottom:7px; }

  /* ── SKIP ── */
  .btn-skip {
    display:block; text-align:center; width:100%; margin-top:12px;
    font-size:12px; color:var(--text-muted); background:none; border:none; cursor:pointer; padding:6px;
    transition:color 0.15s;
  }
  .btn-skip:hover { color:var(--text-dim); }
</style>
` %>
<%- include('../partials/header') %>
<%- include('../partials/flash') %>

<div class="wizard-topbar">
  <div class="wizard-topbar-inner">
    <a href="/pets" class="wizard-topbar-back"><i class="fa-solid fa-arrow-left"></i> Meus Pets</a>
    <h1>Cadastrar Pet</h1>
  </div>
</div>

<main class="flex-1">
  <div class="wizard-wrap">

    <!-- Progress -->
    <div class="progress-section">
      <div class="progress-meta">
        <span id="stepLabel">Passo 1 de 9</span>
        <span id="stepPercent">11%</span>
      </div>
      <div class="progress-track">
        <div id="progressBar" class="progress-fill" style="width:11%"></div>
      </div>
    </div>

    <form action="/pets/cadastro" method="POST" enctype="multipart/form-data" id="formCadastro">

      <!-- Step 1: Nome -->
      <div class="wizard-step" data-step="1">
        <div class="step-icon-wrap"><i class="fa-solid fa-heart"></i></div>
        <h2 class="step-title">Como se chama?</h2>
        <p class="step-sub">Escolha o nome carinhoso do seu companheiro</p>
        <input type="text" name="nome" id="petNome" required placeholder="Ex: Rex, Luna, Thor..."
               class="ds-input center" maxlength="50">
        <button type="button" class="btn-next" onclick="nextStep()">
          Continuar <i class="fa-solid fa-arrow-right"></i>
        </button>
      </div>

      <!-- Step 2: Tipo -->
      <div class="wizard-step hidden" data-step="2">
        <div class="step-icon-wrap"><i class="fa-solid fa-paw"></i></div>
        <h2 class="step-title">Qual o tipo?</h2>
        <p class="step-sub">Selecione a espécie do seu pet</p>
        <input type="hidden" name="tipo" id="petTipo" required>
        <div class="tipo-grid">
          <button type="button" onclick="selectTipo(this,'cachorro')" class="tipo-btn">
            <span class="tipo-btn-icon">🐶</span> Cachorro
          </button>
          <button type="button" onclick="selectTipo(this,'gato')" class="tipo-btn">
            <span class="tipo-btn-icon">🐱</span> Gato
          </button>
          <button type="button" onclick="selectTipo(this,'passaro')" class="tipo-btn">
            <span class="tipo-btn-icon">🦜</span> Pássaro
          </button>
          <button type="button" onclick="selectTipo(this,'outro')" class="tipo-btn">
            <span class="tipo-btn-icon">🐾</span> Outro
          </button>
        </div>
        <button type="button" class="btn-back-step" onclick="prevStep()">
          <i class="fa-solid fa-arrow-left mr-1"></i> Voltar
        </button>
      </div>

      <!-- Step 3: Raça -->
      <div class="wizard-step hidden" data-step="3">
        <div class="step-icon-wrap"><i class="fa-solid fa-dna"></i></div>
        <h2 class="step-title">Qual a raça?</h2>
        <p class="step-sub">Pode digitar ou deixar em branco</p>
        <input type="text" name="raca" id="petRaca" placeholder="Ex: Golden Retriever, SRD..."
               class="ds-input center" maxlength="60">
        <button type="button" class="btn-next" onclick="nextStep()">Continuar <i class="fa-solid fa-arrow-right"></i></button>
        <button type="button" class="btn-skip" onclick="document.getElementById('petRaca').value=''; nextStep()">Pular</button>
        <button type="button" class="btn-back-step" onclick="prevStep()"><i class="fa-solid fa-arrow-left mr-1"></i> Voltar</button>
      </div>

      <!-- Step 4: Sexo -->
      <div class="wizard-step hidden" data-step="4">
        <div class="step-icon-wrap"><i class="fa-solid fa-venus-mars"></i></div>
        <h2 class="step-title">Qual o sexo?</h2>
        <p class="step-sub">Selecione uma opção</p>
        <input type="hidden" name="sexo" id="petSexo">
        <div class="sexo-grid">
          <button type="button" onclick="selectSexo(this,'macho')" class="sexo-btn">
            <i class="fa-solid fa-mars" style="color:#60a5fa;"></i> Macho
          </button>
          <button type="button" onclick="selectSexo(this,'femea')" class="sexo-btn">
            <i class="fa-solid fa-venus" style="color:#f472b6;"></i> Fêmea
          </button>
        </div>
        <button type="button" class="btn-skip" onclick="nextStep()">Pular</button>
        <button type="button" class="btn-back-step" onclick="prevStep()"><i class="fa-solid fa-arrow-left mr-1"></i> Voltar</button>
      </div>

      <!-- Step 5: Porte -->
      <div class="wizard-step hidden" data-step="5">
        <div class="step-icon-wrap"><i class="fa-solid fa-weight-scale"></i></div>
        <h2 class="step-title">Qual o porte?</h2>
        <p class="step-sub">Tamanho aproximado</p>
        <input type="hidden" name="porte" id="petPorte">
        <div class="porte-grid">
          <button type="button" onclick="selectPorte(this,'mini')" class="porte-btn">🐭 Mini</button>
          <button type="button" onclick="selectPorte(this,'pequeno')" class="porte-btn">🐩 Pequeno</button>
          <button type="button" onclick="selectPorte(this,'medio')" class="porte-btn">🐕 Médio</button>
          <button type="button" onclick="selectPorte(this,'grande')" class="porte-btn">🐕‍🦺 Grande</button>
          <button type="button" onclick="selectPorte(this,'gigante')" class="porte-btn">🦮 Gigante</button>
          <button type="button" onclick="nextStep()" class="porte-btn" style="border-style:dashed; font-size:11px;">Não sei</button>
        </div>
        <button type="button" class="btn-back-step" onclick="prevStep()"><i class="fa-solid fa-arrow-left mr-1"></i> Voltar</button>
      </div>

      <!-- Step 6: Nascimento -->
      <div class="wizard-step hidden" data-step="6">
        <div class="step-icon-wrap"><i class="fa-solid fa-cake-candles"></i></div>
        <h2 class="step-title">Quando nasceu?</h2>
        <p class="step-sub">Data de nascimento aproximada</p>
        <input type="date" name="dataNascimento" id="petDataNascimento" class="ds-input center">
        <button type="button" class="btn-next" onclick="nextStep()">Continuar <i class="fa-solid fa-arrow-right"></i></button>
        <button type="button" class="btn-skip" onclick="nextStep()">Pular</button>
        <button type="button" class="btn-back-step" onclick="prevStep()"><i class="fa-solid fa-arrow-left mr-1"></i> Voltar</button>
      </div>

      <!-- Step 7: Cor -->
      <div class="wizard-step hidden" data-step="7">
        <div class="step-icon-wrap"><i class="fa-solid fa-palette"></i></div>
        <h2 class="step-title">Qual a cor/pelagem?</h2>
        <p class="step-sub">Cor predominante do pelo</p>
        <input type="text" name="cor" placeholder="Ex: Preto, Dourado, Tigrado..."
               class="ds-input center" maxlength="50">
        <button type="button" class="btn-next" onclick="nextStep()">Continuar <i class="fa-solid fa-arrow-right"></i></button>
        <button type="button" class="btn-skip" onclick="nextStep()">Pular</button>
        <button type="button" class="btn-back-step" onclick="prevStep()"><i class="fa-solid fa-arrow-left mr-1"></i> Voltar</button>
      </div>

      <!-- Step 8: Foto -->
      <div class="wizard-step hidden" data-step="8">
        <div class="step-icon-wrap"><i class="fa-solid fa-camera"></i></div>
        <h2 class="step-title">Foto do pet</h2>
        <p class="step-sub">Uma boa foto ajuda a identificá-lo</p>
        <label for="petFoto" class="foto-label">
          <img src="" alt="" id="fotoPreviewImg" class="foto-preview hidden">
          <div id="fotoPlaceholder" class="foto-placeholder">
            <i class="fa-solid fa-camera"></i>
            <span>Toque para escolher foto</span>
          </div>
          <div class="foto-overlay"><i class="fa-solid fa-pen mr-2"></i> Alterar</div>
        </label>
        <input type="file" id="petFoto" name="foto" accept="image/*" class="hidden" onchange="previewFoto(this)">
        <button type="button" class="btn-next" onclick="nextStep()">Continuar <i class="fa-solid fa-arrow-right"></i></button>
        <button type="button" class="btn-skip" onclick="nextStep()">Pular</button>
        <button type="button" class="btn-back-step" onclick="prevStep()"><i class="fa-solid fa-arrow-left mr-1"></i> Voltar</button>
      </div>

      <!-- Step 9: Bio / Descrição emocional -->
      <div class="wizard-step hidden" data-step="9">
        <div class="step-icon-wrap"><i class="fa-solid fa-quote-left"></i></div>
        <h2 class="step-title">Algo especial?</h2>
        <p class="step-sub">Uma frase carinhosa sobre o seu pet (opcional)</p>
        <textarea name="descricao" class="ds-input" rows="4"
                  placeholder="Ex: Adora correr na praia e é melhor amigo de todos..."
                  maxlength="200" style="resize:none;"></textarea>
        <div style="font-size:11px;color:var(--text-muted);text-align:right;margin-top:4px;">0/200</div>
        <button type="submit" class="btn-next" style="background:var(--green);">
          <i class="fa-solid fa-paw"></i> Cadastrar pet
        </button>
        <button type="button" class="btn-back-step" onclick="prevStep()"><i class="fa-solid fa-arrow-left mr-1"></i> Voltar</button>
      </div>

    </form>
  </div>
</main>

<script>
var currentStep = 1, totalSteps = 9;

function updateProgress() {
  var pct = Math.round((currentStep / totalSteps) * 100);
  document.getElementById('progressBar').style.width = pct + '%';
  document.getElementById('stepLabel').textContent = 'Passo ' + currentStep + ' de ' + totalSteps;
  document.getElementById('stepPercent').textContent = pct + '%';
}

function showStep(n) {
  document.querySelectorAll('.wizard-step').forEach(function(s) { s.classList.add('hidden'); });
  document.querySelector('[data-step="' + n + '"]').classList.remove('hidden');
  currentStep = n;
  updateProgress();
  window.scrollTo({ top: 0, behavior: 'smooth' });
}

function nextStep() {
  if (currentStep === 1 && !document.getElementById('petNome').value.trim()) {
    document.getElementById('petNome').focus(); return;
  }
  if (currentStep < totalSteps) showStep(currentStep + 1);
}

function prevStep() {
  if (currentStep > 1) showStep(currentStep - 1);
}

function selectTipo(btn, val) {
  document.querySelectorAll('.tipo-btn').forEach(function(b) { b.classList.remove('selected'); });
  btn.classList.add('selected');
  document.getElementById('petTipo').value = val;
  setTimeout(nextStep, 250);
}

function selectSexo(btn, val) {
  document.querySelectorAll('.sexo-btn').forEach(function(b) { b.classList.remove('selected'); });
  btn.classList.add('selected');
  document.getElementById('petSexo').value = val;
  setTimeout(nextStep, 250);
}

function selectPorte(btn, val) {
  document.querySelectorAll('.porte-btn').forEach(function(b) { b.classList.remove('selected'); });
  btn.classList.add('selected');
  document.getElementById('petPorte').value = val;
  setTimeout(nextStep, 250);
}

function previewFoto(input) {
  if (!input.files || !input.files[0]) return;
  var r = new FileReader();
  r.onload = function(e) {
    var img = document.getElementById('fotoPreviewImg');
    var ph = document.getElementById('fotoPlaceholder');
    img.src = e.target.result;
    img.classList.remove('hidden');
    ph.classList.add('hidden');
  };
  r.readAsDataURL(input.files[0]);
}

// Bio counter
var bioArea = document.querySelector('textarea[name="descricao"]');
if (bioArea) {
  bioArea.addEventListener('input', function() {
    this.nextElementSibling.textContent = this.value.length + '/200';
  });
}
</script>

<%- include('../partials/footer') %>
