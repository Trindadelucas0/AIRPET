<% locals.titulo = pet.nome %>
<% locals.extraHead = `
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css">
<style>
  #mapaScan { height: 350px; border-radius: 14px; z-index: 1; }

  .profile-soft-card {
    border-color: color-mix(in srgb, var(--border) 82%, white);
    border-radius: 1.25rem;
    box-shadow: 0 8px 24px rgba(15, 23, 42, 0.04);
  }

  .profile-soft-subcard {
    border: 1px solid color-mix(in srgb, var(--border) 76%, white);
    border-radius: 0.95rem;
    background: color-mix(in srgb, var(--muted) 45%, white);
  }

  .profile-info-card {
    border-color: color-mix(in srgb, var(--border) 78%, white);
    border-radius: 1rem;
    box-shadow: 0 2px 10px rgba(15, 23, 42, 0.03);
  }

  .profile-action-card {
    border-color: color-mix(in srgb, var(--border) 80%, white);
    border-radius: 1rem;
    min-height: 84px;
  }

  .profile-focus:focus-visible {
    outline: 0;
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--ring) 20%, transparent);
    border-color: color-mix(in srgb, var(--ring) 60%, white);
  }

  .profile-callout-card {
    background: color-mix(in srgb, var(--muted) 62%, white);
    border: 1px solid color-mix(in srgb, var(--border) 76%, white);
    border-radius: 1rem;
  }

  .pet-panel {
    padding: 1.1rem;
    border-radius: 1rem;
    border: 1px solid color-mix(in srgb, var(--border) 74%, white);
    background: linear-gradient(180deg, #ffffff 0%, color-mix(in srgb, var(--muted) 45%, white) 100%);
  }

  .pet-chip-soft {
    border: 1px solid color-mix(in srgb, var(--border) 72%, white);
    background: color-mix(in srgb, var(--muted) 58%, white);
  }

  .panel-modal-overlay {
    background: rgba(15, 23, 42, 0.58);
    backdrop-filter: blur(3px);
  }

  .panel-modal-surface {
    border: 1px solid color-mix(in srgb, var(--border) 75%, white);
    border-radius: 1.1rem;
    box-shadow: 0 24px 54px rgba(15, 23, 42, 0.28);
    background: #ffffff;
    overflow: hidden;
  }

  .panel-modal-header {
    padding: 0.85rem 1rem;
    border-bottom: 1px solid color-mix(in srgb, var(--border) 74%, white);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: .75rem;
  }

  .panel-modal-close {
    width: 2rem;
    height: 2rem;
    border: 1px solid color-mix(in srgb, var(--border) 76%, white);
    border-radius: 999px;
    color: #475569;
    background: #fff;
    transition: all .2s ease;
  }

  .panel-modal-close:hover { background: #f8fafc; color: #0f172a; }

  .panel-modal-media-wrap {
    background: #f8fafc;
    max-height: min(70vh, 760px);
    overflow: hidden;
  }

  .panel-map-shell {
    border: 1px solid color-mix(in srgb, var(--border) 76%, white);
    border-radius: 1rem;
    background: color-mix(in srgb, var(--muted) 42%, white);
  }

  .scan-info-grid {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 0.75rem;
    align-items: center;
  }

  .panel-nav-btn {
    border-radius: .85rem;
    border: 1px solid color-mix(in srgb, var(--border) 72%, white);
    font-weight: 600;
    font-size: .86rem;
    transition: all .2s ease;
  }

  .panel-nav-btn:hover { transform: translateY(-1px); }

  .scan-item {
    border-left: 3px solid transparent;
    transition: background-color .2s ease, border-color .2s ease;
  }

  .scan-item:hover { background: color-mix(in srgb, var(--muted) 72%, white); }

  .scan-item.active {
    background: color-mix(in srgb, var(--muted) 64%, white);
    border-left-color: var(--primary);
  }
</style>
` %>
<%- include('../partials/header') %>
<%- include('../partials/flash') %>

<main class="flex-1 container mx-auto px-4 py-6 max-w-3xl">
  <%- include('../partials/page-header', { backHref: '/pets', backLabel: 'Meus Pets', sticky: false }) %>

  <!-- Hero com foto do pet -->
  <div class="card profile-soft-card p-0 overflow-hidden mb-6">
    <div class="relative">
      <% if (pet.foto) { %>
        <img src="<%= pet.foto %><%= pet.data_atualizacao ? '?t=' + new Date(pet.data_atualizacao).getTime() : '' %>" alt="<%= pet.nome %>"
             class="w-full h-56 sm:h-72 object-cover">
      <% } else { %>
        <div class="w-full h-56 sm:h-72 bg-gradient-to-br from-orange-100 to-orange-50 flex items-center justify-center">
          <i class="fa-solid fa-paw text-6xl text-orange-300"></i>
        </div>
      <% } %>
      <span class="absolute top-4 right-4 px-3 py-1.5 rounded-full text-xs font-bold uppercase tracking-wide shadow-sm
        <%= pet.status === 'perdido' ? 'bg-red-500 text-white' : 'bg-emerald-500 text-white' %>">
        <i class="fa-solid <%= pet.status === 'perdido' ? 'fa-triangle-exclamation' : 'fa-shield-halved' %> mr-1"></i>
        <%= pet.status === 'perdido' ? 'Perdido' : 'Seguro' %>
      </span>
    </div>

    <div class="p-5 sm:p-6">
      <div class="pet-panel">
        <div class="flex items-start justify-between gap-3">
          <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 leading-tight">
            <%= pet.nome %>
          </h1>
          <i class="fa-solid fa-paw text-primary-500/60 text-xl mt-1"></i>
        </div>

        <% if (pet.data_nascimento) {
          var agora = new Date();
          var nasc = new Date(pet.data_nascimento);
          var anos = agora.getFullYear() - nasc.getFullYear();
          var meses = agora.getMonth() - nasc.getMonth();
          if (meses < 0) { anos--; meses += 12; }
        %>
          <p class="text-sm text-gray-500 mt-1.5">
            <i class="fa-solid fa-cake-candles mr-1"></i>
            <%= anos %> ano<%= anos !== 1 ? 's' : '' %><% if (meses > 0) { %> e <%= meses %> m<%= meses !== 1 ? 'eses' : 'es' %><% } %>
          </p>
        <% } %>

        <% if (pet.descricao_emocional) { %>
          <p class="text-gray-600 italic text-sm leading-relaxed mt-3">"<%= pet.descricao_emocional %>"</p>
        <% } %>

        <% if (typeof idadePet !== 'undefined' && idadePet) { %>
          <div class="mt-3.5 flex flex-wrap items-center gap-2">
            <span class="pet-chip-soft inline-flex items-center gap-1 px-2.5 py-1 rounded-full text-orange-700 text-xs font-semibold">
              <i class="fa-solid fa-hourglass-half"></i>
              <%= idadePet.anos %> ano<%= idadePet.anos !== 1 ? 's' : '' %>,
              <%= idadePet.meses %> m<%= idadePet.meses !== 1 ? 'eses' : 'es' %> e
              <%= idadePet.dias %> dia<%= idadePet.dias !== 1 ? 's' : '' %>
            </span>
            <% if (idadePet.idadeHumana > 0 && (idadePet.tipo === 'cachorro' || idadePet.tipo === 'gato')) { %>
              <span class="pet-chip-soft inline-flex items-center gap-1 px-2.5 py-1 rounded-full text-blue-700 text-xs font-semibold">
                <i class="fa-solid fa-person"></i>
                ~<%= idadePet.idadeHumana %> anos humanos
              </span>
            <% } %>
          </div>
        <% } %>

        <% if (pet.dono_nome) { %>
          <p class="text-xs text-gray-500 mt-3.5"><i class="fa-solid fa-user mr-1"></i> Tutor: <%= pet.dono_nome %></p>
        <% } %>
      </div>
    </div>
  </div>

  <% if (pet.status === 'perdido') { %>
    <div class="mb-6">
      <button type="button"
        onclick="compartilharWhatsApp('🚨 Pet perdido: <%= pet.nome %>! Se você viu este pet, acesse: ' + window.location.origin + '/pets/<%= pet.id %>')"
        class="w-full inline-flex items-center justify-center gap-2 px-4 py-3 rounded-xl bg-green-500 hover:bg-green-600 text-white font-bold transition-colors shadow-sm">
        <i class="fa-brands fa-whatsapp text-xl"></i> Compartilhar no WhatsApp
      </button>
    </div>
  <% } %>

  <!-- Info cards -->
  <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-6">
    <div class="card profile-info-card text-center !p-4">
      <i class="fa-solid fa-paw text-primary-500 text-lg mb-1"></i>
      <p class="text-xs text-gray-400 uppercase font-medium">Tipo</p>
      <p class="text-sm font-bold text-gray-800 mt-0.5">
        <% if (pet.tipo === 'outro' && pet.tipo_custom) { %>
          <%= pet.tipo_custom %>
        <% } else { %>
          <%= pet.tipo ? pet.tipo.charAt(0).toUpperCase() + pet.tipo.slice(1) : '—' %>
        <% } %>
      </p>
    </div>
    <div class="card profile-info-card text-center !p-4">
      <i class="fa-solid fa-dna text-primary-500 text-lg mb-1"></i>
      <p class="text-xs text-gray-400 uppercase font-medium">Raca</p>
      <p class="text-sm font-bold text-gray-800 mt-0.5"><%= pet.raca || 'SRD' %></p>
    </div>
    <div class="card profile-info-card text-center !p-4">
      <i class="fa-solid fa-weight-scale text-primary-500 text-lg mb-1"></i>
      <p class="text-xs text-gray-400 uppercase font-medium">Peso</p>
      <p class="text-sm font-bold text-gray-800 mt-0.5"><%= pet.peso ? pet.peso + ' kg' : '—' %></p>
    </div>
    <div class="card profile-info-card text-center !p-4">
      <i class="fa-solid fa-cake-candles text-primary-500 text-lg mb-1"></i>
      <p class="text-xs text-gray-400 uppercase font-medium">Nascimento</p>
      <p class="text-sm font-bold text-gray-800 mt-0.5">
        <% if (pet.data_nascimento) { %>
          <%= new Date(pet.data_nascimento).toLocaleDateString('pt-BR') %>
        <% } else { %>—<% } %>
      </p>
    </div>
  </div>

  <!-- Info extra: sexo, porte, cor -->
  <% if (pet.sexo || pet.porte || pet.cor) { %>
    <div class="grid grid-cols-3 gap-3 mb-6">
      <% if (pet.sexo) { %>
        <div class="card profile-info-card text-center !p-3">
          <i class="fa-solid <%= pet.sexo === 'macho' ? 'fa-mars text-blue-500' : pet.sexo === 'femea' ? 'fa-venus text-pink-500' : 'fa-question text-gray-400' %> text-lg mb-1"></i>
          <p class="text-xs text-gray-400 uppercase font-medium">Sexo</p>
          <p class="text-sm font-bold text-gray-800 capitalize"><%= pet.sexo === 'femea' ? 'Femea' : pet.sexo === 'nao_sei' ? 'N/A' : pet.sexo %></p>
        </div>
      <% } %>
      <% if (pet.porte) { %>
        <div class="card profile-info-card text-center !p-3">
          <span class="text-lg block mb-1"><%= pet.porte === 'pequeno' ? '🐕' : pet.porte === 'medio' ? '🐕‍🦺' : '🦮' %></span>
          <p class="text-xs text-gray-400 uppercase font-medium">Porte</p>
          <p class="text-sm font-bold text-gray-800 capitalize"><%= pet.porte %></p>
        </div>
      <% } %>
      <% if (pet.cor) { %>
        <div class="card profile-info-card text-center !p-3">
          <i class="fa-solid fa-palette text-primary-500 text-lg mb-1"></i>
          <p class="text-xs text-gray-400 uppercase font-medium">Cor</p>
          <p class="text-sm font-bold text-gray-800"><%= pet.cor %></p>
        </div>
      <% } %>
    </div>
  <% } %>

  <!-- Acoes do dono -->
  <% if (ehDono) { %>
    <div class="grid grid-cols-2 sm:grid-cols-3 gap-3 mb-6">
      <a href="/pets/<%= pet.id %>/editar" class="card profile-action-card profile-focus !p-4 text-center hover:bg-orange-50/50 transition-colors group">
        <i class="fa-solid fa-pen text-gray-400 group-hover:text-primary-500 text-xl mb-2"></i>
        <p class="text-xs font-semibold text-gray-700">Editar</p>
      </a>
      <a href="/pets/<%= pet.id %>/saude" class="card profile-action-card profile-focus !p-4 text-center hover:bg-green-50/60 transition-colors group">
        <i class="fa-solid fa-heart-pulse text-gray-400 group-hover:text-green-500 text-xl mb-2"></i>
        <p class="text-xs font-semibold text-gray-700">Saude</p>
      </a>
      <% if (pet.status !== 'perdido') { %>
        <a href="/perdidos/<%= pet.id %>/formulario" class="card profile-action-card profile-focus !p-4 text-center hover:bg-red-50/60 transition-colors group">
          <i class="fa-solid fa-triangle-exclamation text-gray-400 group-hover:text-red-500 text-xl mb-2"></i>
          <p class="text-xs font-semibold text-gray-700">Reportar Perda</p>
        </a>
      <% } else { %>
        <a href="/perdidos/<%= pet.id %>/encontrado" class="card profile-action-card profile-focus !p-4 text-center hover:bg-green-50/60 transition-colors group">
          <i class="fa-solid fa-check-circle text-gray-400 group-hover:text-green-500 text-xl mb-2"></i>
          <p class="text-xs font-semibold text-gray-700">Encontrado!</p>
        </a>
      <% } %>
    </div>

    <!-- Seção de Tag NFC -->
    <div class="card profile-soft-card mb-6">
      <div class="flex items-center justify-between mb-3">
        <div class="flex items-center gap-2">
          <div class="w-9 h-9 rounded-xl bg-primary-500/10 flex items-center justify-center">
            <i class="fa-solid fa-microchip text-primary-500"></i>
          </div>
          <div>
            <h2 class="text-lg font-bold text-gray-900">Tag NFC AIRPET</h2>
            <p class="text-xs text-gray-500">A forma mais rápida de trazer <%= pet.nome %> de volta para casa.</p>
          </div>
        </div>
        <% if (typeof tags !== 'undefined' && tags && tags.length > 0) { %>
          <span class="text-xs bg-emerald-100 text-emerald-700 px-2 py-1 rounded-full font-semibold">
            <i class="fa-solid fa-check mr-1"></i><%= tags.length %> tag<%= tags.length > 1 ? 's' : '' %>
          </span>
        <% } %>
      </div>

      <% if (typeof tags !== 'undefined' && tags && tags.length > 0) { %>
        <div class="space-y-2 mb-4">
          <% tags.forEach(function(tag) { %>
            <div class="flex items-center gap-3 profile-soft-subcard p-3">
              <span class="w-9 h-9 rounded-lg bg-primary-500/10 text-primary-500 flex items-center justify-center flex-shrink-0">
                <i class="fa-solid fa-microchip text-sm"></i>
              </span>
              <div class="flex-1 min-w-0">
                <p class="text-sm font-bold font-mono text-gray-800"><%= tag.tag_code %></p>
                <p class="text-xs text-gray-400">
                  Status:
                  <span class="font-semibold capitalize <%= tag.status === 'active' ? 'text-emerald-600' : 'text-amber-600' %>"><%= tag.status %></span>
                  <% if (pet.status === 'perdido') { %>
                    <span class="ml-2 inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-[10px] font-bold bg-red-100 text-red-700">
                      <i class="fa-solid fa-triangle-exclamation"></i> Perdido
                    </span>
                  <% } %>
                </p>
              </div>
              <i class="fa-solid <%= pet.status === 'perdido' ? 'fa-triangle-exclamation text-red-500' : 'fa-shield-halved text-emerald-400' %>"></i>
            </div>
          <% }); %>
        </div>
      <% } else { %>
        <div class="py-4 mb-4">
          <div class="flex items-center gap-3 mb-3">
            <div class="w-10 h-10 rounded-full bg-orange-50 flex items-center justify-center">
              <i class="fa-solid fa-tag text-orange-400"></i>
            </div>
            <div>
              <p class="text-sm font-semibold text-gray-800">Nenhuma tag vinculada ainda</p>
              <p class="text-xs text-gray-500">
                Se alguém encontrar <strong><%= pet.nome %></strong> na rua, a tag NFC ajuda essa pessoa a chegar até você
                em poucos toques no celular.
              </p>
            </div>
          </div>
          <ul class="text-xs text-gray-500 space-y-1.5 pl-3 list-disc list-inside">
            <li>Quem encontra encosta o celular na tag e vê um resumo seguro do perfil.</li>
            <li>Você recebe uma notificação com o local aproximado onde a tag foi escaneada.</li>
            <li>É como uma plaquinha de identificação inteligente, sempre atualizada.</li>
          </ul>
        </div>
      <% } %>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-2 mt-2">
        <a href="/pets/<%= pet.id %>/vincular-tag"
           class="inline-flex items-center justify-center gap-2 px-4 py-3 rounded-xl text-sm font-semibold text-white bg-primary-500 hover:bg-primary-600 transition-colors">
          <i class="fa-solid fa-plus"></i>
          Já tenho uma tag AIRPET
        </a>
        <a href="/parceiros"
           class="inline-flex items-center justify-center gap-2 px-4 py-3 rounded-xl text-sm font-semibold text-primary-500 border-2 border-primary-100 bg-primary-50 hover:bg-primary-100 transition-colors">
          <i class="fa-solid fa-store"></i>
          Quero saber como ter
        </a>
      </div>
    </div>

    <!-- =====================================================
         HISTORICO DE SCANS DA TAG NFC (ultimos 10)
         ===================================================== -->
    <% if (typeof scans !== 'undefined' && scans && scans.length > 0) { %>
      <div class="card profile-soft-card mb-6">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-lg font-bold text-gray-900">
            <i class="fa-solid fa-satellite-dish text-primary-500 mr-2"></i>Historico de Scans
          </h2>
          <span class="text-xs bg-orange-100 text-orange-700 px-2 py-1 rounded-full font-semibold">
            <%= scans.length %> registro<%= scans.length !== 1 ? 's' : '' %>
          </span>
        </div>
        <p class="text-xs text-gray-500 mb-4">
          Ultimas vezes que a tag NFC de <%= pet.nome %> foi escaneada. Toque para ver no mapa.
        </p>

        <div class="space-y-0 divide-y divide-gray-200/70 max-h-[400px] overflow-y-auto rounded-xl border border-gray-200/70 bg-white">
          <% scans.forEach(function(scan, idx) {
            var dt = new Date(scan.data);
            var agora2 = new Date();
            var diffMs = agora2 - dt;
            var diffMin = Math.floor(diffMs / 60000);
            var diffH = Math.floor(diffMin / 60);
            var diffD = Math.floor(diffH / 24);
            var tempoAtras = '';
            if (diffD > 0) { tempoAtras = diffD + ' dia' + (diffD > 1 ? 's' : '') + ' atras'; }
            else if (diffH > 0) { tempoAtras = diffH + 'h atras'; }
            else if (diffMin > 0) { tempoAtras = diffMin + 'min atras'; }
            else { tempoAtras = 'agora'; }
          %>
            <div class="scan-item p-3 flex items-center gap-3 cursor-pointer"
                 data-lat="<%= scan.latitude %>"
                 data-lng="<%= scan.longitude %>"
                 data-data="<%= dt.toISOString() %>"
                 data-cidade="<%= scan.cidade || '' %>"
                 data-idx="<%= idx %>"
                 onclick="mostrarScanNoMapa(this)">
              <div class="w-9 h-9 rounded-full flex items-center justify-center flex-shrink-0
                   <%= idx === 0 ? 'bg-primary-500 text-white' : 'bg-gray-100 text-gray-500' %>">
                <% if (idx === 0) { %>
                  <i class="fa-solid fa-location-dot text-sm"></i>
                <% } else { %>
                  <span class="text-xs font-bold"><%= idx + 1 %></span>
                <% } %>
              </div>
              <div class="flex-1 min-w-0">
                <p class="text-sm font-semibold text-gray-800">
                  <% if (idx === 0) { %>
                    <span class="text-primary-500">Mais recente</span>
                  <% } else { %>
                    Scan #<%= idx + 1 %>
                  <% } %>
                </p>
                <p class="text-xs text-gray-500">
                  <%= dt.toLocaleDateString('pt-BR') %> as <%= dt.toLocaleTimeString('pt-BR', {hour:'2-digit',minute:'2-digit'}) %>
                  <span class="text-gray-400">(<%= tempoAtras %>)</span>
                </p>
                <% if (scan.cidade) { %>
                  <p class="text-xs text-gray-400 truncate"><i class="fa-solid fa-map-pin mr-1"></i><%= scan.cidade %></p>
                <% } %>
              </div>
              <div class="flex items-center gap-2 flex-shrink-0">
                <i class="fa-solid fa-route text-gray-300 text-sm"></i>
                <i class="fa-solid fa-chevron-right text-gray-300 text-xs"></i>
              </div>
            </div>
          <% }); %>
        </div>
      </div>

      <!-- Mapa de scans -->
      <div id="mapaScansContainer" class="card profile-soft-card panel-map-shell mb-6 hidden">
        <div class="flex items-center justify-between mb-3">
          <h2 class="text-lg font-bold text-gray-900 leading-tight">
            <i class="fa-solid fa-map text-primary-500 mr-2"></i>Localizacao do Scan
          </h2>
          <button type="button" onclick="fecharMapaScan()" class="panel-modal-close profile-focus inline-flex items-center justify-center" aria-label="Fechar painel de localizacao">
            <i class="fa-solid fa-times text-lg"></i>
          </button>
        </div>

        <!-- Info do scan selecionado -->
        <div id="scanInfoCard" class="profile-callout-card p-3.5 mb-3">
          <div class="scan-info-grid">
            <div>
              <p class="text-sm font-bold text-gray-800 leading-tight" id="scanInfoTitle"></p>
              <p class="text-xs text-gray-500 mt-0.5" id="scanInfoData"></p>
            </div>
            <div class="text-right rounded-lg border border-gray-200/80 bg-white px-3 py-1.5">
              <p class="text-sm font-bold text-primary-500 leading-tight" id="scanInfoDist"></p>
              <p class="text-[11px] text-gray-500 mt-0.5" id="scanInfoTempo"></p>
            </div>
          </div>
        </div>

        <div id="mapaScan"></div>

        <!-- Botoes de navegacao -->
        <div class="grid grid-cols-2 gap-3 mt-3" id="navButtons" style="display:none">
          <a id="btnGoogleMaps" href="#" target="_blank"
             class="panel-nav-btn profile-focus flex items-center justify-center gap-2 px-4 py-3 bg-blue-600 hover:bg-blue-700 text-white">
            <i class="fa-solid fa-diamond-turn-right"></i> Google Maps
          </a>
          <a id="btnWaze" href="#" target="_blank"
             class="panel-nav-btn profile-focus flex items-center justify-center gap-2 px-4 py-3 bg-[#33ccff] hover:bg-[#28b8e8] text-white">
            <i class="fa-brands fa-waze"></i> Waze
          </a>
        </div>
      </div>
    <% } else { %>
      <!-- Sem scans -->
      <% if (typeof tags !== 'undefined' && tags && tags.length > 0) { %>
        <div class="card profile-soft-card mb-6 text-center">
          <i class="fa-solid fa-satellite-dish text-gray-300 text-3xl mb-2"></i>
          <p class="text-sm text-gray-500">Nenhum scan registrado ainda.</p>
          <p class="text-xs text-gray-400 mt-1">Quando alguem escanear a tag NFC de <%= pet.nome %>, o historico aparecera aqui.</p>
        </div>
      <% } %>
    <% } %>
  <% } %>

  <!-- Fotos recebidas (quem encontrou enviou foto) -->
  <% if (typeof ehDono !== 'undefined' && ehDono && typeof fotosRecebidas !== 'undefined' && fotosRecebidas && fotosRecebidas.length > 0) { %>
    <div class="card profile-soft-card mb-6" id="fotos-recebidas">
      <h2 class="text-lg font-bold text-gray-900 mb-3">
        <i class="fa-solid fa-camera text-primary-500 mr-2"></i>Fotos recebidas
      </h2>
      <p class="text-xs text-gray-500 mb-4">Fotos que alguem enviou ao encontrar <%= pet.nome %>. Toque para ampliar.</p>
      <div class="grid grid-cols-3 sm:grid-cols-4 gap-3">
        <% fotosRecebidas.forEach(function(loc) {
          var dt = loc.data ? new Date(loc.data) : null;
          var dataStr = dt ? dt.toLocaleDateString('pt-BR') + ' ' + dt.toLocaleTimeString('pt-BR', {hour:'2-digit',minute:'2-digit'}) : '';
        %>
          <button type="button" class="block rounded-xl overflow-hidden border border-gray-200/80 hover:border-primary-400/50 focus:outline-none focus:ring-2 focus:ring-primary-500/25 foto-recebida-btn profile-focus"
                  data-foto-url="<%= loc.foto_url %>" data-data-str="<%= dataStr %>">
            <img src="<%= loc.foto_url %>" alt="Foto recebida" class="w-full aspect-square object-cover">
          </button>
        <% }); %>
      </div>
    </div>
    <!-- Modal foto recebida -->
    <div id="modalFotoRecebida" class="fixed inset-0 z-[9999] hidden items-center justify-center p-4 panel-modal-overlay" aria-hidden="true">
      <div class="relative max-w-2xl w-full">
        <div class="panel-modal-surface">
          <div class="panel-modal-header">
            <div class="min-w-0">
              <p class="text-sm font-semibold text-gray-900 truncate">Foto enviada por quem encontrou</p>
              <p id="modalFotoRecebidaData" class="text-xs text-gray-500 truncate"></p>
            </div>
            <button type="button" onclick="fecharModalFoto()" class="panel-modal-close profile-focus inline-flex items-center justify-center flex-shrink-0" aria-label="Fechar modal de foto">
              <i class="fa-solid fa-times text-sm"></i>
            </button>
          </div>
          <div class="panel-modal-media-wrap">
            <img id="modalFotoRecebidaImg" src="" alt="Foto recebida" class="w-full object-contain max-h-[70vh]">
          </div>
        </div>
      </div>
    </div>
    <script>
    function abrirModalFoto(url, dataStr) {
      var modal = document.getElementById('modalFotoRecebida');
      var img = document.getElementById('modalFotoRecebidaImg');
      var dataEl = document.getElementById('modalFotoRecebidaData');
      if (modal && img) {
        img.src = url || '';
        if (dataEl) dataEl.textContent = dataStr || '';
        modal.classList.remove('hidden');
        modal.classList.add('flex');
        modal.setAttribute('aria-hidden', 'false');
        document.body.style.overflow = 'hidden';
      }
    }
    function fecharModalFoto() {
      var modal = document.getElementById('modalFotoRecebida');
      if (modal) {
        modal.classList.add('hidden');
        modal.classList.remove('flex');
        modal.setAttribute('aria-hidden', 'true');
        document.body.style.overflow = '';
      }
    }
    document.querySelectorAll('.foto-recebida-btn').forEach(function(btn) {
      btn.addEventListener('click', function() {
        abrirModalFoto(this.getAttribute('data-foto-url'), this.getAttribute('data-data-str'));
      });
    });
    var modalEl = document.getElementById('modalFotoRecebida');
    if (modalEl) modalEl.addEventListener('click', function(e) { if (e.target === this) fecharModalFoto(); });
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') fecharModalFoto();
    });
    </script>
  <% } %>

  <!-- Telefone de contato publico -->
  <% if (pet.telefone_contato) { %>
    <div class="card profile-soft-card mb-6">
      <h2 class="text-lg font-bold text-gray-900 mb-3">
        <i class="fa-solid fa-phone text-primary-500 mr-2"></i>Contato
      </h2>
      <div class="flex gap-3">
        <a href="tel:<%= pet.telefone_contato %>" class="btn-primary flex-1 !inline-flex items-center justify-center gap-2">
          <i class="fa-solid fa-phone"></i> Ligar
        </a>
        <a href="https://wa.me/55<%= pet.telefone_contato.replace(/\D/g,'') %>" target="_blank"
           class="flex-1 inline-flex items-center justify-center gap-2 px-4 py-3 rounded-xl bg-green-500 hover:bg-green-600 text-white font-semibold transition-colors profile-focus">
          <i class="fa-brands fa-whatsapp"></i> WhatsApp
        </a>
      </div>
    </div>
  <% } %>

  <!-- Contato para quem encontrou (view publica) -->
  <% if (!ehDono) { %>
    <div class="card profile-callout-card text-center mb-6">
      <h2 class="text-lg font-bold text-gray-900 mb-2">
        <i class="fa-solid fa-heart text-red-400 mr-1"></i> Encontrou este pet?
      </h2>
      <p class="text-sm text-gray-500 mb-4">Ajude <%= pet.nome %> a voltar para casa!</p>
      <div class="flex flex-col gap-2">
        <% if (pet.telefone_contato) { %>
          <a href="tel:<%= pet.telefone_contato %>" class="btn-primary !inline-flex items-center justify-center gap-2">
            <i class="fa-solid fa-phone"></i> Ligar para o tutor
          </a>
        <% } %>
        <button type="button" onclick="enviarLocalizacao()" class="btn-outline !inline-flex items-center justify-center gap-2">
          <i class="fa-solid fa-location-dot"></i> Enviar minha localizacao
        </button>
      </div>
    </div>
  <% } %>

</main>

<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script>
(function () {
  var mapaScan = null;
  var scanMarker = null;
  var routeLine = null;
  var userMarker = null;
  var minhaPos = null;

  /* Tenta obter posicao do usuario em background */
  if (navigator.geolocation) {
    navigator.geolocation.getCurrentPosition(function (pos) {
      minhaPos = { lat: pos.coords.latitude, lng: pos.coords.longitude };
    }, function () {}, { timeout: 8000 });
  }

  function initMap() {
    if (mapaScan) return;
    mapaScan = L.map('mapaScan').setView([-15.78, -47.93], 5);
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
      attribution: '&copy; OSM', maxZoom: 19
    }).addTo(mapaScan);
  }

  function calcDistancia(lat1, lon1, lat2, lon2) {
    var R = 6371;
    var dLat = (lat2 - lat1) * Math.PI / 180;
    var dLon = (lon2 - lon1) * Math.PI / 180;
    var a = Math.sin(dLat / 2) * Math.sin(dLat / 2) +
      Math.cos(lat1 * Math.PI / 180) * Math.cos(lat2 * Math.PI / 180) *
      Math.sin(dLon / 2) * Math.sin(dLon / 2);
    var c = 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1 - a));
    return R * c;
  }

  function formatarDistancia(km) {
    if (km < 1) return Math.round(km * 1000) + ' m';
    return km.toFixed(1) + ' km';
  }

  function estimarTempo(km) {
    var minutos = Math.round((km / 40) * 60);
    if (minutos < 1) return '< 1 min';
    if (minutos < 60) return minutos + ' min';
    var h = Math.floor(minutos / 60);
    var m = minutos % 60;
    return h + 'h' + (m > 0 ? ' ' + m + 'min' : '');
  }

  window.mostrarScanNoMapa = function (el) {
    var lat = parseFloat(el.dataset.lat);
    var lng = parseFloat(el.dataset.lng);
    var data = el.dataset.data;
    var cidade = el.dataset.cidade;
    var idx = parseInt(el.dataset.idx, 10);

    document.querySelectorAll('.scan-item').forEach(function (s) { s.classList.remove('active'); });
    el.classList.add('active');

    var container = document.getElementById('mapaScansContainer');
    container.classList.remove('hidden');

    initMap();

    setTimeout(function () {
      mapaScan.invalidateSize();

      if (scanMarker) mapaScan.removeLayer(scanMarker);
      if (routeLine) mapaScan.removeLayer(routeLine);
      if (userMarker) mapaScan.removeLayer(userMarker);

      scanMarker = L.marker([lat, lng], {
        icon: L.divIcon({
          className: 'custom-pin',
          html: '<div style="background:#ec5a1c;width:36px;height:36px;border-radius:50%;border:3px solid #fff;box-shadow:0 2px 8px rgba(0,0,0,.3);display:flex;align-items:center;justify-content:center"><i class="fa-solid fa-paw" style="color:#fff;font-size:14px"></i></div>',
          iconSize: [36, 36], iconAnchor: [18, 18]
        })
      }).addTo(mapaScan);

      var dt = new Date(data);
      var titulo = idx === 0 ? 'Scan mais recente' : 'Scan #' + (idx + 1);
      var dataStr = dt.toLocaleDateString('pt-BR') + ' as ' + dt.toLocaleTimeString('pt-BR', {hour:'2-digit',minute:'2-digit'});

      document.getElementById('scanInfoTitle').textContent = titulo + (cidade ? ' — ' + cidade : '');
      document.getElementById('scanInfoData').textContent = dataStr;

      if (minhaPos) {
        var dist = calcDistancia(minhaPos.lat, minhaPos.lng, lat, lng);
        document.getElementById('scanInfoDist').textContent = formatarDistancia(dist);
        document.getElementById('scanInfoTempo').textContent = '~' + estimarTempo(dist) + ' de carro';

        userMarker = L.marker([minhaPos.lat, minhaPos.lng], {
          icon: L.divIcon({
            className: 'custom-pin',
            html: '<div style="background:#3b82f6;width:28px;height:28px;border-radius:50%;border:3px solid #fff;box-shadow:0 2px 6px rgba(0,0,0,.3);display:flex;align-items:center;justify-content:center"><i class="fa-solid fa-user" style="color:#fff;font-size:10px"></i></div>',
            iconSize: [28, 28], iconAnchor: [14, 14]
          })
        }).addTo(mapaScan).bindPopup('<b>Voce esta aqui</b>');

        routeLine = L.polyline([
          [minhaPos.lat, minhaPos.lng],
          [lat, lng]
        ], {
          color: '#ec5a1c', weight: 3, opacity: 0.7, dashArray: '8, 8'
        }).addTo(mapaScan);

        var bounds = L.latLngBounds([[minhaPos.lat, minhaPos.lng], [lat, lng]]);
        mapaScan.fitBounds(bounds, { padding: [40, 40] });

        document.getElementById('navButtons').style.display = 'grid';
        document.getElementById('btnGoogleMaps').href =
          'https://www.google.com/maps/dir/?api=1&destination=' + lat + ',' + lng;
        document.getElementById('btnWaze').href =
          'https://waze.com/ul?ll=' + lat + ',' + lng + '&navigate=yes';
      } else {
        document.getElementById('scanInfoDist').textContent = '—';
        document.getElementById('scanInfoTempo').textContent = 'Ative o GPS';
        mapaScan.setView([lat, lng], 15);
        document.getElementById('navButtons').style.display = 'grid';
        document.getElementById('btnGoogleMaps').href =
          'https://www.google.com/maps/dir/?api=1&destination=' + lat + ',' + lng;
        document.getElementById('btnWaze').href =
          'https://waze.com/ul?ll=' + lat + ',' + lng + '&navigate=yes';
      }

      container.scrollIntoView({ behavior: 'smooth', block: 'center' });
    }, 150);
  };

  window.fecharMapaScan = function () {
    document.getElementById('mapaScansContainer').classList.add('hidden');
    document.querySelectorAll('.scan-item').forEach(function (s) { s.classList.remove('active'); });
  };
})();

function enviarLocalizacao() {
  if (!navigator.geolocation) { alert('Geolocalizacao nao suportada'); return; }
  navigator.geolocation.getCurrentPosition(function (pos) {
    var body = JSON.stringify({
      pet_id: '<%= pet.id %>',
      latitude: pos.coords.latitude,
      longitude: pos.coords.longitude,
      origem: 'encontrado'
    });
    var run = function () {
      return fetch('/api/localizacao', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        credentials: 'same-origin',
        body: body
      });
    };
    var L = window.AIRPET_LOADING;
    var p = L && typeof L.withDeferredOverlay === 'function'
      ? L.withDeferredOverlay(run, { message: 'A enviar localização…' })
      : run();
    p.then(function () {
      alert('Localizacao enviada! Obrigado por ajudar.');
    }).catch(function () {
      alert('Erro ao enviar. Tente novamente.');
    });
  });
}
</script>

