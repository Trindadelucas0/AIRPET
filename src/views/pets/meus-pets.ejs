<% locals.titulo = 'Meus Pets' %>
<% locals.extraHead = `
<link href="https://fonts.googleapis.com/css2?family=Rubik+Doodle+Shadow&family=Syne:wght@700;800&family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
  :root {
    --ink:#0d0d0f;--ink-2:#13131a;--ink-3:#1c1c26;--ink-4:#242432;
    --border:rgba(255,255,255,0.07);--border-hover:rgba(255,255,255,0.13);
    --text:#e4e4f0;--text-dim:#7a7a96;--text-muted:#3d3d52;
    --accent:#f26020;--accent-light:#ff7a3d;--accent-glow:rgba(242,96,32,0.12);
    --green:#22c55e;--red:#ef4444;
  }
  body { background:var(--ink) !important; color:var(--text) !important; font-family:'DM Sans',sans-serif; }

  .pets-topbar {
    position:sticky; top:56px; z-index:40;
    background:rgba(13,13,15,0.88); backdrop-filter:blur(20px);
    border-bottom:1px solid var(--border); padding:14px 0;
  }
  .pets-topbar-inner {
    max-width:1000px; margin:0 auto; padding:0 20px;
    display:flex; align-items:center; justify-content:space-between;
  }
  .pets-topbar h1 { font-family:var(--font-display); font-size:20px; font-weight:800; color:#fff; letter-spacing:0.02em; display:flex; align-items:center; gap:10px; }
  .count-badge {
    display:inline-flex; align-items:center; justify-content:center;
    min-width:24px; height:24px; padding:0 7px;
    background:var(--accent-glow); border:1px solid rgba(242,96,32,0.2);
    border-radius:100px; font-size:12px; font-weight:700; color:var(--accent);
  }

  .btn-new-pet {
    display:inline-flex; align-items:center; gap:8px;
    padding:9px 20px;
    background:var(--accent); color:#fff;
    border:none; border-radius:10px;
    font-size:14px; font-weight:700;
    font-family:'DM Sans',sans-serif;
    cursor:pointer; text-decoration:none;
    transition:all 0.2s;
  }
  .btn-new-pet:hover { background:var(--accent-light); transform:translateY(-1px); color:#fff; text-decoration:none; }

  .pets-grid {
    max-width:1000px; margin:0 auto;
    padding:24px 20px 80px;
    display:grid;
    grid-template-columns:repeat(3, 1fr);
    gap:16px;
  }
  @media (max-width:800px) { .pets-grid { grid-template-columns:repeat(2,1fr); } }
  @media (max-width:500px) { .pets-grid { grid-template-columns:1fr; } }

  /* ── PET CARD ── */
  .pet-card {
    background:var(--ink-2);
    border:1px solid var(--border);
    border-radius:18px;
    overflow:hidden;
    transition:all 0.3s;
    animation:slide-up 0.4s ease-out both;
    text-decoration:none;
    display:block;
    position:relative;
  }
  .pet-card:hover {
    border-color:var(--border-hover);
    transform:translateY(-4px);
    box-shadow:0 20px 40px rgba(0,0,0,0.4);
    text-decoration:none;
  }

  @keyframes slide-up { from { opacity:0; transform:translateY(16px); } to { opacity:1; transform:none; } }

  .pet-card-photo {
    width:100%; aspect-ratio:1/1;
    object-fit:cover; display:block;
    background:var(--ink-3);
  }
  .pet-card-photo-empty {
    width:100%; aspect-ratio:1/1;
    background:var(--ink-3);
    display:flex; align-items:center; justify-content:center;
    font-size:52px; opacity:0.3;
  }

  .pet-status-badge {
    position:absolute; top:12px; left:12px;
    display:inline-flex; align-items:center; gap:5px;
    padding:4px 10px; border-radius:100px;
    font-size:10px; font-weight:700; letter-spacing:0.08em; text-transform:uppercase;
    backdrop-filter:blur(8px);
  }
  .pet-status-badge.safe { background:rgba(34,197,94,0.85); color:#fff; }
  .pet-status-badge.lost { background:rgba(239,68,68,0.9); color:#fff; animation:pulse-badge 1.5s ease-in-out infinite; }
  @keyframes pulse-badge { 0%,100%{ box-shadow:0 0 0 0 rgba(239,68,68,0.4); } 50%{ box-shadow:0 0 0 6px rgba(239,68,68,0); } }

  .pet-card-body { padding:14px 16px; }
  .pet-card-name {
    font-family:var(--font-display);
    font-size:17px; font-weight:800; color:#fff;
    margin-bottom:3px;
  }
  .pet-card-sub { font-size:12px; color:var(--text-dim); margin-bottom:12px; }

  .pet-card-actions {
    display:flex; gap:6px; flex-wrap:wrap;
  }
  .pet-action-btn {
    flex:1; display:inline-flex; align-items:center; justify-content:center; gap:6px;
    padding:7px 10px;
    border-radius:9px;
    font-size:11px; font-weight:700;
    text-decoration:none; transition:all 0.15s;
  }
  .pet-action-btn.primary { background:var(--accent-glow); border:1px solid rgba(242,96,32,0.2); color:var(--accent); }
  .pet-action-btn.primary:hover { background:var(--accent); color:#fff; border-color:var(--accent); text-decoration:none; }
  .pet-action-btn.ghost { background:var(--ink-3); border:1px solid var(--border); color:var(--text-dim); }
  .pet-action-btn.ghost:hover { border-color:var(--border-hover); color:var(--text); text-decoration:none; }

  /* ── EMPTY STATE ── */
  .pets-empty {
    max-width:400px; margin:80px auto; text-align:center; padding:0 20px;
  }
  .pets-empty-icon { font-size:64px; opacity:0.15; display:block; margin-bottom:20px; }
  .pets-empty h2 { font-family:var(--font-display); font-size:24px; font-weight:800; color:#fff; margin-bottom:8px; }
  .pets-empty p { font-size:14px; color:var(--text-dim); margin-bottom:24px; line-height:1.6; }
</style>
` %>
<%- include('../partials/header') %>
<%- include('../partials/flash') %>

<div class="pets-topbar">
  <div class="pets-topbar-inner">
    <h1>
      Meus Pets
      <% if (typeof pets !== 'undefined' && pets.length > 0) { %>
        <span class="count-badge"><%= pets.length %></span>
      <% } %>
    </h1>
    <a href="/pets/cadastro" class="btn-new-pet">
      <i class="fa-solid fa-plus"></i>
      <span class="hidden sm:inline">Novo Pet</span>
    </a>
  </div>
</div>

<main class="flex-1 pb-24 md:pb-6">
  <% if (typeof pets !== 'undefined' && pets.length > 0) { %>
    <div class="pets-grid">
      <% pets.forEach(function(pet, idx) { %>
        <div class="pet-card" style="animation-delay:<%= idx * 60 %>ms">

          <!-- Photo -->
          <a href="/pets/<%= pet.id %>">
            <% if (pet.foto) { %>
              <img src="<%= pet.foto %>" class="pet-card-photo" alt="<%= pet.nome %>" loading="lazy">
            <% } else { %>
              <div class="pet-card-photo-empty">
                <%= pet.tipo === 'gato' ? '🐱' : pet.tipo === 'passaro' ? '🦜' : '🐾' %>
              </div>
            <% } %>
          </a>

          <!-- Status badge -->
          <span class="pet-status-badge <%= pet.status === 'perdido' ? 'lost' : 'safe' %>">
            <% if (pet.status === 'perdido') { %>
              <i class="fa-solid fa-triangle-exclamation"></i> Perdido
            <% } else { %>
              <i class="fa-solid fa-shield-halved"></i> Seguro
            <% } %>
          </span>

          <!-- Body -->
          <div class="pet-card-body">
            <div class="pet-card-name"><%= pet.nome %></div>
            <div class="pet-card-sub">
              <%= pet.raca || (pet.tipo ? pet.tipo.charAt(0).toUpperCase() + pet.tipo.slice(1) : 'Pet') %>
              <% if (pet.data_nascimento) {
                var anos = Math.floor((Date.now() - new Date(pet.data_nascimento)) / (365.25*24*3600*1000));
                if (anos >= 0) { %> · <%= anos %> ano<%= anos !== 1 ? 's' : '' %><% } } %>
            </div>
            <div class="pet-card-actions">
              <a href="/pets/<%= pet.id %>" class="pet-action-btn primary">
                <i class="fa-solid fa-paw"></i> Ver
              </a>
              <a href="/pets/<%= pet.id %>/editar" class="pet-action-btn ghost">
                <i class="fa-solid fa-pen"></i>
              </a>
              <a href="/pets/<%= pet.id %>/saude" class="pet-action-btn ghost">
                <i class="fa-solid fa-heart-pulse"></i>
              </a>
            </div>
          </div>
        </div>
      <% }); %>
    </div>

  <% } else { %>
    <div class="pets-empty">
      <span class="pets-empty-icon">🐾</span>
      <h2>Nenhum pet ainda</h2>
      <p>Cadastre seu primeiro pet para protegê-lo com tecnologia NFC e conectá-lo à comunidade AIRPET.</p>
      <a href="/pets/cadastro" class="btn-new-pet" style="display:inline-flex;">
        <i class="fa-solid fa-plus"></i>
        Cadastrar meu primeiro pet
      </a>
    </div>
  <% } %>
</main>

<%- include('../partials/footer') %>
