<% locals.titulo = 'Meus Pets' %>
<% locals.extraHead = `
<style>
  @keyframes slideUp {
    from { opacity: 0; transform: translateY(24px); }
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-6px); }
  }
  .card-pet { animation: slideUp 0.5s ease-out both; }
  .card-pet:nth-child(1) { animation-delay: 0.05s; }
  .card-pet:nth-child(2) { animation-delay: 0.1s; }
  .card-pet:nth-child(3) { animation-delay: 0.15s; }
  .card-pet:nth-child(4) { animation-delay: 0.2s; }
  .card-pet:nth-child(5) { animation-delay: 0.25s; }
  .card-pet:nth-child(6) { animation-delay: 0.3s; }
  .empty-float { animation: float 3s ease-in-out infinite; }
  .actions-overlay {
    opacity: 1;
  }
  @media (hover: hover) {
    .actions-overlay { opacity: 0; transition: opacity 0.25s ease; }
    .card-pet:hover .actions-overlay { opacity: 1; }
  }
</style>
` %>
<%- include('../partials/header') %>
<%- include('../partials/flash') %>

<main class="flex-1 pb-24 md:pb-0">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 py-6">

    <div class="flex items-center justify-between mb-8 animate-slideUp">
      <div class="flex items-center gap-3">
        <h1 class="text-2xl sm:text-3xl font-extrabold text-gray-900 tracking-tight">Meus Pets</h1>
        <% if (typeof pets !== 'undefined' && pets.length > 0) { %>
          <span class="inline-flex items-center justify-center min-w-[28px] h-7 px-2 rounded-full bg-primary-100 text-primary-600 text-sm font-bold">
            <%= pets.length %>
          </span>
        <% } %>
      </div>
      <a href="/pets/cadastro"
         class="inline-flex items-center gap-2 px-5 py-2.5 rounded-2xl text-sm font-semibold text-white bg-gradient-to-r from-primary-500 to-primary-600 hover:shadow-lg hover:shadow-primary-500/25 hover:-translate-y-0.5 active:scale-95 transition-all duration-300">
        <i class="fa-solid fa-plus text-xs"></i>
        <span class="hidden sm:inline">Novo Pet</span>
      </a>
    </div>

    <% if (typeof pets !== 'undefined' && pets.length > 0) { %>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        <% pets.forEach(function(pet) { %>
          <div class="card-pet group relative bg-white rounded-3xl shadow-md hover:shadow-xl hover:scale-[1.02] transition-all duration-300 overflow-hidden">

            <div class="relative aspect-square overflow-hidden">
              <% if (pet.foto) { %>
                <img src="<%= pet.foto %>" alt="<%= pet.nome %>"
                     class="w-full h-full object-cover rounded-3xl group-hover:scale-105 transition-transform duration-500">
              <% } else { %>
                <div class="w-full h-full bg-gradient-to-br from-primary-50 via-orange-50 to-amber-50 flex items-center justify-center">
                  <i class="fa-solid fa-paw text-6xl text-primary-200"></i>
                </div>
              <% } %>

              <div class="absolute inset-x-0 bottom-0 h-2/5 bg-gradient-to-t from-black/60 via-black/20 to-transparent pointer-events-none rounded-b-3xl"></div>

              <span class="absolute top-3 right-3 z-10 inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-[11px] font-bold uppercase tracking-wider shadow-lg backdrop-blur-md
                <% if (pet.status === 'perdido') { %>
                  bg-red-500/90 text-white animate-pulse
                <% } else { %>
                  bg-emerald-500/90 text-white
                <% } %>">
                <i class="fa-solid <%= pet.status === 'perdido' ? 'fa-triangle-exclamation' : 'fa-shield-halved' %> text-[10px]"></i>
                <%= pet.status === 'perdido' ? 'Perdido' : 'Seguro' %>
              </span>

              <div class="absolute inset-x-0 bottom-0 p-4 z-10">
                <h3 class="text-lg font-bold text-white truncate drop-shadow-md"><%= pet.nome %></h3>
                <p class="text-white/80 text-sm truncate drop-shadow-sm">
                  <%= pet.tipo ? pet.tipo.charAt(0).toUpperCase() + pet.tipo.slice(1) : '—' %>
                  <% if (pet.raca) { %> · <%= pet.raca %><% } %>
                </p>
              </div>
            </div>

            <div class="actions-overlay absolute inset-x-0 bottom-0 z-20 p-3">
              <div class="flex items-center gap-2 justify-center">
                <a href="/pets/<%= pet.id %>"
                   class="flex-1 inline-flex items-center justify-center gap-1.5 px-3 py-2 rounded-xl text-xs font-semibold text-white bg-white/20 backdrop-blur-xl border border-white/30 hover:bg-white/30 transition-all duration-200"
                   title="Ver Perfil">
                  <i class="fa-solid fa-eye"></i>
                  <span>Perfil</span>
                </a>
                <a href="/diario/<%= pet.id %>"
                   class="flex-1 inline-flex items-center justify-center gap-1.5 px-3 py-2 rounded-xl text-xs font-semibold text-white bg-white/20 backdrop-blur-xl border border-white/30 hover:bg-white/30 transition-all duration-200"
                   title="Diário">
                  <i class="fa-solid fa-book"></i>
                  <span>Diário</span>
                </a>
                <a href="/saude/<%= pet.id %>"
                   class="flex-1 inline-flex items-center justify-center gap-1.5 px-3 py-2 rounded-xl text-xs font-semibold text-white bg-white/20 backdrop-blur-xl border border-white/30 hover:bg-white/30 transition-all duration-200"
                   title="Saúde">
                  <i class="fa-solid fa-heart-pulse"></i>
                  <span>Saúde</span>
                </a>
              </div>
            </div>

          </div>
        <% }); %>
      </div>

    <% } else { %>

      <div class="flex flex-col items-center justify-center text-center py-20 animate-slideUp">
        <div class="empty-float relative mb-8">
          <div class="w-28 h-28 rounded-full bg-gradient-to-br from-primary-100 to-orange-50 flex items-center justify-center shadow-inner">
            <i class="fa-solid fa-paw text-5xl text-primary-300"></i>
          </div>
          <div class="absolute -bottom-1 -right-1 w-10 h-10 rounded-full bg-accent-100 flex items-center justify-center shadow-sm">
            <i class="fa-solid fa-plus text-accent-500 text-sm"></i>
          </div>
        </div>
        <h2 class="text-xl font-bold text-gray-800 mb-2">Nenhum pet cadastrado ainda</h2>
        <p class="text-gray-500 text-sm mb-8 max-w-xs leading-relaxed">
          Cadastre seu primeiro companheiro e comece a usar a proteção inteligente da AIRPET.
        </p>
        <a href="/pets/cadastro"
           class="inline-flex items-center gap-2.5 px-7 py-3 rounded-2xl text-sm font-bold text-white bg-gradient-to-r from-primary-500 to-primary-600 hover:shadow-xl hover:shadow-primary-500/30 hover:-translate-y-0.5 active:scale-95 transition-all duration-300">
          <i class="fa-solid fa-plus"></i>
          Cadastrar meu pet
        </a>
      </div>

    <% } %>

  </div>
</main>

<%- include('../partials/footer') %>
