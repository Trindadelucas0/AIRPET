<% locals.titulo = 'Vincular Tag NFC — ' + pet.nome %>
<% locals.extraHead = `
<link href="https://fonts.googleapis.com/css2?family=Rubik+Doodle+Shadow&family=Syne:wght@700;800&family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
  /* Layout do fluxo de pets deve seguir o design system (tema claro no PC). */
  body{font-family:'DM Sans',sans-serif;}
  .nfc-wrap{max-width:520px;margin:0 auto;padding:24px 20px 80px;}
  .page-topbar{position:sticky;top:56px;z-index:40;background:rgba(255,255,255,0.88);backdrop-filter:blur(20px);border-bottom:1px solid var(--border);padding:12px 0;}
  .topbar-inner{max-width:520px;margin:0 auto;padding:0 20px;display:flex;align-items:center;gap:12px;}
  .back-link{color:var(--text-dim);font-size:13px;text-decoration:none;display:flex;align-items:center;gap:6px;transition:color 0.15s;}
  .back-link:hover{color:var(--accent);text-decoration:none;}
  .page-title{font-family:var(--font-display);font-size:18px;font-weight:800;color:var(--text);}
  /* Hero */
  .nfc-hero{text-align:center;padding:36px 0 28px;}
  .nfc-hero-icon{width:96px;height:96px;border-radius:28px;margin:0 auto 20px;background:var(--accent-glow);border:1px solid rgba(242,96,32,0.2);display:flex;align-items:center;justify-content:center;font-size:40px;color:var(--accent);position:relative;}
  @keyframes nfc-pulse{0%,100%{box-shadow:0 0 0 0 rgba(242,96,32,0.3);}50%{box-shadow:0 0 0 16px rgba(242,96,32,0);}}
  .nfc-hero-icon.scanning{animation:nfc-pulse 1.5s ease-in-out infinite;}
  .nfc-hero h1{font-family:var(--font-display);font-size:24px;font-weight:800;color:var(--text);margin-bottom:6px;}
  .nfc-hero p{font-size:14px;color:var(--text-dim);max-width:320px;margin:0 auto;}
  /* Tabs */
  .tab-bar{display:flex;background:var(--ink-3);border-radius:12px;padding:4px;margin-bottom:20px;gap:4px;}
  .tab-btn{flex:1;padding:11px;border-radius:9px;border:none;background:transparent;font-family:'DM Sans',sans-serif;font-size:14px;font-weight:600;color:var(--text-dim);cursor:pointer;transition:all 0.15s;}
  .tab-btn.active{background:var(--ink-2);color:var(--text);box-shadow:0 2px 8px rgba(0,0,0,0.3);}
  /* Panel */
  .nfc-panel{background:var(--ink-2);border:1px solid var(--border);border-radius:18px;padding:28px;text-align:center;}
  .nfc-panel h2{font-family:var(--font-display);font-size:18px;font-weight:800;color:var(--text);margin-bottom:6px;}
  .nfc-panel p{font-size:13px;color:var(--text-dim);margin-bottom:20px;line-height:1.6;}
  .ds-input{width:100%;background:var(--ink-3);border:1px solid var(--border);border-radius:10px;padding:11px 14px;color:var(--text);font-family:'DM Sans',sans-serif;font-size:14px;outline:none;transition:border-color 0.2s,box-shadow 0.2s;text-align:center;letter-spacing:0.1em;font-weight:700;}
  .ds-input::placeholder{color:var(--text-muted);font-weight:400;letter-spacing:0;}
  .ds-input:focus{border-color:rgba(242,96,32,0.5);box-shadow:0 0 0 3px rgba(242,96,32,0.06);}
  .btn-primary{width:100%;padding:14px;background:var(--accent);color:#fff;border:none;border-radius:12px;font-family:'DM Sans',sans-serif;font-size:16px;font-weight:700;cursor:pointer;transition:all 0.2s;display:flex;align-items:center;justify-content:center;gap:8px;margin-top:14px;}
  .btn-primary:hover{background:var(--accent-light);transform:translateY(-1px);}
  .btn-primary:disabled{opacity:0.5;cursor:not-allowed;transform:none;}
  /* Status */
  .nfc-status{padding:14px 18px;border-radius:12px;display:flex;align-items:center;gap:10px;margin-bottom:14px;font-size:13px;font-weight:600;}
  .nfc-status.success{background:rgba(34,197,94,0.1);border:1px solid rgba(34,197,94,0.2);color:var(--green);}
  .nfc-status.reading{background:rgba(96,165,250,0.1);border:1px solid rgba(96,165,250,0.2);color:var(--blue);}
  .nfc-status.error{background:rgba(239,68,68,0.1);border:1px solid rgba(239,68,68,0.2);color:#f87171;}
  /* Tag já vinculada */
  .tag-linked-card{background:var(--ink-2);border:1px solid rgba(34,197,94,0.2);border-radius:18px;padding:24px;text-align:center;margin-bottom:14px;}
  .tag-linked-icon{width:64px;height:64px;border-radius:20px;background:rgba(34,197,94,0.1);display:flex;align-items:center;justify-content:center;font-size:28px;color:var(--green);margin:0 auto 14px;}
  .tag-code{font-size:18px;font-weight:800;color:var(--accent);letter-spacing:0.12em;font-family:var(--font-display);margin:8px 0;}
  /* Info tip */
  .info-tip{display:flex;align-items:flex-start;gap:10px;padding:12px 16px;background:var(--ink-3);border-radius:10px;font-size:12px;color:var(--text-dim);margin-top:14px;}
  .info-tip i{color:var(--blue);flex-shrink:0;margin-top:1px;}
</style>
` %>
<%- include('../partials/header') %>
<%- include('../partials/flash') %>

<div class="page-topbar">
  <div class="topbar-inner">
    <a href="/pets/<%= pet.id %>" class="back-link"><i class="fa-solid fa-arrow-left"></i> <%= pet.nome %></a>
    <span class="page-title">Tag NFC</span>
  </div>
</div>

<main class="flex-1">
  <div class="nfc-wrap">
    <section style="background:var(--ink-2);border:1px solid var(--border);border-radius:18px;padding:18px;margin-bottom:14px;">
      <div style="display:flex;align-items:center;gap:12px;">
        <div style="width:56px;height:56px;border-radius:14px;overflow:hidden;background:var(--ink-3);display:flex;align-items:center;justify-content:center;">
          <% if (pet.foto) { %>
            <img src="<%= pet.foto %>" alt="<%= pet.nome %>" style="width:100%;height:100%;object-fit:cover;">
          <% } else { %>
            <i class="fa-solid fa-paw" style="font-size:20px;color:var(--text-dim);"></i>
          <% } %>
        </div>
        <div>
          <div style="font-family:var(--font-display);font-size:17px;color:var(--text);"><%= pet.nome %></div>
          <div style="font-size:12px;color:var(--text-dim);">
            <%= pet.tipo ? pet.tipo.charAt(0).toUpperCase() + pet.tipo.slice(1) : 'Pet' %>
            <% if (pet.raca) { %> • <%= pet.raca %><% } %>
            <% if (pet.porte) { %> • <%= pet.porte %><% } %>
          </div>
        </div>
      </div>
      <div style="display:grid;grid-template-columns:1fr;gap:8px;margin-top:12px;">
        <div style="background:var(--ink-3);border:1px solid var(--border);border-radius:10px;padding:10px 12px;font-size:12px;color:var(--text-dim);">
          <strong style="display:block;color:var(--text);font-size:12px;">Saúde</strong>
          <%= pet.alergias_medicacoes || 'Sem alergias/medicações cadastradas' %>
        </div>
        <div style="background:var(--ink-3);border:1px solid var(--border);border-radius:10px;padding:10px 12px;font-size:12px;color:var(--text-dim);">
          <strong style="display:block;color:var(--text);font-size:12px;">Comportamento e observações</strong>
          <%= pet.observacoes || pet.descricao_emocional || 'Sem observações cadastradas' %>
        </div>
        <div style="background:var(--ink-3);border:1px solid var(--border);border-radius:10px;padding:10px 12px;font-size:12px;color:var(--text-dim);">
          <strong style="display:block;color:var(--text);font-size:12px;">Contato para resgate</strong>
          <%= pet.telefone_contato || 'Não informado no cadastro do pet' %>
        </div>
      </div>
    </section>

    <% if (pet.tag_uid) { %>
      <!-- Tag já vinculada -->
      <div class="tag-linked-card">
        <div class="tag-linked-icon"><i class="fa-solid fa-circle-check"></i></div>
        <div style="font-family:var(--font-display);font-size:18px;font-weight:800;color:var(--accent);margin-bottom:4px;">Tag Vinculada!</div>
        <p style="font-size:13px;color:var(--text-dim);margin-bottom:12px;">Código da tag de <strong style="color:var(--text)"><%= pet.nome %></strong></p>
        <div class="tag-code"><%= pet.tag_uid %></div>
      </div>
      <div style="background:var(--ink-2);border:1px solid var(--border);border-radius:18px;padding:20px;margin-bottom:14px;">
        <h2 style="font-family:var(--font-display);font-size:14px;font-weight:700;color:var(--text);margin-bottom:14px;">Trocar tag</h2>
    <% } %>

    <% if (!pet.tag_uid) { %>
    <div class="nfc-hero">
      <div class="nfc-hero-icon" id="heroIcon"><i class="fa-solid fa-wifi fa-rotate-90"></i></div>
      <h1>Vincular Tag NFC</h1>
      <p>Registre uma tag NFC para proteger <strong style="color:var(--text)"><%= pet.nome %></strong> e facilitar o resgate</p>
    </div>
    <% } %>

    <div id="etapa1">
      <div class="tab-bar">
        <button type="button" id="tabNfc" class="tab-btn active" onclick="trocarTab('nfc')">
          <i class="fa-solid fa-wifi mr-1.5"></i> Aproximar
        </button>
        <button type="button" id="tabDigitar" class="tab-btn" onclick="trocarTab('digitar')">
          <i class="fa-solid fa-keyboard mr-1.5"></i> Digitar código
        </button>
      </div>

      <!-- NFC Panel -->
      <div id="painelNfc" class="nfc-panel">
        <div id="nfcDisponivel">
          <h2 id="nfcTitulo">Aproxime a tag</h2>
          <p id="nfcDescricao">Encoste a tag NFC na parte traseira do celular para ler automaticamente</p>
          <button type="button" id="btnIniciarNfc" class="btn-primary" onclick="iniciarLeituraNfc()">
            <i class="fa-solid fa-satellite-dish"></i> Iniciar leitura NFC
          </button>
        </div>
        <div id="nfcIndisponivel" class="hidden">
          <div style="font-size:40px;opacity:0.2;margin-bottom:14px;">📵</div>
          <h2>NFC não disponível</h2>
          <p>Use a aba "Digitar código" para inserir o código manualmente</p>
          <button type="button" class="btn-primary" onclick="trocarTab('digitar')">
            <i class="fa-solid fa-keyboard"></i> Digitar código
          </button>
        </div>
      </div>

      <!-- Manual Panel -->
      <div id="painelDigitar" class="nfc-panel hidden">
        <h2>Digite o código da tag</h2>
        <p>O código está impresso na etiqueta ou embalagem da tag NFC</p>
        <input type="text" id="inputTagManual" class="ds-input" placeholder="AIRPET-XXXXXXXX"
               maxlength="30" autocomplete="off" autocapitalize="characters">
        <button type="button" class="btn-primary" onclick="confirmarTagManual()">
          <i class="fa-solid fa-link"></i> Vincular tag
        </button>
      </div>

      <div class="info-tip">
        <i class="fa-solid fa-circle-info"></i>
        <span>A leitura NFC funciona em smartphones Android com NFC ativado. Em iPhones, use o modo manual.</span>
      </div>
    </div>

    <!-- Etapa 2: Confirmação -->
    <div id="etapa2" class="hidden">
      <div class="nfc-panel">
        <div id="tagSuccessIcon" style="font-size:48px;margin-bottom:14px;">✅</div>
        <h2>Tag detectada!</h2>
        <p>Confirme o vínculo da tag abaixo com <strong style="color:var(--text)"><%= pet.nome %></strong></p>
        <div id="tagCodigoDisplay" style="font-family:var(--font-display);font-size:20px;font-weight:800;color:var(--accent);letter-spacing:0.12em;margin:12px 0;"></div>
        <form id="formVincular" action="/pets/<%= pet.id %>/vincular-tag" method="POST">
          <input type="hidden" name="tag_code" id="tagUidConfirm">
          <div style="margin:14px 0 8px;">
            <label class="ds-label" for="codigoAtivacaoInput">Código de ativação *</label>
            <input type="text"
                   id="codigoAtivacaoInput"
                   name="codigo_ativacao"
                   required
                   maxlength="30"
                   autocomplete="off"
                   autocapitalize="characters"
                   class="ds-input"
                   placeholder="Informe o código de ativação">
          </div>
          <button type="submit" class="btn-primary" style="background:var(--green);">
            <i class="fa-solid fa-link"></i> Confirmar vínculo
          </button>
        </form>
        <button type="button" onclick="voltarEtapa1()" style="margin-top:10px;width:100%;padding:12px;background:transparent;color:var(--text-dim);border:1px solid var(--border);border-radius:11px;font-family:'DM Sans',sans-serif;font-size:14px;font-weight:600;cursor:pointer;">
          <i class="fa-solid fa-arrow-left mr-1"></i> Tentar novamente
        </button>
      </div>
    </div>

    <% if (pet.tag_uid) { %></div><% } %>

  </div>
</main>

<script>
function trocarTab(tab) {
  var isNfc = tab === 'nfc';
  document.getElementById('tabNfc').classList.toggle('active', isNfc);
  document.getElementById('tabDigitar').classList.toggle('active', !isNfc);
  document.getElementById('painelNfc').classList.toggle('hidden', !isNfc);
  document.getElementById('painelDigitar').classList.toggle('hidden', isNfc);
}

async function iniciarLeituraNfc() {
  if (!('NDEFReader' in window)) {
    document.getElementById('nfcDisponivel').classList.add('hidden');
    document.getElementById('nfcIndisponivel').classList.remove('hidden');
    return;
  }
  var icon = document.getElementById('heroIcon');
  if (icon) icon.classList.add('scanning');
  document.getElementById('nfcTitulo').textContent = 'Aguardando tag...';
  document.getElementById('nfcDescricao').textContent = 'Encoste a tag NFC no celular';
  document.getElementById('btnIniciarNfc').disabled = true;
  try {
    var reader = new NDEFReader();
    await reader.scan();
    reader.addEventListener('reading', function(e) {
      confirmarTag(e.serialNumber || 'TAG-' + Date.now());
    });
  } catch(err) {
    document.getElementById('nfcTitulo').textContent = 'Erro ao iniciar NFC';
    document.getElementById('nfcDescricao').textContent = err.message;
    document.getElementById('btnIniciarNfc').disabled = false;
    if (icon) icon.classList.remove('scanning');
  }
}

function confirmarTagManual() {
  var val = document.getElementById('inputTagManual').value.trim();
  if (!val) { document.getElementById('inputTagManual').focus(); return; }
  confirmarTag(val);
}

function confirmarTag(uid) {
  document.getElementById('etapa1').classList.add('hidden');
  document.getElementById('etapa2').classList.remove('hidden');
  document.getElementById('tagCodigoDisplay').textContent = uid;
  document.getElementById('tagUidConfirm').value = uid;
}

function voltarEtapa1() {
  document.getElementById('etapa1').classList.remove('hidden');
  document.getElementById('etapa2').classList.add('hidden');
}
</script>

<%- include('../partials/footer') %>
