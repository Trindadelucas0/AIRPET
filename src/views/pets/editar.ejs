<% locals.titulo = 'Editar ' + pet.nome %>
<% locals.extraHead = `
<link rel="stylesheet" href="/css/pet-profile.css">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/cropperjs@1.6.2/dist/cropper.min.css">
<style>
  .edit-wrap   { max-width:560px; margin:0 auto; padding:16px 16px 120px; }
  .edit-topbar {
    position:sticky; top:56px; z-index:40;
    background:rgba(255,255,255,.94); backdrop-filter:blur(16px);
    border-bottom:1px solid var(--border);
  }
  .edit-topbar-inner {
    max-width:560px; margin:0 auto;
    padding:10px 16px 0;
    display:flex; align-items:center; gap:10px;
  }
  .back-link {
    font-size:13px; color:var(--text-dim); text-decoration:none;
    display:inline-flex; align-items:center; gap:6px; flex-shrink:0;
    transition:color .15s;
  }
  .back-link:hover { color:var(--accent); text-decoration:none; }
  .edit-title {
    font-size:16px; font-weight:800; color:var(--text);
    white-space:nowrap; overflow:hidden; text-overflow:ellipsis; flex:1;
  }
  .edit-nav-row { padding:10px 16px 8px; }
</style>
` %>
<%- include('../partials/header') %>
<%- include('../partials/flash') %>

<!-- ════ TOPBAR ════ -->
<div class="edit-topbar" id="editTopbar">
  <div class="edit-topbar-inner">
    <a href="/pets/<%= pet.id %>" class="back-link">
      <i class="fa-solid fa-arrow-left"></i>
    </a>
    <h1 class="edit-title">Editar <%= pet.nome %></h1>
  </div>
  <!-- Section pills -->
  <div class="edit-nav-row">
    <nav class="pp-edit-nav" id="sectionNav" aria-label="Seções do formulário">
      <a href="#sec-foto"   class="pp-edit-pill active" data-section="sec-foto">
        <span class="pp-pill-dot"></span>Foto
      </a>
      <a href="#sec-dados"  class="pp-edit-pill"        data-section="sec-dados">
        <span class="pp-pill-dot"></span>Identidade
      </a>
      <a href="#sec-medidas" class="pp-edit-pill"       data-section="sec-medidas">
        <span class="pp-pill-dot"></span>Medidas
      </a>
      <a href="#sec-id"     class="pp-edit-pill"        data-section="sec-id">
        <span class="pp-pill-dot"></span>ID Oficial
      </a>
      <a href="#sec-saude"  class="pp-edit-pill"        data-section="sec-saude">
        <span class="pp-pill-dot"></span>Saúde
      </a>
    </nav>
  </div>
</div>

<main class="flex-1">
  <form class="edit-wrap" id="editForm"
        action="/pets/<%= pet.id %>/editar"
        method="POST"
        enctype="multipart/form-data">

    <input type="file" id="petFoto" name="foto" accept="image/*" class="hidden">
    <input type="hidden" id="fotoCropped" name="foto_cropped">

    <!-- ── FOTO ── -->
    <section class="pp-section" id="sec-foto">
      <p class="pp-section-label"><i class="fa-solid fa-camera"></i>Foto do pet</p>

      <label for="petFoto" class="pp-photo-card" id="triggerFoto" tabindex="0" role="button"
             aria-label="Escolher foto de <%= pet.nome %>">
        <% if (pet.foto) { %>
          <img src="<%= pet.foto %><%= pet.data_atualizacao ? '?t=' + new Date(pet.data_atualizacao).getTime() : '' %>"
               id="fotoAtual" class="pp-photo-preview" alt="<%= pet.nome %>">
        <% } else { %>
          <div id="fotoAtual" class="pp-photo-empty">
            <i class="fa-solid fa-camera" style="font-size:28px"></i>
            <span style="font-size:13px;font-weight:600">Toque para adicionar foto</span>
            <span style="font-size:11px;color:var(--text-muted)">JPG, PNG ou HEIC · até 10 MB</span>
          </div>
        <% } %>
        <div class="pp-photo-overlay">
          <span class="pp-photo-hint">
            <i class="fa-solid fa-crop-simple"></i>
            Cortar, dar zoom e posicionar
          </span>
        </div>
      </label>
    </section>

    <!-- ── IDENTIDADE ── -->
    <section class="pp-section" id="sec-dados">
      <p class="pp-section-label"><i class="fa-solid fa-id-badge"></i>Identidade</p>

      <div class="pp-field">
        <label class="pp-label" for="nome">Nome</label>
        <input class="pp-input" id="nome" name="nome"
               maxlength="50" required autocomplete="off"
               value="<%= pet.nome %>">
      </div>

      <div class="pp-row">
        <div class="pp-field">
          <label class="pp-label" for="tipo">Espécie</label>
          <select class="pp-input" id="tipo" name="tipo">
            <option value="cachorro" <%= pet.tipo==='cachorro'?'selected':'' %>>Cachorro</option>
            <option value="gato"     <%= pet.tipo==='gato'?'selected':'' %>>Gato</option>
            <option value="passaro"  <%= pet.tipo==='passaro'?'selected':'' %>>Pássaro</option>
            <option value="outro"    <%= pet.tipo==='outro'?'selected':'' %>>Outro</option>
          </select>
        </div>
        <div class="pp-field">
          <label class="pp-label" for="sexo">Sexo</label>
          <select class="pp-input" id="sexo" name="sexo">
            <option value="">Não informado</option>
            <option value="macho" <%= pet.sexo==='macho'?'selected':'' %>>Macho</option>
            <option value="femea" <%= pet.sexo==='femea'?'selected':'' %>>Fêmea</option>
          </select>
        </div>
      </div>

      <div class="pp-field">
        <label class="pp-label" for="raca">Raça <span style="font-weight:400;text-transform:none;letter-spacing:0">(ex: Labrador, SRD)</span></label>
        <input class="pp-input" id="raca" name="raca"
               placeholder="Ex: Labrador Retriever"
               value="<%= pet.raca||'' %>">
      </div>

      <div class="pp-row">
        <div class="pp-field">
          <label class="pp-label" for="porte">Porte</label>
          <select class="pp-input" id="porte" name="porte">
            <option value="">—</option>
            <option value="mini"    <%= pet.porte==='mini'?'selected':'' %>>Mini</option>
            <option value="pequeno" <%= pet.porte==='pequeno'?'selected':'' %>>Pequeno</option>
            <option value="medio"   <%= pet.porte==='medio'?'selected':'' %>>Médio</option>
            <option value="grande"  <%= pet.porte==='grande'?'selected':'' %>>Grande</option>
            <option value="gigante" <%= pet.porte==='gigante'?'selected':'' %>>Gigante</option>
          </select>
        </div>
        <div class="pp-field">
          <label class="pp-label" for="cor">Cor / pelagem</label>
          <input class="pp-input" id="cor" name="cor"
                 placeholder="Ex: Amarelo, Preto"
                 value="<%= pet.cor||'' %>">
        </div>
      </div>

      <div class="pp-field">
        <label class="pp-label" for="descricao">Descrição <span style="font-weight:400;text-transform:none;letter-spacing:0">(opcional)</span></label>
        <textarea class="pp-input" id="descricao" name="descricao"
                  rows="2" maxlength="200"
                  placeholder="Uma frase sobre a personalidade do pet…"><%= pet.descricao_emocional||'' %></textarea>
      </div>

      <div class="pp-field">
        <label class="pp-label" for="bio_pet">Bio pública do pet <span style="font-weight:400;text-transform:none;letter-spacing:0">(opcional, até 160 caracteres)</span></label>
        <textarea class="pp-input" id="bio_pet" name="bio_pet"
                  rows="2" maxlength="160"
                  placeholder="Em primeira pessoa: “Eu sou o Thor, adoro bolinha…”"><%= (pet.bio_pet || '').trim() %></textarea>
        <p style="font-size:11px;color:var(--text-muted);margin-top:6px;">Aparece no perfil público <code>/p/<%= pet.slug %></code> e em compartilhamentos.</p>
      </div>

      <label class="pp-toggle" style="margin-top:8px;" role="switch"
             aria-checked="<%= pet.privado ? 'true' : 'false' %>">
        <input type="checkbox" name="privado" value="on" <%= pet.privado ? 'checked' : '' %>
               style="width:18px;height:18px;accent-color:var(--accent);">
        <span class="pp-toggle-label" style="margin-left:10px;">Perfil privado — só quem segue o pet vê posts e destaques</span>
      </label>
    </section>

    <!-- ── MEDIDAS ── -->
    <section class="pp-section" id="sec-medidas">
      <p class="pp-section-label"><i class="fa-solid fa-ruler-combined"></i>Medidas e dados físicos</p>

      <div class="pp-row">
        <div class="pp-field">
          <label class="pp-label" for="dataNascimento">Nascimento</label>
          <input class="pp-input" type="date" id="dataNascimento" name="dataNascimento"
                 value="<%= pet.data_nascimento ? new Date(pet.data_nascimento).toISOString().split('T')[0] : '' %>">
        </div>
        <div class="pp-field">
          <label class="pp-label" for="peso">Peso (kg)</label>
          <input class="pp-input" type="number" step="0.1" min="0" max="200"
                 id="peso" name="peso"
                 placeholder="Ex: 12.5"
                 value="<%= pet.peso||'' %>">
        </div>
      </div>

      <label class="pp-toggle" id="castradoToggle" role="switch"
             aria-checked="<%= pet.castrado ? 'true' : 'false' %>">
        <input type="hidden" id="castradoVal" name="castrado"
               value="<%= pet.castrado ? 'sim' : 'nao' %>">
        <span class="pp-track <%= pet.castrado ? 'on' : '' %>" id="castradoTrack">
          <span class="pp-thumb"></span>
        </span>
        <span id="castradoLabel" class="pp-toggle-label">
          <%= pet.castrado ? 'Castrado(a)' : 'Não castrado(a)' %>
        </span>
      </label>
    </section>

    <!-- ── IDENTIFICAÇÃO OFICIAL ── -->
    <section class="pp-section" id="sec-id">
      <p class="pp-section-label"><i class="fa-solid fa-fingerprint"></i>Identificação oficial</p>

      <div class="pp-field">
        <label class="pp-label" for="telefoneContato">Telefone de contato <span style="font-weight:400;text-transform:none;letter-spacing:0">(aparece no perfil público)</span></label>
        <input class="pp-input" id="telefoneContato" name="telefoneContato"
               type="tel" placeholder="(11) 99999-9999"
               value="<%= pet.telefone_contato||'' %>">
      </div>
      <div class="pp-field">
        <label class="pp-label" for="microchip">Microchip</label>
        <input class="pp-input" id="microchip" name="microchip"
               placeholder="Número do chip implantado"
               value="<%= pet.microchip||'' %>">
      </div>
      <div class="pp-field">
        <label class="pp-label" for="numero_pedigree">Pedigree</label>
        <input class="pp-input" id="numero_pedigree" name="numero_pedigree"
               placeholder="Nº do registro de pedigree"
               value="<%= pet.numero_pedigree||'' %>">
      </div>
    </section>

    <!-- ── SAÚDE ── -->
    <section class="pp-section" id="sec-saude">
      <p class="pp-section-label"><i class="fa-solid fa-stethoscope"></i>Saúde e veterinário</p>

      <div class="pp-row">
        <div class="pp-field">
          <label class="pp-label" for="veterinario_nome">Veterinário responsável</label>
          <input class="pp-input" id="veterinario_nome" name="veterinario_nome"
                 placeholder="Nome do veterinário"
                 value="<%= pet.veterinario_nome||'' %>">
        </div>
        <div class="pp-field">
          <label class="pp-label" for="veterinario_telefone">Telefone do vet</label>
          <input class="pp-input" id="veterinario_telefone" name="veterinario_telefone"
                 type="tel" placeholder="(11) 99999-9999"
                 value="<%= pet.veterinario_telefone||'' %>">
        </div>
      </div>

      <!-- Alergias — callout visual de atenção -->
      <div class="pp-callout-field pp-field">
        <p class="pp-callout-label">
          <i class="fa-solid fa-triangle-exclamation"></i>
          Alergias e medicações em uso
        </p>
        <textarea class="pp-input pp-input--warning" rows="3"
                  id="alergias_medicacoes" name="alergias_medicacoes"
                  placeholder="Ex: Alergia a dipirona. Em uso de Prednisona 5mg 1x/dia."><%= pet.alergias_medicacoes||'' %></textarea>
      </div>

      <div class="pp-field">
        <label class="pp-label" for="observacoes">Observações gerais</label>
        <textarea class="pp-input" rows="3" id="observacoes" name="observacoes"
                  placeholder="Comportamento, rotina, particularidades…"><%= pet.observacoes||'' %></textarea>
      </div>
    </section>

    <!-- Botão submit (acessível sem JS) -->
    <div style="display:none">
      <button type="submit" id="submitFallback">Salvar</button>
    </div>
  </form>

  <!-- ── STICKY SAVE BAR ── -->
  <div class="pp-save-bar" id="saveBar">
    <div class="pp-save-bar-inner">
      <p class="pp-save-dirty-hint">
        <i class="fa-solid fa-circle-dot" style="font-size:8px;margin-right:4px"></i>
        Há alterações não salvas
      </p>
      <a class="pp-btn pp-btn-ghost" href="/pets/<%= pet.id %>">Cancelar</a>
      <button type="button" id="saveBtn"
              class="pp-btn pp-btn-primary"
              onclick="document.getElementById('editForm').requestSubmit()">
        <i class="fa-solid fa-floppy-disk"></i> Salvar
      </button>
    </div>
  </div>
</main>

<!-- ════ CROP SHEET ════ -->
<div class="pp-crop-sheet" id="cropSheet" aria-hidden="true" role="dialog"
     aria-label="Ajustar foto do pet">
  <div class="pp-crop-backdrop" id="cropBackdrop"></div>
  <div class="pp-crop-panel">
    <div class="pp-crop-handle"></div>

    <div class="flex items-center justify-between mb-3">
      <h3 style="font-size:15px;font-weight:800;color:var(--text)">
        Ajustar foto de <%= pet.nome %>
      </h3>
      <button type="button" id="closeCropper"
              style="width:32px;height:32px;border-radius:50%;border:1px solid var(--border);
                     background:var(--ink-2);color:var(--text-dim);display:flex;
                     align-items:center;justify-content:center;cursor:pointer;"
              aria-label="Fechar">
        <i class="fa-solid fa-xmark"></i>
      </button>
    </div>

    <!-- Área de crop -->
    <div class="pp-crop-wrap">
      <img id="cropImage" alt="Prévia para recorte">
    </div>

    <!-- Zoom -->
    <div class="pp-field">
      <label class="pp-label" for="zoomRange">Zoom</label>
      <input id="zoomRange" type="range" min="0" max="100" value="0"
             style="width:100%;accent-color:var(--accent)">
    </div>

    <!-- Preview strip — 3 tamanhos -->
    <div class="pp-preview-strip" id="previewStrip">
      <div class="pp-preview-item">
        <div class="pp-preview-circle" id="prevCircle">
          <img id="prevCircleImg" src="" alt="" style="display:none">
        </div>
        <span class="pp-preview-label">Lista</span>
      </div>
      <div class="pp-preview-item">
        <div class="pp-preview-square" id="prevSquare">
          <img id="prevSquareImg" src="" alt="" style="display:none">
        </div>
        <span class="pp-preview-label">Cartão</span>
      </div>
      <div class="pp-preview-item" style="flex:2">
        <div class="pp-preview-wide" id="prevWide">
          <img id="prevWideImg" src="" alt="" style="display:none">
        </div>
        <span class="pp-preview-label">Hero</span>
      </div>
    </div>

    <p style="font-size:11px;color:var(--text-muted);margin-bottom:14px;text-align:center">
      O recorte é quadrado (1:1) — garante aparência consistente em todo o app.
    </p>

    <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px">
      <button type="button" id="rotateCrop" class="pp-btn pp-btn-ghost" style="padding:10px 8px;font-size:13px">
        <i class="fa-solid fa-rotate-right"></i> Girar
      </button>
      <button type="button" id="cancelCrop" class="pp-btn pp-btn-ghost" style="padding:10px 8px;font-size:13px">
        Cancelar
      </button>
      <button type="button" id="applyCrop" class="pp-btn pp-btn-primary" style="padding:10px 8px;font-size:13px">
        Usar foto
      </button>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/cropperjs@1.6.2/dist/cropper.min.js"></script>
<script>
(function () {
  /* ── REFS ── */
  var inputFoto    = document.getElementById('petFoto');
  var fotoAtualEl  = document.getElementById('fotoAtual');
  var cropSheet    = document.getElementById('cropSheet');
  var cropImage    = document.getElementById('cropImage');
  var closeCropBtn = document.getElementById('closeCropper');
  var cancelCropBtn = document.getElementById('cancelCrop');
  var applyCropBtn = document.getElementById('applyCrop');
  var rotateCropBtn = document.getElementById('rotateCrop');
  var zoomRange    = document.getElementById('zoomRange');
  var fotoCropped  = document.getElementById('fotoCropped');
  var saveBar      = document.getElementById('saveBar');
  var saveBtn      = document.getElementById('saveBtn');
  var editForm     = document.getElementById('editForm');
  var navPills     = document.querySelectorAll('.pp-edit-pill');
  var sections     = document.querySelectorAll('.pp-section[id]');

  /* preview strip elements */
  var prevCircleImg = document.getElementById('prevCircleImg');
  var prevSquareImg = document.getElementById('prevSquareImg');
  var prevWideImg   = document.getElementById('prevWideImg');

  var cropper = null;
  var previewThrottle = null;

  /* ── CROP SHEET OPEN/CLOSE ── */
  function openSheet() {
    cropSheet.classList.add('open');
    cropSheet.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
  }
  function closeSheet() {
    cropSheet.classList.remove('open');
    cropSheet.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
    if (cropper) { cropper.destroy(); cropper = null; }
    zoomRange.value = 0;
    /* reset previews */
    [prevCircleImg, prevSquareImg, prevWideImg].forEach(function(img) {
      img.src = ''; img.style.display = 'none';
    });
  }

  /* ── FILE INPUT → open sheet ── */
  inputFoto.addEventListener('change', function () {
    if (!inputFoto.files || !inputFoto.files[0]) return;
    var file = inputFoto.files[0];
    var reader = new FileReader();
    reader.onload = function (e) {
      cropImage.src = e.target.result;
      openSheet();
      if (cropper) cropper.destroy();
      cropper = new Cropper(cropImage, {
        aspectRatio: 1,
        viewMode: 1,
        dragMode: 'move',
        autoCropArea: 1,
        responsive: true,
        background: false,
        crop: throttlePreview
      });
    };
    reader.readAsDataURL(file);
  });

  /* ── PREVIEW — throttled to ~250ms ── */
  function throttlePreview() {
    if (previewThrottle) return;
    previewThrottle = setTimeout(refreshPreviews, 250);
  }
  function refreshPreviews() {
    previewThrottle = null;
    if (!cropper) return;
    try {
      var canvas = cropper.getCroppedCanvas({ width: 240, height: 240 });
      var dataUrl = canvas.toDataURL('image/jpeg', 0.85);
      [prevCircleImg, prevSquareImg, prevWideImg].forEach(function(img) {
        img.src = dataUrl;
        img.style.display = 'block';
      });
    } catch (e) {}
  }

  /* ── ZOOM SLIDER ── */
  zoomRange.addEventListener('input', function () {
    if (!cropper) return;
    cropper.zoomTo(1 + Number(zoomRange.value) / 100);
  });

  /* ── ROTATE ── */
  rotateCropBtn.addEventListener('click', function () {
    if (cropper) { cropper.rotate(90); refreshPreviews(); }
  });

  /* ── CLOSE / CANCEL ── */
  [closeCropBtn, cancelCropBtn].forEach(function(btn) {
    btn.addEventListener('click', closeSheet);
  });
  document.getElementById('cropBackdrop').addEventListener('click', closeSheet);

  /* ── APPLY CROP ── */
  applyCropBtn.addEventListener('click', function () {
    if (!cropper) return;
    var canvas = cropper.getCroppedCanvas({ width: 1080, height: 1080, imageSmoothingQuality: 'high' });
    var dataUrl = canvas.toDataURL('image/jpeg', 0.9);
    fotoCropped.value = dataUrl;

    /* update photo card */
    if (fotoAtualEl && fotoAtualEl.tagName === 'IMG') {
      fotoAtualEl.src = dataUrl;
    } else if (fotoAtualEl) {
      var img = document.createElement('img');
      img.id = 'fotoAtual';
      img.className = 'pp-photo-preview';
      img.src = dataUrl;
      fotoAtualEl.parentNode.replaceChild(img, fotoAtualEl);
      fotoAtualEl = img;
    }
    inputFoto.value = '';
    closeSheet();
    markDirty();
  });

  /* ── CASTRADO TOGGLE ── */
  var track    = document.getElementById('castradoTrack');
  var trackLbl = document.getElementById('castradoLabel');
  var trackVal = document.getElementById('castradoVal');
  document.getElementById('castradoToggle').addEventListener('click', function (e) {
    if (e.target.tagName === 'INPUT') return;
    var on = track.classList.toggle('on');
    trackVal.value = on ? 'sim' : 'nao';
    trackLbl.textContent = on ? 'Castrado(a)' : 'Não castrado(a)';
    document.getElementById('castradoToggle').setAttribute('aria-checked', on ? 'true' : 'false');
    markDirty();
  });

  /* ── DIRTY TRACKING ── */
  var originalSnapshot = '';
  function formSnapshot() {
    var data = new FormData(editForm);
    var parts = [];
    for (var pair of data.entries()) {
      if (pair[0] !== 'foto' && pair[0] !== 'foto_cropped') {
        parts.push(pair[0] + '=' + pair[1]);
      }
    }
    return parts.join('&');
  }

  function markDirty() {
    saveBar.classList.add('dirty');
    saveBtn.removeAttribute('disabled');
  }
  function checkDirty() {
    if (formSnapshot() !== originalSnapshot) {
      markDirty();
    } else {
      saveBar.classList.remove('dirty');
    }
  }

  /* snapshot on load (after DOM is fully settled) */
  window.addEventListener('load', function () {
    originalSnapshot = formSnapshot();
  });

  editForm.addEventListener('input', checkDirty);
  editForm.addEventListener('change', checkDirty);

  /* ── SECTION NAV — active pill on scroll ── */
  function updateActivePill(id) {
    navPills.forEach(function(pill) {
      pill.classList.toggle('active', pill.dataset.section === id);
    });
  }

  var observedSections = Array.from(sections);
  var io = new IntersectionObserver(function(entries) {
    entries.forEach(function(entry) {
      if (entry.isIntersecting) {
        updateActivePill(entry.target.id);
      }
    });
  }, { rootMargin: '-30% 0px -60% 0px', threshold: 0 });

  observedSections.forEach(function(s) { io.observe(s); });

  /* smooth-scroll on pill click, prevent anchor jump */
  navPills.forEach(function(pill) {
    pill.addEventListener('click', function (e) {
      e.preventDefault();
      var target = document.getElementById(pill.dataset.section);
      if (target) {
        target.scrollIntoView({ behavior: 'smooth', block: 'start' });
        updateActivePill(pill.dataset.section);
      }
    });
  });

  /* fill pill dot when section has data */
  (function markFilledSections() {
    var sectionFields = {
      'sec-dados':   ['nome','raca','cor'],
      'sec-medidas': ['dataNascimento','peso'],
      'sec-id':      ['telefoneContato','microchip','numero_pedigree'],
      'sec-saude':   ['veterinario_nome','alergias_medicacoes','observacoes']
    };
    Object.keys(sectionFields).forEach(function(secId) {
      var hasData = sectionFields[secId].some(function(name) {
        var el = document.querySelector('[name="' + name + '"]');
        return el && el.value && el.value.trim() !== '';
      });
      var pill = document.querySelector('[data-section="' + secId + '"]');
      if (pill && hasData) pill.classList.add('has-data');
    });
    /* photo section */
    var photoPill = document.querySelector('[data-section="sec-foto"]');
    if (photoPill && <%= pet.foto ? 'true' : 'false' %>) {
      photoPill.classList.add('has-data');
    }
  })();

})();
</script>

