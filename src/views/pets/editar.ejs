<% locals.titulo = 'Editar ' + pet.nome %>
<% locals.extraHead = `
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/cropperjs@1.6.2/dist/cropper.min.css">
<style>
  .edit-wrap{max-width:560px;margin:0 auto;padding:16px 16px 120px;}
  .edit-topbar{position:sticky;top:56px;z-index:40;background:rgba(255,255,255,.92);backdrop-filter:blur(16px);border-bottom:1px solid var(--border);}
  .edit-topbar-inner{max-width:560px;margin:0 auto;padding:12px 16px;display:flex;align-items:center;gap:12px;}
  .edit-title{font-size:18px;font-weight:800;color:#0f172a;}
  .back-link{font-size:13px;color:#64748b;text-decoration:none;display:inline-flex;align-items:center;gap:6px}
  .section{background:#fff;border-radius:20px;box-shadow:0 4px 20px rgba(15,23,42,.05);padding:18px;margin-bottom:14px}
  .section-label{font-size:10px;font-weight:800;letter-spacing:.14em;text-transform:uppercase;color:#94a3b8;margin-bottom:12px}
  .field{margin-bottom:12px}
  .field:last-child{margin-bottom:0}
  .label{display:block;font-size:11px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:#64748b;margin-bottom:6px}
  .input{width:100%;background:#f8fafc;border:1px solid #e2e8f0;border-radius:12px;padding:12px 14px;font-size:14px;color:#0f172a;outline:none;transition:border-color .15s,box-shadow .15s}
  .input:focus{border-color:#fb923c;box-shadow:0 0 0 3px rgba(251,146,60,.16)}
  .row{display:grid;grid-template-columns:1fr 1fr;gap:10px}
  @media (max-width:460px){.row{grid-template-columns:1fr}}
  .photo-card{position:relative;display:block;cursor:pointer;border-radius:18px;overflow:hidden;background:#f1f5f9;min-height:240px}
  .photo-preview{width:100%;height:240px;object-fit:cover}
  .photo-empty{height:240px;display:flex;align-items:center;justify-content:center;flex-direction:column;color:#94a3b8;gap:8px}
  .photo-hint{position:absolute;bottom:10px;left:10px;right:10px;padding:8px 10px;border-radius:10px;background:rgba(15,23,42,.45);backdrop-filter:blur(6px);color:#fff;font-size:12px;font-weight:600;text-align:center}
  .switch{display:flex;align-items:center;gap:12px;padding:12px;border-radius:12px;background:#f8fafc;border:1px solid #e2e8f0;cursor:pointer}
  .track{width:44px;height:24px;border-radius:999px;background:#cbd5e1;position:relative;transition:background .2s}
  .track.on{background:#22c55e}
  .thumb{position:absolute;top:3px;left:3px;width:18px;height:18px;border-radius:999px;background:#fff;transition:left .2s}
  .track.on .thumb{left:23px}
  .actions{position:fixed;left:0;right:0;bottom:0;padding:10px 16px calc(env(safe-area-inset-bottom) + 10px);background:rgba(255,255,255,.96);backdrop-filter:blur(10px);border-top:1px solid #e2e8f0;z-index:50}
  .actions-inner{max-width:560px;margin:0 auto;display:grid;grid-template-columns:1fr 1fr;gap:10px}
  .btn{border-radius:12px;padding:13px 14px;font-size:14px;font-weight:700;text-align:center;text-decoration:none;display:inline-flex;align-items:center;justify-content:center;gap:7px;transition:transform .12s}
  .btn:active{transform:scale(.98)}
  .btn-primary{background:#ec5a1c;color:#fff}
  .btn-soft{background:#fff;color:#334155;border:1px solid #e2e8f0}
  .sheet{position:fixed;inset:0;z-index:80;display:none}
  .sheet.open{display:block}
  .sheet-backdrop{position:absolute;inset:0;background:rgba(15,23,42,.62)}
  .sheet-panel{position:absolute;left:0;right:0;bottom:0;background:#fff;border-radius:18px 18px 0 0;max-width:560px;margin:0 auto;padding:14px 14px 20px;max-height:88svh;overflow:auto}
  .crop-wrap{height:320px;background:#0f172a;border-radius:14px;overflow:hidden}
  .crop-wrap img{max-width:100%}
</style>
` %>
<%- include('../partials/header') %>
<%- include('../partials/flash') %>

<div class="edit-topbar">
  <div class="edit-topbar-inner">
    <a href="/pets/<%= pet.id %>" class="back-link"><i class="fa-solid fa-arrow-left"></i> Voltar</a>
    <h1 class="edit-title">Editar <%= pet.nome %></h1>
  </div>
</div>

<main class="flex-1">
  <form class="edit-wrap" action="/pets/<%= pet.id %>/editar" method="POST" enctype="multipart/form-data">
    <input type="file" id="petFoto" name="foto" accept="image/*" class="hidden">
    <input type="hidden" id="fotoCropped" name="foto_cropped">

    <section class="section">
      <p class="section-label">Foto</p>
      <label for="petFoto" class="photo-card" id="triggerFoto">
        <% if (pet.foto) { %>
          <img src="<%= pet.foto %><%= pet.data_atualizacao ? '?t=' + new Date(pet.data_atualizacao).getTime() : '' %>" id="fotoAtual" class="photo-preview" alt="<%= pet.nome %>">
        <% } else { %>
          <div id="fotoAtual" class="photo-empty">
            <i class="fa-solid fa-camera text-3xl"></i>
            <span>Escolher foto</span>
          </div>
        <% } %>
        <div class="photo-hint">Toque para cortar, dar zoom e posicionar</div>
      </label>
    </section>

    <section class="section">
      <p class="section-label">Sobre o pet</p>
      <div class="field"><label class="label" for="nome">Nome</label><input class="input" id="nome" name="nome" maxlength="50" required value="<%= pet.nome %>"></div>
      <div class="row">
        <div class="field"><label class="label" for="tipo">Tipo</label><select class="input" id="tipo" name="tipo"><option value="cachorro" <%= pet.tipo==='cachorro'?'selected':'' %>>Cachorro</option><option value="gato" <%= pet.tipo==='gato'?'selected':'' %>>Gato</option><option value="passaro" <%= pet.tipo==='passaro'?'selected':'' %>>Pássaro</option><option value="outro" <%= pet.tipo==='outro'?'selected':'' %>>Outro</option></select></div>
        <div class="field"><label class="label" for="sexo">Sexo</label><select class="input" id="sexo" name="sexo"><option value="">Não informado</option><option value="macho" <%= pet.sexo==='macho'?'selected':'' %>>Macho</option><option value="femea" <%= pet.sexo==='femea'?'selected':'' %>>Fêmea</option></select></div>
      </div>
      <div class="field"><label class="label" for="raca">Raça</label><input class="input" id="raca" name="raca" value="<%= pet.raca||'' %>"></div>
      <div class="row">
        <div class="field"><label class="label" for="porte">Porte</label><select class="input" id="porte" name="porte"><option value="">—</option><option value="mini" <%= pet.porte==='mini'?'selected':'' %>>Mini</option><option value="pequeno" <%= pet.porte==='pequeno'?'selected':'' %>>Pequeno</option><option value="medio" <%= pet.porte==='medio'?'selected':'' %>>Médio</option><option value="grande" <%= pet.porte==='grande'?'selected':'' %>>Grande</option><option value="gigante" <%= pet.porte==='gigante'?'selected':'' %>>Gigante</option></select></div>
        <div class="field"><label class="label" for="cor">Cor</label><input class="input" id="cor" name="cor" value="<%= pet.cor||'' %>"></div>
      </div>
      <div class="row">
        <div class="field"><label class="label" for="dataNascimento">Nascimento</label><input class="input" type="date" id="dataNascimento" name="dataNascimento" value="<%= pet.data_nascimento ? new Date(pet.data_nascimento).toISOString().split('T')[0] : '' %>"></div>
        <div class="field"><label class="label" for="peso">Peso (kg)</label><input class="input" type="number" step="0.1" min="0" id="peso" name="peso" value="<%= pet.peso||'' %>"></div>
      </div>
      <label class="switch" id="castradoToggle">
        <input type="hidden" id="castradoVal" name="castrado" value="<%= pet.castrado ? 'sim' : 'nao' %>">
        <span class="track <%= pet.castrado ? 'on' : '' %>" id="castradoTrack"><span class="thumb"></span></span>
        <span id="castradoLabel"><%= pet.castrado ? 'Castrado(a)' : 'Não castrado(a)' %></span>
      </label>
    </section>

    <section class="section">
      <p class="section-label">Identificação</p>
      <div class="field"><label class="label" for="telefoneContato">Telefone contato</label><input class="input" id="telefoneContato" name="telefoneContato" value="<%= pet.telefone_contato||'' %>"></div>
      <div class="field"><label class="label" for="microchip">Microchip</label><input class="input" id="microchip" name="microchip" value="<%= pet.microchip||'' %>"></div>
      <div class="field"><label class="label" for="numero_pedigree">Número de pedigree</label><input class="input" id="numero_pedigree" name="numero_pedigree" value="<%= pet.numero_pedigree||'' %>"></div>
    </section>

    <section class="section">
      <p class="section-label">Saúde e veterinário</p>
      <div class="field"><label class="label" for="veterinario_nome">Veterinário</label><input class="input" id="veterinario_nome" name="veterinario_nome" value="<%= pet.veterinario_nome||'' %>"></div>
      <div class="field"><label class="label" for="veterinario_telefone">Telefone veterinário</label><input class="input" id="veterinario_telefone" name="veterinario_telefone" value="<%= pet.veterinario_telefone||'' %>"></div>
      <div class="field"><label class="label" for="alergias_medicacoes">Alergias/medicações</label><textarea class="input" rows="3" id="alergias_medicacoes" name="alergias_medicacoes"><%= pet.alergias_medicacoes||'' %></textarea></div>
    </section>

    <section class="section">
      <p class="section-label">Observações</p>
      <div class="field"><label class="label" for="descricao">Descrição</label><textarea class="input" rows="3" maxlength="200" id="descricao" name="descricao"><%= pet.descricao_emocional||'' %></textarea></div>
      <div class="field"><label class="label" for="observacoes">Observações gerais</label><textarea class="input" rows="4" id="observacoes" name="observacoes"><%= pet.observacoes||'' %></textarea></div>
    </section>

    <div class="actions">
      <div class="actions-inner">
        <a class="btn btn-soft" href="/pets/<%= pet.id %>">Cancelar</a>
        <button type="submit" class="btn btn-primary"><i class="fa-solid fa-floppy-disk"></i> Salvar</button>
      </div>
    </div>
  </form>
</main>

<div class="sheet" id="cropSheet" aria-hidden="true">
  <div class="sheet-backdrop"></div>
  <div class="sheet-panel">
    <div class="flex items-center justify-between mb-2">
      <h3 class="text-sm font-bold text-slate-900">Ajustar foto do pet</h3>
      <button type="button" id="closeCropper" class="w-8 h-8 rounded-full border border-slate-200 text-slate-600"><i class="fa-solid fa-xmark"></i></button>
    </div>
    <div class="crop-wrap mb-3"><img id="cropImage" alt="Prévia para recorte"></div>
    <div class="mb-3">
      <label class="label" for="zoomRange">Zoom</label>
      <input id="zoomRange" type="range" min="0" max="100" value="0" class="w-full">
    </div>
    <div class="grid grid-cols-3 gap-2">
      <button type="button" id="rotateCrop" class="btn btn-soft !py-2.5">Girar</button>
      <button type="button" id="cancelCrop" class="btn btn-soft !py-2.5">Cancelar</button>
      <button type="button" id="applyCrop" class="btn btn-primary !py-2.5">Usar foto</button>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/cropperjs@1.6.2/dist/cropper.min.js"></script>
<script>
  var inputFoto = document.getElementById('petFoto');
  var fotoAtual = document.getElementById('fotoAtual');
  var cropSheet = document.getElementById('cropSheet');
  var cropImage = document.getElementById('cropImage');
  var closeCropperBtn = document.getElementById('closeCropper');
  var cancelCropBtn = document.getElementById('cancelCrop');
  var applyCropBtn = document.getElementById('applyCrop');
  var rotateCropBtn = document.getElementById('rotateCrop');
  var zoomRange = document.getElementById('zoomRange');
  var fotoCropped = document.getElementById('fotoCropped');
  var cropper = null;

  function openSheet() { cropSheet.classList.add('open'); cropSheet.setAttribute('aria-hidden', 'false'); document.body.style.overflow = 'hidden'; }
  function closeSheet() { cropSheet.classList.remove('open'); cropSheet.setAttribute('aria-hidden', 'true'); document.body.style.overflow = ''; if (cropper) { cropper.destroy(); cropper = null; } zoomRange.value = 0; }

  inputFoto.addEventListener('change', function () {
    if (!inputFoto.files || !inputFoto.files[0]) return;
    var file = inputFoto.files[0];
    var reader = new FileReader();
    reader.onload = function (e) {
      cropImage.src = e.target.result;
      openSheet();
      if (cropper) cropper.destroy();
      cropper = new Cropper(cropImage, {
        aspectRatio: 1,
        viewMode: 1,
        dragMode: 'move',
        autoCropArea: 1,
        responsive: true,
        background: false
      });
    };
    reader.readAsDataURL(file);
  });

  zoomRange.addEventListener('input', function () {
    if (!cropper) return;
    var val = Number(zoomRange.value) / 100;
    cropper.zoomTo(1 + val);
  });

  rotateCropBtn.addEventListener('click', function () { if (cropper) cropper.rotate(90); });
  closeCropperBtn.addEventListener('click', closeSheet);
  cancelCropBtn.addEventListener('click', closeSheet);
  cropSheet.querySelector('.sheet-backdrop').addEventListener('click', closeSheet);

  applyCropBtn.addEventListener('click', function () {
    if (!cropper) return;
    var canvas = cropper.getCroppedCanvas({ width: 1080, height: 1080, imageSmoothingQuality: 'high' });
    var dataUrl = canvas.toDataURL('image/jpeg', 0.9);
    fotoCropped.value = dataUrl;
    if (fotoAtual && fotoAtual.tagName === 'IMG') {
      fotoAtual.src = dataUrl;
    } else if (fotoAtual) {
      var img = document.createElement('img');
      img.id = 'fotoAtual';
      img.className = 'photo-preview';
      img.src = dataUrl;
      fotoAtual.parentNode.replaceChild(img, fotoAtual);
      fotoAtual = img;
    }
    inputFoto.value = '';
    closeSheet();
  });

  var track = document.getElementById('castradoTrack');
  var label = document.getElementById('castradoLabel');
  var val = document.getElementById('castradoVal');
  document.getElementById('castradoToggle').addEventListener('click', function (e) {
    if (e.target.tagName === 'INPUT') return;
    var on = track.classList.toggle('on');
    val.value = on ? 'sim' : 'nao';
    label.textContent = on ? 'Castrado(a)' : 'Não castrado(a)';
  });
</script>

<%- include('../partials/footer') %>
