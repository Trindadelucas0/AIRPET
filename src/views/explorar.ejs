    if (composerActions) composerActions.classList.add('hidden');
    if (composerCard) composerCard.classList.remove('is-active');
    if (petSelect && petSelect.options && petSelect.options.length) petSelect.selectedIndex = 0;
    if (btnPublicar) { btnPublicar.disabled = false; btnPublicar.innerHTML = 'Publicar'; }
    validarFormPost();
    abrirModal('newPostModal');
    ajustarSheetViewport();
    setTimeout(function () { if (novoPostTexto) novoPostTexto.focus(); }, 80);
    var counter = document.getElementById('postCounter');
    if (counter) counter.textContent = totalPostsLocal + '/10';
  }
  function autoResizeComposer() {
    if (!novoPostTexto) return;
    novoPostTexto.style.height = 'auto';
    novoPostTexto.style.height = Math.min(novoPostTexto.scrollHeight, 180) + 'px';
  }

  function ativarComposer() {
    if (composerActions) composerActions.classList.remove('hidden');
    if (composerCard) composerCard.classList.add('is-active');
  }
  function ajustarSheetViewport() {
    if (!newPostSheet) return;
    var vv = window.visualViewport;
    var vh = vv ? Math.floor(vv.height) : window.innerHeight;
    if (vh > 0) newPostSheet.style.maxHeight = Math.max(380, vh - 10) + 'px';
  }

  function generateIdempotencyKey() {
    return 'post_' + Date.now().toString(36) + '_' + Math.random().toString(36).slice(2, 10);
  }

  function payloadHash(texto, petId, file) {
    return [texto || '', petId || '', file ? file.size : 0, file ? file.name : ''].join('|');
  }

  function isRecentDuplicate(hash) {
    var now = Date.now();
    var ts = recentPayloadHashes.get(hash);
    if (!ts) return false;
    return (now - ts) < 15000;
  }

  function validarFormPost() {
    if (!btnPublicar) return;
    var temFoto = !!selectedFile;
    var temTexto = !!(novoPostTexto && novoPostTexto.value.trim());
    btnPublicar.disabled = isSubmittingPost || !(temFoto || temTexto);
  }

  uploadArea.addEventListener('click', function () { photoInput.click(); });
  uploadArea.addEventListener('dragover', function (e) { e.preventDefault(); this.classList.add('border-primary-400', 'bg-primary-50/50'); });
  uploadArea.addEventListener('dragleave', function () { this.classList.remove('border-primary-400', 'bg-primary-50/50'); });
  uploadArea.addEventListener('drop', function (e) {
    e.preventDefault();
    this.classList.remove('border-primary-400', 'bg-primary-50/50');
    if (e.dataTransfer.files && e.dataTransfer.files[0]) handleFile(e.dataTransfer.files[0]);
  });
  photoInput.addEventListener('change', function () { if (this.files && this.files[0]) handleFile(this.files[0]); });

  function handleFile(file) {
    if (!file.type.match(/^image\/(jpeg|png|gif|webp)$/)) { toast('Formato não suportado.', 'erro'); return; }
    if (file.size > 10 * 1024 * 1024) { toast('Imagem muito grande (max 10MB).', 'erro'); return; }
    var reader = new FileReader();
    reader.onload = function (ev) {
      if (typeof openCropModal !== 'function') {
        selectedFile = file;
        uploadPlaceholder.classList.add('hidden');
        uploadPreview.classList.remove('hidden');
        previewImg.src = ev.target.result;
        validarFormPost();
        return;
      }
      openCropModal({
        src: ev.target.result,
        aspectRatio: 0,
        maxWidth: 1200,
        maxHeight: 1200,
        onConfirm: function (blob) {
          selectedFile = new File([blob], 'foto-post.jpg', { type: 'image/jpeg' });
          uploadPlaceholder.classList.add('hidden');
          uploadPreview.classList.remove('hidden');
          previewImg.src = URL.createObjectURL(blob);
          validarFormPost();
        },
        onCancel: function () {
          selectedFile = file;
          uploadPlaceholder.classList.add('hidden');
          uploadPreview.classList.remove('hidden');
          previewImg.src = ev.target.result;
          validarFormPost();
        }
      });
    };
    reader.readAsDataURL(file);
  }

  document.getElementById('removePhoto').addEventListener('click', function (e) {
    e.stopPropagation();
    selectedFile = null;
    photoInput.value = '';
    uploadPlaceholder.classList.remove('hidden');
    uploadPreview.classList.add('hidden');
    validarFormPost();
  });

  novoPostTexto.addEventListener('focus', ativarComposer);
  novoPostTexto.addEventListener('input', function () {
    autoResizeComposer();
    charCount.textContent = this.value.length + '/500';
    validarFormPost();
  });
  novoPostTexto.addEventListener('paste', function (e) {
    if (!e.clipboardData || !e.clipboardData.items) return;
    for (var i = 0; i < e.clipboardData.items.length; i++) {
      var item = e.clipboardData.items[i];
      if (item.type && item.type.indexOf('image/') === 0) {
        var file = item.getAsFile();
        if (file) {
          e.preventDefault();
          handleFile(file);
          break;
        }
      }
    }
  });
  novoPostTexto.addEventListener('keydown', function (e) {
    if ((e.ctrlKey || e.metaKey) && e.key === 'Enter') {
      e.preventDefault();
      if (!btnPublicar.disabled) btnPublicar.click();
    }
  });
  if (btnOpenImagePicker) {
    btnOpenImagePicker.addEventListener('click', function () {
      ativarComposer();
      if (uploadArea && uploadArea.classList.contains('hidden')) {
        uploadArea.classList.remove('hidden');
      }
      photoInput.click();
    });
  }
  window.addEventListener('resize', ajustarSheetViewport);
  if (window.visualViewport) window.visualViewport.addEventListener('resize', ajustarSheetViewport);

  if (btnPublicar) btnPublicar.addEventListener('click', function () {
    if (isSubmittingPost) return;
    var textoPayload = novoPostTexto ? novoPostTexto.value.trim() : '';
    if (!selectedFile && !textoPayload) return;
    var petSelect = document.getElementById('novoPostPet');
    var petVal = (petSelect && petSelect.value) ? petSelect.value : '';
    var hash = payloadHash(textoPayload, petVal, selectedFile);
    if (isRecentDuplicate(hash)) {
      toast('Publicação já enviada recentemente. Aguarde alguns segundos.', 'erro');
      return;
    }
    isSubmittingPost = true;

    var formData = new FormData();
    if (selectedFile) formData.append('foto', selectedFile);
    if (textoPayload) formData.append('texto', textoPayload);
    if (petVal) formData.append('pet_id', petVal);

    var busyLabel = '<i class="fa-solid fa-spinner fa-spin mr-2"></i><span class="airpet-inline-dots">Publicando</span>';
    var work = function () {
      return explorarDeferred(function () {
        return fetch('/explorar/post', {
          method: 'POST',
          credentials: 'same-origin',
          headers: { 'Idempotency-Key': generateIdempotencyKey() },
          body: formData
        })
          .then(function (r) {
            return r.text().then(function (text) {
              try { return { ok: r.ok, data: JSON.parse(text) }; }
              catch (_) { return { ok: false, data: { sucesso: false, mensagem: r.status === 401 ? 'Sessão expirada. Faça login de novo.' : 'Erro no servidor. Tente novamente.' } }; }
            });
          })
          .then(function (result) {
            var data = result.data;
            if (!result.ok || !data.sucesso) {
              toast(data.mensagem || 'Erro ao publicar.', 'erro');
              validarFormPost();
              return result;
            }
            recentPayloadHashes.set(hash, Date.now());
            fecharModal('newPostModal');
            toast('Publicado!');
            totalPostsLocal = data.totalPosts != null ? data.totalPosts : (totalPostsLocal + 1);
            if (data.post && postTemMidiaExplorarCliente(data.post)) {
              var emptyState = feedContainer.querySelector('.explorar-empty-explore');
              if (emptyState) emptyState.remove();
              feedContainer.classList.add('explore-mosaic-grid');
              feedContainer.insertAdjacentHTML('afterbegin', renderPostHTML(data.post));
              syncExploreMosaicCellSize();
              observarCardVisualizacao(feedContainer.firstElementChild);
            }
            if (data.removido) {
              var old = document.getElementById('post-' + data.removido);
              if (old) { old.classList.add('fade-out'); setTimeout(function () { if (old.parentNode) old.parentNode.removeChild(old); }, 400); }
            }
            return result;
          })
          .catch(function () {
            toast('Erro de conexão. Verifique a internet e tente novamente.', 'erro');
            validarFormPost();
            throw new Error('network');
          });
      }, 'A publicar…');
    };
    var p = window.AIRPET_LOADING
      ? window.AIRPET_LOADING.runLocked({ button: btnPublicar, busyText: busyLabel }, work)
      : work();
    p.finally(function () { isSubmittingPost = false; });
  });

  var fabBtn = document.getElementById('fabNewPost');
  if (fabBtn) {
    fabBtn.addEventListener('click', function (e) {
      e.preventDefault();
      e.stopPropagation();
      abrirNovoPost();
    });
  }

  /* ──────────── Pin / Unpin ──────────── */
  function fixarPost(postId, estaFixada) {
    explorarDeferred(function () {
      var c = explorarCoordinator();
      var method = estaFixada ? 'DELETE' : 'POST';
      var url = '/explorar/post/' + postId + '/fixar';
      if (c && typeof c.enqueue === 'function') {
        return c.enqueue({
          key: 'explorarFixar:' + postId + ':' + (estaFixada ? 'off' : 'on'),
          group: 'explorarPostActions',
          priority: c.PRIORITY ? c.PRIORITY.HIGH : 'HIGH',
          fetchFn: function (signal) {
            return fetch(url, {
              method: method,
              headers: { 'Accept': 'application/json' },
              credentials: 'same-origin',
              signal: signal
            }).then(function (r) { return r.json(); });
          }
        });
      }
      return fetch(url, {
        method: method,
        headers: { 'Accept': 'application/json' },
        credentials: 'same-origin'
      }).then(function (r) { return r.json(); });
    }, estaFixada ? 'A desafixar publicação…' : 'A fixar publicação…')
      .then(function (data) {
        if (!data || !data.sucesso) { toast((data && data.mensagem) || 'Erro.', 'erro'); return; }
        toast(data.fixada ? 'Post fixado!' : 'Post desafixado!');
        totalFixadasLocal += data.fixada ? 1 : -1;
        setTimeout(function () { window.location.reload(); }, 600);
      })
      .catch(function () { toast('Erro de conexão.', 'erro'); });
  }

  /* ──────────── Delete Post ──────────── */
  function deletarPost(postId) {
    if (!confirm('Excluir esta publicação?')) return;
    explorarDeferred(function () {
      var c = explorarCoordinator();
      var url = '/explorar/post/' + postId;
      if (c && typeof c.enqueue === 'function') {
        return c.enqueue({
          key: 'explorarDeletePost:' + postId,
          group: 'explorarPostActions',
          priority: c.PRIORITY ? c.PRIORITY.HIGH : 'HIGH',
          fetchFn: function (signal) {
            return fetch(url, {
              method: 'DELETE',
              headers: { 'Accept': 'application/json' },
              credentials: 'same-origin',
              signal: signal
            }).then(function (r) { return r.json(); });
          }
        });
      }
      return fetch(url, {
        method: 'DELETE',
        headers: { 'Accept': 'application/json' },
        credentials: 'same-origin'
      }).then(function (r) { return r.json(); });
    }, 'A apagar publicação…')
      .then(function (data) {
        if (!data || !data.sucesso) { toast((data && data.mensagem) || 'Não foi possível excluir agora. Tente novamente.', 'erro'); return; }
        var card = document.getElementById('post-' + postId);
        if (card) {
          card.classList.add('fade-out');
          setTimeout(function () { if (card.parentNode) card.parentNode.removeChild(card); }, 400);
        }
        totalPostsLocal = Math.max(0, totalPostsLocal - 1);
        toast('Publicação excluída.');
        requestClosePostDetail();
      })
      .catch(function () { toast('Erro de conexão. Tente novamente.', 'erro'); });
  }

  /* ──────────── Share ──────────── */
  function compartilhar(postId, autor) {
    var url = window.location.origin + '/explorar#post-' + postId;
    var texto = 'Veja o post de ' + autor + ' no AIRPET! 🐾 ' + url;
    window.open('https://wa.me/?text=' + encodeURIComponent(texto), '_blank');
  }

  (function bindPostDetailCompartilhar() {
    var btn = document.getElementById('postDetailBtnCompartilhar');
    if (!btn || btn.dataset.airpetShareBound) return;
    btn.dataset.airpetShareBound = '1';
    btn.addEventListener('click', function () {
      var id = this.getAttribute('data-post-id');
      var aut = this.getAttribute('data-autor') || '';
      if (id) compartilhar(id, aut);
    });
  })();

  /* ──────────── Three-dot Menu ──────────── */
  function fecharMenus() {
    var menus = document.querySelectorAll('.menu-dropdown');
    for (var i = 0; i < menus.length; i++) menus[i].classList.add('hidden');
  }

  function toggleMenu(btn) {
    var dropdown = btn.parentElement.querySelector('.menu-dropdown');
    if (!dropdown) return;
    var wasHidden = dropdown.classList.contains('hidden');
    fecharMenus();
    if (wasHidden) dropdown.classList.remove('hidden');
  }

  /* ──────────── Infinite Scroll ──────────── */
  function explorarSkeletonBlock(count) {
    var n = count || 2;
    var card = '<div class="airpet-skeleton-post"><div class="airpet-skeleton-post__head"><div class="airpet-skeleton-circle"></div><div class="airpet-skeleton-lines"><div class="airpet-skeleton-line airpet-skeleton-line--med"></div><div class="airpet-skeleton-line airpet-skeleton-line--short"></div></div></div><div class="airpet-skeleton-post__media"></div></div>';
    var i;
    var html = '<div class="airpet-skeleton-feed col-span-full" data-airpet-explore-skel="1">';
    for (i = 0; i < n; i++) html += card;
    html += '</div>';
    return html;
  }

  function carregarMaisPosts() {
    if (isLoading || !hasMore) return;
    isLoading = true;
    currentPage++;
    var loadingPage = currentPage;

    var skWrap = document.createElement('div');
    skWrap.innerHTML = explorarSkeletonBlock(2);
    var skEl = skWrap.firstChild;
    if (scrollSentinel && scrollSentinel.parentNode) {
      scrollSentinel.parentNode.insertBefore(skEl, scrollSentinel);
    }

    function removeExploreSkel() {
      if (skEl && skEl.parentNode) skEl.remove();
    }

    function applyExplorePage(data) {
      isLoading = false;
      removeExploreSkel();
      if (!data || !data.sucesso || !data.posts || !data.posts.length) {
        hasMore = false;
        if (scrollSentinel) scrollSentinel.innerHTML = '<p class="text-xs text-gray-300 text-center">Você chegou ao fim 🐾</p>';
        return;
      }
      if (typeof data.layoutSeed === 'number') explorarLayoutSeed = data.layoutSeed >>> 0;
      data.posts.forEach(function (post) {
        if (!postTemMidiaExplorarCliente(post)) return;
        feedContainer.insertAdjacentHTML('beforeend', renderPostHTML(post));
        observarCardVisualizacao(feedContainer.lastElementChild);
      });
      syncExploreMosaicCellSize();
      atualizarTempos();
      if (typeof data.temMais === 'boolean') {
        hasMore = data.temMais;
      } else {
        hasMore = data.posts.length >= 20;
      }
      if (!hasMore && scrollSentinel) {
        scrollSentinel.innerHTML = '<p class="text-xs text-gray-300 text-center">Você chegou ao fim 🐾</p>';
      }
    }

    if (typeof swrFetchGet === 'function') {
      var cEx = window.AIRPET_REQ_COORDINATOR;
      explorarDeferred(function () {
        return swrFetchGet({
          key: 'explorar:page:' + loadingPage,
          url: '/explorar?page=' + loadingPage,
          staleTimeMs: 30000,
          cacheTimeMs: 480000,
          group: 'explorarPagination',
          priority: cEx && cEx.PRIORITY ? cEx.PRIORITY.MEDIUM : 'MEDIUM',
          credentials: 'same-origin'
        })
          .then(function (res) {
            var data = res && Object.prototype.hasOwnProperty.call(res, 'data') ? res.data : res;
            applyExplorePage(data || {});
          })
          .catch(function () {
            isLoading = false;
            removeExploreSkel();
          });
      }, 'A carregar mais publicações…');
      return;
    }

    explorarDeferred(function () {
      return fetch('/explorar?page=' + loadingPage, {
        headers: { 'Accept': 'application/json' },
        credentials: 'same-origin'
      })
        .then(function (r) { return r.json(); })
        .then(function (data) { applyExplorePage(data); })
        .catch(function () {
          isLoading = false;
          removeExploreSkel();
        });
    }, 'A carregar mais publicações…');
  }

  if ('IntersectionObserver' in window) {
    viewObserver = new IntersectionObserver(function (entries) {
      entries.forEach(function (entry) {
        if (!entry.isIntersecting || entry.intersectionRatio < 0.6) return;
        var card = entry.target;
        var postId = parseInt(card.getAttribute('data-post-id'), 10);
        if (!postId || viewedPosts.has(postId)) return;
        viewedPosts.add(postId);
        var source = card.getAttribute('data-view-source') || 'explorar';
        registrarVisualizacao(postId, 1500, source);
        viewObserver.unobserve(card);
      });
    }, { threshold: [0.6] });
    document.querySelectorAll('article[data-post-id]').forEach(observarCardVisualizacao);
  }

  if (scrollSentinel && 'IntersectionObserver' in window) {
    var observer = new IntersectionObserver(function (entries) {
      if (entries[0].isIntersecting) carregarMaisPosts();
    }, { rootMargin: '200px' });
    observer.observe(scrollSentinel);
  }

  /* ──────────── Client-side Post Render (mosaico só imagem) ──────────── */
  function explorarTileSpanClass(p) {
    var s = p && p.explorar_tile_span;
    if (s === '1x2' || s === '2x1' || s === '2x2') return s;
    return '1x1';
  }

  function exploreTilePhotoHtml(src, loadingMode, withPriority) {
    if (!src) return '';
    var lazy = loadingMode === 'eager' ? 'loading="eager"' : 'loading="lazy"';
    var pri = withPriority ? ' fetchpriority="high"' : '';
    return '<img src="' + escapeHtml(src) + '" alt="" class="post-photo" decoding="async" ' + lazy + pri +
      ' onload="var s=this.previousElementSibling;if(s&&s.classList)s.classList.add(\'is-hidden\');"' +
      ' onerror="var s=this.previousElementSibling;if(s&&s.classList)s.classList.add(\'is-hidden\');">';
  }

  function renderSponsoredHTML(p) {
    var sid = p.sponsored_key || ('sponsored-' + (p.boost_id || 'x') + '-' + (p.pet_id || 'x'));
    var sponsoredPostId = parseInt(p.id, 10);
    var hasSponsoredPostId = !Number.isNaN(sponsoredPostId) && sponsoredPostId > 0;
    var sponsoredText = p.texto || p.legenda || '';
    var petNome = p.pet_nome || ('Pet ' + (p.pet_id || ''));
    var tutorNome = p.autor_nome || ('Usuário ' + (p.usuario_id || ''));
    var meta = {
      kind: 'sponsored',
      postId: hasSponsoredPostId ? sponsoredPostId : null,
      foto: p.foto || '',
      texto: sponsoredText,
      criado_em: p.criado_em || '',
      pet_nome: petNome,
      pet_foto: p.pet_foto || '',
      autor_nome: tutorNome,
      usuario_id: p.usuario_id,
      pet_id: p.pet_id,
      comments: hasSponsoredPostId
    };
    var sp = explorarTileSpanClass(p);
    var inner = '<div class="explore-tile-inner"><div class="explore-tile-skeleton" aria-hidden="true"></div>';
    inner += p.foto ? exploreTilePhotoHtml(p.foto, 'lazy', false) : '';
    inner += '<span class="explore-tile-overlay" aria-hidden="true"></span></div>';
    return '<article class="explore-tile-cell explore-tile--' + sp + ' explorar-post-card post-enter" tabindex="0" aria-label="Abrir publicação patrocinada" data-post-id="' + (hasSponsoredPostId ? sponsoredPostId : '') + '" data-view-source="' + (hasSponsoredPostId ? 'sponsored_explorar' : '') + '" data-author-id="' + escapeHtml(p.usuario_id || '') + '"' + explorarMetaAttr(meta) + ' id="' + sid + '">' + inner + '</article>';
  }

  function renderPetshopPublicationHTML(p) {
    var publicationKey = p.publicationKey || '';
    var safeKey = String(publicationKey).replace(/[^a-zA-Z0-9]/g, '-');
    var isPromo = p.publicationType === 'promocao' || p.is_promocao;
    var meta = {
      kind: 'petshop',
      postId: publicationKey,
      foto: p.foto_url || '',
      texto: p.texto || '',
      created_em: p.created_em || '',
      displayName: p.petshop_nome || ('Petshop ' + (p.petshop_id || '')),
      avatar: p.petshop_logo_url || '',
      petshop_id: p.petshop_id,
      preco: p.preco,
      whatsapp_publico: p.whatsapp_publico || '',
      contato_link: p.contato_link || '',
      isPromo: !!isPromo,
      comments: true
    };
    var sp = explorarTileSpanClass(p);
    var inner = '<div class="explore-tile-inner"><div class="explore-tile-skeleton" aria-hidden="true"></div>';
    inner += p.foto_url ? exploreTilePhotoHtml(p.foto_url, 'lazy', false) : '';
    inner += '<span class="explore-tile-overlay" aria-hidden="true"></span></div>';
    return '<article class="explore-tile-cell explore-tile--' + sp + ' explorar-post-card post-enter" tabindex="0" aria-label="Abrir publicação do parceiro" data-post-id="' + escapeHtml(publicationKey) + '" data-view-source="petshop_explorar" data-author-id="' + escapeHtml(p.petshop_id || '') + '"' + explorarMetaAttr(meta) + ' id="petshop-publication-' + safeKey + '">' + inner + '</article>';
  }

  function renderPostHTML(p) {
    if (p && p.is_petshop_publication) return renderPetshopPublicationHTML(p);
    if (p && p.is_sponsored) return renderSponsoredHTML(p);
    var txt = p.texto || p.legenda || '';
    var exFoto = fotoExplorarOrganico(p);
    var pCor = p.cor_perfil || '#ec5a1c';
    var meta = {
      kind: 'organic',
      postId: p.id,
      foto: exFoto || '',
      texto: txt,
      criado_em: p.criado_em || '',
      autor_nome: p.autor_nome || '',
      usuario_id: p.usuario_id,
      foto_perfil: p.foto_perfil || '',
      cor_perfil: pCor,
      pet_id: p.pet_id || null,
      pet_nome: p.pet_nome || '',
      pet_foto: p.pet_foto || '',
      fixada: !!p.fixada,
      comments: true,
      tipo: p.tipo || 'original',
      orig_id: p.orig_id || null,
      orig_foto: p.orig_foto || '',
      orig_texto: p.orig_texto || '',
      orig_legenda: p.orig_legenda || '',
      orig_autor_nome: p.orig_autor_nome || '',
      orig_usuario_id: p.orig_usuario_id || null,
      orig_pet_id: p.orig_pet_id || null,
      orig_pet_nome: p.orig_pet_nome || '',
      orig_pet_foto: p.orig_pet_foto || '',
      orig_foto_perfil: p.orig_foto_perfil || '',
      orig_criado_em: p.orig_criado_em || ''
    };
    var sp = explorarTileSpanClass(p);
    var inner = '<div class="explore-tile-inner"><div class="explore-tile-skeleton" aria-hidden="true"></div>';
    inner += exFoto ? exploreTilePhotoHtml(exFoto, 'eager', true) : '';
    inner += '<span class="explore-tile-overlay" aria-hidden="true"></span></div>';
    return '<article class="explore-tile-cell explore-tile--' + sp + ' explorar-post-card post-enter" tabindex="0" aria-label="Abrir publicação" data-post-id="' + p.id + '" data-author-id="' + p.usuario_id + '"' + explorarMetaAttr(meta) + ' id="post-' + p.id + '">' + inner + '</article>';
  }

  /* ──────────── Event Delegation ──────────── */
  feedContainer.addEventListener('click', function (e) {
    var btn;
    var phLb = e.target.closest('img.post-photo');
    var artFromPhoto = phLb ? phLb.closest('article[data-explorar-meta]') : null;
    if (artFromPhoto && feedContainer.contains(artFromPhoto)) {
      if (e.target.closest('.menu-dropdown')) { fecharMenus(); return; }
      if (e.target.closest('button')) return;
      fecharMenus();
      openPostDetailFromArticle(artFromPhoto);
      return;
    }
    if (phLb && feedContainer.contains(phLb) && typeof window.openPostImageLightbox === 'function') {
      var srcLb = phLb.currentSrc || phLb.src;
      if (srcLb) {
        e.preventDefault();
        e.stopPropagation();
        fecharMenus();
        window.openPostImageLightbox(srcLb, phLb.getAttribute('alt') || '');
        return;
      }
    }

    btn = e.target.closest('.btn-repost');
    if (btn) { abrirRepostModal(btn.getAttribute('data-post-id')); return; }

    btn = e.target.closest('.btn-share');
    if (btn) { compartilhar(btn.getAttribute('data-post-id'), btn.getAttribute('data-autor')); return; }

    btn = e.target.closest('.btn-menu-post');
    if (btn) { e.stopPropagation(); toggleMenu(btn); return; }

    btn = e.target.closest('.btn-fixar');
    if (btn) { fecharMenus(); fixarPost(btn.getAttribute('data-post-id'), btn.getAttribute('data-fixada') === '1'); return; }

    btn = e.target.closest('.btn-deletar');
    if (btn) { fecharMenus(); deletarPost(btn.getAttribute('data-post-id')); return; }

    var artOpen = e.target.closest('article[data-explorar-meta]');
    if (artOpen && feedContainer.contains(artOpen)) {
      if (e.target.closest('.menu-dropdown')) { fecharMenus(); return; }
      if (e.target.closest('button')) return;
      if (e.target.closest('a[href]')) {
        e.preventDefault();
        e.stopPropagation();
      }
      fecharMenus();
      openPostDetailFromArticle(artOpen);
      return;
    }

    fecharMenus();
  });

  feedContainer.addEventListener('keydown', function (e) {
    if (e.key === 'Enter' && e.target.classList.contains('input-comentario-inline')) {
      e.preventDefault();
      var txt = e.target.value.trim();
      if (txt) enviarComentario(e.target.getAttribute('data-post-id'), txt, e.target);
      return;
    }
    if ((e.key === 'Enter' || e.key === ' ') && e.target.matches && e.target.matches('article.explorar-post-card[data-explorar-meta]')) {
      e.preventDefault();
      openPostDetailFromArticle(e.target);
    }
  });

  document.addEventListener('click', function (e) {
    if (!e.target.closest('.btn-menu-post') && !e.target.closest('.menu-dropdown')) fecharMenus();
  });

  /* ──────────── Init ──────────── */
  atualizarTempos();
  setInterval(atualizarTempos, 60000);

  function tryOpenPostFromHash() {
    var m = (window.location.hash || '').match(/^#post-(\d+)$/);
    if (!m) return;
    var el = document.getElementById('post-' + m[1]);
    if (el && el.getAttribute('data-explorar-meta')) openPostDetailFromArticle(el);
  }
  window.addEventListener('hashchange', tryOpenPostFromHash);
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', tryOpenPostFromHash);
  } else {
    setTimeout(tryOpenPostFromHash, 0);
  }

  /* ──────────── Sidebar Follow Buttons ──────────── */
  document.querySelectorAll('.btn-seguir-sidebar').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var userId = this.getAttribute('data-user-id');
      var el = this;
      explorarDeferred(function () {
        return fetch('/explorar/seguir/' + userId, { method: 'POST', headers: { 'Content-Type': 'application/json' }, credentials: 'same-origin' })
          .then(function(r) { return r.json(); })
          .then(function(d) {
            if (d.sucesso) {
              el.textContent = 'Seguindo';
              el.classList.remove('border-primary-500', 'text-primary-500', 'bg-white', 'hover:bg-primary-50', 'hover:text-primary-600');
              el.classList.add('bg-primary-500', 'text-white', 'hover:bg-primary-600');
              el.disabled = true;
            }
          });
      }, 'A seguir utilizador…');
    });
  });
  document.querySelectorAll('.btn-seguir-pet-sidebar').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var petId = this.getAttribute('data-pet-id');
      var el = this;
      explorarDeferred(function () {
        return fetch('/explorar/pet/' + petId + '/seguir', { method: 'POST', headers: { 'Content-Type': 'application/json' }, credentials: 'same-origin' })
          .then(function(r) { return r.json(); })
          .then(function(d) {
            if (d.sucesso) {
              el.textContent = 'Seguindo';
              el.classList.remove('border-primary-500', 'text-primary-500', 'hover:bg-primary-500', 'hover:text-white');
              el.classList.add('bg-primary-500', 'text-white', 'border-primary-500');
              el.disabled = true;
            }
          });
      }, 'A seguir pet…');
    });
  });

  /* ──────────── Onboarding (Driver.js) ──────────── */
  if (typeof window.driver !== 'undefined' && !localStorage.getItem('airpet_onboarding_done')) {
    setTimeout(function () {
      var steps = [];
      var feedTab = document.getElementById('bottomNavFeedTab');
      if (feedTab && feedTab.offsetParent !== null) {
        steps.push({ element: '#bottomNavFeedTab', popover: { title: 'Publique no Feed', description: 'Toque em Feed na barra inferior para criar posts com foto e texto do seu pet. Nesta página você também pode usar o botão de publicar acima.', side: 'top', align: 'center' } });
      }
      if (document.querySelector('article.explorar-post-card[data-explorar-meta]')) {
        steps.push({ element: 'article.explorar-post-card[data-explorar-meta]', popover: { title: 'Veja os detalhes', description: 'Toque em qualquer lugar do card para abrir o post: foto, texto completo, data e comentários.', side: 'top', align: 'center' } });
      }
      if (!steps.length) return;
      var driverObj = window.driver.js.driver({
        showProgress: true,
        steps: steps,
        nextBtnText: 'Próximo',
        prevBtnText: 'Anterior',
        doneBtnText: 'Entendi!',
        onDestroyed: function () { localStorage.setItem('airpet_onboarding_done', '1'); }
      });
      driverObj.drive();
    }, 800);
  }

})();
</script>

