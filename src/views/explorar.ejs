<%
  locals.extraHead = `
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/driver.js@1.3.1/dist/driver.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.1/cropper.min.css"
          integrity="sha512-0x6JxdTnmQSFJb7g8+YovV0OXFWVQlpnYbJwY9FpZ0P4B+GacePAfjxqRgJ0hnW50Omh2kHh2k9nN1F4b0q1Sw=="
          crossorigin="anonymous" referrerpolicy="no-referrer">
    <style>
      @keyframes heartPop { 0%{transform:scale(1)} 30%{transform:scale(1.35)} 60%{transform:scale(0.95)} 100%{transform:scale(1)} }
      @keyframes shimmer { 0%{background-position:-200% 0} 100%{background-position:200% 0} }
      @keyframes floatHeart { 0%{opacity:1;transform:translateY(0) scale(1)} 100%{opacity:0;transform:translateY(-60px) scale(1.4)} }
      @keyframes explorarHero { from { opacity: 0; transform: translateY(-8px); } to { opacity: 1; transform: translateY(0); } }
      .animate-heartPop { animation: heartPop 0.4s ease-out; }
      .float-heart { position:absolute; pointer-events:none; animation:floatHeart 0.7s ease-out forwards; color:#ef4444; }
      .skeleton { background:linear-gradient(90deg,#f0f0f0 25%,#e0e0e0 50%,#f0f0f0 75%); background-size:200% 100%; animation:shimmer 1.5s infinite; border-radius:8px; }
      .menu-dropdown { transform-origin:top right; animation:scaleIn .15s ease-out; }
      .mention { color:#328dff; font-weight:500; cursor:pointer; }
      .mention:hover { text-decoration:underline; }
      .autocomplete-dropdown { position:absolute; bottom:100%; left:0; right:0; max-height:160px; overflow-y:auto; background:#fff; border:1px solid #e5e7eb; border-radius:12px; box-shadow:0 -4px 12px rgba(0,0,0,.08); z-index:10; margin-bottom:4px; }
      .autocomplete-item { display:flex; align-items:center; gap:8px; padding:8px 12px; cursor:pointer; font-size:13px; transition:background .15s; }
      .autocomplete-item:hover { background:#f9fafb; }
      .post-enter { animation: slideUp .4s ease-out both; }
      .driver-popover { border-radius:16px !important; }
      .driver-popover-title { font-weight:700 !important; color:#111827 !important; }
      .driver-popover-description { color:#6b7280 !important; }
      .driver-popover-next-btn { background:linear-gradient(135deg,#ec5a1c,#dd4212) !important; border:none !important; border-radius:10px !important; font-weight:600 !important; }
      .driver-popover-prev-btn { border-radius:10px !important; font-weight:600 !important; }
      /* Explorar layout */
      .explorar-hero { background: linear-gradient(180deg, rgba(236,90,28,.06) 0%, transparent 100%); }
      .explorar-search-bar { transition: box-shadow .2s, border-color .2s; }
      .explorar-search-bar:focus-within { box-shadow: 0 0 0 3px rgba(236,90,28,.12); border-color: rgba(236,90,28,.4); }
      .masonry-feed { column-gap: 1rem; columns: 2; }
      @media (min-width: 768px) { .masonry-feed { columns: 3; } }
      @media (min-width: 1536px) { .masonry-feed { columns: 4; } }
      .masonry-card {
        break-inside: avoid;
        -webkit-column-break-inside: avoid;
        page-break-inside: avoid;
        display: inline-block;
        width: 100%;
        margin-bottom: 1rem;
        transition: transform .2s ease, box-shadow .2s ease;
      }
      .masonry-card:hover { transform: translateY(-2px); box-shadow: 0 12px 24px -8px rgba(0,0,0,.08); }
      .explorar-card { border-radius: 1.25rem; box-shadow: 0 1px 3px rgba(0,0,0,.04); border: 1px solid rgba(0,0,0,.04); }
      .explorar-sidebar-card { border-radius: 1.25rem; box-shadow: 0 2px 8px rgba(0,0,0,.04); border: 1px solid rgba(0,0,0,.04); }
      .explorar-sidebar-card .divide-y > * + * { border-top: 1px solid rgba(0,0,0,.04); }
      .btn-seguir-explorar { transition: transform .15s, box-shadow .15s; }
      .btn-seguir-explorar:hover { transform: scale(1.02); }
      .btn-seguir-explorar:active { transform: scale(0.98); }
    </style>
  `;
%>
<%- include('partials/header') %>
<%- include('partials/flash') %>

<% var isLogado = typeof usuario !== 'undefined' && usuario; %>

<main class="flex-1 pb-24 md:pb-6">

  <!-- ═══ Header Explorar ═══ -->
  <div class="sticky top-14 z-40 bg-white/95 backdrop-blur-xl border-b border-gray-100/80 explorar-hero">
    <div class="max-w-7xl mx-auto px-4 py-4 md:py-5">
      <div class="flex flex-col gap-4">
        <div class="flex items-baseline justify-between gap-3">
          <div>
            <h1 class="text-2xl md:text-[1.75rem] font-black text-gray-900 tracking-tight">
              <span class="inline-flex items-center justify-center w-9 h-9 rounded-xl bg-gradient-to-br from-primary-500 to-primary-600 text-white text-lg mr-2.5 align-middle shadow-md shadow-primary-500/20"><i class="fa-solid fa-compass"></i></span>
              Explorar
            </h1>
            <p class="text-sm text-gray-500 mt-1">Descubra pets e tutores perto de você</p>
          </div>
        </div>
        <!-- Barra de busca única (mobile + desktop) -->
        <a href="/explorar/busca" class="explorar-search-bar flex items-center gap-3 w-full bg-white border border-gray-200 rounded-2xl pl-4 pr-4 py-3.5 text-left shadow-sm hover:border-primary-200 hover:shadow-md transition-all duration-200 group">
          <span class="flex items-center justify-center w-10 h-10 rounded-xl bg-gray-100 text-gray-400 group-hover:bg-primary-50 group-hover:text-primary-500 transition-colors">
            <i class="fa-solid fa-magnifying-glass"></i>
          </span>
          <span class="flex-1 text-sm text-gray-500 group-hover:text-gray-600">Buscar pets ou pessoas...</span>
          <i class="fa-solid fa-chevron-right text-gray-300 text-xs group-hover:text-primary-400 transition-colors"></i>
        </a>
      </div>
    </div>
  </div>

  <div class="max-w-7xl mx-auto flex gap-6 px-4 pt-5 pb-2">

  <!-- ═══ Feed (coluna principal) ═══ -->
  <div class="flex-1 min-w-0">
  <div id="feedContainer" class="masonry-feed">


    <% if (posts && posts.length > 0) { %>
      <% posts.forEach(function(post, idx) { %>
        <% if (post.is_sponsored) { %>
          <% var sponsoredPostId = Number(post.id); %>
          <% var hasSponsoredPostId = Number.isFinite(sponsoredPostId) && sponsoredPostId > 0; %>
          <article class="masonry-card explorar-card bg-gradient-to-b from-amber-50/80 to-white overflow-hidden post-enter border-amber-200/60"
                   style="animation-delay:<%= Math.min(idx * 60, 400) %>ms"
                   data-post-id="<%= hasSponsoredPostId ? sponsoredPostId : '' %>"
                   data-view-source="<%= hasSponsoredPostId ? 'sponsored_explorar' : '' %>"
                   data-author-id="<%= post.usuario_id || '' %>"
                   id="<%= post.sponsored_key || ('sponsored-' + post.boost_id + '-' + post.pet_id) %>">
            <div class="px-3 py-2 flex items-center justify-between text-[10px] font-bold text-amber-800 uppercase tracking-wide">
              <span><i class="fa-solid fa-bullhorn mr-1"></i><%= post.sponsored_label || 'Patrocinado' %></span>
              <a href="/explorar/pet/<%= post.pet_id %>" class="normal-case font-semibold text-amber-700 hover:underline">Ver pet</a>
            </div>

            <% if (post.foto) { %>
              <img src="<%= post.foto %>" alt="" class="w-full object-cover post-photo" loading="lazy">
            <% } %>

            <div class="px-3 py-2">
              <div class="flex items-center gap-2">
                <% if (post.pet_foto) { %>
                  <img src="<%= post.pet_foto %>" alt="" class="w-7 h-7 rounded-full object-cover ring-2 ring-amber-200">
                <% } else { %>
                  <span class="w-7 h-7 rounded-full bg-amber-100 text-amber-700 flex items-center justify-center text-[11px]">
                    <i class="fa-solid fa-paw"></i>
                  </span>
                <% } %>
                <div class="min-w-0">
                  <p class="text-xs font-semibold text-gray-900 truncate"><%= post.pet_nome || ('Pet ' + post.pet_id) %></p>
                  <p class="text-[11px] text-gray-500 truncate"><%= post.autor_nome || ('Usuário ' + post.usuario_id) %></p>
                </div>
              </div>
              <% var sponsoredTexto = post.texto || post.legenda || ''; %>
              <% if (sponsoredTexto) { %>
                <p class="mt-2 text-xs text-gray-700 leading-relaxed line-clamp-2 post-text"><%= sponsoredTexto %></p>
              <% } %>
              <% if (hasSponsoredPostId) { %>
                <div class="mt-2 flex items-center gap-2 border-t border-amber-100 pt-2">
                  <button type="button" class="flex-1 flex items-center justify-center gap-1.5 py-1.5 rounded-lg transition-all text-xs btn-curtir relative <%= post.curtiu ? 'text-red-500' : 'text-gray-500 hover:text-red-500 hover:bg-red-50/70' %>"
                          data-post-id="<%= sponsoredPostId %>" data-curtiu="<%= post.curtiu ? '1' : '0' %>">
                    <i class="<%= post.curtiu ? 'fa-solid' : 'fa-regular' %> fa-heart"></i>
                    <span class="count-curtidas"><%= post.total_curtidas || '' %></span>
                  </button>
                  <button type="button" class="flex-1 flex items-center justify-center gap-1.5 py-1.5 rounded-lg text-xs text-gray-500 hover:text-accent-500 hover:bg-accent-50/70 transition-all btn-comentar"
                          data-post-id="<%= sponsoredPostId %>">
                    <i class="fa-regular fa-comment"></i>
                    <span class="count-comentarios"><%= post.total_comentarios || '' %></span>
                  </button>
                </div>
              <% } %>
            </div>
          </article>
        <% } else { %>
          <article class="masonry-card explorar-card bg-white overflow-hidden post-enter"
                   style="animation-delay:<%= Math.min(idx * 60, 400) %>ms"
                   data-post-id="<%= post.id %>" data-author-id="<%= post.usuario_id %>" id="post-<%= post.id %>">
            <% var postCor = post.cor_perfil || '#ec5a1c'; %>

            <div class="px-3 pt-2.5 pb-2">
              <div class="flex items-start gap-2">
                <a href="/explorar/perfil/<%= post.usuario_id %>" class="shrink-0 rounded-full transition-all" title="Ver perfil de <%= post.autor_nome %>">
                  <% if (post.foto_perfil) { %>
                    <img src="<%= post.foto_perfil %>" alt="" class="w-8 h-8 rounded-full object-cover post-author-avatar" style="box-shadow: 0 0 0 2px <%= postCor %>">
                  <% } else { %>
                    <span class="w-8 h-8 rounded-full flex items-center justify-center text-xs font-bold text-white post-author-avatar bg-gray-400"
                          style="box-shadow: 0 0 0 2px <%= postCor %>">
                      <%= post.autor_nome ? post.autor_nome.charAt(0).toUpperCase() : 'U' %>
                    </span>
                  <% } %>
                </a>

                <div class="flex-1 min-w-0">
                  <div class="flex items-center gap-1">
                    <a href="/explorar/perfil/<%= post.usuario_id %>" class="font-semibold text-xs text-gray-900 truncate post-author-name"><%= post.autor_nome %></a>
                    <% if (post.fixada) { %>
                      <i class="fa-solid fa-thumbtack text-[10px] text-gray-400"></i>
                    <% } %>
                    <% if (post.tipo === 'repost') { %>
                      <i class="fa-solid fa-retweet text-[10px] text-emerald-500"></i>
                    <% } %>
                  </div>
                  <span class="text-[11px] text-gray-400 tempo-relativo" data-time="<%= post.criado_em %>"></span>
                </div>

                <% if (isLogado && usuario.id === post.usuario_id) { %>
                  <div class="relative shrink-0">
                    <button type="button" class="p-1 text-gray-400 hover:text-gray-600 hover:bg-gray-100 rounded-full transition-colors btn-menu-post">
                      <i class="fa-solid fa-ellipsis text-xs"></i>
                    </button>
                    <div class="menu-dropdown hidden absolute right-0 top-full mt-1 w-40 bg-white rounded-xl shadow-lg ring-1 ring-black/5 py-1 z-30">
                      <button type="button" class="w-full px-3 py-2 text-left text-xs hover:bg-gray-50 flex items-center gap-2 transition-colors btn-fixar"
                              data-post-id="<%= post.id %>" data-fixada="<%= post.fixada ? '1' : '0' %>">
                        <i class="fa-solid fa-thumbtack text-gray-400 w-3 text-center"></i>
                        <span><%= post.fixada ? 'Desafixar' : 'Fixar' %></span>
                      </button>
                      <button type="button" class="w-full px-3 py-2 text-left text-xs hover:bg-red-50 text-red-500 flex items-center gap-2 transition-colors btn-deletar"
                              data-post-id="<%= post.id %>">
                        <i class="fa-solid fa-trash-can w-3 text-center"></i>
                        <span>Excluir</span>
                      </button>
                    </div>
                  </div>
                <% } %>
              </div>
            </div>

            <% if (post.foto) { %>
              <img src="<%= post.foto %>" alt="" class="w-full object-cover post-photo" loading="lazy">
            <% } %>

            <% var postTexto = post.texto || post.legenda || ''; %>
            <% if (postTexto) { %>
              <div class="px-3 pt-2">
                <p class="text-xs text-gray-700 leading-relaxed line-clamp-3 post-text"><%= postTexto %></p>
                <button type="button" class="text-accent-500 text-[11px] font-semibold mt-1 btn-ver-mais hidden hover:underline">ver mais</button>
              </div>
            <% } %>

            <div class="px-2.5 py-2 mt-1 border-t border-gray-100">
              <div class="flex items-center gap-1.5">
                <button type="button" class="flex-1 flex items-center justify-center gap-1 py-1.5 rounded-lg transition-all text-xs btn-curtir relative <%= post.curtiu ? 'text-red-500' : 'text-gray-500 hover:text-red-500 hover:bg-red-50/70' %>"
                        data-post-id="<%= post.id %>" data-curtiu="<%= post.curtiu ? '1' : '0' %>">
                  <i class="<%= post.curtiu ? 'fa-solid' : 'fa-regular' %> fa-heart"></i>
                  <span class="count-curtidas"><%= post.total_curtidas || '' %></span>
                </button>
                <button type="button" class="flex-1 flex items-center justify-center gap-1 py-1.5 rounded-lg text-xs text-gray-500 hover:text-accent-500 hover:bg-accent-50/70 transition-all btn-comentar"
                        data-post-id="<%= post.id %>">
                  <i class="fa-regular fa-comment"></i>
                  <span class="count-comentarios"><%= post.total_comentarios || '' %></span>
                </button>
              </div>
            </div>
          </article>
        <% } %>
      <% }); %>
    <% } else { %>
      <div class="masonry-card explorar-card text-center py-16 px-6 animate-fadeIn bg-white">
        <div class="w-24 h-24 mx-auto mb-6 rounded-2xl bg-gradient-to-br from-primary-50 to-orange-50 flex items-center justify-center shadow-inner">
          <i class="fa-solid fa-compass text-4xl text-primary-400"></i>
        </div>
        <h3 class="text-xl font-bold text-gray-800 mb-2">Nenhuma publicação por perto</h3>
        <p class="text-sm text-gray-500 max-w-sm mx-auto leading-relaxed mb-6">
          Ainda não há publicações na sua região. Seja o primeiro a compartilhar uma foto do seu pet!
        </p>
        <% if (isLogado) { %>
          <button type="button" onclick="document.getElementById('fabNewPost') && document.getElementById('fabNewPost').click();" class="inline-flex items-center gap-2 px-6 py-3 rounded-2xl text-sm font-bold text-white bg-gradient-to-r from-primary-500 to-primary-600 shadow-lg shadow-primary-500/25 hover:shadow-xl hover:-translate-y-0.5 transition-all duration-200">
            <i class="fa-solid fa-plus"></i> Criar primeira publicação
          </button>
        <% } else { %>
          <a href="/auth/login" class="inline-flex items-center gap-2 px-6 py-3 rounded-2xl text-sm font-bold text-white bg-gradient-to-r from-primary-500 to-primary-600 shadow-lg shadow-primary-500/25 hover:shadow-xl hover:-translate-y-0.5 transition-all duration-200">
            Entrar para publicar
          </a>
        <% } %>
      </div>
    <% } %>
  </div><!-- /feedContainer -->
  <div>
    <!-- ═══ Scroll Sentinel ═══ -->
    <% if (temMais) { %>
      <div id="scrollSentinel" class="py-10 flex justify-center">
        <div class="flex items-center gap-2.5 text-gray-400 text-sm px-4 py-2.5 rounded-2xl bg-gray-50">
          <i class="fa-solid fa-spinner fa-spin text-primary-500"></i>
          <span>Carregando mais…</span>
        </div>
      </div>
    <% } %>
  </div>
  </div>

  <!-- ═══ Sidebar (desktop only) ═══ -->
  <aside class="hidden lg:block w-80 flex-shrink-0 space-y-5 sticky top-24 self-start">

    <!-- Busca (desktop: link para página de busca) -->
    <div class="explorar-sidebar-card bg-white overflow-hidden p-0">
      <a href="/explorar/busca" class="explorar-search-bar flex items-center gap-3 w-full px-4 py-3.5 text-left border-0 rounded-2xl group hover:bg-gray-50/80 transition-colors">
        <span class="flex items-center justify-center w-9 h-9 rounded-xl bg-gray-100 text-gray-400 group-hover:bg-primary-50 group-hover:text-primary-500 transition-colors">
          <i class="fa-solid fa-magnifying-glass text-sm"></i>
        </span>
        <span class="flex-1 text-sm text-gray-500 group-hover:text-gray-700">Buscar pets ou pessoas</span>
        <i class="fa-solid fa-chevron-right text-gray-300 text-xs group-hover:text-primary-400"></i>
      </a>
    </div>

    <% if (typeof recomendacoes !== 'undefined' && recomendacoes.length > 0) { %>
    <div class="explorar-sidebar-card bg-white overflow-hidden">
      <div class="px-4 pt-4 pb-3">
        <h3 class="font-bold text-gray-900 text-[15px] flex items-center gap-2">
          <span class="w-8 h-8 rounded-xl bg-primary-100 text-primary-500 flex items-center justify-center text-sm"><i class="fa-solid fa-user-plus"></i></span>
          Quem seguir
        </h3>
        <p class="text-xs text-gray-500 mt-1">Pessoas perto de você</p>
      </div>
      <div class="divide-y divide-gray-100">
        <% recomendacoes.forEach(function(rec) { %>
          <div class="flex items-center gap-3 px-4 py-3 hover:bg-gray-50/70 transition-colors">
            <a href="/explorar/perfil/<%= rec.id %>" class="shrink-0">
              <% var recCor = rec.cor_perfil || '#ec5a1c'; %>
              <% if (rec.foto_perfil) { %>
                <img src="<%= rec.foto_perfil %>" alt="" class="w-10 h-10 rounded-full object-cover ring-2 ring-white shadow-sm" style="border: 2px solid <%= recCor %>">
              <% } else { %>
                <span class="w-10 h-10 rounded-full flex items-center justify-center text-sm font-bold text-white bg-gray-400 shadow-sm"
                      style="box-shadow: 0 0 0 2px <%= recCor %>">
                  <%= rec.nome ? rec.nome.charAt(0).toUpperCase() : 'U' %>
                </span>
              <% } %>
            </a>
            <div class="flex-1 min-w-0">
              <a href="/explorar/perfil/<%= rec.id %>" class="font-semibold text-sm text-gray-900 hover:text-primary-600 hover:underline truncate block"><%= rec.nome %></a>
              <% if (rec.bairro || rec.cidade) { %>
                <p class="text-xs text-gray-400 truncate mt-0.5"><i class="fa-solid fa-location-dot mr-0.5 text-gray-300"></i><%= rec.bairro ? rec.bairro + ', ' : '' %><%= rec.cidade || '' %>
                  <% if (rec.distancia_km) { %> · <%= rec.distancia_km %>km<% } %>
                </p>
              <% } %>
            </div>
            <button class="btn-seguir-sidebar btn-seguir-explorar shrink-0 px-3.5 py-2 text-xs font-bold rounded-xl bg-gray-900 text-white hover:bg-gray-700 shadow-sm"
                    data-user-id="<%= rec.id %>">
              Seguir
            </button>
          </div>
        <% }) %>
      </div>
      <a href="/explorar/busca" class="block text-center text-sm text-primary-500 font-semibold py-3.5 hover:bg-primary-50/50 transition-colors border-t border-gray-100">
        Ver mais
      </a>
    </div>
    <% } %>

    <% if (typeof petsRecomendados !== 'undefined' && petsRecomendados.length > 0) { %>
    <div class="explorar-sidebar-card bg-white overflow-hidden">
      <div class="px-4 pt-4 pb-3">
        <h3 class="font-bold text-gray-900 text-[15px] flex items-center gap-2">
          <span class="w-8 h-8 rounded-xl bg-amber-100 text-amber-600 flex items-center justify-center text-sm"><i class="fa-solid fa-paw"></i></span>
          Pets populares
        </h3>
      </div>
      <div class="divide-y divide-gray-100">
        <% petsRecomendados.slice(0, 5).forEach(function(pet) { %>
          <div class="flex items-center gap-3 px-4 py-3 hover:bg-gray-50/70 transition-colors">
            <a href="/pets/<%= pet.id %>" class="shrink-0">
              <% if (pet.foto) { %>
                <img src="<%= pet.foto %>" alt="<%= pet.nome %>" class="w-10 h-10 rounded-full object-cover ring-2 ring-primary-100 shadow-sm">
              <% } else { %>
                <div class="w-10 h-10 rounded-full bg-primary-50 flex items-center justify-center shadow-sm">
                  <i class="fa-solid fa-paw text-primary-400 text-sm"></i>
                </div>
              <% } %>
            </a>
            <div class="flex-1 min-w-0">
              <a href="/pets/<%= pet.id %>" class="font-semibold text-sm text-gray-900 hover:text-primary-600 hover:underline truncate block"><%= pet.nome %></a>
              <p class="text-xs text-gray-400 truncate mt-0.5"><%= pet.raca || pet.tipo || '' %> · <%= pet.total_seguidores %> seguidor<%= pet.total_seguidores !== 1 ? 'es' : '' %></p>
            </div>
            <button class="btn-seguir-pet-sidebar btn-seguir-explorar shrink-0 px-3.5 py-2 text-xs font-bold rounded-xl border-2 border-primary-500 text-primary-500 hover:bg-primary-500 hover:text-white transition-all shadow-sm"
                    data-pet-id="<%= pet.id %>">
              Seguir
            </button>
          </div>
        <% }) %>
      </div>
      <a href="/explorar/busca" class="block text-center text-sm text-primary-500 font-semibold py-3.5 hover:bg-primary-50/50 transition-colors border-t border-gray-100">
        Buscar pets
      </a>
    </div>
    <% } %>

  </aside>

  </div><!-- /flex wrapper -->

</main>


<!-- ══════════════════════════════════════════════ -->
<!-- ═══ NEW POST MODAL ═══════════════════════════ -->
<!-- ══════════════════════════════════════════════ -->
<div id="newPostModal" class="fixed inset-0 z-[60] hidden">
  <div class="absolute inset-0 bg-black/50 backdrop-blur-sm" id="newPostOverlay"></div>
  <div class="absolute bottom-0 left-0 right-0 bg-white rounded-t-3xl max-h-[85vh] flex flex-col animate-slideUp safe-bottom shadow-2xl
              md:relative md:top-1/2 md:-translate-y-1/2 md:max-w-lg md:mx-auto md:rounded-2xl md:max-h-[80vh] md:border md:border-gray-100">

    <div class="flex items-center justify-between px-5 py-4 border-b border-gray-100 bg-gray-50/50">
      <h3 class="font-bold text-gray-900 text-lg">Nova publicação</h3>
      <div class="flex items-center gap-3">
        <span id="postCounter" class="text-xs font-semibold px-2.5 py-1 rounded-full <%= totalPosts >= 10 ? 'bg-red-50 text-red-500' : 'bg-gray-100 text-gray-500' %>">
          <%= totalPosts %>/10
        </span>
        <button type="button" id="closeNewPost" class="p-1 text-gray-400 hover:text-gray-600 transition-colors">
          <i class="fa-solid fa-xmark text-lg"></i>
        </button>
      </div>
    </div>

    <div class="flex-1 overflow-y-auto px-5 py-4 space-y-4 scrollbar-hide">
      <% if (totalPosts >= 10) { %>
        <div class="flex items-center gap-2 px-4 py-3 rounded-xl bg-amber-50 text-amber-700 text-xs font-medium">
          <i class="fa-solid fa-info-circle"></i>
          Ao publicar, o post mais antigo (não fixado) pode ser removido automaticamente.
        </div>
      <% } %>

      <div id="uploadArea"
           class="border-2 border-dashed border-gray-200 rounded-2xl p-8 text-center cursor-pointer hover:border-primary-300 hover:bg-primary-50/30 transition-all duration-200">
        <div id="uploadPlaceholder">
          <div class="w-14 h-14 mx-auto mb-3 rounded-full bg-primary-50 flex items-center justify-center">
            <i class="fa-solid fa-camera text-xl text-primary-400"></i>
          </div>
          <p class="text-sm font-medium text-gray-600">Toque para adicionar foto</p>
          <p class="text-xs text-gray-400 mt-1">ou arraste uma imagem aqui</p>
        </div>
        <div id="uploadPreview" class="hidden relative min-h-[180px] flex items-center justify-center">
          <img id="previewImg" src="" alt="Preview" class="max-h-60 w-full max-w-full mx-auto rounded-xl object-contain">
          <button type="button" id="removePhoto"
                  class="absolute top-2 right-2 w-8 h-8 bg-black/50 backdrop-blur-sm rounded-full flex items-center justify-center text-white hover:bg-black/70 transition-colors">
            <i class="fa-solid fa-xmark text-sm"></i>
          </button>
        </div>
      </div>
      <input type="file" id="photoInput" accept="image/jpeg,image/png,image/gif,image/webp" class="hidden">

      <div>
        <label for="novoPostTexto" class="block text-xs font-medium text-gray-500 mb-1.5">Legenda</label>
        <textarea id="novoPostTexto" rows="3" maxlength="500"
                  placeholder="Conte algo sobre essa foto…"
                  class="w-full resize-none border border-gray-200 rounded-xl px-4 py-3 text-sm text-gray-800 placeholder-gray-400 focus:ring-2 focus:ring-primary-500/20 focus:border-primary-400 outline-none transition-all"></textarea>
        <div class="text-right mt-1">
          <span id="charCount" class="text-[11px] text-gray-300">0/500</span>
        </div>
      </div>

      <% if (pets && pets.length > 0) { %>
        <div>
          <label class="text-xs font-medium text-gray-500 mb-1.5 block">Em qual perfil (pet) postar? (opcional)</label>
          <select id="novoPostPet" class="w-full border border-gray-200 rounded-xl px-3 py-2.5 text-sm text-gray-800 focus:ring-2 focus:ring-primary-500/20 focus:border-primary-400 outline-none bg-white transition-all">
            <option value="">Meu perfil (sem pet)</option>
            <% pets.forEach(function(p) { %>
              <option value="<%= p.id %>"><%= p.nome %></option>
            <% }); %>
          </select>
        </div>
      <% } else { %>
        <input type="hidden" id="novoPostPet" value="">
        <p class="text-xs text-gray-500">A publicação será no seu perfil. <a href="/pets/cadastro" class="text-primary-500 hover:underline">Cadastre um pet</a> para postar em nome dele.</p>
      <% } %>
    </div>

    <div class="px-5 py-4 border-t border-gray-100">
      <button type="button" id="btnPublicar" disabled
              class="w-full py-3 rounded-xl text-sm font-semibold text-white bg-gradient-to-r from-primary-500 to-primary-600 shadow-lg shadow-primary-500/20 hover:shadow-xl hover:shadow-primary-500/30 hover:-translate-y-0.5 transition-all duration-300 disabled:opacity-40 disabled:shadow-none disabled:translate-y-0 disabled:cursor-not-allowed">
        Publicar
      </button>
    </div>
  </div>
</div>

<%- include('partials/modal-crop') %>

<!-- ══════════════════════════════════════════════ -->
<!-- ═══ REPOST MODAL ═════════════════════════════ -->
<!-- ══════════════════════════════════════════════ -->
<div id="repostModal" class="fixed inset-0 z-[60] hidden">
  <div class="absolute inset-0 bg-black/40 backdrop-blur-sm" id="repostOverlay"></div>
  <div class="absolute bottom-0 left-0 right-0 bg-white rounded-t-3xl max-h-[75vh] flex flex-col animate-slideUp safe-bottom
              md:relative md:top-1/2 md:-translate-y-1/2 md:max-w-lg md:mx-auto md:rounded-2xl md:max-h-[70vh]">

    <div class="flex items-center justify-between px-5 py-4 border-b border-gray-100">
      <h3 class="font-bold text-gray-900">Repostar</h3>
      <button type="button" id="closeRepost" class="p-1 text-gray-400 hover:text-gray-600 transition-colors">
        <i class="fa-solid fa-xmark text-lg"></i>
      </button>
    </div>

    <div class="flex-1 overflow-y-auto px-5 py-4 space-y-4 scrollbar-hide">
      <div id="repostPreviewContent" class="border border-gray-200 rounded-2xl p-3 bg-gray-50/50"></div>

      <textarea id="repostTexto" rows="3" maxlength="500"
                placeholder="Adicione um comentário…"
                class="w-full resize-none border border-gray-200 rounded-xl px-4 py-3 text-sm text-gray-800 placeholder-gray-400 focus:ring-2 focus:ring-primary-500/20 focus:border-primary-400 outline-none transition-all"></textarea>
    </div>

    <input type="hidden" id="repostPostId" value="">

    <div class="px-5 py-4 border-t border-gray-100">
      <button type="button" id="btnRepostar" disabled
              class="w-full py-3 rounded-xl text-sm font-semibold text-white bg-gradient-to-r from-emerald-500 to-emerald-600 shadow-lg shadow-emerald-500/20 hover:shadow-xl hover:-translate-y-0.5 transition-all duration-300 disabled:opacity-40 disabled:shadow-none disabled:translate-y-0 disabled:cursor-not-allowed">
        <i class="fa-solid fa-retweet mr-1.5"></i> Repostar
      </button>
    </div>
  </div>
</div>


<!-- ══════════════════════════════════════════════ -->
<!-- ═══ COMMENT MODAL ════════════════════════════ -->
<!-- ══════════════════════════════════════════════ -->
<div id="commentModal" class="fixed inset-0 z-[60] hidden">
  <div class="absolute inset-0 bg-black/40 backdrop-blur-sm" id="commentOverlay"></div>
  <div class="absolute bottom-0 left-0 right-0 bg-white rounded-t-3xl max-h-[80vh] flex flex-col animate-slideUp safe-bottom
              md:relative md:top-1/2 md:-translate-y-1/2 md:max-w-lg md:mx-auto md:rounded-2xl md:max-h-[75vh]">

    <div class="flex items-center justify-between px-5 py-4 border-b border-gray-100">
      <h3 class="font-bold text-gray-900">Comentários</h3>
      <button type="button" id="closeComment" class="p-1 text-gray-400 hover:text-gray-600 transition-colors">
        <i class="fa-solid fa-xmark text-lg"></i>
      </button>
    </div>

    <div id="commentList" class="flex-1 overflow-y-auto px-5 py-3 scrollbar-hide min-h-[120px]">
      <div class="space-y-1">
        <div class="skeleton h-10 w-full mb-3"></div>
        <div class="skeleton h-10 w-3/4 mb-3"></div>
        <div class="skeleton h-10 w-5/6"></div>
      </div>
    </div>

    <div id="petsProximosContainer" class="border-t border-gray-100 px-5 py-3 hidden">
      <h4 class="text-xs font-bold uppercase tracking-wider text-gray-400 mb-2 flex items-center gap-1.5">
        <i class="fa-solid fa-location-dot"></i> Pets na região
      </h4>
      <div id="petsProximosList" class="flex gap-3 overflow-x-auto pb-1 scrollbar-hide"></div>
    </div>

    <div class="relative border-t border-gray-100">
      <div id="mentionDropdown" class="autocomplete-dropdown hidden"></div>
      <div class="flex items-center gap-2 px-5 py-3">
        <% if (isLogado) { %>
          <% var modalCor = usuario.cor_perfil || '#ec5a1c'; %>
          <% if (usuario.foto_perfil) { %>
            <img src="<%= usuario.foto_perfil %>" alt="" class="w-8 h-8 rounded-full object-cover shrink-0" style="box-shadow: 0 0 0 2px <%= modalCor %>">
          <% } else { %>
            <span class="w-8 h-8 rounded-full flex items-center justify-center text-xs font-bold text-white shrink-0 bg-gray-400"
                  style="box-shadow: 0 0 0 2px <%= modalCor %>">
              <%= usuario.nome ? usuario.nome.charAt(0).toUpperCase() : 'U' %>
            </span>
          <% } %>
        <% } %>
        <input type="text" id="commentInput" placeholder="Adicionar comentário…" maxlength="500"
               class="flex-1 text-sm bg-gray-50 rounded-full px-4 py-2.5 outline-none focus:bg-gray-100 focus:ring-2 focus:ring-primary-500/10 transition-all"
               data-post-id="">
        <button type="button" id="btnEnviarComentario"
                class="w-9 h-9 rounded-full bg-gradient-to-r from-primary-500 to-primary-600 flex items-center justify-center text-white shrink-0 hover:shadow-lg hover:shadow-primary-500/25 transition-all disabled:opacity-40"
                disabled>
          <i class="fa-solid fa-paper-plane text-xs"></i>
        </button>
      </div>
    </div>
  </div>
</div>


<!-- ══════════════════════════════════════════════ -->
<!-- ═══ SCRIPTS ══════════════════════════════════ -->
<!-- ══════════════════════════════════════════════ -->
<script src="https://cdn.jsdelivr.net/npm/driver.js@1.3.1/dist/driver.js.iife.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.1/cropper.min.js"
        integrity="sha512-9KkIqdfN7ipE6L4oF4lF0W5f+Yk3nN7+E2n1Q0Y1kHjAPiVnJjOVT1fE2YTYL4e1kCwTxmU1nPqkRIKO1pV4Eg=="
        crossorigin="anonymous" referrerpolicy="no-referrer"></script>
<script src="/js/crop-modal.js"></script>
<script>
(function () {
  'use strict';

  /* ──────────── Config & State ──────────── */
  var currentPage = <%= page %>;
  var hasMore = <%= temMais ? 'true' : 'false' %>;
  var totalPostsLocal = <%= totalPosts %>;
  var totalFixadasLocal = <%= totalFixadas %>;
  var meuId = <%= isLogado ? usuario.id : 0 %>;
  var meuNome = '<%= isLogado ? usuario.nome.replace(/'/g, "\\'") : "" %>';
  var meuCorPerfil = '<%= isLogado ? (usuario.cor_perfil || "#ec5a1c") : "#ec5a1c" %>';
  var meuFotoPerfil = '<%= isLogado ? (usuario.foto_perfil || "") : "" %>';
  var isLoading = false;
  var selectedFile = null;
  var commentPostId = null;
  var searchTimeout = null;

  var feedContainer = document.getElementById('feedContainer');
  var scrollSentinel = document.getElementById('scrollSentinel');
  var viewObserver = null;
  var viewedPosts = new Set();

  function registrarVisualizacao(postId, watchMs, source) {
    fetch('/explorar/api/interactions/view', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
      credentials: 'same-origin',
      body: JSON.stringify({ postId: postId, watchMs: watchMs || 1500, source: source || 'explorar' })
    }).catch(function () {});
  }

  function observarCardVisualizacao(card) {
    if (!card || !viewObserver) return;
    var postId = parseInt(card.getAttribute('data-post-id'), 10);
    if (!postId || viewedPosts.has(postId)) return;
    viewObserver.observe(card);
  }

  /* ──────────── Utilities ──────────── */
  function tempoRelativo(dateStr) {
    if (!dateStr) return '';
    var now = Date.now();
    var then = new Date(dateStr).getTime();
    var diff = Math.floor((now - then) / 1000);
    if (diff < 60) return 'agora';
    if (diff < 3600) return 'há ' + Math.floor(diff / 60) + 'm';
    if (diff < 86400) return 'há ' + Math.floor(diff / 3600) + 'h';
    if (diff < 604800) return 'há ' + Math.floor(diff / 86400) + 'd';
    var d = new Date(dateStr);
    var meses = ['jan','fev','mar','abr','mai','jun','jul','ago','set','out','nov','dez'];
    return d.getDate() + ' ' + meses[d.getMonth()];
  }

  function atualizarTempos() {
    var els = document.querySelectorAll('.tempo-relativo');
    for (var i = 0; i < els.length; i++) {
      var t = els[i].getAttribute('data-time');
      if (t) els[i].textContent = tempoRelativo(t);
    }
  }

  function escapeHtml(str) {
    var div = document.createElement('div');
    div.textContent = str || '';
    return div.innerHTML;
  }

  function renderMencoes(texto) {
    return escapeHtml(texto).replace(/@(\S+)/g, '<span class="mention" data-user="$1">@$1</span>');
  }

  function toast(msg, tipo) {
    var el = document.createElement('div');
    el.className = 'fixed top-20 left-1/2 -translate-x-1/2 z-[70] px-5 py-3 rounded-2xl text-sm font-semibold shadow-xl animate-slideUp ' +
      (tipo === 'erro' ? 'bg-red-500 text-white' : 'bg-white text-gray-800 ring-1 ring-black/5');
    el.textContent = msg;
    document.body.appendChild(el);
    setTimeout(function () { el.classList.add('fade-out'); }, 2500);
    setTimeout(function () { if (el.parentNode) el.parentNode.removeChild(el); }, 3000);
  }

  /* ──────────── Modal Helpers ──────────── */
  function abrirModal(id) {
    var modal = document.getElementById(id);
    if (!modal) return;
    modal.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
  }

  function fecharModal(id) {
    var modal = document.getElementById(id);
    if (!modal) return;
    modal.classList.add('hidden');
    document.body.style.overflow = '';
  }

  document.getElementById('newPostOverlay').addEventListener('click', function () { fecharModal('newPostModal'); });
  document.getElementById('closeNewPost').addEventListener('click', function () { fecharModal('newPostModal'); });
  document.getElementById('repostOverlay').addEventListener('click', function () { fecharModal('repostModal'); });
  document.getElementById('closeRepost').addEventListener('click', function () { fecharModal('repostModal'); });
  document.getElementById('commentOverlay').addEventListener('click', function () { fecharModal('commentModal'); });
  document.getElementById('closeComment').addEventListener('click', function () { fecharModal('commentModal'); });

  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape') {
      fecharModal('newPostModal');
      fecharModal('repostModal');
      fecharModal('commentModal');
    }
  });

  /* ──────────── Like ──────────── */
  function curtirPost(postId, btn) {
    var curtiu = btn.getAttribute('data-curtiu') === '1';
    var method = curtiu ? 'DELETE' : 'POST';
    var icon = btn.querySelector('i');
    var countEl = btn.querySelector('.count-curtidas');

    btn.setAttribute('data-curtiu', curtiu ? '0' : '1');
    if (curtiu) {
      btn.classList.remove('text-red-500');
      btn.classList.add('text-gray-400');
      icon.className = 'fa-regular fa-heart';
    } else {
      btn.classList.remove('text-gray-400');
      btn.classList.add('text-red-500');
      icon.className = 'fa-solid fa-heart animate-heartPop';
      var heart = document.createElement('i');
      heart.className = 'fa-solid fa-heart float-heart';
      heart.style.left = '50%';
      heart.style.bottom = '100%';
      btn.appendChild(heart);
      setTimeout(function () { if (heart.parentNode) heart.parentNode.removeChild(heart); }, 800);
    }

    fetch('/explorar/post/' + postId + '/curtir', {
      method: method,
      headers: { 'Accept': 'application/json' },
      credentials: 'same-origin'
    })
    .then(function (r) { return r.json(); })
    .then(function (data) {
      if (data.sucesso) {
        countEl.textContent = data.total || '';
      }
    })
    .catch(function () {});
  }

  /* ──────────── Comments ──────────── */
  function abrirComentarios(postId) {
    commentPostId = postId;
    var input = document.getElementById('commentInput');
    input.setAttribute('data-post-id', postId);
    input.value = '';
    document.getElementById('btnEnviarComentario').disabled = true;
    abrirModal('commentModal');
    carregarComentarios(postId);
  }

  function carregarComentarios(postId) {
    var list = document.getElementById('commentList');
    list.innerHTML = '<div class="space-y-3"><div class="skeleton h-12 w-full"></div><div class="skeleton h-12 w-3/4"></div><div class="skeleton h-12 w-5/6"></div></div>';

    var petsContainer = document.getElementById('petsProximosContainer');
    var petsList = document.getElementById('petsProximosList');
    petsContainer.classList.add('hidden');
    petsList.innerHTML = '';

    fetch('/explorar/post/' + postId + '/comentarios', {
      headers: { 'Accept': 'application/json' },
      credentials: 'same-origin'
    })
    .then(function (r) { return r.json(); })
    .then(function (data) {
      if (!data.sucesso) return;
      if (!data.comentarios || data.comentarios.length === 0) {
        list.innerHTML = '<div class="text-center py-10"><p class="text-sm text-gray-400">Nenhum comentário ainda.</p><p class="text-xs text-gray-300 mt-1">Seja o primeiro a comentar!</p></div>';
      } else {
        var html = '<div class="space-y-4">';
        data.comentarios.forEach(function (c) { html += renderComentario(c); });
        html += '</div>';
        list.innerHTML = html;
        var tempos = list.querySelectorAll('.tempo-relativo');
        for (var i = 0; i < tempos.length; i++) {
          var t = tempos[i].getAttribute('data-time');
          if (t) tempos[i].textContent = tempoRelativo(t);
        }
      }
      carregarPetsProximos(postId);
    })
    .catch(function () {
      list.innerHTML = '<div class="text-center py-8"><p class="text-sm text-red-400">Erro ao carregar comentários.</p></div>';
      carregarPetsProximos(postId);
    });
  }

  function carregarPetsProximos(postId) {
    var petsContainer = document.getElementById('petsProximosContainer');
    var petsList = document.getElementById('petsProximosList');
    fetch('/explorar/post/' + postId + '/pets-proximos', {
      headers: { 'Accept': 'application/json' },
      credentials: 'same-origin'
    })
    .then(function (r) { return r.json(); })
    .then(function (data) {
      var lista = data.lista || [];
      if (lista.length === 0) {
        petsContainer.classList.add('hidden');
        return;
      }
      petsContainer.classList.remove('hidden');
      var html = '';
      lista.forEach(function (p) {
        var avatar = p.foto
          ? '<img src="' + escapeHtml(p.foto) + '" alt="" class="w-12 h-12 rounded-full object-cover flex-shrink-0">'
          : '<span class="w-12 h-12 rounded-full flex items-center justify-center text-primary-500 bg-primary-50 flex-shrink-0"><i class="fa-solid fa-paw"></i></span>';
        var btnClass = p.seguindo
          ? 'text-xs font-semibold px-2 py-1 rounded-full border border-gray-300 text-gray-500 cursor-default'
          : 'text-xs font-semibold px-2 py-1 rounded-full border border-primary-500 text-primary-500 hover:bg-primary-500 hover:text-white transition-colors btn-seguir-pet-proximo';
        var btnText = p.seguindo ? 'Seguindo' : 'Seguir';
        html += '<div class="flex flex-col items-center gap-1.5 flex-shrink-0 w-20">' +
          '<a href="/explorar/pet/' + p.id + '" class="block">' + avatar + '</a>' +
          '<a href="/explorar/pet/' + p.id + '" class="text-xs font-semibold text-gray-900 truncate w-full text-center block">' + escapeHtml(p.nome) + '</a>' +
          '<span class="text-[10px] text-gray-400 truncate w-full text-center block">' + escapeHtml(p.dono_nome || '') + '</span>' +
          '<button type="button" class="' + btnClass + '" data-pet-id="' + p.id + '" data-seguindo="' + (p.seguindo ? 'true' : 'false') + '">' + btnText + '</button>' +
        '</div>';
      });
      petsList.innerHTML = html;
      petsList.querySelectorAll('.btn-seguir-pet-proximo').forEach(function (btn) {
        btn.addEventListener('click', function (e) {
          e.preventDefault();
          var petId = btn.getAttribute('data-pet-id');
          if (btn.getAttribute('data-seguindo') === 'true') return;
          fetch('/explorar/pet/' + petId + '/seguir', { method: 'POST', headers: { 'Content-Type': 'application/json' }, credentials: 'same-origin' })
            .then(function (r) { return r.json(); })
            .then(function (d) {
              if (d.sucesso) {
                btn.setAttribute('data-seguindo', 'true');
                btn.textContent = 'Seguindo';
                btn.className = 'text-xs font-semibold px-2 py-1 rounded-full border border-gray-300 text-gray-500 cursor-default';
              }
            });
        });
      });
    })
    .catch(function () { petsContainer.classList.add('hidden'); });
  }

  function renderComentario(c) {
    var cCor = c.cor_perfil || '#ec5a1c';
    var avatar;
    if (c.foto_perfil) {
      avatar = '<img src="' + escapeHtml(c.foto_perfil) + '" class="w-8 h-8 rounded-full object-cover shrink-0" style="box-shadow:0 0 0 2px ' + escapeHtml(cCor) + '">';
    } else {
      avatar = '<span class="w-8 h-8 rounded-full flex items-center justify-center text-xs font-bold text-white shrink-0 bg-gray-400" style="box-shadow:0 0 0 2px ' + escapeHtml(cCor) + '">' + escapeHtml((c.nome || c.autor_nome || 'U').charAt(0).toUpperCase()) + '</span>';
    }
    var podeApagar = (c.usuario_id === meuId);
    return '<div class="flex gap-3 group" data-comment-id="' + c.id + '">' +
      '<a href="/explorar/perfil/' + c.usuario_id + '" class="shrink-0">' + avatar + '</a>' +
      '<div class="flex-1 min-w-0">' +
        '<div class="flex items-baseline gap-2">' +
          '<a href="/explorar/perfil/' + c.usuario_id + '" class="text-sm font-semibold text-gray-900 hover:underline">' + escapeHtml(c.nome || c.autor_nome) + '</a>' +
          '<span class="text-[11px] text-gray-400 tempo-relativo" data-time="' + c.criado_em + '"></span>' +
        '</div>' +
        '<p class="text-sm text-gray-700 mt-0.5 leading-relaxed">' + renderMencoes(c.texto) + '</p>' +
      '</div>' +
      (podeApagar ? '<button type="button" class="shrink-0 p-1 text-gray-300 hover:text-red-400 opacity-0 group-hover:opacity-100 transition-all btn-del-comment" data-comment-id="' + c.id + '"><i class="fa-solid fa-trash-can text-xs"></i></button>' : '') +
    '</div>';
  }

  function enviarComentario(postId, texto, inputEl) {
    if (!texto) return;
    fetch('/explorar/post/' + postId + '/comentar', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
      credentials: 'same-origin',
      body: JSON.stringify({ texto: texto })
    })
    .then(function (r) { return r.json(); })
    .then(function (data) {
      if (!data.sucesso) { toast(data.mensagem || 'Erro ao comentar.', 'erro'); return; }
      if (inputEl) inputEl.value = '';
      var card = document.querySelector('article[data-post-id="' + postId + '"]');
      if (card) {
        var counts = card.querySelectorAll('.count-comentarios');
        for (var i = 0; i < counts.length; i++) counts[i].textContent = data.total || '';
      }
      if (commentPostId === postId) carregarComentarios(postId);
    })
    .catch(function () { toast('Erro de conexão.', 'erro'); });
  }

  /* ──────────── Delete comment ──────────── */
  document.getElementById('commentList').addEventListener('click', function (e) {
    var btn = e.target.closest('.btn-del-comment');
    if (!btn) return;
    var cid = btn.getAttribute('data-comment-id');
    if (!confirm('Excluir comentário?')) return;
    fetch('/explorar/comentario/' + cid, {
      method: 'DELETE',
      headers: { 'Accept': 'application/json' },
      credentials: 'same-origin'
    })
    .then(function (r) { return r.json(); })
    .then(function (data) {
      if (data.sucesso && commentPostId) carregarComentarios(commentPostId);
    })
    .catch(function () {});
  });

  /* ──────────── Comment input in modal ──────────── */
  var commentInput = document.getElementById('commentInput');
  var btnEnviarComentario = document.getElementById('btnEnviarComentario');

  commentInput.addEventListener('input', function () {
    btnEnviarComentario.disabled = !this.value.trim();
    handleMentionAutocomplete(this);
  });
  commentInput.addEventListener('keydown', function (e) {
    if (e.key === 'Enter') {
      e.preventDefault();
      var txt = this.value.trim();
      if (txt) enviarComentario(this.getAttribute('data-post-id'), txt, this);
      btnEnviarComentario.disabled = true;
    }
  });
  btnEnviarComentario.addEventListener('click', function () {
    var txt = commentInput.value.trim();
    if (txt) enviarComentario(commentInput.getAttribute('data-post-id'), txt, commentInput);
    btnEnviarComentario.disabled = true;
  });

  /* ──────────── Mention Autocomplete ──────────── */
  var mentionDropdown = document.getElementById('mentionDropdown');

  function handleMentionAutocomplete(input) {
    var val = input.value;
    var cursor = input.selectionStart;
    var before = val.substring(0, cursor);
    var match = before.match(/@(\w*)$/);

    if (!match) {
      mentionDropdown.classList.add('hidden');
      return;
    }
    var query = (match[1] || '').trim();
    clearTimeout(searchTimeout);
    searchTimeout = setTimeout(function () {
      var url = '/explorar/api/usuarios?seguindo=1';
      if (query.length) url += '&q=' + encodeURIComponent(query);
      fetch(url, {
        headers: { 'Accept': 'application/json' },
        credentials: 'same-origin'
      })
      .then(function (r) { return r.json(); })
      .then(function (users) {
        if (!users || !users.length) { mentionDropdown.classList.add('hidden'); return; }
        var html = '';
        users.forEach(function (u) {
          var uCor = u.cor_perfil || '#ec5a1c';
          var av = u.foto_perfil
            ? '<img src="' + escapeHtml(u.foto_perfil) + '" class="w-7 h-7 rounded-full object-cover" style="box-shadow:0 0 0 2px ' + escapeHtml(uCor) + '">'
            : '<span class="w-7 h-7 rounded-full flex items-center justify-center text-[10px] font-bold text-white bg-gray-400" style="box-shadow:0 0 0 2px ' + escapeHtml(uCor) + '">' + escapeHtml((u.nome || 'U').charAt(0).toUpperCase()) + '</span>';
          html += '<div class="autocomplete-item" data-nome="' + escapeHtml(u.nome) + '">' + av + '<span class="font-medium text-gray-700">' + escapeHtml(u.nome) + '</span></div>';
        });
        mentionDropdown.innerHTML = html;
        mentionDropdown.classList.remove('hidden');
      })
      .catch(function () { mentionDropdown.classList.add('hidden'); });
    }, query.length ? 250 : 100);
  }

  mentionDropdown.addEventListener('click', function (e) {
    var item = e.target.closest('.autocomplete-item');
    if (!item) return;
    var nome = item.getAttribute('data-nome');
    var val = commentInput.value;
    var cursor = commentInput.selectionStart;
    var before = val.substring(0, cursor);
    var after = val.substring(cursor);
    var replaced = before.replace(/@(\w*)$/, '@' + nome + ' ');
    commentInput.value = replaced + after;
    commentInput.focus();
    commentInput.setSelectionRange(replaced.length, replaced.length);
    mentionDropdown.classList.add('hidden');
  });

  /* ──────────── Repost ──────────── */
  function abrirRepostModal(postId) {
    var card = document.querySelector('article[data-post-id="' + postId + '"]');
    if (!card) return;
    var preview = document.getElementById('repostPreviewContent');
    var avatarEl = card.querySelector('.post-author-avatar');
    var nameEl = card.querySelector('.post-author-name');
    var textEl = card.querySelector('.post-text');
    var photoEl = card.querySelector('.post-photo');

    var html = '<div class="flex items-center gap-2 mb-2">';
    if (avatarEl) {
      var cloned = avatarEl.cloneNode(true);
      cloned.className = cloned.className.replace(/w-10 h-10/g, 'w-7 h-7').replace('ring-2 ring-gray-100', '');
      html += cloned.outerHTML;
    }
    html += '<span class="text-xs font-semibold text-gray-700">' + escapeHtml(nameEl ? nameEl.textContent : '') + '</span></div>';
    if (textEl) html += '<p class="text-xs text-gray-600 line-clamp-3">' + escapeHtml(textEl.textContent) + '</p>';
    if (photoEl) html += '<img src="' + photoEl.src + '" class="mt-2 w-full max-h-[150px] object-cover rounded-xl" loading="lazy">';
    preview.innerHTML = html;

    document.getElementById('repostPostId').value = postId;
    document.getElementById('repostTexto').value = '';
    document.getElementById('btnRepostar').disabled = true;
    abrirModal('repostModal');
  }

  document.getElementById('repostTexto').addEventListener('input', function () {
    document.getElementById('btnRepostar').disabled = !this.value.trim();
  });

  document.getElementById('btnRepostar').addEventListener('click', function () {
    var postId = document.getElementById('repostPostId').value;
    var texto = document.getElementById('repostTexto').value.trim();
    if (!texto || !postId) return;
    this.disabled = true;

    fetch('/explorar/post/' + postId + '/repost', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
      credentials: 'same-origin',
      body: JSON.stringify({ texto: texto })
    })
    .then(function (r) { return r.json(); })
    .then(function (data) {
      if (!data.sucesso) { toast(data.mensagem || 'Erro ao repostar.', 'erro'); return; }
      fecharModal('repostModal');
      toast('Repostado!');
      var card = document.querySelector('article[data-post-id="' + postId + '"]');
      if (card) {
        var rpBtn = card.querySelector('.btn-repost');
        if (rpBtn) { rpBtn.classList.remove('text-gray-400'); rpBtn.classList.add('text-emerald-500'); }
        var cnt = card.querySelector('.count-reposts');
        if (cnt && data.totalReposts) cnt.textContent = data.totalReposts;
      }
      if (data.post) {
        totalPostsLocal = data.totalPosts || totalPostsLocal;
        feedContainer.insertAdjacentHTML('afterbegin', renderPostHTML(data.post));
        initVerMaisForCard(feedContainer.firstElementChild);
        observarCardVisualizacao(feedContainer.firstElementChild);
      }
      if (data.removido) {
        var old = document.getElementById('post-' + data.removido);
        if (old) { old.classList.add('fade-out'); setTimeout(function () { if (old.parentNode) old.parentNode.removeChild(old); }, 400); }
      }
    })
    .catch(function () { toast('Erro de conexão.', 'erro'); });
  });

  /* ──────────── New Post ──────────── */
  var uploadArea = document.getElementById('uploadArea');
  var photoInput = document.getElementById('photoInput');
  var previewImg = document.getElementById('previewImg');
  var uploadPlaceholder = document.getElementById('uploadPlaceholder');
  var uploadPreview = document.getElementById('uploadPreview');
  var novoPostTexto = document.getElementById('novoPostTexto');
  var charCount = document.getElementById('charCount');
  var btnPublicar = document.getElementById('btnPublicar');

  function abrirNovoPost() {
    var petSelect = document.getElementById('novoPostPet');
    selectedFile = null;
    photoInput.value = '';
    novoPostTexto.value = '';
    charCount.textContent = '0/500';
    uploadPlaceholder.classList.remove('hidden');
    uploadPreview.classList.add('hidden');
    if (petSelect && petSelect.options && petSelect.options.length) petSelect.selectedIndex = 0;
    if (btnPublicar) { btnPublicar.disabled = false; btnPublicar.innerHTML = 'Publicar'; }
    validarFormPost();
    abrirModal('newPostModal');
    var counter = document.getElementById('postCounter');
    if (counter) counter.textContent = totalPostsLocal + '/10';
  }

  function validarFormPost() {
    if (!btnPublicar) return;
    var temFoto = !!selectedFile;
    var temTexto = !!(novoPostTexto && novoPostTexto.value.trim());
    btnPublicar.disabled = !(temFoto && temTexto);
  }

  uploadArea.addEventListener('click', function () { photoInput.click(); });
  uploadArea.addEventListener('dragover', function (e) { e.preventDefault(); this.classList.add('border-primary-400', 'bg-primary-50/50'); });
  uploadArea.addEventListener('dragleave', function () { this.classList.remove('border-primary-400', 'bg-primary-50/50'); });
  uploadArea.addEventListener('drop', function (e) {
    e.preventDefault();
    this.classList.remove('border-primary-400', 'bg-primary-50/50');
    if (e.dataTransfer.files && e.dataTransfer.files[0]) handleFile(e.dataTransfer.files[0]);
  });
  photoInput.addEventListener('change', function () { if (this.files && this.files[0]) handleFile(this.files[0]); });

  function handleFile(file) {
    if (!file.type.match(/^image\/(jpeg|png|gif|webp)$/)) { toast('Formato não suportado.', 'erro'); return; }
    if (file.size > 10 * 1024 * 1024) { toast('Imagem muito grande (max 10MB).', 'erro'); return; }
    var reader = new FileReader();
    reader.onload = function (ev) {
      if (typeof openCropModal !== 'function') {
        selectedFile = file;
        uploadPlaceholder.classList.add('hidden');
        uploadPreview.classList.remove('hidden');
        previewImg.src = ev.target.result;
        validarFormPost();
        return;
      }
      openCropModal({
        src: ev.target.result,
        aspectRatio: 0,
        maxWidth: 1200,
        maxHeight: 1200,
        onConfirm: function (blob) {
          selectedFile = new File([blob], 'foto-post.jpg', { type: 'image/jpeg' });
          uploadPlaceholder.classList.add('hidden');
          uploadPreview.classList.remove('hidden');
          previewImg.src = URL.createObjectURL(blob);
          validarFormPost();
        },
        onCancel: function () {
          selectedFile = file;
          uploadPlaceholder.classList.add('hidden');
          uploadPreview.classList.remove('hidden');
          previewImg.src = ev.target.result;
          validarFormPost();
        }
      });
    };
    reader.readAsDataURL(file);
  }

  document.getElementById('removePhoto').addEventListener('click', function (e) {
    e.stopPropagation();
    selectedFile = null;
    photoInput.value = '';
    uploadPlaceholder.classList.remove('hidden');
    uploadPreview.classList.add('hidden');
    validarFormPost();
  });

  novoPostTexto.addEventListener('input', function () {
    charCount.textContent = this.value.length + '/500';
    validarFormPost();
  });

  if (btnPublicar) btnPublicar.addEventListener('click', function () {
    if (!selectedFile || !novoPostTexto || !novoPostTexto.value.trim()) return;
    var petSelect = document.getElementById('novoPostPet');
    var petVal = (petSelect && petSelect.value) ? petSelect.value : '';
    this.disabled = true;
    this.innerHTML = '<i class="fa-solid fa-spinner fa-spin mr-2"></i>Publicando…';

    var formData = new FormData();
    formData.append('foto', selectedFile);
    formData.append('texto', novoPostTexto.value.trim());
    if (petVal) formData.append('pet_id', petVal);

    fetch('/explorar/post', { method: 'POST', credentials: 'same-origin', body: formData })
    .then(function (r) {
      return r.text().then(function (text) {
        try { return { ok: r.ok, data: JSON.parse(text) }; }
        catch (_) { return { ok: false, data: { sucesso: false, mensagem: r.status === 401 ? 'Sessão expirada. Faça login de novo.' : 'Erro no servidor. Tente novamente.' } }; }
      });
    })
    .then(function (result) {
      var data = result.data;
      btnPublicar.disabled = false;
      btnPublicar.innerHTML = 'Publicar';
      if (!result.ok || !data.sucesso) {
        toast(data.mensagem || 'Erro ao publicar.', 'erro');
        validarFormPost();
        return;
      }
      fecharModal('newPostModal');
      toast('Publicado!');
      totalPostsLocal = data.totalPosts != null ? data.totalPosts : (totalPostsLocal + 1);
      if (data.post) {
        var emptyState = feedContainer.querySelector('.text-center.py-20');
        if (emptyState) emptyState.remove();
        feedContainer.insertAdjacentHTML('afterbegin', renderPostHTML(data.post));
        initVerMaisForCard(feedContainer.firstElementChild);
        observarCardVisualizacao(feedContainer.firstElementChild);
      }
      if (data.removido) {
        var old = document.getElementById('post-' + data.removido);
        if (old) { old.classList.add('fade-out'); setTimeout(function () { if (old.parentNode) old.parentNode.removeChild(old); }, 400); }
      }
    })
    .catch(function () {
      toast('Erro de conexão. Verifique a internet e tente novamente.', 'erro');
      btnPublicar.disabled = false;
      btnPublicar.innerHTML = 'Publicar';
      validarFormPost();
    });
  });

  var fabBtn = document.getElementById('fabNewPost');
  if (fabBtn) {
    fabBtn.addEventListener('click', function (e) {
      e.preventDefault();
      e.stopPropagation();
      abrirNovoPost();
    });
  }

  /* ──────────── Pin / Unpin ──────────── */
  function fixarPost(postId, estaFixada) {
    fetch('/explorar/post/' + postId + '/fixar', {
      method: estaFixada ? 'DELETE' : 'POST',
      headers: { 'Accept': 'application/json' },
      credentials: 'same-origin'
    })
    .then(function (r) { return r.json(); })
    .then(function (data) {
      if (!data.sucesso) { toast(data.mensagem || 'Erro.', 'erro'); return; }
      toast(data.fixada ? 'Post fixado!' : 'Post desafixado!');
      totalFixadasLocal += data.fixada ? 1 : -1;
      setTimeout(function () { window.location.reload(); }, 600);
    })
    .catch(function () { toast('Erro de conexão.', 'erro'); });
  }

  /* ──────────── Delete Post ──────────── */
  function deletarPost(postId) {
    if (!confirm('Excluir esta publicação?')) return;
    fetch('/explorar/post/' + postId, {
      method: 'DELETE',
      headers: { 'Accept': 'application/json' },
      credentials: 'same-origin'
    })
    .then(function (r) { return r.json(); })
    .then(function (data) {
      if (!data.sucesso) { toast('Erro ao excluir.', 'erro'); return; }
      var card = document.getElementById('post-' + postId);
      if (card) {
        card.classList.add('fade-out');
        setTimeout(function () { if (card.parentNode) card.parentNode.removeChild(card); }, 400);
      }
      totalPostsLocal = Math.max(0, totalPostsLocal - 1);
      toast('Publicação excluída.');
    })
    .catch(function () { toast('Erro de conexão.', 'erro'); });
  }

  /* ──────────── Share ──────────── */
  function compartilhar(postId, autor) {
    var url = window.location.origin + '/explorar#post-' + postId;
    var texto = 'Veja o post de ' + autor + ' no AIRPET! 🐾 ' + url;
    window.open('https://wa.me/?text=' + encodeURIComponent(texto), '_blank');
  }

  /* ──────────── Three-dot Menu ──────────── */
  function fecharMenus() {
    var menus = document.querySelectorAll('.menu-dropdown');
    for (var i = 0; i < menus.length; i++) menus[i].classList.add('hidden');
  }

  function toggleMenu(btn) {
    var dropdown = btn.parentElement.querySelector('.menu-dropdown');
    if (!dropdown) return;
    var wasHidden = dropdown.classList.contains('hidden');
    fecharMenus();
    if (wasHidden) dropdown.classList.remove('hidden');
  }

  /* ──────────── Text Toggle ──────────── */
  function initVerMaisForCard(card) {
    if (!card) return;
    var texts = card.querySelectorAll('.post-text');
    for (var i = 0; i < texts.length; i++) {
      var p = texts[i];
      var btn = p.parentElement.querySelector('.btn-ver-mais');
      if (btn && p.scrollHeight > p.clientHeight + 2) {
        btn.classList.remove('hidden');
      }
    }
  }

  function initVerMais() {
    var texts = feedContainer.querySelectorAll('.post-text');
    for (var i = 0; i < texts.length; i++) {
      var p = texts[i];
      var btn = p.parentElement.querySelector('.btn-ver-mais');
      if (!btn) continue;
      if (p.scrollHeight > p.clientHeight + 2) btn.classList.remove('hidden');
    }
  }

  function toggleTexto(btn) {
    var p = btn.previousElementSibling || btn.parentElement.querySelector('.post-text');
    if (!p) return;
    var clamped = p.classList.contains('line-clamp-3');
    if (clamped) {
      p.classList.remove('line-clamp-3');
      btn.textContent = 'ver menos';
    } else {
      p.classList.add('line-clamp-3');
      btn.textContent = 'ver mais';
    }
  }

  /* ──────────── Infinite Scroll ──────────── */
  function carregarMaisPosts() {
    if (isLoading || !hasMore) return;
    isLoading = true;
    currentPage++;

    fetch('/explorar?page=' + currentPage, {
      headers: { 'Accept': 'application/json' },
      credentials: 'same-origin'
    })
    .then(function (r) { return r.json(); })
    .then(function (data) {
      isLoading = false;
      if (!data.sucesso || !data.posts || !data.posts.length) {
        hasMore = false;
        if (scrollSentinel) scrollSentinel.innerHTML = '<p class="text-xs text-gray-300 text-center">Você chegou ao fim 🐾</p>';
        return;
      }
      data.posts.forEach(function (post) {
        feedContainer.insertAdjacentHTML('beforeend', renderPostHTML(post));
        initVerMaisForCard(feedContainer.lastElementChild);
        observarCardVisualizacao(feedContainer.lastElementChild);
      });
      atualizarTempos();
      if (data.posts.length < 20) {
        hasMore = false;
        if (scrollSentinel) scrollSentinel.innerHTML = '<p class="text-xs text-gray-300 text-center">Você chegou ao fim 🐾</p>';
      }
    })
    .catch(function () { isLoading = false; });
  }

  if ('IntersectionObserver' in window) {
    viewObserver = new IntersectionObserver(function (entries) {
      entries.forEach(function (entry) {
        if (!entry.isIntersecting || entry.intersectionRatio < 0.6) return;
        var card = entry.target;
        var postId = parseInt(card.getAttribute('data-post-id'), 10);
        if (!postId || viewedPosts.has(postId)) return;
        viewedPosts.add(postId);
        var source = card.getAttribute('data-view-source') || 'explorar';
        registrarVisualizacao(postId, 1500, source);
        viewObserver.unobserve(card);
      });
    }, { threshold: [0.6] });
    document.querySelectorAll('article[data-post-id]').forEach(observarCardVisualizacao);
  }

  if (scrollSentinel && 'IntersectionObserver' in window) {
    var observer = new IntersectionObserver(function (entries) {
      if (entries[0].isIntersecting) carregarMaisPosts();
    }, { rootMargin: '200px' });
    observer.observe(scrollSentinel);
  }

  /* ──────────── Client-side Post Render ──────────── */
  function renderSponsoredHTML(p) {
    var sid = p.sponsored_key || ('sponsored-' + (p.boost_id || 'x') + '-' + (p.pet_id || 'x'));
    var sponsoredPostId = parseInt(p.id, 10);
    var hasSponsoredPostId = !Number.isNaN(sponsoredPostId) && sponsoredPostId > 0;
    var petNome = escapeHtml(p.pet_nome || ('Pet ' + (p.pet_id || '')));
    var tutorNome = escapeHtml(p.autor_nome || ('Usuário ' + (p.usuario_id || '')));
    var sponsoredText = p.texto || p.legenda || '';
    var fotoPet = p.pet_foto
      ? '<img src="' + escapeHtml(p.pet_foto) + '" alt="" class="w-7 h-7 rounded-full object-cover ring-2 ring-amber-200">'
      : '<span class="w-7 h-7 rounded-full bg-amber-100 text-amber-700 flex items-center justify-center text-[11px]"><i class="fa-solid fa-paw"></i></span>';

    var h = '<article class="masonry-card explorar-card bg-gradient-to-b from-amber-50/80 to-white overflow-hidden post-enter border-amber-200/60" data-post-id="' + (hasSponsoredPostId ? sponsoredPostId : '') + '" data-view-source="' + (hasSponsoredPostId ? 'sponsored_explorar' : '') + '" data-author-id="' + escapeHtml(p.usuario_id || '') + '" id="' + sid + '">';
    h += '<div class="px-3 py-2 flex items-center justify-between text-[10px] font-bold text-amber-800 uppercase tracking-wide"><span><i class="fa-solid fa-bullhorn mr-1"></i>' + escapeHtml(p.sponsored_label || 'Patrocinado') + '</span><a href="/explorar/pet/' + escapeHtml(p.pet_id) + '" class="normal-case font-semibold text-amber-700 hover:underline">Ver pet</a></div>';
    if (p.foto) h += '<img src="' + escapeHtml(p.foto) + '" alt="" class="w-full object-cover post-photo" loading="lazy">';
    h += '<div class="px-3 py-2"><div class="flex items-center gap-2">' + fotoPet + '<div class="min-w-0"><p class="text-xs font-semibold text-gray-900 truncate">' + petNome + '</p><p class="text-[11px] text-gray-500 truncate">' + tutorNome + '</p></div></div>';
    if (sponsoredText) h += '<p class="mt-2 text-xs text-gray-700 leading-relaxed line-clamp-2 post-text">' + escapeHtml(sponsoredText) + '</p>';
    if (hasSponsoredPostId) {
      h += '<div class="mt-2 flex items-center gap-2 border-t border-amber-100 pt-2">';
      h += '<button type="button" class="flex-1 flex items-center justify-center gap-1.5 py-1.5 rounded-lg transition-all text-xs btn-curtir relative ' + (p.curtiu ? 'text-red-500' : 'text-gray-500 hover:text-red-500 hover:bg-red-50/70') + '" data-post-id="' + sponsoredPostId + '" data-curtiu="' + (p.curtiu ? '1' : '0') + '"><i class="' + (p.curtiu ? 'fa-solid' : 'fa-regular') + ' fa-heart"></i><span class="count-curtidas">' + (p.total_curtidas || '') + '</span></button>';
      h += '<button type="button" class="flex-1 flex items-center justify-center gap-1.5 py-1.5 rounded-lg text-xs text-gray-500 hover:text-accent-500 hover:bg-accent-50/70 transition-all btn-comentar" data-post-id="' + sponsoredPostId + '"><i class="fa-regular fa-comment"></i><span class="count-comentarios">' + (p.total_comentarios || '') + '</span></button>';
      h += '</div>';
    }
    h += '</div></article>';
    return h;
  }

  function renderPostHTML(p) {
    if (p && p.is_sponsored) return renderSponsoredHTML(p);
    var txt = p.texto || p.legenda || '';
    var isRepost = p.tipo === 'repost';
    var isMine = p.usuario_id === meuId;
    var pCor = p.cor_perfil || '#ec5a1c';
    var avatarHtml;
    if (p.foto_perfil) {
      avatarHtml = '<img src="' + escapeHtml(p.foto_perfil) + '" alt="" class="w-8 h-8 rounded-full object-cover post-author-avatar" style="box-shadow:0 0 0 2px ' + escapeHtml(pCor) + '">';
    } else {
      avatarHtml = '<span class="w-8 h-8 rounded-full flex items-center justify-center text-xs font-bold text-white post-author-avatar bg-gray-400" style="box-shadow:0 0 0 2px ' + escapeHtml(pCor) + '">' + escapeHtml((p.autor_nome || 'U').charAt(0).toUpperCase()) + '</span>';
    }
    var h = '<article class="masonry-card explorar-card bg-white overflow-hidden post-enter" data-post-id="' + p.id + '" data-author-id="' + p.usuario_id + '" id="post-' + p.id + '">';
    h += '<div class="px-3 pt-2.5 pb-2"><div class="flex items-start gap-2">';
    var tutorHref = '/explorar/perfil/' + p.usuario_id;
    h += '<a href="' + tutorHref + '" class="shrink-0 rounded-full transition-all">' + avatarHtml + '</a>';
    h += '<div class="flex-1 min-w-0"><div class="flex items-center gap-1"><a href="' + tutorHref + '" class="font-semibold text-xs text-gray-900 truncate post-author-name">' + escapeHtml(p.autor_nome) + '</a>';
    if (p.fixada) h += '<i class="fa-solid fa-thumbtack text-[10px] text-gray-400"></i>';
    if (isRepost) h += '<i class="fa-solid fa-retweet text-[10px] text-emerald-500"></i>';
    h += '</div><span class="text-[11px] text-gray-400 tempo-relativo" data-time="' + p.criado_em + '">' + tempoRelativo(p.criado_em) + '</span></div>';

    if (isMine) {
      h += '<div class="relative shrink-0"><button type="button" class="p-1 text-gray-400 hover:text-gray-600 hover:bg-gray-100 rounded-full transition-colors btn-menu-post"><i class="fa-solid fa-ellipsis text-xs"></i></button>';
      h += '<div class="menu-dropdown hidden absolute right-0 top-full mt-1 w-40 bg-white rounded-xl shadow-lg ring-1 ring-black/5 py-1 z-30">';
      h += '<button type="button" class="w-full px-3 py-2 text-left text-xs hover:bg-gray-50 flex items-center gap-2 transition-colors btn-fixar" data-post-id="' + p.id + '" data-fixada="' + (p.fixada ? '1' : '0') + '"><i class="fa-solid fa-thumbtack text-gray-400 w-3 text-center"></i><span>' + (p.fixada ? 'Desafixar' : 'Fixar') + '</span></button>';
      h += '<button type="button" class="w-full px-3 py-2 text-left text-xs hover:bg-red-50 text-red-500 flex items-center gap-2 transition-colors btn-deletar" data-post-id="' + p.id + '"><i class="fa-solid fa-trash-can w-3 text-center"></i><span>Excluir</span></button>';
      h += '</div></div>';
    }
    h += '</div></div>';

    if (p.foto) h += '<img src="' + escapeHtml(p.foto) + '" alt="" class="w-full object-cover post-photo" loading="lazy">';
    if (txt) h += '<div class="px-3 pt-2"><p class="text-xs text-gray-700 leading-relaxed line-clamp-3 post-text">' + escapeHtml(txt) + '</p><button type="button" class="text-accent-500 text-[11px] font-semibold mt-1 btn-ver-mais hidden hover:underline">ver mais</button></div>';
    h += '<div class="px-2.5 py-2 mt-1 border-t border-gray-100"><div class="flex items-center gap-1.5">';
    h += '<button type="button" class="flex-1 flex items-center justify-center gap-1 py-1.5 rounded-lg transition-all text-xs btn-curtir relative ' + (p.curtiu ? 'text-red-500' : 'text-gray-500 hover:text-red-500 hover:bg-red-50/70') + '" data-post-id="' + p.id + '" data-curtiu="' + (p.curtiu ? '1' : '0') + '"><i class="' + (p.curtiu ? 'fa-solid' : 'fa-regular') + ' fa-heart"></i><span class="count-curtidas">' + (p.total_curtidas || '') + '</span></button>';
    h += '<button type="button" class="flex-1 flex items-center justify-center gap-1 py-1.5 rounded-lg text-xs text-gray-500 hover:text-accent-500 hover:bg-accent-50/70 transition-all btn-comentar" data-post-id="' + p.id + '"><i class="fa-regular fa-comment"></i><span class="count-comentarios">' + (p.total_comentarios || '') + '</span></button>';
    h += '</div></div>';

    h += '</article>';
    return h;
  }

  /* ──────────── Event Delegation ──────────── */
  feedContainer.addEventListener('click', function (e) {
    var btn;

    btn = e.target.closest('.btn-curtir');
    if (btn) { curtirPost(btn.getAttribute('data-post-id'), btn); return; }

    btn = e.target.closest('.btn-comentar');
    if (btn) { abrirComentarios(btn.getAttribute('data-post-id')); return; }

    btn = e.target.closest('.btn-repost');
    if (btn) { abrirRepostModal(btn.getAttribute('data-post-id')); return; }

    btn = e.target.closest('.btn-share');
    if (btn) { compartilhar(btn.getAttribute('data-post-id'), btn.getAttribute('data-autor')); return; }

    btn = e.target.closest('.btn-menu-post');
    if (btn) { e.stopPropagation(); toggleMenu(btn); return; }

    btn = e.target.closest('.btn-fixar');
    if (btn) { fecharMenus(); fixarPost(btn.getAttribute('data-post-id'), btn.getAttribute('data-fixada') === '1'); return; }

    btn = e.target.closest('.btn-deletar');
    if (btn) { fecharMenus(); deletarPost(btn.getAttribute('data-post-id')); return; }

    btn = e.target.closest('.btn-ver-mais');
    if (btn) { toggleTexto(btn); return; }

    fecharMenus();
  });

  feedContainer.addEventListener('keydown', function (e) {
    if (e.key === 'Enter' && e.target.classList.contains('input-comentario-inline')) {
      e.preventDefault();
      var txt = e.target.value.trim();
      if (txt) enviarComentario(e.target.getAttribute('data-post-id'), txt, e.target);
    }
  });

  document.addEventListener('click', function (e) {
    if (!e.target.closest('.btn-menu-post') && !e.target.closest('.menu-dropdown')) fecharMenus();
  });

  /* ──────────── Init ──────────── */
  atualizarTempos();
  setInterval(atualizarTempos, 60000);
  setTimeout(initVerMais, 100);

  /* ──────────── Sidebar Follow Buttons ──────────── */
  document.querySelectorAll('.btn-seguir-sidebar').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var userId = this.getAttribute('data-user-id');
      var el = this;
      fetch('/explorar/seguir/' + userId, { method: 'POST', headers: { 'Content-Type': 'application/json' } })
        .then(function(r) { return r.json(); })
        .then(function(d) {
          if (d.sucesso) {
            el.textContent = 'Seguindo';
            el.classList.remove('bg-gray-900', 'hover:bg-gray-700');
            el.classList.add('bg-primary-500', 'hover:bg-primary-600');
            el.disabled = true;
          }
        });
    });
  });
  document.querySelectorAll('.btn-seguir-pet-sidebar').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var petId = this.getAttribute('data-pet-id');
      var el = this;
      fetch('/explorar/pet/' + petId + '/seguir', { method: 'POST', headers: { 'Content-Type': 'application/json' } })
        .then(function(r) { return r.json(); })
        .then(function(d) {
          if (d.sucesso) {
            el.textContent = 'Seguindo';
            el.classList.remove('border-primary-500', 'text-primary-500', 'hover:bg-primary-500', 'hover:text-white');
            el.classList.add('bg-primary-500', 'text-white', 'border-primary-500');
            el.disabled = true;
          }
        });
    });
  });

  /* ──────────── Onboarding (Driver.js) ──────────── */
  if (typeof window.driver !== 'undefined' && !localStorage.getItem('airpet_onboarding_done')) {
    setTimeout(function () {
      var steps = [];
      if (fabBtn) steps.push({ element: '#fabNewPost', popover: { title: 'Crie seu primeiro post!', description: 'Toque aqui para compartilhar uma foto e texto do seu pet com a comunidade.', side: 'top', align: 'center' } });
      var firstActions = document.querySelector('.btn-curtir');
      if (firstActions) {
        var actionBar = firstActions.closest('.flex.items-center');
        if (actionBar) steps.push({ element: actionBar, popover: { title: 'Interaja!', description: 'Curta, comente, reposte e compartilhe publicações.', side: 'top', align: 'center' } });
      }
      if (!steps.length) return;
      var driverObj = window.driver.js.driver({
        showProgress: true,
        steps: steps,
        nextBtnText: 'Próximo',
        prevBtnText: 'Anterior',
        doneBtnText: 'Entendi!',
        onDestroyed: function () { localStorage.setItem('airpet_onboarding_done', '1'); }
      });
      driverObj.drive();
    }, 800);
  }

})();
</script>

