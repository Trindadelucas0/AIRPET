<%
  locals.extraHead = `
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/driver.js@1.3.1/dist/driver.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.1/cropper.min.css"
          integrity="sha512-0x6JxdTnmQSFJb7g8+YovV0OXFWVQlpnYbJwY9FpZ0P4B+GacePAfjxqRgJ0hnW50Omh2kHh2k9nN1F4b0q1Sw=="
          crossorigin="anonymous" referrerpolicy="no-referrer">
    <style>
      @keyframes explorarHero { from { opacity: 0; transform: translateY(-8px); } to { opacity: 1; transform: translateY(0); } }
      .menu-dropdown { transform-origin:top right; animation:scaleIn .15s ease-out; }
      .mention { color:var(--accent); font-weight:600; cursor:pointer; }
      .mention:hover { text-decoration:underline; }
      .autocomplete-dropdown { position:absolute; bottom:100%; left:0; right:0; max-height:160px; overflow-y:auto; background:var(--ink-2); border:1px solid var(--border); border-radius:12px; box-shadow:0 18px 48px rgba(15,23,42,0.10); z-index:10; margin-bottom:4px; }
      .autocomplete-item { display:flex; align-items:center; gap:8px; padding:8px 12px; cursor:pointer; font-size:13px; transition:background .15s; }
      .autocomplete-item:hover { background:var(--ink-3); }
      .post-enter { animation: slideUp .4s ease-out both; }
      .driver-popover { border-radius:16px !important; }
      .driver-popover-title { font-weight:700 !important; color:#111827 !important; }
      .driver-popover-description { color:#6b7280 !important; }
      .driver-popover-next-btn { background:linear-gradient(135deg,#ec5a1c,#dd4212) !important; border:none !important; border-radius:10px !important; font-weight:600 !important; }
      .driver-popover-prev-btn { border-radius:10px !important; font-weight:600 !important; }
      /* Tipografia Explorar: corpo legível (DM Sans), título com Rubik Doodle Shadow + Syne */
      .explorar-page {
        font-family: 'DM Sans', ui-sans-serif, system-ui, -apple-system, sans-serif;
        font-feature-settings: "kern" 1, "liga" 1;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
      }
      .explorar-hero-title {
        font-family: var(--font-display), "DM Sans", sans-serif;
        letter-spacing: 0.02em;
        line-height: 1.15;
      }
      .explorar-card-name {
        font-family: 'DM Sans', sans-serif;
        font-weight: 600;
        font-size: 0.875rem;
        line-height: 1.35;
        letter-spacing: -0.015em;
      }
      .explorar-card-meta {
        font-size: 0.75rem;
        line-height: 1.4;
        letter-spacing: 0.01em;
      }
      #postDetailModal {
        font-family: 'DM Sans', ui-sans-serif, system-ui, -apple-system, sans-serif;
        -webkit-font-smoothing: antialiased;
      }
      .explorar-card .explorar-badge {
        font-family: 'DM Sans', sans-serif;
        font-size: 0.6875rem;
        font-weight: 700;
        letter-spacing: 0.08em;
        line-height: 1.25;
      }
      @media (min-width: 768px) {
        .explorar-card .explorar-badge { font-size: 0.75rem; letter-spacing: 0.06em; }
      }
      .explorar-modal-title { font-family: var(--font-display), "DM Sans", sans-serif; letter-spacing: 0.02em; }
      .explorar-modal-body { font-size: 0.9375rem; line-height: 1.65; letter-spacing: 0.01em; }
      /* Explorar layout */
      .explorar-hero { background: linear-gradient(180deg, rgba(236,90,28,.06) 0%, transparent 100%); }
      .explorar-search-bar { transition: box-shadow .2s, border-color .2s; }
      .explorar-search-bar:focus-within { box-shadow: 0 0 0 3px rgba(236,90,28,.12); border-color: rgba(236,90,28,.4); }
      /* Mobile: barra explorar fixa abaixo da navbar */
      .explorar-mobile-topbar {
        position: fixed;
        top: var(--explorar-mobile-nav-h, 56px);
        left: 0;
        right: 0;
      }
      .explorar-mobile-content-offset {
        padding-top: calc(var(--explorar-mobile-topbar-h, 148px) + 8px);
      }
      @media (min-width: 768px) {
        .explorar-mobile-topbar {
          position: sticky;
          top: 56px;
          left: auto;
          right: auto;
        }
        .explorar-mobile-content-offset {
          padding-top: 1.25rem;
        }
      }
      /* Mosaico Explorar (CSS Grid dense) */
      #feedContainer.explore-mosaic-grid {
        --explore-cols: 2;
        --explore-gap: 5px;
        display: grid;
        grid-template-columns: repeat(var(--explore-cols), minmax(0, 1fr));
        grid-auto-rows: var(--explore-cell, 118px);
        grid-auto-flow: dense;
        gap: var(--explore-gap);
        align-items: stretch;
      }
      @media (min-width: 480px) {
        #feedContainer.explore-mosaic-grid { --explore-cols: 3; }
      }
      @media (min-width: 768px) {
        #feedContainer.explore-mosaic-grid { --explore-cols: 3; --explore-gap: 6px; }
      }
      @media (min-width: 1024px) {
        #feedContainer.explore-mosaic-grid { --explore-cols: 4; }
      }
      @media (min-width: 1280px) {
        #feedContainer.explore-mosaic-grid { --explore-cols: 5; }
      }
      .explore-tile--1x1 { grid-column: span 1; grid-row: span 1; }
      .explore-tile--1x2 { grid-column: span 1; grid-row: span 2; }
      .explore-tile--2x1 { grid-column: span 2; grid-row: span 1; }
      .explore-tile--2x2 { grid-column: span 2; grid-row: span 2; }
      @media (max-width: 479px) {
        .explore-tile--2x1 { grid-column: span 2; grid-row: span 1; }
        .explore-tile--2x2 { grid-column: span 2; grid-row: span 2; }
      }
      .explore-tile-cell {
        min-height: 0;
        position: relative;
        border-radius: 0.85rem;
        overflow: hidden;
        box-shadow: 0 2px 10px -4px rgba(15,23,42,.12);
        border: 1px solid rgba(15,23,42,.06);
        background: #e2e8f0;
        transition: transform .2s ease, box-shadow .2s ease;
      }
      @media (hover: hover) and (pointer: fine) {
        .explore-tile-cell:hover { transform: translateY(-1px); box-shadow: 0 12px 28px -10px rgba(15,23,42,.18); }
      }
      .explore-tile-cell:focus-visible {
        outline: 2px solid rgba(236,90,28,.5);
        outline-offset: 2px;
      }
      .explore-tile-inner {
        position: absolute;
        inset: 0;
        background: #e2e8f0;
      }
      .explore-tile-inner img.post-photo {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
        vertical-align: bottom;
      }
      .explore-tile-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(180deg, transparent 55%, rgba(15,23,42,.22) 100%);
        opacity: 0;
        transition: opacity .2s ease;
        pointer-events: none;
      }
      @media (hover: hover) and (pointer: fine) {
        .explore-tile-cell:hover .explore-tile-overlay { opacity: 1; }
      }
      .explore-tile-cell.explore-tile--touch .explore-tile-overlay { opacity: 1; }
      @keyframes exploreShimmer {
        0% { background-position: 200% 0; }
        100% { background-position: -200% 0; }
      }
      .explore-tile-skeleton {
        position: absolute;
        inset: 0;
        background: linear-gradient(110deg, #e2e8f0 0%, #f1f5f9 45%, #e2e8f0 90%);
        background-size: 200% 100%;
        animation: exploreShimmer 1.2s ease-in-out infinite;
      }
      .explore-tile-skeleton.is-hidden { display: none; }
      @media (prefers-reduced-motion: reduce) {
        .explore-tile-skeleton { animation: none; background: #e2e8f0; }
      }
      .explorar-card { border-radius: 1.25rem; box-shadow: 0 1px 3px rgba(15,23,42,.04); border: 1px solid var(--border); }
      .explorar-sidebar-card { border-radius: 1.25rem; box-shadow: 0 2px 8px rgba(15,23,42,.05); border: 1px solid var(--border); }
      .explorar-sidebar-card .divide-y > * + * { border-top: 1px solid var(--border); }
      .btn-seguir-explorar { transition: transform .15s, box-shadow .15s; }
      .btn-seguir-explorar:hover { transform: scale(1.02); }
      .btn-seguir-explorar:active { transform: scale(0.98); }
      /* Mídia com altura variável (estilo grade Instagram): largura da coluna, proporção natural */
      .explorar-media-box { display: block; width: 100%; line-height: 0; }
      .explorar-media-box .post-photo { display: block; width: 100%; height: auto; vertical-align: bottom; }
      article.explorar-post-card[data-explorar-meta] {
        cursor: pointer;
        -webkit-tap-highlight-color: transparent;
      }
      article.explorar-post-card[data-explorar-meta]:focus-visible {
        outline: 2px solid rgba(236,90,28,.45);
        outline-offset: 2px;
      }
      .post-detail-panel { box-shadow: 0 25px 50px -12px rgba(15,23,42,.18); }
      .post-detail-media-col {
        background: linear-gradient(165deg, #1e293b 0%, #0f172a 50%, #1e293b 100%);
      }
      .post-detail-media-inner {
        max-height: min(40vh, 360px);
      }
      @media (min-width: 768px) {
        .post-detail-media-inner {
          max-height: min(78vh, 780px);
        }
      }
      .post-detail-composer-safe {
        padding-bottom: max(0.75rem, env(safe-area-inset-bottom, 0px));
      }
    </style>
  `;
%>
<%- include('partials/header') %>
<%- include('partials/flash') %>

<% var isLogado = typeof usuario !== 'undefined' && usuario; %>

<main class="explorar-page flex-1 pb-24 md:pb-6">

  <!-- ═══ Header Explorar ═══ -->
  <div id="explorarTopbar" class="explorar-mobile-topbar z-40 bg-white/95 backdrop-blur-xl border-b border-gray-100/80 explorar-hero">
    <div class="max-w-7xl mx-auto px-4 py-4 md:py-5">
      <div class="flex flex-col gap-4">
        <div class="flex items-baseline justify-between gap-3">
          <div>
            <h1 class="explorar-hero-title text-2xl md:text-[1.7rem] font-extrabold text-gray-900">
              <span class="inline-flex items-center justify-center w-9 h-9 rounded-xl bg-gradient-to-br from-primary-500 to-primary-600 text-white text-base mr-2.5 align-middle shadow-md shadow-primary-500/20" aria-hidden="true"><i class="fa-solid fa-compass"></i></span>
              Explorar
            </h1>
            <p class="text-sm text-gray-500 mt-2 leading-relaxed max-w-md">Descubra pets e tutores perto de você</p>
          </div>
        </div>
        <!-- Barra de busca única (mobile + desktop) -->
        <a href="/explorar/busca" class="explorar-search-bar flex items-center gap-3 w-full bg-white border border-gray-200 rounded-2xl pl-4 pr-4 py-3.5 text-left shadow-sm hover:border-primary-200 hover:shadow-md transition-all duration-200 group">
          <span class="flex items-center justify-center w-10 h-10 rounded-xl bg-gray-100 text-gray-400 group-hover:bg-primary-50 group-hover:text-primary-500 transition-colors">
            <i class="fa-solid fa-magnifying-glass"></i>
          </span>
          <span class="flex-1 text-sm font-medium text-gray-500 group-hover:text-gray-700">Buscar pets ou pessoas…</span>
          <i class="fa-solid fa-chevron-right text-gray-300 text-xs group-hover:text-primary-400 transition-colors"></i>
        </a>
      </div>
    </div>
  </div>

  <script>
    (function () {
      var root = document.documentElement;
      var topbar = document.getElementById('explorarTopbar');
      if (!root || !topbar) return;

      function syncMobileTopbarOffset() {
        if (window.innerWidth >= 768) {
          root.style.removeProperty('--explorar-mobile-topbar-h');
          root.style.removeProperty('--explorar-mobile-nav-h');
          return;
        }

        var navbar = document.getElementById('navbar');
        if (navbar) {
          var navH = Math.ceil(navbar.getBoundingClientRect().height || 0);
          if (navH > 0) root.style.setProperty('--explorar-mobile-nav-h', navH + 'px');
        }

        var h = Math.ceil(topbar.getBoundingClientRect().height || 0);
        if (h > 0) root.style.setProperty('--explorar-mobile-topbar-h', h + 'px');
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', syncMobileTopbarOffset, { once: true });
      } else {
        syncMobileTopbarOffset();
      }

      window.addEventListener('resize', syncMobileTopbarOffset, { passive: true });
      window.addEventListener('orientationchange', syncMobileTopbarOffset);
      window.addEventListener('load', syncMobileTopbarOffset, { once: true });
    })();
  </script>

  <div class="max-w-7xl mx-auto flex gap-6 px-4 pb-2 explorar-mobile-content-offset">

  <!-- ═══ Feed (coluna principal) ═══ -->
  <div class="flex-1 min-w-0">
  <div id="feedContainer" class="<%= (posts && posts.length) ? 'explore-mosaic-grid' : '' %>">


    <% if (posts && posts.length > 0) { %>
      <% posts.forEach(function(post, idx) { %>
        <% var tileSpan = post.explorar_tile_span; if (tileSpan !== '1x2' && tileSpan !== '2x1' && tileSpan !== '2x2') tileSpan = '1x1'; %>
        <% var imgPriority = idx < 6 ? 'fetchpriority="high"' : ''; %>
        <% if (post.is_petshop_publication) { %>
          <% var petshopMetaObj = {
            kind: 'petshop',
            postId: post.publicationKey || '',
            foto: post.foto_url || '',
            texto: post.texto || '',
            created_em: post.created_em || '',
            displayName: post.petshop_nome || ('Petshop ' + post.petshop_id),
            avatar: post.petshop_logo_url || '',
            petshop_id: post.petshop_id,
            preco: post.preco,
            whatsapp_publico: post.whatsapp_publico || '',
            contato_link: post.contato_link || '',
            isPromo: !!(post.publicationType === 'promocao' || post.is_promocao),
            comments: true
          }; %>
          <article class="explore-tile-cell explore-tile--<%= tileSpan %> explorar-post-card post-enter"
                   style="animation-delay:<%= Math.min(idx * 45, 380) %>ms"
                   tabindex="0" aria-label="Abrir publicação do parceiro"
                   data-post-id="<%= post.publicationKey || '' %>" data-view-source="petshop_explorar"
                   data-author-id="<%= post.petshop_id || '' %>"
                   data-explorar-meta="<%= encodeURIComponent(JSON.stringify(petshopMetaObj)) %>"
                   id="petshop-publication-<%= String(post.publicationKey || '').replace(/[^a-zA-Z0-9]/g, '-') %>">
            <div class="explore-tile-inner">
              <div class="explore-tile-skeleton" aria-hidden="true"></div>
              <% if (post.foto_url) { %>
                <img src="<%= post.foto_url %>" alt="" class="post-photo" loading="<%= idx < 8 ? 'eager' : 'lazy' %>" decoding="async" <%- imgPriority %>
                     onload="var s=this.previousElementSibling; if(s&&s.classList)s.classList.add('is-hidden');"
                     onerror="var s=this.previousElementSibling; if(s&&s.classList)s.classList.add('is-hidden');">
              <% } %>
              <span class="explore-tile-overlay" aria-hidden="true"></span>
            </div>
          </article>
        <% } else if (post.is_sponsored) { %>
          <% var sponsoredPostId = Number(post.id); %>
          <% var hasSponsoredPostId = Number.isFinite(sponsoredPostId) && sponsoredPostId > 0; %>
          <% var sponsoredTexto = post.texto || post.legenda || ''; %>
          <% var sponsoredMetaObj = {
            kind: 'sponsored',
            postId: hasSponsoredPostId ? sponsoredPostId : null,
            foto: post.foto || '',
            texto: sponsoredTexto,
            criado_em: post.criado_em || '',
            pet_nome: post.pet_nome || ('Pet ' + post.pet_id),
            pet_foto: post.pet_foto || '',
            autor_nome: post.autor_nome || ('Usuário ' + post.usuario_id),
            usuario_id: post.usuario_id,
            pet_id: post.pet_id,
            comments: hasSponsoredPostId
          }; %>
          <article class="explore-tile-cell explore-tile--<%= tileSpan %> explorar-post-card post-enter"
                   style="animation-delay:<%= Math.min(idx * 45, 380) %>ms"
                   tabindex="0" aria-label="Abrir publicação patrocinada"
                   data-post-id="<%= hasSponsoredPostId ? sponsoredPostId : '' %>"
                   data-view-source="<%= hasSponsoredPostId ? 'sponsored_explorar' : '' %>"
                   data-author-id="<%= post.usuario_id || '' %>"
                   data-explorar-meta="<%= encodeURIComponent(JSON.stringify(sponsoredMetaObj)) %>"
                   id="<%= post.sponsored_key || ('sponsored-' + post.boost_id + '-' + post.pet_id) %>">
            <div class="explore-tile-inner">
              <div class="explore-tile-skeleton" aria-hidden="true"></div>
              <% if (post.foto) { %>
                <img src="<%= post.foto %>" alt="" class="post-photo" loading="<%= idx < 8 ? 'eager' : 'lazy' %>" decoding="async" <%- imgPriority %>
                     onload="var s=this.previousElementSibling; if(s&&s.classList)s.classList.add('is-hidden');"
                     onerror="var s=this.previousElementSibling; if(s&&s.classList)s.classList.add('is-hidden');">
              <% } %>
              <span class="explore-tile-overlay" aria-hidden="true"></span>
            </div>
          </article>
        <% } else { %>
          <% var postTexto = post.texto || post.legenda || ''; %>
          <% var exibirFotoOrg = (post.foto && String(post.foto).trim()) ? post.foto : ((post.tipo === 'repost' && post.orig_foto) ? post.orig_foto : ''); %>
          <% var organicMetaObj = {
            kind: 'organic',
            postId: post.id,
            foto: exibirFotoOrg || '',
            texto: postTexto,
            criado_em: post.criado_em || '',
            autor_nome: post.autor_nome || '',
            usuario_id: post.usuario_id,
            foto_perfil: post.foto_perfil || '',
            cor_perfil: post.cor_perfil || '#ec5a1c',
            pet_id: post.pet_id || null,
            pet_nome: post.pet_nome || '',
            pet_foto: post.pet_foto || '',
            fixada: !!post.fixada,
            comments: true,
            tipo: post.tipo || 'original',
            orig_id: post.orig_id || null,
            orig_foto: post.orig_foto || '',
            orig_texto: post.orig_texto || '',
            orig_legenda: post.orig_legenda || '',
            orig_autor_nome: post.orig_autor_nome || '',
            orig_usuario_id: post.orig_usuario_id || null,
            orig_pet_id: post.orig_pet_id || null,
            orig_pet_nome: post.orig_pet_nome || '',
            orig_pet_foto: post.orig_pet_foto || '',
            orig_foto_perfil: post.orig_foto_perfil || '',
            orig_criado_em: post.orig_criado_em || ''
          }; %>
          <article class="explore-tile-cell explore-tile--<%= tileSpan %> explorar-post-card post-enter"
                   style="animation-delay:<%= Math.min(idx * 45, 380) %>ms"
                   tabindex="0" aria-label="Abrir publicação"
                   data-post-id="<%= post.id %>" data-author-id="<%= post.usuario_id %>"
                   data-explorar-meta="<%= encodeURIComponent(JSON.stringify(organicMetaObj)) %>"
                   id="post-<%= post.id %>">
            <div class="explore-tile-inner">
              <div class="explore-tile-skeleton" aria-hidden="true"></div>
              <% if (exibirFotoOrg) { %>
                <img src="<%= exibirFotoOrg %>" alt="" class="post-photo" loading="<%= idx < 8 ? 'eager' : 'lazy' %>" decoding="async" <%- imgPriority %>
                     onload="var s=this.previousElementSibling; if(s&&s.classList)s.classList.add('is-hidden');"
                     onerror="var s=this.previousElementSibling; if(s&&s.classList)s.classList.add('is-hidden');">
              <% } %>
              <span class="explore-tile-overlay" aria-hidden="true"></span>
            </div>
          </article>
        <% } %>
      <% }); %>
    <% } else { %>
      <div class="explorar-empty-explore explorar-card text-center py-16 px-6 animate-fadeIn bg-white rounded-2xl">
        <div class="w-24 h-24 mx-auto mb-6 rounded-2xl bg-gradient-to-br from-primary-50 to-orange-50 flex items-center justify-center shadow-inner">
          <i class="fa-solid fa-compass text-4xl text-primary-400"></i>
        </div>
        <h3 class="explorar-hero-title text-xl md:text-[1.35rem] font-extrabold text-gray-900 mb-2 tracking-tight">Nenhuma publicação por perto</h3>
        <p class="text-sm text-gray-500 max-w-sm mx-auto leading-relaxed mb-6">
          Ainda não há publicações na sua região. Seja o primeiro a compartilhar uma foto do seu pet!
        </p>
        <% if (isLogado) { %>
          <button type="button" onclick="document.getElementById('fabNewPost') && document.getElementById('fabNewPost').click();" class="inline-flex items-center gap-2 px-6 py-3 rounded-2xl text-sm font-bold text-white bg-gradient-to-r from-primary-500 to-primary-600 shadow-lg shadow-primary-500/25 hover:shadow-xl hover:-translate-y-0.5 transition-all duration-200">
            <i class="fa-solid fa-plus"></i> Criar primeira publicação
          </button>
        <% } else { %>
          <a href="/auth/login" class="inline-flex items-center gap-2 px-6 py-3 rounded-2xl text-sm font-bold text-white bg-gradient-to-r from-primary-500 to-primary-600 shadow-lg shadow-primary-500/25 hover:shadow-xl hover:-translate-y-0.5 transition-all duration-200">
            Entrar para publicar
          </a>
        <% } %>
      </div>
    <% } %>
  </div><!-- /feedContainer -->
  <div>
    <!-- ═══ Scroll Sentinel ═══ -->
    <% if (temMais) { %>
      <div id="scrollSentinel" class="py-10 flex justify-center">
        <div class="flex items-center gap-2.5 text-gray-400 text-sm px-4 py-2.5 rounded-2xl bg-gray-50">
          <i class="fa-solid fa-spinner fa-spin text-primary-500"></i>
          <span>Carregando mais…</span>
        </div>
      </div>
    <% } %>
  </div>
  </div>

  <!-- ═══ Sidebar (desktop only) ═══ -->
  <aside class="hidden lg:block w-80 flex-shrink-0 space-y-5 sticky top-24 self-start">

    <!-- Busca (desktop: link para página de busca) -->
    <div class="explorar-sidebar-card bg-white overflow-hidden p-0">
      <a href="/explorar/busca" class="explorar-search-bar flex items-center gap-3 w-full px-4 py-3.5 text-left border-0 rounded-2xl group hover:bg-gray-50/80 transition-colors">
        <span class="flex items-center justify-center w-9 h-9 rounded-xl bg-gray-100 text-gray-400 group-hover:bg-primary-50 group-hover:text-primary-500 transition-colors">
          <i class="fa-solid fa-magnifying-glass text-sm"></i>
        </span>
        <span class="flex-1 text-sm text-gray-500 group-hover:text-gray-700">Buscar pets ou pessoas</span>
        <i class="fa-solid fa-chevron-right text-gray-300 text-xs group-hover:text-primary-400"></i>
      </a>
    </div>

    <% if (typeof recomendacoes !== 'undefined' && recomendacoes.length > 0) { %>
    <div class="explorar-sidebar-card bg-white overflow-hidden">
      <div class="px-4 pt-4 pb-3">
        <h3 class="explorar-hero-title font-extrabold text-gray-900 text-base flex items-center gap-2">
          <span class="w-8 h-8 rounded-xl bg-primary-100 text-primary-500 flex items-center justify-center text-sm"><i class="fa-solid fa-user-plus"></i></span>
          Quem seguir
        </h3>
        <p class="text-xs text-gray-500 mt-1">Pessoas perto de você</p>
      </div>
      <div class="divide-y divide-gray-100">
        <% recomendacoes.forEach(function(rec) { %>
          <div class="flex items-center gap-3 px-4 py-3 hover:bg-gray-50/70 transition-colors">
            <a href="/explorar/perfil/<%= rec.id %>" class="shrink-0">
              <% var recCor = rec.cor_perfil || '#ec5a1c'; %>
              <% if (rec.foto_perfil) { %>
                <img src="<%= rec.foto_perfil %>" alt="" class="w-10 h-10 rounded-full object-cover ring-2 ring-white shadow-sm" style="border: 2px solid <%= recCor %>">
              <% } else { %>
                <span class="w-10 h-10 rounded-full flex items-center justify-center text-sm font-bold text-white bg-gray-400 shadow-sm"
                      style="box-shadow: 0 0 0 2px <%= recCor %>">
                  <%= rec.nome ? rec.nome.charAt(0).toUpperCase() : 'U' %>
                </span>
              <% } %>
            </a>
            <div class="flex-1 min-w-0">
              <a href="/explorar/perfil/<%= rec.id %>" class="font-semibold text-sm text-gray-900 hover:text-primary-600 hover:underline truncate block"><%= rec.nome %></a>
              <% if (rec.bairro || rec.cidade) { %>
                <p class="text-xs text-gray-400 truncate mt-0.5"><i class="fa-solid fa-location-dot mr-0.5 text-gray-300"></i><%= rec.bairro ? rec.bairro + ', ' : '' %><%= rec.cidade || '' %>
                  <% if (rec.distancia_km) { %> · <%= rec.distancia_km %>km<% } %>
                </p>
              <% } %>
            </div>
            <button class="btn-seguir-sidebar btn-seguir-explorar shrink-0 px-3.5 py-2 text-xs font-bold rounded-xl border-2 border-primary-500 text-primary-500 bg-white hover:bg-primary-50 hover:text-primary-600 shadow-sm transition-all"
                    data-user-id="<%= rec.id %>">
              Seguir
            </button>
          </div>
        <% }) %>
      </div>
      <a href="/explorar/busca" class="block text-center text-sm text-primary-500 font-semibold py-3.5 hover:bg-primary-50/50 transition-colors border-t border-gray-100">
        Ver mais
      </a>
    </div>
    <% } %>

    <% if (typeof petsRecomendados !== 'undefined' && petsRecomendados.length > 0) { %>
    <div class="explorar-sidebar-card bg-white overflow-hidden">
      <div class="px-4 pt-4 pb-3">
        <h3 class="explorar-hero-title font-extrabold text-gray-900 text-base flex items-center gap-2">
          <span class="w-8 h-8 rounded-xl bg-amber-100 text-amber-600 flex items-center justify-center text-sm"><i class="fa-solid fa-paw"></i></span>
          Pets populares
        </h3>
      </div>
      <div class="divide-y divide-gray-100">
        <% petsRecomendados.slice(0, 5).forEach(function(pet) { %>
          <div class="flex items-center gap-3 px-4 py-3 hover:bg-gray-50/70 transition-colors">
            <a href="/pets/<%= pet.id %>" class="shrink-0">
              <% if (pet.foto) { %>
                <img src="<%= pet.foto %>" alt="<%= pet.nome %>" class="w-10 h-10 rounded-full object-cover ring-2 ring-primary-100 shadow-sm">
              <% } else { %>
                <div class="w-10 h-10 rounded-full bg-primary-50 flex items-center justify-center shadow-sm">
                  <i class="fa-solid fa-paw text-primary-400 text-sm"></i>
                </div>
              <% } %>
            </a>
            <div class="flex-1 min-w-0">
              <a href="/pets/<%= pet.id %>" class="font-semibold text-sm text-gray-900 hover:text-primary-600 hover:underline truncate block"><%= pet.nome %></a>
              <p class="text-xs text-gray-400 truncate mt-0.5"><%= pet.raca || pet.tipo || '' %> · <%= pet.total_seguidores %> seguidor<%= pet.total_seguidores !== 1 ? 'es' : '' %></p>
            </div>
            <button class="btn-seguir-pet-sidebar btn-seguir-explorar shrink-0 px-3.5 py-2 text-xs font-bold rounded-xl border-2 border-primary-500 text-primary-500 hover:bg-primary-500 hover:text-white transition-all shadow-sm"
                    data-pet-id="<%= pet.id %>">
              Seguir
            </button>
          </div>
        <% }) %>
      </div>
      <a href="/explorar/busca" class="block text-center text-sm text-primary-500 font-semibold py-3.5 hover:bg-primary-50/50 transition-colors border-t border-gray-100">
        Buscar pets
      </a>
    </div>
    <% } %>

  </aside>

  </div><!-- /flex wrapper -->

</main>


