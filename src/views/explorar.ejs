<!-- ═══ SCRIPTS ══════════════════════════════════ -->
<!-- ══════════════════════════════════════════════ -->
<script src="https://cdn.jsdelivr.net/npm/driver.js@1.3.1/dist/driver.js.iife.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.1/cropper.min.js"
        integrity="sha512-9KkIqdfN7ipE6L4oF4lF0W5f+Yk3nN7+E2n1Q0Y1kHjAPiVnJjOVT1fE2YTYL4e1kCwTxmU1nPqkRIKO1pV4Eg=="
        crossorigin="anonymous" referrerpolicy="no-referrer"></script>
<script src="/js/crop-modal.js"></script>
<script src="/js/post-image-lightbox.js"></script>
<script>
(function () {
  'use strict';

  /* ──────────── Config & State ──────────── */
  var currentPage = <%= page %>;
  var hasMore = <%= temMais ? 'true' : 'false' %>;
  var totalPostsLocal = <%= totalPosts %>;
  var totalFixadasLocal = <%= totalFixadas %>;
  var meuId = <%= isLogado ? usuario.id : 0 %>;
  var meuNome = '<%= isLogado ? usuario.nome.replace(/'/g, "\\'") : "" %>';
  var meuCorPerfil = '<%= isLogado ? (usuario.cor_perfil || "#ec5a1c") : "#ec5a1c" %>';
  var meuFotoPerfil = '<%= isLogado ? (usuario.foto_perfil || "") : "" %>';
  var isLoading = false;
  var selectedFile = null;
  var commentPostId = null;
  var searchTimeout = null;
  var commentsTarget = {
    list: null,
    petsC: null,
    petsL: null,
    group: 'commentsModal'
  };

  var feedContainer = document.getElementById('feedContainer');
  var scrollSentinel = document.getElementById('scrollSentinel');
  var viewObserver = null;
  var viewedPosts = new Set();
  var explorarLayoutSeed = <%= typeof layoutSeed !== 'undefined' ? (Number(layoutSeed) || 0) : 0 %>;

  function explorarDeferred(workFn, message) {
    var L = window.AIRPET_LOADING;
    if (L && typeof L.withDeferredOverlay === 'function') {
      return L.withDeferredOverlay(workFn, { message: message || 'Ainda a processar…' });
    }
    return Promise.resolve().then(workFn);
  }

  function explorarCoordinator() {
    return window.AIRPET_REQ_COORDINATOR || null;
  }

  function syncExploreMosaicCellSize() {
    var el = document.getElementById('feedContainer');
    if (!el || !el.classList.contains('explore-mosaic-grid')) return;
    var st = getComputedStyle(el);
    var cols = parseInt(st.getPropertyValue('--explore-cols').trim(), 10);
    if (!Number.isFinite(cols) || cols < 1) cols = 3;
    var gapStr = st.getPropertyValue('--explore-gap').trim() || '5px';
    var gap = parseFloat(gapStr, 10);
    if (!Number.isFinite(gap)) gap = 5;
    var w = el.clientWidth;
    var cell = (w - gap * (cols - 1)) / cols;
    el.style.setProperty('--explore-cell', Math.max(72, Math.floor(cell)) + 'px');
  }

  if (feedContainer) {
    if (window.ResizeObserver) {
      try {
        var exploreRo = new ResizeObserver(function () { syncExploreMosaicCellSize(); });
        exploreRo.observe(feedContainer);
      } catch (_) {}
    }
    window.addEventListener('resize', syncExploreMosaicCellSize);
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', syncExploreMosaicCellSize);
    } else {
      syncExploreMosaicCellSize();
    }
    var exploreTouchTimer = null;
    feedContainer.addEventListener('touchstart', function (e) {
      var tile = e.target.closest('.explore-tile-cell');
      if (!tile || !feedContainer.contains(tile)) return;
      tile.classList.add('explore-tile--touch');
      clearTimeout(exploreTouchTimer);
      exploreTouchTimer = setTimeout(function () { tile.classList.remove('explore-tile--touch'); }, 600);
    }, { passive: true });
    feedContainer.addEventListener('touchend', function (e) {
      var tile = e.target.closest('.explore-tile-cell');
      if (!tile) return;
      setTimeout(function () { tile.classList.remove('explore-tile--touch'); }, 180);
    }, { passive: true });
  }

  function registrarVisualizacao(postId, watchMs, source) {
    fetch('/explorar/api/interactions/view', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
      credentials: 'same-origin',
      body: JSON.stringify({ postId: postId, watchMs: watchMs || 1500, source: source || 'explorar' })
    }).catch(function () {});
  }

  function observarCardVisualizacao(card) {
    if (!card || !viewObserver) return;
    var postId = parseInt(card.getAttribute('data-post-id'), 10);
    if (!postId || viewedPosts.has(postId)) return;
    viewObserver.observe(card);
  }

  /* ──────────── Utilities ──────────── */
  function tempoRelativo(dateStr) {
    if (!dateStr) return '';
    var now = Date.now();
    var then = new Date(dateStr).getTime();
    var diff = Math.floor((now - then) / 1000);
    if (diff < 60) return 'agora';
    if (diff < 3600) return 'há ' + Math.floor(diff / 60) + 'm';
    if (diff < 86400) return 'há ' + Math.floor(diff / 3600) + 'h';
    if (diff < 604800) return 'há ' + Math.floor(diff / 86400) + 'd';
    var d = new Date(dateStr);
    var meses = ['jan','fev','mar','abr','mai','jun','jul','ago','set','out','nov','dez'];
    return d.getDate() + ' ' + meses[d.getMonth()];
  }

  function formatarDataHoraCompleta(dateStr) {
    if (!dateStr) return '';
    var d = new Date(dateStr);
    if (Number.isNaN(d.getTime())) return '';
    try {
      return d.toLocaleString('pt-BR', { day: 'numeric', month: 'short', year: 'numeric', hour: '2-digit', minute: '2-digit' });
    } catch (_) {
      return '';
    }
  }

  function atualizarTempos() {
    var els = document.querySelectorAll('.tempo-relativo');
    for (var i = 0; i < els.length; i++) {
      var t = els[i].getAttribute('data-time');
      if (t) els[i].textContent = tempoRelativo(t);
    }
  }

  function escapeHtml(str) {
    var div = document.createElement('div');
    div.textContent = str || '';
    return div.innerHTML;
  }

  function renderMencoes(texto) {
    return escapeHtml(texto).replace(/@(\S+)/g, '<span class="mention" data-user="$1">@$1</span>');
  }

  function normalizeWhatsappDigits(raw) {
    var digits = String(raw || '').replace(/\D+/g, '');
    if (!digits) return '';
    if (digits.length === 11 && digits.charAt(0) === '0') digits = digits.slice(1);
    if (digits.length === 10 || digits.length === 11) return '55' + digits;
    if (digits.length > 11 && digits.slice(0, 2) === '55') return digits;
    return digits;
  }

  function buildWhatsappUrl(phone, text) {
    var normalized = normalizeWhatsappDigits(phone);
    if (!normalized) return null;
    var msg = String(text || '').trim();
    if (!msg) return 'https://wa.me/' + normalized;
    return 'https://wa.me/' + normalized + '?text=' + encodeURIComponent(msg);
  }

  function toast(msg, tipo) {
    var el = document.createElement('div');
    var isErro = (tipo === 'erro');
    var borderColor = isErro ? 'var(--red)' : 'var(--accent)';
    el.className = 'fixed top-20 left-1/2 -translate-x-1/2 z-[70] px-5 py-3 rounded-2xl text-sm font-semibold shadow-xl ring-1 ring-black/5 animate-slideUp';
    el.style.background = 'var(--ink-2)';
    el.style.color = 'var(--text)';
    el.style.borderLeft = '5px solid ' + borderColor;
    el.textContent = msg;
    document.body.appendChild(el);
    setTimeout(function () { el.classList.add('fade-out'); }, 2500);
    setTimeout(function () { if (el.parentNode) el.parentNode.removeChild(el); }, 3000);
  }

  /* ──────────── Modal Helpers ──────────── */
  function abrirModal(id) {
    var modal = document.getElementById(id);
    if (!modal) return;
    modal.classList.remove('hidden');
    syncBodyScrollLock();
  }

  function fecharModal(id) {
    var modal = document.getElementById(id);
    if (!modal) return;
    modal.classList.add('hidden');
    syncBodyScrollLock();
  }

  function syncBodyScrollLock() {
    if (window.AIRPET_modalUi && typeof window.AIRPET_modalUi.refreshBodyScroll === 'function') {
      window.AIRPET_modalUi.refreshBodyScroll();
      return;
    }
    var ids = ['newPostModal', 'repostModal', 'commentModal', 'postDetailModal', 'commentsModal'];
    var any = false;
    for (var i = 0; i < ids.length; i++) {
      var el = document.getElementById(ids[i]);
      if (el && !el.classList.contains('hidden')) { any = true; break; }
    }
    if (!any) {
      var lb = document.getElementById('postImageLightbox');
      if (lb && !lb.classList.contains('hidden')) any = true;
    }
    document.body.style.overflow = any ? 'hidden' : '';
  }

