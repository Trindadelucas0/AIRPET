  function fotoExplorarOrganico(p) {
    if (!p) return '';
    if (p.foto && String(p.foto).trim()) return String(p.foto).trim();
    if (p.tipo === 'repost' && p.orig_foto && String(p.orig_foto).trim()) return String(p.orig_foto).trim();
    return '';
  }

  function postTemMidiaExplorarCliente(p) {
    if (!p) return false;
    if (p.is_petshop_publication) return !!(p.foto_url && String(p.foto_url).trim());
    if (p.is_sponsored) return !!(p.foto && String(p.foto).trim());
