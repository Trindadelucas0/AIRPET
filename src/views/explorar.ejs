  /* ──────────── Mention Autocomplete ──────────── */
  var mentionDropdown = document.getElementById('mentionDropdown');
  var postDetailMentionDropdown = document.getElementById('postDetailMentionDropdown');

  function getMentionDd(input) {
    if (input && input.id === 'postDetailCommentInput') return postDetailMentionDropdown;
    return mentionDropdown;
  }

  function handleMentionAutocomplete(input) {
    var dd = getMentionDd(input);
    if (!dd) return;
    var val = input.value;
    var cursor = input.selectionStart;
    var before = val.substring(0, cursor);
    var match = before.match(/@(\w*)$/);

    if (!match) {
      dd.classList.add('hidden');
      return;
    }
    var query = (match[1] || '').trim();
    clearTimeout(searchTimeout);
    searchTimeout = setTimeout(function () {
      var url = '/explorar/api/usuarios?seguindo=1';
      var qKey = query.toLowerCase();
      if (query.length) url += '&q=' + encodeURIComponent(query);

      try { if (window.AIRPET_REQ_COORDINATOR && window.AIRPET_REQ_COORDINATOR.cancelGroup) window.AIRPET_REQ_COORDINATOR.cancelGroup('mentionAutocomplete'); } catch (_) {}

      function fillDropdown(users) {
        if (!users || !users.length) { dd.classList.add('hidden'); return; }
        var html = '';
        users.forEach(function (u) {
          var uCor = u.cor_perfil || '#ec5a1c';
          var av = u.foto_perfil
            ? '<img src="' + escapeHtml(u.foto_perfil) + '" class="w-7 h-7 rounded-full object-cover" style="box-shadow:0 0 0 2px ' + escapeHtml(uCor) + '">'
            : '<span class="w-7 h-7 rounded-full flex items-center justify-center text-xs font-bold text-white bg-gray-400" style="box-shadow:0 0 0 2px ' + escapeHtml(uCor) + '">' + escapeHtml((u.nome || 'U').charAt(0).toUpperCase()) + '</span>';
          html += '<div class="autocomplete-item" data-nome="' + escapeHtml(u.nome) + '">' + av + '<span class="font-medium text-gray-700">' + escapeHtml(u.nome) + '</span></div>';
        });
        dd.innerHTML = html;
        dd.classList.remove('hidden');
      }

      if (typeof swrFetchGet === 'function') {
        var uidPart = (typeof meuId !== 'undefined' && meuId !== null && meuId !== undefined) ? String(meuId) : 'anon';
        var key = 'mentionUsers:' + uidPart + ':' + qKey;
        swrFetchGet({
          key: key,
          url: url,
          priority: window.AIRPET_REQ_COORDINATOR && window.AIRPET_REQ_COORDINATOR.PRIORITY
            ? window.AIRPET_REQ_COORDINATOR.PRIORITY.MEDIUM
            : 'MEDIUM',
          staleTimeMs: 300000,
          cacheTimeMs: 1800000,
          serveStale: false,
          group: 'mentionAutocomplete'
        }).then(function (res) {
          var users = res && res.data ? res.data : res;
          fillDropdown(users);
        }).catch(function () { dd.classList.add('hidden'); });
        return;
      }

      fetch(url, {
        headers: { 'Accept': 'application/json' },
        credentials: 'same-origin'
      })
      .then(function (r) { return r.json(); })
      .then(function (users) { fillDropdown(users); })
      .catch(function () { dd.classList.add('hidden'); });
    }, query.length ? 250 : 100);
  }

  function wireMentionPick(dd, inputEl) {
    if (!dd || !inputEl) return;
    dd.addEventListener('click', function (e) {
      var item = e.target.closest('.autocomplete-item');
      if (!item) return;
      var nome = item.getAttribute('data-nome');
      var val = inputEl.value;
      var cursor = inputEl.selectionStart;
      var before = val.substring(0, cursor);
      var after = val.substring(cursor);
      var replaced = before.replace(/@(\w*)$/, '@' + nome + ' ');
      inputEl.value = replaced + after;
      inputEl.focus();
      inputEl.setSelectionRange(replaced.length, replaced.length);
      dd.classList.add('hidden');
    });
  }
  wireMentionPick(mentionDropdown, commentInput);
  wireMentionPick(postDetailMentionDropdown, postDetailCommentInput);

  /* ──────────── Repost ──────────── */
  function abrirRepostModal(postId) {
    var card = document.querySelector('article[data-post-id="' + postId + '"]');
    if (!card) return;
    var preview = document.getElementById('repostPreviewContent');
    var avatarEl = card.querySelector('.post-author-avatar');
    var nameEl = card.querySelector('.post-author-name');
    var photoEl = card.querySelector('.post-photo');
    var textoPreview = '';
    var rawMeta = card.getAttribute('data-explorar-meta');
    if (rawMeta) {
      try {
        var pm = JSON.parse(decodeURIComponent(rawMeta));
        textoPreview = pm.texto || '';
      } catch (_) {}
    }

    var html = '<div class="flex items-center gap-2 mb-2">';
    if (avatarEl) {
      var cloned = avatarEl.cloneNode(true);
      cloned.className = cloned.className.replace(/w-10 h-10/g, 'w-7 h-7').replace('ring-2 ring-gray-100', '');
      html += cloned.outerHTML;
    }
    html += '<span class="text-xs font-semibold text-gray-700">' + escapeHtml(nameEl ? nameEl.textContent : '') + '</span></div>';
    if (textoPreview) html += '<p class="text-xs text-gray-600 line-clamp-3">' + escapeHtml(textoPreview) + '</p>';
    if (photoEl) html += '<img src="' + escapeHtml(photoEl.src) + '" class="mt-2 w-full max-h-[150px] object-cover rounded-xl" loading="lazy">';
    preview.innerHTML = html;

    document.getElementById('repostPostId').value = postId;
    document.getElementById('repostTexto').value = '';
    document.getElementById('btnRepostar').disabled = true;
    abrirModal('repostModal');
  }

  document.getElementById('repostTexto').addEventListener('input', function () {
    document.getElementById('btnRepostar').disabled = !this.value.trim();
  });

  document.getElementById('btnRepostar').addEventListener('click', function () {
    var postId = document.getElementById('repostPostId').value;
    var texto = document.getElementById('repostTexto').value.trim();
    if (!texto || !postId) return;
    var btnRep = this;
    var body = JSON.stringify({ texto: texto });
    var work = function () {
      return explorarDeferred(function () {
        var c = explorarCoordinator();
        if (c && typeof c.enqueue === 'function') {
          return c.enqueue({
            key: 'explorarRepost:' + postId,
            group: 'explorarRepost',
            priority: c.PRIORITY ? c.PRIORITY.MEDIUM : 'MEDIUM',
            fetchFn: function (signal) {
              return fetch('/explorar/post/' + postId + '/repost', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
                credentials: 'same-origin',
                body: body,
                signal: signal
              }).then(function (r) { return r.json(); });
            }
          });
        }
        return fetch('/explorar/post/' + postId + '/repost', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
          credentials: 'same-origin',
          body: body
        }).then(function (r) { return r.json(); });
      }, 'A republicar…');
    };
    var p = window.AIRPET_LOADING
      ? window.AIRPET_LOADING.runLocked({
        button: btnRep,
        busyText: '<span class="airpet-inline-dots">A republicar</span>'
      }, work)
      : work();
    p.then(function (data) {
      if (!data || !data.sucesso) {
        toast((data && data.mensagem) || 'Erro ao repostar.', 'erro');
        return;
      }
      fecharModal('repostModal');
      toast('Repostado!');
      var card = document.querySelector('article[data-post-id="' + postId + '"]');
      if (card) {
        var rpBtn = card.querySelector('.btn-repost');
        if (rpBtn) { rpBtn.classList.remove('text-gray-400'); rpBtn.classList.add('text-emerald-500'); }
        var cnt = card.querySelector('.count-reposts');
        if (cnt && data.totalReposts) cnt.textContent = data.totalReposts;
      }
      if (data.post && postTemMidiaExplorarCliente(data.post)) {
        totalPostsLocal = data.totalPosts || totalPostsLocal;
        feedContainer.classList.add('explore-mosaic-grid');
        feedContainer.insertAdjacentHTML('afterbegin', renderPostHTML(data.post));
        syncExploreMosaicCellSize();
        observarCardVisualizacao(feedContainer.firstElementChild);
      } else if (data.post) {
        totalPostsLocal = data.totalPosts || totalPostsLocal;
      }
      if (data.removido) {
        var old = document.getElementById('post-' + data.removido);
        if (old) { old.classList.add('fade-out'); setTimeout(function () { if (old.parentNode) old.parentNode.removeChild(old); }, 400); }
      }
    }).catch(function () { toast('Erro de conexão.', 'erro'); });
  });

