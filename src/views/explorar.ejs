  function enviarComentario(postId, texto, inputEl, actionBtn) {
    if (!texto) return;
    var isPetshop = String(postId || '').includes(':');
    var url = isPetshop
      ? '/explorar/petshops-post/' + encodeURIComponent(postId) + '/comentar'
      : '/explorar/post/' + postId + '/comentar';

    var payload = { texto: texto };
    if (commentReplyParentId && !isPetshop) payload.parent_id = parseInt(commentReplyParentId, 10);
    var body = JSON.stringify(payload);
    var sendBtn = actionBtn;
    if (!sendBtn && inputEl) {
      var row = inputEl.closest('.post-comment-row');
      if (row) sendBtn = row.querySelector('.btn-enviar-inline');
    }
    if (!sendBtn && inputEl) {
      if (inputEl.id === 'commentInput') sendBtn = document.getElementById('btnEnviarComentario');
      else if (inputEl.id === 'postDetailCommentInput') sendBtn = document.getElementById('postDetailBtnEnviar');
    }

    var runInner = function () {
      var c = explorarCoordinator();
      if (c && typeof c.enqueue === 'function') {
        return c.enqueue({
          key: 'explorarComentar:' + postId,
          group: 'explorarComentar',
          priority: c.PRIORITY ? c.PRIORITY.HIGH : 'HIGH',
          fetchFn: function (signal) {
            return fetch(url, {
              method: 'POST',
              headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
              credentials: 'same-origin',
              body: body,
              signal: signal
            }).then(function (r) { return r.json(); });
          }
        });
      }
      return fetch(url, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
        credentials: 'same-origin',
        body: body
      }).then(function (r) { return r.json(); });
    };
    var run = function () {
      return explorarDeferred(runInner, 'A enviar comentário…');
    };
    var p = window.AIRPET_LOADING && sendBtn
      ? window.AIRPET_LOADING.runLocked({
        button: sendBtn,
        busyText: '<span class="airpet-inline-dots">Enviando</span>'
      }, run)
      : run();
    p.then(function (data) {
      if (data && data.sucesso) {
        if (inputEl) inputEl.value = '';
        clearCommentReplyTarget();
        if (commentPostId === postId) carregarComentarios(postId);
      } else if (data && !data.sucesso) {
        toast(data.mensagem || 'Erro ao comentar.', 'erro');
      }
    }).catch(function () { toast('Erro de conexão.', 'erro'); });
  }

