  function abrirPostDetailModal() {
    if (!postDetailModal) return;
    var wasHidden = postDetailModal.classList.contains('hidden');
    postDetailModal.classList.remove('hidden');
    postDetailModal.setAttribute('aria-hidden', 'false');
