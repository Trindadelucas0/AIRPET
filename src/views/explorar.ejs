  function carregarComentarios(postId) {
    var list = commentsTarget.list || document.getElementById('commentList');
    var isPetshop = String(postId || '').includes(':');
    var cacheTimeMs = 1800000; // 30 min
    var staleTimeMs = 300000; // 5 min
    var key = 'comments:' + postId;
    var group = commentsTarget.group || 'commentsModal';

    try { if (window.AIRPET_REQ_COORDINATOR && window.AIRPET_REQ_COORDINATOR.cancelGroup) window.AIRPET_REQ_COORDINATOR.cancelGroup(group); } catch (_) {}

    list.innerHTML = '<div class="space-y-3"><div class="skeleton h-12 w-full"></div><div class="skeleton h-12 w-3/4"></div><div class="skeleton h-12 w-5/6"></div></div>';

    var petsContainer = commentsTarget.petsC || document.getElementById('petsProximosContainer');
    var petsList = commentsTarget.petsL || document.getElementById('petsProximosList');
    petsContainer.classList.add('hidden');
    petsList.innerHTML = '';

    var url = isPetshop
      ? '/explorar/petshops-post/' + encodeURIComponent(postId) + '/comentarios'
      : '/explorar/post/' + postId + '/comentarios';

    var didLoadPets = false;
    function maybeLoadPets() {
      if (didLoadPets) return;
      didLoadPets = true;
      if (!isPetshop) carregarPetsProximos(postId, petsContainer, petsList);
    }

    function renderData(data) {
      if (!data || !data.sucesso) return;
      if (!data.comentarios || data.comentarios.length === 0) {
        list.innerHTML = '<div class="text-center py-10"><p class="text-sm text-gray-400">Nenhum comentário ainda.</p><p class="text-xs text-gray-300 mt-1">Seja o primeiro a comentar!</p></div>';
      } else {
        var html = '';
        if (window.AIRPET_commentRender && window.AIRPET_commentRender.renderList) {
          html = window.AIRPET_commentRender.renderList(data.comentarios, {
            meuId: meuId,
            escapeHtml: escapeHtml,
            renderMencoes: renderMencoes,
            tempoRelativo: tempoRelativo,
            useDataTimeAttr: true,
            allowReply: !!(meuId) && !isPetshop
          });
        } else {
          html = '<div class="space-y-4">';
          data.comentarios.forEach(function (c) { html += renderComentario(c); });
          html += '</div>';
        }
        list.innerHTML = html;
        var tempos = list.querySelectorAll('.tempo-relativo');
        for (var i = 0; i < tempos.length; i++) {
          var t = tempos[i].getAttribute('data-time');
          if (t) tempos[i].textContent = tempoRelativo(t);
        }
      }
      maybeLoadPets();
    }

    // Cache imediato (sem skeleton), se existir.
    if (window.AIRPET_SWR_CACHE && window.AIRPET_SWR_CACHE.getCached) {
      var cached = window.AIRPET_SWR_CACHE.getCached(key, cacheTimeMs);
      if (cached && cached.value) renderData(cached.value);
    }

    if (typeof swrFetchGet === 'function') {
      explorarDeferred(function () {
        return swrFetchGet({
          key: key,
          url: url,
          priority: window.AIRPET_REQ_COORDINATOR && window.AIRPET_REQ_COORDINATOR.PRIORITY
            ? window.AIRPET_REQ_COORDINATOR.PRIORITY.HIGH
            : 'HIGH',
          staleTimeMs: staleTimeMs,
          cacheTimeMs: cacheTimeMs,
          group: group,
          onUpdate: function (data) {
            if (commentPostId !== postId) return;
            renderData(data);
          }
        }).then(function (res) {
          if (commentPostId !== postId) return;
          renderData(res.data);
        }).catch(function () {
          if (commentPostId !== postId) return;
          list.innerHTML = '<div class="text-center py-8"><p class="text-sm text-red-400">Erro ao carregar comentários.</p></div>';
          maybeLoadPets();
        });
      }, 'A carregar comentários…');
      return;
    }

    explorarDeferred(function () {
      return fetch(url, {
        headers: { 'Accept': 'application/json' },
        credentials: 'same-origin'
      })
        .then(function (r) { return r.json(); })
        .then(function (data) {
          if (commentPostId !== postId) return;
          renderData(data);
        })
        .catch(function () {
          if (commentPostId !== postId) return;
          list.innerHTML = '<div class="text-center py-8"><p class="text-sm text-red-400">Erro ao carregar comentários.</p></div>';
          maybeLoadPets();
        });
    }, 'A carregar comentários…');
  }

  function carregarPetsProximos(postId, petsContainerOpt, petsListOpt) {
    var petsContainer = petsContainerOpt || document.getElementById('petsProximosContainer');
    var petsList = petsListOpt || document.getElementById('petsProximosList');
    explorarDeferred(function () {
