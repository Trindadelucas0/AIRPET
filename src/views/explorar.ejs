      requestAnimationFrame(function () { postDetailModal.classList.add('is-open'); });
    });
    if (wasHidden && typeof window.AIRPET_modalHistory_afterPostDetailOpen === 'function') {
      window.AIRPET_modalHistory_afterPostDetailOpen();
