  function abrirComentarios(postId) {
    clearCommentReplyTarget();
    commentsTarget.list = document.getElementById('commentList');
    commentsTarget.petsC = document.getElementById('petsProximosContainer');
    commentsTarget.petsL = document.getElementById('petsProximosList');
    commentsTarget.group = 'commentsModal';
    commentPostId = postId;
    var input = document.getElementById('commentInput');
    input.setAttribute('data-post-id', postId);
