      commentsTarget.petsL = document.getElementById('postDetailPetsList');
      commentsTarget.group = 'postDetailComments';
      if (meuId && comp && hint && inpDetail && btnDet) {
        comp.classList.remove('hidden');
        hint.classList.add('hidden');
        inpDetail.disabled = false;
        inpDetail.setAttribute('data-post-id', commentPostId);
        inpDetail.value = '';
