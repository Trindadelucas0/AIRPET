<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <title>Lista de espera | AIRPET</title>
  <meta name="robots" content="noindex">
  <meta name="theme-color" content="#ec5a1c">
  <link rel="icon" type="image/svg+xml" href="/images/icons/icon-192.svg">
  <link rel="stylesheet" href="/css/output.css">
</head>
<body class="min-h-screen bg-white text-gray-800 antialiased">

  <header class="border-b border-gray-200 bg-white/95 backdrop-blur-md sticky top-0 z-40">
    <div class="max-w-lg mx-auto px-4 h-14 flex items-center justify-between">
      <a href="/proteger-meu-pet" class="text-sm font-semibold text-gray-500 hover:text-primary-600 flex items-center gap-1">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
        Voltar
      </a>
      <span class="font-display font-extrabold text-gray-900">AIRPET</span>
    </div>
  </header>

  <div class="sticky top-14 z-30 bg-white/95 backdrop-blur border-b border-gray-200">
    <div class="max-w-lg mx-auto px-4 py-3">
      <div class="flex items-center justify-between text-xs font-semibold text-gray-500 mb-2">
        <span id="leProgressLabel">Passo 1 de 6</span>
        <span id="leProgressPct">17%</span>
      </div>
      <div class="h-2 rounded-full bg-gray-200 overflow-hidden">
        <div id="leProgressBar" class="h-full bg-primary-500 rounded-full transition-all duration-300 ease-out" style="width: 17%"></div>
      </div>
    </div>
  </div>

  <main class="max-w-lg mx-auto px-4 py-6 pb-28">
    <div id="listaEsperaWizard" class="relative overflow-hidden">

      <!-- Passo 1 -->
      <section class="le-step" data-step="1">
        <h1 class="text-2xl font-display font-extrabold text-gray-900 leading-tight">Antes de tudo, como te chamamos?</h1>
        <p class="mt-2 text-sm text-gray-600">Promessa: zero spam. Só te avisamos quando as vagas de teste abrirem.</p>
        <div class="mt-6 space-y-4">
          <div>
            <label for="leNome" class="block text-sm font-semibold text-gray-700 mb-1">Seu nome *</label>
            <input type="text" id="leNome" maxlength="120" autocomplete="name" placeholder="Seu nome"
              class="w-full rounded-xl border border-gray-200 bg-white px-4 py-3 text-gray-900 shadow-sm focus:border-primary-500 focus:ring-2 focus:ring-primary-500/20 outline-none">
          </div>
          <div>
            <label for="leEmail" class="block text-sm font-semibold text-gray-700 mb-1">E-mail *</label>
            <input type="email" id="leEmail" autocomplete="email" placeholder="seu@email.com"
              class="w-full rounded-xl border border-gray-200 bg-white px-4 py-3 text-gray-900 shadow-sm focus:border-primary-500 focus:ring-2 focus:ring-primary-500/20 outline-none">
          </div>
        </div>
        <p id="errStep1" class="mt-3 text-sm text-red-600 hidden" role="alert"></p>
        <div class="mt-8 flex flex-col gap-3">
          <button type="button" class="le-next w-full rounded-full bg-primary-500 hover:bg-primary-600 text-white font-bold py-3.5 shadow-lg shadow-primary-500/20 transition-colors">Continuar</button>
        </div>
      </section>

      <!-- Passo 2 -->
      <section class="le-step hidden" data-step="2">
        <h1 class="text-2xl font-display font-extrabold text-gray-900 leading-tight">Com quem você divide a vida?</h1>
        <p class="mt-4 text-sm font-semibold text-gray-500 uppercase tracking-wide">Tipo de pet *</p>
        <div class="mt-3 grid grid-cols-3 gap-2" data-single="tipo_pet">
          <button type="button" class="le-pet-card flex flex-col items-center gap-2 rounded-2xl border-2 border-gray-200 bg-white p-4 hover:border-primary-300 transition-colors" data-value="cachorro">
            <span class="text-4xl" aria-hidden="true">🐶</span>
            <span class="text-sm font-bold text-gray-800">Cachorro</span>
          </button>
          <button type="button" class="le-pet-card flex flex-col items-center gap-2 rounded-2xl border-2 border-gray-200 bg-white p-4 hover:border-primary-300 transition-colors" data-value="gato">
            <span class="text-4xl" aria-hidden="true">🐱</span>
            <span class="text-sm font-bold text-gray-800">Gato</span>
          </button>
          <button type="button" class="le-pet-card flex flex-col items-center gap-2 rounded-2xl border-2 border-gray-200 bg-white p-4 hover:border-primary-300 transition-colors" data-value="outro">
            <span class="text-4xl" aria-hidden="true">🐾</span>
            <span class="text-sm font-bold text-gray-800">Outro</span>
          </button>
        </div>
        <p class="mt-6 text-sm font-semibold text-gray-500 uppercase tracking-wide">Quantos pets? *</p>
        <div class="mt-3 flex flex-wrap gap-2" data-single="qtd_pets">
          <button type="button" class="le-chip rounded-full border-2 border-gray-200 bg-white px-5 py-2 text-sm font-semibold text-gray-700" data-value="1">1</button>
          <button type="button" class="le-chip rounded-full border-2 border-gray-200 bg-white px-5 py-2 text-sm font-semibold text-gray-700" data-value="2">2</button>
          <button type="button" class="le-chip rounded-full border-2 border-gray-200 bg-white px-5 py-2 text-sm font-semibold text-gray-700" data-value="3+">3 ou mais</button>
        </div>
        <p id="errStep2" class="mt-3 text-sm text-red-600 hidden" role="alert"></p>
        <div class="mt-8 flex flex-col sm:flex-row gap-3">
          <button type="button" class="le-next flex-1 rounded-full bg-primary-500 hover:bg-primary-600 text-white font-bold py-3.5">Continuar</button>
          <button type="button" class="le-prev rounded-full border border-gray-200 bg-white text-gray-700 font-semibold py-3.5 px-6">Voltar</button>
        </div>
      </section>

      <!-- Passo 3 -->
      <section class="le-step hidden" data-step="3">
        <h1 class="text-2xl font-display font-extrabold text-gray-900 leading-tight">Já viveu esse pesadelo?</h1>
        <p class="mt-2 text-sm text-gray-600">Não tem resposta errada — queremos entender o que você já passou.</p>
        <div class="mt-6 space-y-3" data-single="ja_perdeu_pet">
          <button type="button" class="le-big-card w-full text-left rounded-2xl border-2 border-gray-200 bg-white p-5 flex gap-4 items-start hover:border-primary-300 transition-colors" data-value="sim">
            <span class="text-3xl shrink-0" aria-hidden="true">😰</span>
            <span class="font-semibold text-gray-900">Sim, já perdi um pet</span>
          </button>
          <button type="button" class="le-big-card w-full text-left rounded-2xl border-2 border-gray-200 bg-white p-5 flex gap-4 items-start hover:border-primary-300 transition-colors" data-value="quase">
            <span class="text-3xl shrink-0" aria-hidden="true">😅</span>
            <span class="font-semibold text-gray-900">Quase perdi, foi por pouco</span>
          </button>
          <button type="button" class="le-big-card w-full text-left rounded-2xl border-2 border-gray-200 bg-white p-5 flex gap-4 items-start hover:border-primary-300 transition-colors" data-value="nao">
            <span class="text-3xl shrink-0" aria-hidden="true">😨</span>
            <span class="font-semibold text-gray-900">Nunca perdi, mas tenho medo</span>
          </button>
        </div>
        <p id="errStep3" class="mt-3 text-sm text-red-600 hidden" role="alert"></p>
        <div class="mt-8 flex flex-col sm:flex-row gap-3">
          <button type="button" class="le-next flex-1 rounded-full bg-primary-500 hover:bg-primary-600 text-white font-bold py-3.5">Continuar</button>
          <button type="button" class="le-prev rounded-full border border-gray-200 bg-white text-gray-700 font-semibold py-3.5 px-6">Voltar</button>
        </div>
      </section>

      <!-- Passo 4 -->
      <section class="le-step hidden" data-step="4">
        <h1 class="text-2xl font-display font-extrabold text-gray-900 leading-tight">Se sumisse agora, qual seria seu primeiro movimento?</h1>
        <p class="mt-2 text-sm text-gray-600">Marque tudo que você realmente faria — não o que acha certo.</p>
        <div class="mt-6 space-y-2" data-multi="metodos_busca">
          <label class="le-check flex items-center gap-3 rounded-xl border-2 border-gray-200 bg-white p-4 cursor-pointer hover:border-primary-200 has-[:checked]:border-primary-500 has-[:checked]:bg-primary-50/50">
            <input type="checkbox" class="le-check-input sr-only" value="whatsapp">
            <span class="text-xl" aria-hidden="true">📱</span>
            <span class="text-sm font-semibold text-gray-800">Grupos de WhatsApp do bairro</span>
          </label>
          <label class="le-check flex items-center gap-3 rounded-xl border-2 border-gray-200 bg-white p-4 cursor-pointer hover:border-primary-200 has-[:checked]:border-primary-500 has-[:checked]:bg-primary-50/50">
            <input type="checkbox" class="le-check-input sr-only" value="facebook">
            <span class="text-xl" aria-hidden="true">📣</span>
            <span class="text-sm font-semibold text-gray-800">Facebook / Instagram</span>
          </label>
          <label class="le-check flex items-center gap-3 rounded-xl border-2 border-gray-200 bg-white p-4 cursor-pointer hover:border-primary-200 has-[:checked]:border-primary-500 has-[:checked]:bg-primary-50/50">
            <input type="checkbox" class="le-check-input sr-only" value="panfletos">
            <span class="text-xl" aria-hidden="true">🖨️</span>
            <span class="text-sm font-semibold text-gray-800">Panfletos na rua</span>
          </label>
          <label class="le-check flex items-center gap-3 rounded-xl border-2 border-gray-200 bg-white p-4 cursor-pointer hover:border-primary-200 has-[:checked]:border-primary-500 has-[:checked]:bg-primary-50/50">
            <input type="checkbox" class="le-check-input sr-only" value="rua">
            <span class="text-xl" aria-hidden="true">🚶</span>
            <span class="text-sm font-semibold text-gray-800">Sair andando e procurar</span>
          </label>
          <label class="le-check flex items-center gap-3 rounded-xl border-2 border-gray-200 bg-white p-4 cursor-pointer hover:border-primary-200 has-[:checked]:border-primary-500 has-[:checked]:bg-primary-50/50">
            <input type="checkbox" class="le-check-input sr-only" value="veterinario">
            <span class="text-xl" aria-hidden="true">🏥</span>
            <span class="text-sm font-semibold text-gray-800">Ligar para clínicas e abrigos</span>
          </label>
          <label class="le-check flex items-center gap-3 rounded-xl border-2 border-gray-200 bg-white p-4 cursor-pointer hover:border-primary-200 has-[:checked]:border-primary-500 has-[:checked]:bg-primary-50/50">
            <input type="checkbox" class="le-check-input sr-only" value="outro">
            <span class="text-xl" aria-hidden="true">🤷</span>
            <span class="text-sm font-semibold text-gray-800">Não saberia o que fazer</span>
          </label>
        </div>
        <p id="errStep4" class="mt-3 text-sm text-red-600 hidden" role="alert"></p>
        <div class="mt-8 flex flex-col sm:flex-row gap-3">
          <button type="button" class="le-next flex-1 rounded-full bg-primary-500 hover:bg-primary-600 text-white font-bold py-3.5">Continuar</button>
          <button type="button" class="le-prev rounded-full border border-gray-200 bg-white text-gray-700 font-semibold py-3.5 px-6">Voltar</button>
        </div>
      </section>

      <!-- Passo 5 -->
      <section class="le-step hidden" data-step="5">
        <h1 class="text-2xl font-display font-extrabold text-gray-900 leading-tight">Na hora do desespero, o que mais te salvaria?</h1>
        <p class="mt-2 text-sm text-gray-600">Escolha até 2 — isso define o que priorizamos primeiro.</p>
        <div class="mt-6 space-y-2" data-multi="prioridades" data-max="2">
          <label class="le-check le-prio flex items-center gap-3 rounded-xl border-2 border-gray-200 bg-white p-4 cursor-pointer hover:border-primary-200 has-[:checked]:border-primary-500 has-[:checked]:bg-primary-50/50">
            <input type="checkbox" class="le-check-input sr-only" value="identificar_dono">
            <span class="text-xl" aria-hidden="true">🪪</span>
            <span class="text-sm font-semibold text-gray-800">Saber na hora de quem é o pet</span>
          </label>
          <label class="le-check le-prio flex items-center gap-3 rounded-xl border-2 border-gray-200 bg-white p-4 cursor-pointer hover:border-primary-200 has-[:checked]:border-primary-500 has-[:checked]:bg-primary-50/50">
            <input type="checkbox" class="le-check-input sr-only" value="contato_tutor">
            <span class="text-xl" aria-hidden="true">📞</span>
            <span class="text-sm font-semibold text-gray-800">Falar com o dono do pet em segundos</span>
          </label>
          <label class="le-check le-prio flex items-center gap-3 rounded-xl border-2 border-gray-200 bg-white p-4 cursor-pointer hover:border-primary-200 has-[:checked]:border-primary-500 has-[:checked]:bg-primary-50/50">
            <input type="checkbox" class="le-check-input sr-only" value="ultima_localizacao">
            <span class="text-xl" aria-hidden="true">📍</span>
            <span class="text-sm font-semibold text-gray-800">Ver por onde o pet passou</span>
          </label>
        </div>
        <p id="errStep5" class="mt-3 text-sm text-red-600 hidden" role="alert"></p>
        <div class="mt-8 flex flex-col sm:flex-row gap-3">
          <button type="button" class="le-next flex-1 rounded-full bg-primary-500 hover:bg-primary-600 text-white font-bold py-3.5">Continuar</button>
          <button type="button" class="le-prev rounded-full border border-gray-200 bg-white text-gray-700 font-semibold py-3.5 px-6">Voltar</button>
        </div>
      </section>

      <!-- Passo 6 -->
      <section class="le-step hidden" data-step="6">
        <h1 class="text-2xl font-display font-extrabold text-gray-900 leading-tight">Você é exatamente quem queremos no AIRPET.</h1>
        <p class="mt-2 text-sm text-gray-600">Última coisa: onde você mora? Priorizamos cidades com mais candidatos.</p>
        <div class="mt-6 grid grid-cols-3 gap-2">
          <div class="col-span-2">
            <label for="leCidade" class="block text-sm font-semibold text-gray-700 mb-1">Cidade</label>
            <input type="text" id="leCidade" maxlength="80" placeholder="Sua cidade"
              class="w-full rounded-xl border border-gray-200 bg-white px-4 py-3 shadow-sm focus:border-primary-500 focus:ring-2 focus:ring-primary-500/20 outline-none">
          </div>
          <div>
            <label for="leEstado" class="block text-sm font-semibold text-gray-700 mb-1">UF</label>
            <input type="text" id="leEstado" maxlength="2" placeholder="UF"
              class="w-full rounded-xl border border-gray-200 bg-white px-4 py-3 uppercase shadow-sm focus:border-primary-500 focus:ring-2 focus:ring-primary-500/20 outline-none">
          </div>
        </div>
        <div class="mt-4">
          <label for="leTelefone" class="block text-sm font-semibold text-gray-700 mb-1">Telefone</label>
          <p class="text-xs text-gray-500 mb-2">WhatsApp facilita o contato para avisos do AIRPET</p>
          <input type="tel" id="leTelefone" maxlength="30" placeholder="(00) 00000-0000" autocomplete="tel"
            class="w-full rounded-xl border border-gray-200 bg-white px-4 py-3 shadow-sm focus:border-primary-500 focus:ring-2 focus:ring-primary-500/20 outline-none">
        </div>
        <p class="mt-6 text-sm font-semibold text-gray-500 uppercase tracking-wide">Quer entrar nas primeiras vagas do AIRPET? *</p>
        <div class="mt-3 space-y-2" data-single="beta_interesse">
          <button type="button" class="le-big-card w-full text-left rounded-2xl border-2 border-gray-200 bg-white p-4 flex gap-3 items-center hover:border-primary-300 transition-colors" data-value="sim">
            <span class="text-2xl" aria-hidden="true">✅</span>
            <span class="font-semibold text-gray-900">Sim, quero ser dos primeiros</span>
          </button>
          <button type="button" class="le-big-card w-full text-left rounded-2xl border-2 border-gray-200 bg-white p-4 flex gap-3 items-center hover:border-primary-300 transition-colors" data-value="talvez">
            <span class="text-2xl" aria-hidden="true">🤔</span>
            <span class="font-semibold text-gray-900">Talvez, depende</span>
          </button>
          <button type="button" class="le-big-card w-full text-left rounded-2xl border-2 border-gray-200 bg-white p-4 flex gap-3 items-center hover:border-primary-300 transition-colors" data-value="nao">
            <span class="text-2xl" aria-hidden="true">⏳</span>
            <span class="font-semibold text-gray-900">Ainda não, mas quero acompanhar</span>
          </button>
        </div>
        <input type="text" id="leWebsite" name="website" tabindex="-1" autocomplete="off" class="absolute opacity-0 pointer-events-none h-0 w-0" aria-hidden="true">
        <p id="errStep6" class="mt-3 text-sm text-red-600 hidden" role="alert"></p>
        <div class="mt-8 flex flex-col gap-3">
          <button type="button" id="leSubmit" class="w-full rounded-full bg-primary-500 hover:bg-primary-600 disabled:opacity-60 disabled:cursor-not-allowed text-white font-bold py-3.5 shadow-lg shadow-primary-500/20 flex items-center justify-center gap-2 transition-colors">
            <span id="leSubmitLabel">Garantir minha vaga</span>
            <svg id="leSubmitSpinner" class="hidden w-5 h-5 animate-spin" fill="none" viewBox="0 0 24 24" aria-hidden="true">
              <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
              <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
            </svg>
          </button>
          <button type="button" class="le-prev rounded-full border border-gray-200 bg-white text-gray-700 font-semibold py-3">Voltar</button>
        </div>
        <p class="mt-4 text-xs text-gray-400 text-center">
          <a href="/privacidade" class="underline hover:text-primary-600">Política de privacidade</a>
        </p>
      </section>

    </div>
  </main>

  <style>
    @media (prefers-reduced-motion: no-preference) {
      .le-step { transition: transform 0.35s ease, opacity 0.35s ease; }
      .le-step.le-enter { transform: translateX(1.5rem); opacity: 0; }
      .le-step.le-exit { transform: translateX(-1.5rem); opacity: 0; }
    }
    .le-pet-card.le-selected, .le-chip.le-selected, .le-big-card.le-selected {
      border-color: rgb(236 90 28);
      background-color: rgb(255 247 237);
      box-shadow: 0 0 0 1px rgb(236 90 28 / 0.2);
    }
  </style>
  <script src="/js/lista-espera-wizard.js" defer></script>
</body>
</html>
