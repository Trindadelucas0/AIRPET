<%
  locals.extraHead = `
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@500;700;800&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,400&display=swap" rel="stylesheet">
    <style>
      .feed-page {
        /* Tokens locais do feed para evitar impacto global */
        --radius-card: 16px;
        --radius-btn: 12px;
        --font-body: "DM Sans", sans-serif;
        --feed-bg-start: #f9fafc;
        --feed-bg-mid: #f7f9fc;
        --feed-bg-end: #f2f6fb;
        --feed-surface: #ffffff;
        --feed-surface-soft: #f7f9fd;
        --feed-border: #d9e2f1;
        --feed-border-hover: #c2d0e7;
        --feed-shadow: 0 12px 26px rgba(36, 55, 90, 0.1);
        --feed-shadow-soft: 0 6px 14px rgba(36, 55, 90, 0.07);
        --feed-text: #1f2c44;
        --feed-muted: #596a89;
        --feed-muted-soft: #7483a0;
      }

      .feed-page {
        position: relative;
        isolation: isolate;
      }

      .feed-page::before {
        content: "";
        position: fixed;
        inset: 56px 0 0;
        z-index: -1;
        pointer-events: none;
        background:
          radial-gradient(1000px 460px at 8% -12%, rgba(125, 160, 236, 0.22), transparent 68%),
          radial-gradient(920px 420px at 92% -10%, rgba(242, 96, 32, 0.1), transparent 70%),
          linear-gradient(180deg, var(--feed-bg-start) 0%, var(--feed-bg-mid) 55%, var(--feed-bg-end) 100%);
      }

      /* ── TOP HEADER BAR ── */
      .feed-topbar {
        position: relative; z-index: 1;
        background: color-mix(in srgb, var(--feed-surface) 92%, transparent);
        backdrop-filter: blur(8px) saturate(120%);
        -webkit-backdrop-filter: blur(8px);
        border-bottom: 1px solid var(--feed-border);
        padding: 10px 0;
      }

      .feed-topbar-inner {
        max-width: 1100px;
        margin: 0 auto;
        padding: 0 20px;
        display: flex;
        align-items: center;
        justify-content: space-between;
      }

      .feed-topbar h1 {
        font-family: var(--font-body);
        font-size: 19px;
        font-weight: 700;
        color: var(--feed-text);
        letter-spacing: -0.015em;
      }

      .feed-tabs {
        display: flex;
        gap: 8px;
        margin-top: 10px;
        max-width: 360px;
      }
      .feed-tab {
        flex: 1;
        text-align: center;
        padding: 9px 10px;
        border-radius: 12px;
        font-size: 13px;
        font-weight: 700;
        text-decoration: none;
        color: var(--feed-muted);
        border: 1px solid var(--feed-border);
        background: var(--feed-surface);
      }
      .feed-tab--active {
        color: #fff;
        background: #ec5a1c;
        border-color: #ec5a1c;
      }

      .feed-welcome {
        font-size: 12px;
        color: var(--feed-muted);
        background: color-mix(in srgb, var(--feed-surface-soft) 88%, transparent);
        border: 1px solid var(--feed-border);
        padding: 6px 10px;
        border-radius: 999px;
        line-height: 1;
      }

      /* ── LAYOUT ── */
      .feed-layout {
        max-width: 1100px;
        margin: 0 auto;
        padding: 24px 20px 80px;
        display: grid;
        grid-template-columns: minmax(0, 1fr) 300px;
        gap: 24px;
        align-items: start;
      }

      @media (max-width: 900px) { .feed-layout { grid-template-columns: 1fr; } }
      @media (max-width: 900px) { .feed-sidebar { display: none; } }
      @media (max-width: 640px) {
        .feed-layout { padding: 16px 12px 78px; gap: 14px; }
        .feed-topbar-inner { padding: 0 12px; }
        .feed-welcome { font-size: 11px; padding: 5px 9px; }
        .composer { padding: 14px; border-radius: 14px; }
        .post-header { padding: 14px 14px 10px; gap: 12px; }
        .post-text { padding: 0 14px 12px; font-size: 13.5px; }
        .post-embed { margin: 0 14px 12px; }
        .post-view-comments { padding: 0 14px 10px; }
        .post-comment-row { padding: 10px 14px 13px; }
        .post-action-btn { padding: 11px 6px; font-size: 12px; gap: 5px; }
      }

      /* ── SEARCH (mobile) ── */
      .mobile-search {
        display: flex; align-items: center; gap: 10px;
        background: var(--feed-surface-soft);
        border: 1px solid var(--feed-border);
        border-radius: 12px;
        padding: 10px 14px;
        color: var(--feed-muted);
        font-size: 13px;
        text-decoration: none;
        margin-bottom: 16px;
        transition: all 0.2s;
      }
      .mobile-search:hover { border-color: var(--feed-border-hover); color: var(--feed-text); text-decoration: none; }

      /* ── COMPOSER ── */
      .composer {
        background: var(--feed-surface);
        border: 1px solid var(--feed-border);
        border-radius: var(--radius-card);
        padding: 20px;
        margin-bottom: 16px;
        box-shadow: var(--feed-shadow-soft);
      }

      .composer-top {
        display: flex; gap: 12px; align-items: flex-start;
        margin-bottom: 14px;
      }

      .composer textarea.composer-textarea {
        flex: 1;
        width: 100%;
        box-sizing: border-box;
        min-height: 104px;
        padding: 12px 14px;
        line-height: 1.5;
        resize: vertical;
        font-family: var(--font-body);
        font-size: 15px;
        outline: none;
        background: var(--feed-surface-soft) !important;
        border: 1px solid var(--feed-border) !important;
        border-radius: 12px !important;
        color: var(--feed-text) !important;
      }

      .composer textarea.composer-textarea::placeholder { color: var(--feed-muted-soft); }

      .composer textarea.composer-textarea:focus {
        border-color: rgba(242, 96, 32, 0.45) !important;
        box-shadow: 0 0 0 3px rgba(242, 96, 32, 0.08) !important;
      }

      .composer-actions {
        display: flex; align-items: center; justify-content: space-between;
        border-top: 1px solid var(--feed-border);
        padding-top: 14px;
      }

      .composer-tools {
        display: flex; gap: 4px;
      }

      .composer-tool-btn {
        width: 34px; height: 34px; border-radius: 8px;
        background: transparent; border: none; cursor: pointer;
        color: var(--feed-muted); font-size: 14px;
        display: flex; align-items: center; justify-content: center;
        transition: all 0.15s;
      }
      .composer-tool-btn:hover { background: var(--feed-surface-soft); color: var(--accent); }

      .btn-post {
        display: inline-flex; align-items: center; gap: 7px;
        padding: 9px 20px;
        background: var(--accent);
        color: #fff;
        border: none; border-radius: var(--radius-btn);
        font-family: var(--font-body);
        font-size: 14px; font-weight: 700;
        cursor: pointer; transition: all 0.2s;
      }
      .btn-post:hover { background: var(--accent-light); transform: translateY(-1px); }
      .btn-post:disabled { opacity: 0.5; cursor: not-allowed; transform: none; }

      @media (max-width: 480px) {
        .composer { padding: 14px 12px; margin-bottom: 12px; }
        .composer-top { gap: 10px; }
        .composer textarea.composer-textarea {
          min-height: 96px;
          font-size: 16px;
          padding: 12px;
        }
        .composer-actions {
          flex-direction: column-reverse;
          align-items: stretch;
          gap: 12px;
          padding-top: 12px;
        }
        .composer-actions > div:last-child {
          display: flex;
          flex-direction: column;
          gap: 10px;
          width: 100%;
        }
        .composer-tools { flex-wrap: wrap; }
        .composer-tool-btn {
          width: 44px;
          height: 44px;
          font-size: 17px;
          border-radius: 10px;
        }
        .btn-post {
          width: 100%;
          justify-content: center;
          min-height: 48px;
          padding: 12px 18px;
          font-size: 16px;
        }
        .feed-tabs { flex-wrap: wrap; gap: 6px; }
        .feed-tab { min-height: 44px; padding: 10px 14px; font-size: 13px; }
      }

      /* ── POST CARD ── */
      .post-card {
        background: var(--feed-surface);
        border: 1px solid var(--feed-border);
        border-radius: var(--radius-card);
        overflow: hidden;
        margin-bottom: 14px;
        transition: border-color 0.2s, transform 0.2s, box-shadow 0.2s;
        box-shadow: var(--feed-shadow-soft);
      }

      .post-card:hover { border-color: var(--feed-border-hover); transform: translateY(-1px); box-shadow: var(--feed-shadow); }

      /* Repost / Pinned strip */
      .post-strip {
        display: flex; align-items: center; gap: 7px;
        padding: 8px 16px 0;
        font-size: 11px; font-weight: 600;
        letter-spacing: 0.04em;
        text-transform: uppercase;
      }
      .post-strip.repost { color: var(--green); }
      .post-strip.pinned { color: var(--text-dim); }

      /* Promo strip */
      .promo-strip {
        display: flex; align-items: center; justify-content: space-between;
        padding: 7px 16px;
        background: rgba(34,197,94,0.06);
        border-bottom: 1px solid rgba(34,197,94,0.1);
        font-size: 11px; font-weight: 700;
        color: var(--green); letter-spacing: 0.06em; text-transform: uppercase;
      }
      .promo-strip span:last-child { color: var(--text-dim); font-weight: 400; text-transform: none; letter-spacing: 0; }

      .post-header {
        display: flex; align-items: flex-start; gap: 14px;
        padding: 18px 18px 12px;
      }

      .post-avatar-wrap { flex-shrink: 0; transition: transform 0.18s ease, opacity 0.18s ease; }
      .post-avatar-wrap:active { transform: scale(0.96); }

      .post-avatar {
        width: 38px; height: 38px; border-radius: 50%;
        object-fit: cover; display: block;
      }

      .post-avatar.post-pet-avatar {
        width: 46px; height: 46px;
        box-shadow: 0 4px 14px rgba(15, 23, 42, 0.08);
        border: 2px solid color-mix(in srgb, var(--accent) 22%, transparent);
      }

      .post-avatar-initial {
        width: 38px; height: 38px; border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
        font-size: 14px; font-weight: 700; color: var(--text);
        background: var(--ink-4);
      }

      .post-avatar-initial.post-pet-initial {
        width: 46px; height: 46px;
        font-size: 20px;
        background: color-mix(in srgb, var(--accent) 12%, var(--ink-3));
        border: 2px solid color-mix(in srgb, var(--accent) 25%, transparent);
        box-shadow: 0 4px 14px rgba(15, 23, 42, 0.06);
      }

      .post-meta { flex: 1; min-width: 0; padding-top: 2px; }

      .post-title-stack { display: flex; flex-direction: column; gap: 3px; }

      .post-pet-name {
        font-family: var(--font-display);
        font-size: 1.05rem;
        font-weight: 800;
        letter-spacing: -0.03em;
        color: var(--feed-text);
        text-decoration: none;
        line-height: 1.2;
        display: inline-flex;
        align-items: center;
        gap: 6px;
      }
      .post-pet-name:hover { color: var(--accent); text-decoration: none; }

      .post-pet-emoji { font-size: 0.95rem; opacity: 0.92; line-height: 1; }

      .post-tutor-line {
        font-size: 12px;
        color: var(--feed-muted-soft);
        line-height: 1.35;
      }

      .post-tutor-prefix {
        opacity: 0.72;
        margin-right: 4px;
        font-weight: 500;
      }

      .post-tutor-name {
        font-weight: 600;
        color: var(--feed-muted);
        text-decoration: none;
      }
      .post-tutor-name:hover { color: var(--accent); text-decoration: none; }

      .post-author-name {
        font-family: var(--font-display);
        font-weight: 800; font-size: 15px; color: var(--feed-text);
        text-decoration: none;
        letter-spacing: -0.02em;
      }
      .post-author-name:hover { color: var(--accent); text-decoration: none; }

      .post-author-name.post-author-fallback {
        font-size: 15px;
      }

      .post-time {
        font-size: 11px; color: var(--feed-muted); display: block; margin-top: 5px;
      }

      .post-menu-btn {
        width: 32px; height: 32px; border-radius: 8px; border: none;
        background: transparent; color: var(--feed-muted); font-size: 14px;
        cursor: pointer; display: flex; align-items: center; justify-content: center;
        transition: all 0.15s;
      }
      .post-menu-btn:hover { background: var(--feed-surface-soft); color: var(--feed-text); }

      /* Post dropdown */
      .post-dropdown {
        position: absolute; right: 0; top: calc(100% + 4px);
        min-width: 168px;
        background: var(--feed-surface-soft);
        border: 1px solid var(--feed-border);
        border-radius: 12px;
        box-shadow: 0 18px 48px rgba(15, 23, 42, 0.12);
        overflow: hidden; z-index: 30;
        transform-origin: top right;
        animation: scale-in 0.12s ease-out;
      }

      @keyframes scale-in {
        from { opacity: 0; transform: scale(0.9); }
        to   { opacity: 1; transform: scale(1); }
      }

      .post-dropdown-item {
        display: flex; align-items: center; gap: 10px;
        padding: 11px 16px;
        font-size: 13px; font-weight: 500;
        color: var(--feed-text); cursor: pointer;
        border: none; background: transparent;
        width: 100%; text-align: left;
        transition: background 0.1s;
      }
      .post-dropdown-item:hover { background: color-mix(in srgb, var(--feed-surface-soft) 92%, #eaf0fa); }
      .post-dropdown-item.danger { color: #f87171; }
      .post-dropdown-item.danger:hover { background: rgba(239,68,68,0.08); }

      /* Post body */
      .post-text {
        padding: 0 18px 14px;
        font-size: 14px; line-height: 1.65;
        color: var(--feed-text);
        white-space: pre-wrap;
      }

      .post-photo {
        width: 100%;
        max-height: 520px;
        object-fit: cover;
        display: block;
        cursor: zoom-in;
      }

      .post-photo--fofinhos {
        outline: 3px solid #f59e0b;
        outline-offset: -2px;
        border-radius: 12px;
      }

      /* Repost embed */
      .post-embed {
        margin: 0 18px 14px;
        border: 1px solid var(--feed-border);
        border-radius: 12px;
        overflow: hidden;
        background: var(--feed-surface-soft);
      }

      .post-embed-header {
        display: flex; align-items: flex-start; gap: 10px;
        padding: 10px 12px 6px;
      }

      .post-embed-avatar {
        width: 22px; height: 22px; border-radius: 50%;
        object-fit: cover;
      }

      .post-embed-avatar.post-embed-pet-av {
        width: 28px; height: 28px;
        border: 1px solid color-mix(in srgb, var(--accent) 20%, transparent);
      }

      .post-embed-pet-name {
        font-family: var(--font-display);
        font-size: 13px; font-weight: 800; color: var(--feed-text);
        text-decoration: none; letter-spacing: -0.02em;
        display: block; line-height: 1.2;
      }
      .post-embed-pet-name:hover { color: var(--accent); text-decoration: none; }

      .post-embed-tutor {
        font-size: 11px; color: var(--feed-muted-soft); margin-top: 2px;
      }

      .post-embed-name {
        font-size: 12px; font-weight: 700; color: var(--feed-text);
        text-decoration: none;
      }
      .post-embed-name:hover { color: var(--accent); text-decoration: none; }

      .post-embed-text {
        padding: 0 12px 10px;
        font-size: 12px; color: var(--feed-muted); line-height: 1.5;
        display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
      }

      .post-embed-img {
        width: 100%; max-height: 180px; object-fit: cover; display: block;
        cursor: zoom-in;
      }

      /* Post actions */
      .post-actions {
        display: flex;
        border-top: 1px solid var(--feed-border);
        background: color-mix(in srgb, var(--feed-surface-soft) 50%, #fff);
      }

      .post-action-btn {
        flex: 1;
        display: flex; align-items: center; justify-content: center; gap: 7px;
        padding: 12px 8px;
        font-size: 13px; font-weight: 500;
        color: var(--feed-muted);
        background: transparent; border: none; cursor: pointer;
        transition: all 0.18s ease;
        border-radius: 0;
        position: relative;
      }

      .post-action-btn:hover {
        color: var(--feed-text);
        background: color-mix(in srgb, var(--feed-surface-soft) 92%, #eaf0fa);
        transform: translateY(-1px);
      }

      .post-action-btn.liked { color: var(--red); }
      .post-action-btn.reposted { color: var(--green); }
      .post-action-btn:not(:last-child) { border-right: 1px solid var(--feed-border); }

      /* Inline comment */
      .post-view-comments {
        padding: 0 18px 10px;
      }

      .post-view-comments button {
        font-size: 12px; color: var(--feed-muted); font-weight: 500;
        background: transparent; border: none; cursor: pointer; padding: 0;
      }
      .post-view-comments button:hover { color: var(--accent); }

      .post-comment-row {
        display: flex; align-items: center; gap: 10px;
        padding: 12px 18px 14px;
        border-top: 1px solid var(--feed-border);
      }

      .comment-input {
        flex: 1;
        background: var(--feed-surface-soft);
        border: 1px solid var(--feed-border);
        border-radius: 10px;
        padding: 8px 14px;
        font-size: 13px;
        color: var(--feed-text);
        font-family: var(--font-body);
        outline: none;
        transition: border-color 0.15s;
      }
      .comment-input::placeholder { color: var(--feed-muted-soft); }
      .comment-input:focus { border-color: rgba(242,96,32,0.4); }

      .comment-inline-send {
        width: 34px;
        height: 34px;
        border: none;
        border-radius: 10px;
        background: var(--accent);
        color: #fff;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        flex-shrink: 0;
        transition: all 0.15s;
      }
      .comment-inline-send:hover { background: var(--accent-light); }

      /* ── MENTION ── */
      .mention { color: var(--accent); font-weight: 600; cursor: pointer; }
      .mention:hover { text-decoration: underline; }

      .autocomplete-dropdown {
        position: absolute; bottom: 100%; left: 0; right: 0;
        max-height: 160px; overflow-y: auto;
        background: var(--feed-surface);
        border: 1px solid var(--feed-border);
        border-radius: 12px;
        box-shadow: 0 16px 44px rgba(15, 23, 42, 0.12);
        z-index: 10; margin-bottom: 4px;
      }

      .autocomplete-item {
        display: flex; align-items: center; gap: 8px;
        padding: 9px 12px; cursor: pointer; font-size: 13px;
        color: var(--feed-text); transition: background 0.1s;
      }
      .autocomplete-item:hover { background: var(--feed-surface-soft); }

      /* ── PROMO CARD ── */
      .promo-card-body { padding: 14px 16px; }
      .promo-store-header { display: flex; align-items: center; gap: 10px; margin-bottom: 10px; }
      .promo-logo { width: 36px; height: 36px; border-radius: 10px; object-fit: cover; }
      .promo-logo-empty {
        width: 36px; height: 36px; border-radius: 10px;
        background: var(--feed-surface-soft); display: flex; align-items: center; justify-content: center;
        color: var(--feed-muted-soft); font-size: 16px;
      }
      .promo-store-name { font-size: 14px; font-weight: 700; color: var(--feed-text); }
      .promo-status { font-size: 11px; color: var(--feed-muted); }
      .promo-title { font-size: 15px; font-weight: 700; color: var(--feed-text); margin-bottom: 4px; }
      .promo-desc { font-size: 13px; color: var(--feed-muted); line-height: 1.5; }
      .promo-btns { display: flex; gap: 8px; margin-top: 14px; }
      .promo-btn-main {
        display: inline-flex; align-items: center; gap: 6px;
        padding: 8px 16px;
        background: rgba(34,197,94,0.12);
        color: var(--green); border: 1px solid rgba(34,197,94,0.2);
        border-radius: 9px; font-size: 12px; font-weight: 700;
        text-decoration: none; transition: all 0.15s;
      }
      .promo-btn-main:hover { background: rgba(34,197,94,0.2); color: #4ade80; text-decoration: none; }

      /* ── SPONSORED CARD ── */
      .sponsored-strip {
        display: flex; align-items: center; justify-content: space-between;
        padding: 7px 16px;
        background: rgba(167,139,250,0.06);
        border-bottom: 1px solid rgba(167,139,250,0.1);
        font-size: 11px; font-weight: 700;
        color: var(--purple); letter-spacing: 0.06em; text-transform: uppercase;
      }

      /* ── SIDEBAR ── */
      .feed-sidebar {
        position: sticky; top: calc(56px + 56px + 16px);
      }

      .sidebar-card {
        background: color-mix(in srgb, var(--feed-surface) 92%, transparent);
        border: 1px solid var(--feed-border);
        border-radius: var(--radius-card);
        padding: 18px;
        margin-bottom: 14px;
        box-shadow: var(--feed-shadow-soft);
      }

      .sidebar-title {
        font-family: var(--font-display);
        font-size: 13px; font-weight: 700; color: var(--feed-text);
        margin-bottom: 14px; letter-spacing: 0.01em;
      }

      .sidebar-user-item {
        display: flex; align-items: center; gap: 10px;
        padding: 6px 0;
      }

      .sidebar-avatar {
        width: 34px; height: 34px; border-radius: 50%;
        object-fit: cover; flex-shrink: 0;
      }

      .sidebar-avatar-init {
        width: 34px; height: 34px; border-radius: 50%;
        flex-shrink: 0; display: flex; align-items: center; justify-content: center;
        font-size: 12px; font-weight: 700; color: var(--feed-text); background: var(--feed-surface-soft);
      }

      .sidebar-user-name {
        flex: 1; min-width: 0;
        font-size: 13px; font-weight: 600; color: var(--feed-text);
        white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
      }

      .sidebar-follow-btn {
        padding: 5px 12px;
        background: transparent;
        border: 1px solid var(--feed-border);
        border-radius: 7px;
        font-size: 11px; font-weight: 700; color: var(--feed-text);
        cursor: pointer; transition: all 0.15s;
        white-space: nowrap;
      }
      .sidebar-follow-btn:hover {
        background: var(--accent); border-color: var(--accent); color: #fff;
      }

      .sidebar-divider { height: 1px; background: var(--feed-border); margin: 4px 0 10px; }

      /* ── FLOAT HEARTS ── */
      @keyframes floatHeart { 0%{opacity:1;transform:translateY(0) scale(1)} 100%{opacity:0;transform:translateY(-60px) scale(1.4)} }
      .float-heart { position:absolute; pointer-events:none; animation:floatHeart 0.7s ease-out forwards; color:var(--red); font-size:14px; }

      /* ── SKELETON ── */
      @keyframes shimmer-dark { 0%{background-position:-200% 0} 100%{background-position:200% 0} }
      .skeleton-dark {
        background: linear-gradient(90deg, var(--ink-3) 25%, var(--ink-4) 50%, var(--ink-3) 75%);
        background-size: 200% 100%;
        animation: shimmer-dark 1.5s infinite;
        border-radius: 8px;
      }

      /* ── POST ENTER ANIM ── */
      @keyframes post-enter { from { opacity:0; transform:translateY(12px); } to { opacity:1; transform:none; } }
      .post-enter { animation: post-enter 0.35s ease-out both; }

      /* ── HEART POP ── */
      @keyframes heartPop { 0%{transform:scale(1)} 30%{transform:scale(1.35)} 60%{transform:scale(0.9)} 100%{transform:scale(1)} }
      .animate-heartPop { animation: heartPop 0.35s ease-out; }

      /* ── LOAD MORE ── */
      #loadMoreBtn {
        display: block; width: 100%;
        padding: 13px;
        background: var(--feed-surface);
        border: 1px solid var(--feed-border);
        border-radius: 14px;
        color: var(--feed-muted);
        font-family: var(--font-body);
        font-size: 14px; font-weight: 500;
        cursor: pointer; transition: all 0.2s;
        text-align: center;
      }
      #loadMoreBtn:hover { border-color: var(--feed-border-hover); color: var(--feed-text); background: var(--feed-surface-soft); }

      #feedContainer .mention { color: var(--accent); font-weight: 600; }
      .autocomplete-dropdown { position: absolute; bottom: 100%; left: 0; right: 0; max-height: 160px; overflow-y: auto; background: var(--ink-2); border: 1px solid var(--border); border-radius: 12px; box-shadow: 0 18px 48px rgba(15,23,42,0.1); z-index: 10; margin-bottom: 4px; }

      /* Stories (24h) */
      .feed-stories-strip {
        display: flex; gap: 14px; overflow-x: auto; padding: 10px 4px 14px;
        margin-bottom: 4px; scrollbar-width: thin;
        -webkit-overflow-scrolling: touch;
      }
      .feed-stories-strip::-webkit-scrollbar { height: 4px; }
      .feed-stories-strip::-webkit-scrollbar-thumb { background: var(--border); border-radius: 4px; }
      .story-bubble {
        flex: 0 0 auto; width: 72px; text-align: center; cursor: pointer;
        font-size: 11px; color: var(--text-dim); text-decoration: none; border: none; background: none; padding: 0;
      }
      .story-bubble:focus-visible { outline: 2px solid var(--accent); outline-offset: 2px; border-radius: 12px; }
      .story-ring {
        width: 64px; height: 64px; margin: 0 auto 6px; border-radius: 50%;
        padding: 3px;
        background: linear-gradient(135deg, #f97316, #ec4899, #a855f7);
        display: flex; align-items: center; justify-content: center;
      }
      .story-ring--new {
        background: var(--border);
        border: 2px dashed var(--accent);
        padding: 2px;
      }
      .story-ring-inner {
        width: 100%; height: 100%; border-radius: 50%; overflow: hidden;
        background: var(--feed-surface); display: flex; align-items: center; justify-content: center;
        border: 2px solid var(--feed-surface);
      }
      .story-ring-inner img { width: 100%; height: 100%; object-fit: cover; }
      .story-new-plus {
        font-size: 22px; font-weight: 800; color: var(--accent); line-height: 1;
      }
      #storyComposerModal, #storyViewerModal {
        position: fixed; inset: 0; z-index: 2000; display: none;
        align-items: center; justify-content: center; padding: 16px;
        background: rgba(15,23,42,0.55);
      }
      #storyComposerModal.is-open, #storyViewerModal.is-open { display: flex; }
      .story-modal-card {
        width: 100%; max-width: 400px; background: var(--feed-surface);
        border-radius: 16px; border: 1px solid var(--feed-border);
        box-shadow: 0 24px 64px rgba(0,0,0,0.2); max-height: 90vh; overflow: auto;
      }
      .story-modal-head {
        display: flex; align-items: center; justify-content: space-between;
        padding: 14px 16px; border-bottom: 1px solid var(--feed-border);
        font-weight: 700; font-size: 16px; color: var(--feed-text);
      }
      .story-modal-body { padding: 16px; }
      .story-viewer-inner {
        max-width: 420px; width: 100%; background: #0f172a; border-radius: 16px; overflow: hidden;
        position: relative; max-height: 85vh;
      }
      .story-viewer-inner img {
        width: 100%; display: block; max-height: 70vh; object-fit: contain; background: #000;
        position: relative; z-index: 1;
      }
      #storyTapPrev, #storyTapNext {
        position: absolute; top: 0; bottom: 0; width: 30%; z-index: 3;
        border: none; background: transparent; cursor: pointer; padding: 0;
      }
      #storyTapPrev { left: 0; }
      #storyTapNext { right: 0; }
      #storyViewerClose { z-index: 6 !important; }
      #storyProgressWrap { pointer-events: none; }
      .story-viewer-cap { padding: 12px 14px; color: #e2e8f0; font-size: 14px; }
    </style>
  `;
%>
<%- include('partials/header') %>
<%- include('partials/flash') %>

<% var isLogado = typeof usuario !== 'undefined' && usuario; %>
<% var meusPets = typeof meusPets !== 'undefined' ? meusPets : (typeof pets !== 'undefined' ? pets : []); %>
<% var sugestoesUsuarios = typeof sugestoesUsuarios !== 'undefined' ? sugestoesUsuarios : (typeof recomendacoes !== 'undefined' ? recomendacoes : []); %>
<% var sugestoesPets = typeof sugestoesPets !== 'undefined' ? sugestoesPets : (typeof petsRecomendados !== 'undefined' ? petsRecomendados : []); %>
<% var petshopsProximos = typeof petshopsProximos !== 'undefined' ? petshopsProximos : (typeof petshopDestaques !== 'undefined' ? petshopDestaques : []); %>
<% var hasMore = typeof hasMore !== 'undefined' ? hasMore : (typeof temMais !== 'undefined' ? temMais : false); %>
<% var feedAba = typeof feedAbaAtiva !== 'undefined' ? feedAbaAtiva : 'pets'; %>

<main class="feed-page flex-1 pb-24 md:pb-6">

  <!-- Top bar -->
  <div class="feed-topbar">
    <div class="feed-topbar-inner">
      <div>
        <h1>Feed</h1>
        <nav class="feed-tabs" aria-label="Tipo de feed">
          <a href="/feed" class="feed-tab <%= feedAba === 'pets' ? 'feed-tab--active' : '' %>">Pets</a>
          <a href="/feed/parceiros" class="feed-tab <%= feedAba === 'parceiros' ? 'feed-tab--active' : '' %>">Parceiros</a>
        </nav>
      </div>
      <div class="feed-welcome">
        <% if (isLogado) { %>
          <% var primeiroNome = (usuario.nome || '').split(' ')[0] || ''; %>
          <% var primeiroNomeFormatado = primeiroNome ? (primeiroNome.charAt(0).toUpperCase() + primeiroNome.slice(1).toLowerCase()) : ''; %>
          Bem-vindo, <%= primeiroNomeFormatado %>
        <% } %>
      </div>
    </div>
  </div>

  <div class="feed-layout">

    <!-- ═══ MAIN COLUMN ═══ -->
    <div>

      <!-- Mobile search -->
      <div class="lg:hidden">
        <a href="/explorar/busca" class="mobile-search">
          <i class="fa-solid fa-magnifying-glass" style="font-size:13px;"></i>
          Buscar pets ou pessoas...
        </a>
      </div>

      <% if (isLogado && feedAba === 'pets' && meusPets && meusPets.length) { %>
      <section class="composer" style="padding-bottom:10px;margin-bottom:12px;" aria-label="Stories">
        <div style="font-size:12px;font-weight:700;color:var(--text-dim);margin:0 4px 8px;letter-spacing:0.02em;">Stories</div>
        <div class="feed-stories-strip" id="feedStoriesStrip">
          <button type="button" class="story-bubble" id="btnAbrirStoryComposer" title="Nova story">
            <span class="story-ring story-ring--new"><span class="story-ring-inner"><span class="story-new-plus">+</span></span></span>
            <span style="color:var(--accent);font-weight:600;">Novo</span>
          </button>
        </div>
      </section>
      <% } %>

      <!-- Composer -->
      <% if (isLogado) { %>
      <% var feedFotoRaw = (usuario.foto_perfil || '').trim();
         var feedFotoSrc = '';
         if (feedFotoRaw) {
           if (/^https?:\/\//i.test(feedFotoRaw)) feedFotoSrc = feedFotoRaw;
           else feedFotoSrc = feedFotoRaw.indexOf('/') === 0 ? feedFotoRaw : '/' + feedFotoRaw;
         }
         var feedInicial = (usuario.nome || 'U').charAt(0).toUpperCase();
         var corMe = usuario.cor_perfil || '#ec5a1c';
      %>
      <div class="composer">
        <div class="composer-top">
          <% if (feedFotoSrc) { %>
          <span class="post-avatar-wrap" style="flex-shrink:0;width:38px;height:38px;display:inline-flex;align-items:center;justify-content:center;">
            <img src="<%= feedFotoSrc %>" class="post-avatar" style="box-shadow:0 0 0 2px <%= corMe %>;" alt="" onerror="this.style.display='none';var n=this.nextElementSibling;if(n)n.style.display='flex';">
            <div class="post-avatar-initial" style="display:none;box-shadow:0 0 0 2px <%= corMe %>;"><%= feedInicial %></div>
          </span>
          <% } else { %>
          <div class="post-avatar-initial" style="box-shadow:0 0 0 2px <%= corMe %>; flex-shrink:0;"><%= feedInicial %></div>
          <% } %>
          <div style="flex:1; min-width:0; position:relative;">
            <div id="mentionDropdownNovaPublicacao" class="autocomplete-dropdown hidden"></div>
            <textarea
              id="novoPostTexto"
              class="composer-textarea"
              rows="3"
              placeholder="O que está acontecendo com seu pet?"
              maxlength="500"
              aria-label="Texto da nova publicação"
            ></textarea>
          </div>
        </div>
        <div id="novoPostPreview" class="hidden mb-3" style="position:relative;">
          <img id="novoPostPreviewImg" src="" alt="" style="max-height:200px; border-radius:12px; object-fit:cover; width:100%;">
          <button type="button" id="removerFoto" style="position:absolute;top:8px;right:8px;width:28px;height:28px;border-radius:50%;background:rgba(0,0,0,0.6);border:none;color:#fff;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:12px;">
            <i class="fa-solid fa-xmark"></i>
          </button>
        </div>

        <!-- Pet selector -->
        <% if (typeof meusPets !== 'undefined' && meusPets && meusPets.length > 0) { %>
        <div style="margin-bottom:12px;">
          <select id="novoPetId" required style="background:var(--ink-3);border:1px solid var(--border);border-radius:9px;padding:7px 12px;color:var(--text);font-family:var(--font-body);font-size:13px;outline:none;width:100%;cursor:pointer;">
            <% meusPets.forEach(function(p, idx) { %>
              <option value="<%= p.id %>"<%= idx === 0 ? ' selected' : '' %>><%= p.nome %></option>
            <% }); %>
          </select>
        </div>
        <label class="flex items-start gap-2 mt-2" style="font-size:12px;color:var(--text-dim);cursor:pointer;">
          <input type="checkbox" id="feedPostFofinhosMoldura" value="1" style="margin-top:3px;">
          <span>Moldura <strong style="color:var(--accent);">Pets mais fofinhos</strong> na foto (se o pet já puder concorrer).</span>
        </label>
        <% } %>

        <div class="composer-actions">
          <div class="composer-tools">
            <button type="button" class="composer-tool-btn" id="btnAnexarFoto" title="Foto">
              <i class="fa-solid fa-image"></i>
            </button>
          </div>
          <div style="display:flex;align-items:center;gap:10px;">
            <span id="charCount" style="font-size:12px;color:var(--text-dim);">0/500</span>
            <button type="button" id="btnPublicar" class="btn-post" disabled>
              <i class="fa-solid fa-paper-plane"></i>
              Publicar
            </button>
          </div>
        </div>
        <input type="file" id="inputFotoPost" accept="image/*" class="hidden">
      </div>
      <% } %>

      <!-- FEED -->
      <div id="feedContainer">
        <% if (posts && posts.length > 0) { %>
          <% posts.forEach(function(post, idx) { %>
            <% if (post.is_petshop_promo) { %>
              <article class="post-card post-enter" id="promo-<%= post.petshop_id %>" style="animation-delay:<%= Math.min(idx*50,300) %>ms">
                <div class="promo-strip">
                  <span><i class="fa-solid fa-badge-percent mr-1"></i>Promoção para você</span>
                  <span>Baseado no seu relacionamento</span>
                </div>
                <div class="promo-card-body">
                  <div class="promo-store-header">
                    <% if (post.petshop_logo_url) { %>
                      <img src="<%= post.petshop_logo_url %>" class="promo-logo" alt="">
                    <% } else { %>
                      <div class="promo-logo-empty"><i class="fa-solid fa-store"></i></div>
                    <% } %>
                    <div>
                      <div class="promo-store-name"><%= post.petshop_nome || 'Parceiro' %></div>
                      <div class="promo-status"><%= post.usuario_vinculado ? 'Vinculado' : 'Seguindo' %></div>
                    </div>
                  </div>
                  <div class="promo-title"><%= post.titulo || 'Promoção' %></div>
                  <div class="promo-desc"><%= post.descricao_curta || '' %></div>
                  <div class="promo-btns">
                    <a href="/petshops/<%= post.petshop_slug || post.petshop_id %>" class="promo-btn-main">
                      <i class="fa-solid fa-store"></i>Ver petshop
                    </a>
                    <% if (post.contato_link) { %>
                      <a href="<%= post.contato_link %>" target="_blank" rel="noopener" class="promo-btn-main" style="background:rgba(242,96,32,0.1);color:var(--accent);border-color:rgba(242,96,32,0.2);">
                        <i class="fa-solid fa-arrow-up-right-from-square"></i>Aproveitar
                      </a>
                    <% } %>
                  </div>
                </div>
              </article>

            <% } else if (post.is_sponsored) { %>
              <article class="post-card post-enter" id="sponsored-<%= post.id %>" style="animation-delay:<%= Math.min(idx*50,300) %>ms">
                <div class="sponsored-strip">
                  <span><i class="fa-solid fa-circle-dollar mr-1"></i>Patrocinado</span>
                </div>
                <div class="post-header">
                  <% if (post.pet_id) { %><a href="/p/<%= post.pet_slug || post.pet_id %>" class="post-avatar-wrap pet-photo-wrap"><% } else { %><span class="post-avatar-wrap pet-photo-wrap"><% } %>
                  <% if (post.pet_foto) { %>
                    <img src="<%= post.pet_foto %>" class="post-avatar post-pet-avatar" alt="">
                  <% } else { %>
                    <div class="post-avatar-initial post-pet-initial" style="background:var(--ink-4)">🐾</div>
                  <% } %>
                  <%- include('partials/pet-verified-badge', { pet: { tem_tag_ativa: post.pet_tem_tag_ativa, verificado: post.pet_verificado }, size: 'xs' }) %>
                  <% if (post.pet_id) { %></a><% } else { %></span><% } %>
                  <div class="post-meta">
                    <div class="post-title-stack">
                      <% if (post.pet_id) { %>
                        <a href="/p/<%= post.pet_slug || post.pet_id %>" class="post-pet-name"><span class="post-pet-emoji" aria-hidden="true">🐾</span><%= post.pet_nome || 'Pet' %></a>
                        <% if (post.autor_nome) { %>
                          <div class="post-tutor-line"><span class="post-tutor-prefix">por</span><span class="post-tutor-name" style="text-decoration:none;cursor:default;"><%= post.autor_nome %></span></div>
                        <% } %>
                      <% } else { %>
                        <span class="post-pet-name" style="cursor:default;"><span class="post-pet-emoji" aria-hidden="true">🐾</span><%= post.pet_nome || 'Perfil pet patrocinado' %></span>
                      <% } %>
                    </div>
                    <span class="post-time">Patrocinado</span>
                  </div>
                </div>
                <% if (post.sponsored_label) { %>
                  <div class="post-text" style="font-weight:700;font-size:16px;padding-bottom:4px;"><%= post.sponsored_label %></div>
                <% } %>
                <% if (post.texto || post.legenda) { %>
                  <div class="post-text"><%= post.texto || post.legenda %></div>
                <% } %>
                <% if (post.foto) { %>
                  <img src="<%= post.foto %>" class="post-photo" loading="lazy" alt="">
                <% } %>
                <% if (post.pet_id) { %>
                  <div style="padding:10px 16px 14px;">
                    <a href="/explorar/pet/<%= post.pet_id %>" style="display:inline-flex;align-items:center;gap:6px;padding:9px 18px;background:var(--accent);color:#fff;border-radius:9px;font-size:13px;font-weight:700;text-decoration:none;transition:all 0.15s;" onmouseover="this.style.background='var(--accent-light)'" onmouseout="this.style.background='var(--accent)'">
                      Ver perfil do pet <i class="fa-solid fa-arrow-right" style="font-size:11px;"></i>
                    </a>
                  </div>
                <% } %>
              </article>

            <% } else { %>
              <%
                var isRepost = post.tipo === 'repost';
                var isMine = typeof usuario !== 'undefined' && usuario && post.usuario_id === usuario.id;
                var pCor = post.cor_perfil || '#ec5a1c';
                var feedMetaObj = {
                  kind: 'organic',
                  postId: post.id,
                  foto: post.foto || '',
                  texto: post.texto || post.legenda || '',
                  criado_em: post.criado_em || '',
                  autor_nome: post.autor_nome || '',
                  usuario_id: post.usuario_id,
                  foto_perfil: post.foto_perfil || '',
                  cor_perfil: pCor,
                  pet_id: post.pet_id || null,
                  pet_nome: post.pet_nome || '',
                  pet_foto: post.pet_foto || '',
                  fixada: !!post.fixada,
                  comments: true,
                  tipo: post.tipo || 'original',
                  orig_id: post.orig_id || null,
                  orig_foto: post.orig_foto || '',
                  orig_texto: post.orig_texto || '',
                  orig_legenda: post.orig_legenda || '',
                  orig_autor_nome: post.orig_autor_nome || '',
                  orig_usuario_id: post.orig_usuario_id || null,
                  orig_pet_id: post.orig_pet_id || null,
                  orig_pet_nome: post.orig_pet_nome || '',
                  orig_pet_foto: post.orig_pet_foto || '',
                  orig_foto_perfil: post.orig_foto_perfil || '',
                  orig_criado_em: post.orig_criado_em || ''
                };
              %>
              <article class="post-card post-enter" data-explorar-meta="<%= encodeURIComponent(JSON.stringify(feedMetaObj)) %>" tabindex="0" aria-label="Abrir publicação" data-post-id="<%= post.id %>" data-author-id="<%= post.usuario_id %>" id="post-<%= post.id %>" style="animation-delay:<%= Math.min(idx*50,300) %>ms">

                <% if (isRepost) { %>
                  <div class="post-strip repost"><i class="fa-solid fa-retweet"></i><%= post.autor_nome %> repostou</div>
                <% } %>
                <% if (post.fixada) { %>
                  <div class="post-strip pinned"><i class="fa-solid fa-thumbtack"></i>Fixado</div>
                <% } %>

                <% var feedHasPet = post.pet_id && post.pet_nome; %>
                <div class="post-header">
                  <% if (feedHasPet) { %>
                  <a href="/p/<%= post.pet_slug || post.pet_id %>" class="post-avatar-wrap pet-photo-wrap">
                    <% if (post.pet_foto) { %>
                      <img src="<%= post.pet_foto %>" class="post-avatar post-pet-avatar" alt="">
                    <% } else { %>
                      <div class="post-avatar-initial post-pet-initial">🐾</div>
                    <% } %>
                    <%- include('partials/pet-verified-badge', { pet: { tem_tag_ativa: post.pet_tem_tag_ativa, verificado: post.pet_verificado }, size: 'xs' }) %>
                  </a>
                  <div class="post-meta">
                    <div class="post-title-stack">
                      <a href="/p/<%= post.pet_slug || post.pet_id %>" class="post-pet-name"><span class="post-pet-emoji" aria-hidden="true">🐾</span><%= post.pet_nome %></a>
                      <div class="post-tutor-line">
                        <span class="post-tutor-prefix">por</span>
                        <a href="/explorar/perfil/<%= post.usuario_id %>" class="post-tutor-name"><%= post.autor_nome %></a>
                      </div>
                    </div>
                    <span class="post-time tempo-relativo" data-time="<%= post.criado_em %>"><%= post.criado_em %></span>
                  </div>
                  <% } else { %>
                  <a href="/explorar/perfil/<%= post.usuario_id %>" class="post-avatar-wrap">
                    <% if (post.foto_perfil) { %>
                      <img src="<%= post.foto_perfil %>" class="post-avatar post-author-avatar" style="box-shadow:0 0 0 2px <%= pCor %>" alt="">
                    <% } else { %>
                      <div class="post-avatar-initial post-author-avatar" style="box-shadow:0 0 0 2px <%= pCor %>"><%= (post.autor_nome || 'U').charAt(0).toUpperCase() %></div>
                    <% } %>
                  </a>
                  <div class="post-meta">
                    <div class="post-title-stack">
                      <a href="/explorar/perfil/<%= post.usuario_id %>" class="post-author-name post-author-fallback"><%= post.autor_nome %></a>
                      <span class="post-tutor-line" style="font-size:11px;opacity:0.85;">Publicação do tutor</span>
                    </div>
                    <span class="post-time tempo-relativo" data-time="<%= post.criado_em %>"><%= post.criado_em %></span>
                  </div>
                  <% } %>
                  <% if (isMine) { %>
                  <div style="position:relative; flex-shrink:0;">
                    <button type="button" class="post-menu-btn btn-menu-post"><i class="fa-solid fa-ellipsis"></i></button>
                    <div class="post-dropdown hidden">
                      <button type="button" class="post-dropdown-item btn-fixar" data-post-id="<%= post.id %>" data-fixada="<%= post.fixada ? '1' : '0' %>">
                        <i class="fa-solid fa-thumbtack" style="width:16px;text-align:center;color:var(--text-dim);"></i>
                        <%= post.fixada ? 'Desafixar' : 'Fixar' %>
                      </button>
                      <button type="button" class="post-dropdown-item danger btn-deletar" data-post-id="<%= post.id %>">
                        <i class="fa-solid fa-trash-can" style="width:16px;text-align:center;"></i>
                        Excluir
                      </button>
                    </div>
                  </div>
                  <% } %>
                </div>

                <% if (post.texto || post.legenda) { %>
                  <div class="post-text line-clamp-3 post-text-body"><%= post.texto || post.legenda %></div>
                  <div style="padding:0 18px 10px;"><button type="button" class="btn-ver-mais hidden" style="font-size:12px;color:var(--accent);font-weight:600;background:transparent;border:none;cursor:pointer;padding:0;">ver mais</button></div>
                <% } %>

                <% if (post.foto) { %>
                  <img src="<%= post.foto %>" class="post-photo" loading="lazy" alt="">
                <% } %>

                <% if (isRepost && post.orig_id) { %>
                  <div class="post-embed">
                    <div class="post-embed-header">
                      <% var origHasPet = post.orig_pet_id && post.orig_pet_nome; %>
                      <% if (origHasPet) { %>
                        <a href="/explorar/pet/<%= post.orig_pet_id %>">
                          <% if (post.orig_pet_foto) { %>
                            <img src="<%= post.orig_pet_foto %>" class="post-embed-avatar post-embed-pet-av" alt="">
                          <% } else { %>
                            <div class="post-embed-avatar post-embed-pet-av" style="background:color-mix(in srgb,var(--accent) 14%,var(--ink-4));display:flex;align-items:center;justify-content:center;font-size:12px;">🐾</div>
                          <% } %>
                        </a>
                        <div class="min-w-0 flex-1">
                          <a href="/explorar/pet/<%= post.orig_pet_id %>" class="post-embed-pet-name"><%= post.orig_pet_nome %></a>
                          <div class="post-embed-tutor"><span class="post-tutor-prefix">por</span><a href="/explorar/perfil/<%= post.orig_usuario_id %>" class="post-tutor-name" style="font-size:11px;"><%= post.orig_autor_nome %></a></div>
                        </div>
                      <% } else { %>
                      <% if (post.orig_foto_perfil) { %>
                        <img src="<%= post.orig_foto_perfil %>" class="post-embed-avatar" alt="">
                      <% } else { %>
                        <div class="post-embed-avatar" style="background:var(--ink-4);display:flex;align-items:center;justify-content:center;font-size:9px;font-weight:700;color:var(--text);"><%= (post.orig_autor_nome || 'U').charAt(0).toUpperCase() %></div>
                      <% } %>
                      <a href="/explorar/perfil/<%= post.orig_usuario_id %>" class="post-embed-name"><%= post.orig_autor_nome %></a>
                      <% } %>
                    </div>
                    <% if (post.orig_texto || post.orig_legenda) { %>
                      <div class="post-embed-text"><%= post.orig_texto || post.orig_legenda %></div>
                    <% } %>
                    <% if (post.orig_foto) { %>
                      <img src="<%= post.orig_foto %>" class="post-embed-img" loading="lazy" alt="">
                    <% } %>
                  </div>
                <% } %>

                <div class="post-actions">
                  <button type="button" class="post-action-btn btn-comentar" data-post-id="<%= post.id %>">
                    <i class="fa-regular fa-comment"></i>
                    <span class="count-comentarios"><%= post.total_comentarios || '' %></span>
                  </button>
                  <button type="button" class="post-action-btn btn-repost <%= post.repostou ? 'reposted' : '' %>" data-post-id="<%= post.id %>">
                    <i class="fa-solid fa-retweet"></i>
                    <span class="count-reposts"><%= post.total_reposts || '' %></span>
                  </button>
                  <button type="button" class="post-action-btn btn-curtir <%= post.curtiu ? 'liked' : '' %>" data-post-id="<%= post.id %>" data-curtiu="<%= post.curtiu ? '1' : '0' %>" style="position:relative;">
                    <i class="<%= post.curtiu ? 'fa-solid' : 'fa-regular' %> fa-heart"></i>
                    <span class="count-curtidas"><%= post.total_curtidas || '' %></span>
                  </button>
                  <button type="button" class="post-action-btn btn-share" data-post-id="<%= post.id %>" data-autor="<%= post.autor_nome %>" data-pet-nome="<%= feedHasPet ? post.pet_nome : '' %>">
                    <i class="fa-solid fa-share-from-square"></i>
                  </button>
                </div>

                <% if (post.total_comentarios > 0) { %>
                <div class="post-view-comments">
                  <button type="button" class="btn-comentar" data-post-id="<%= post.id %>">
                    Ver todos os <%= post.total_comentarios %> comentários
                  </button>
                </div>
                <% } %>

                <% if (isLogado) { %>
                <div class="post-comment-row">
                  <% var corCom = usuario.cor_perfil || '#ec5a1c'; %>
                  <% if (feedFotoSrc) { %>
                  <span style="flex-shrink:0;width:28px;height:28px;display:inline-flex;align-items:center;justify-content:center;">
                    <img src="<%= feedFotoSrc %>" style="width:28px;height:28px;border-radius:50%;object-fit:cover;box-shadow:0 0 0 2px <%= corCom %>;" alt="" onerror="this.style.display='none';var n=this.nextElementSibling;if(n){n.style.display='flex';n.style.alignItems='center';n.style.justifyContent='center';}">
                    <div style="display:none;width:28px;height:28px;border-radius:50%;flex-shrink:0;background:var(--ink-4);box-shadow:0 0 0 2px <%= corCom %>;font-size:10px;font-weight:700;color:var(--text);" class="inline-avatar-fallback"><%= feedInicial %></div>
                  </span>
                  <% } else { %>
                  <div style="width:28px;height:28px;border-radius:50%;flex-shrink:0;background:var(--ink-4);display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:700;color:var(--text);box-shadow:0 0 0 2px <%= corCom %>;"><%= feedInicial %></div>
                  <% } %>
                  <input type="text" class="comment-input input-comentario-inline" data-post-id="<%= post.id %>" placeholder="Adicionar comentário…" maxlength="500">
                  <button type="button" class="comment-inline-send btn-enviar-inline" data-post-id="<%= post.id %>" aria-label="Enviar comentário">
                    <i class="fa-solid fa-paper-plane"></i>
                  </button>
                </div>
                <% } %>

              </article>
            <% } %>
          <% }); %>
        <% } else { %>
          <div style="text-align:center; padding:80px 24px; color:var(--text-dim);">
            <div style="font-size:48px; margin-bottom:16px; opacity:0.3;">🐾</div>
            <p style="font-size:16px; font-weight:600; color:var(--text); margin-bottom:8px;">Seu feed está vazio</p>
            <p style="font-size:14px;">Siga pessoas e pets para ver publicações aqui.</p>
            <a href="/explorar" style="display:inline-flex;align-items:center;gap:8px;margin-top:20px;padding:10px 22px;background:var(--accent);color:#fff;border-radius:10px;font-size:14px;font-weight:700;text-decoration:none;">
              <i class="fa-solid fa-compass"></i>Explorar
            </a>
          </div>
        <% } %>

        <% if (typeof hasMore !== 'undefined' && hasMore) { %>
          <button id="loadMoreBtn" data-page="2">
            <i class="fa-solid fa-arrows-rotate mr-2"></i>Carregar mais publicações
          </button>
        <% } %>
      </div>
    </div>

    <!-- ═══ SIDEBAR ═══ -->
    <aside class="feed-sidebar">

      <!-- Search desktop -->
      <div style="margin-bottom:14px;">
        <a href="/explorar/busca" style="display:flex;align-items:center;gap:10px;background:var(--ink-2);border:1px solid var(--border);border-radius:12px;padding:10px 14px;color:var(--text-dim);font-size:13px;text-decoration:none;transition:all 0.2s;" onmouseover="this.style.borderColor='var(--border-hover)'" onmouseout="this.style.borderColor='var(--border)'">
          <i class="fa-solid fa-magnifying-glass" style="font-size:13px;"></i>
          Buscar pets ou pessoas...
        </a>
        <div style="display:flex;flex-wrap:wrap;gap:12px;margin-top:10px;font-size:12px;font-weight:600;">
          <a href="/explorar/pet-do-mes" style="color:var(--accent);text-decoration:none;">Pets mais fofinhos</a>
        </div>
      </div>

      <!-- Sugestões de usuários -->
      <% if (typeof sugestoesUsuarios !== 'undefined' && sugestoesUsuarios && sugestoesUsuarios.length > 0) { %>
      <div class="sidebar-card">
        <div class="sidebar-title">Quem seguir</div>
        <% sugestoesUsuarios.forEach(function(u) { %>
          <div class="sidebar-user-item">
            <% var uCor = u.cor_perfil || '#ec5a1c'; %>
            <% if (u.foto_perfil) { %>
              <img src="<%= u.foto_perfil %>" class="sidebar-avatar" style="box-shadow:0 0 0 2px <%= uCor %>" alt="">
            <% } else { %>
              <div class="sidebar-avatar-init" style="box-shadow:0 0 0 2px <%= uCor %>"><%= (u.nome || 'U').charAt(0).toUpperCase() %></div>
            <% } %>
            <a href="/explorar/perfil/<%= u.id %>" style="flex:1;min-width:0;font-size:13px;font-weight:600;color:var(--text);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;text-decoration:none;" onmouseover="this.style.color='var(--accent)'" onmouseout="this.style.color='var(--text)'"><%= u.nome %></a>
            <button type="button" class="sidebar-follow-btn btn-seguir-sidebar" data-user-id="<%= u.id %>">Seguir</button>
          </div>
        <% }); %>
      </div>
      <% } %>

      <!-- Pets para seguir -->
      <% if (typeof sugestoesPets !== 'undefined' && sugestoesPets && sugestoesPets.length > 0) { %>
      <div class="sidebar-card">
        <div class="sidebar-title">Pets em destaque</div>
        <% sugestoesPets.forEach(function(pet) { %>
          <div class="sidebar-user-item">
            <% if (pet.foto) { %>
              <img src="<%= pet.foto %>" class="sidebar-avatar" alt="">
            <% } else { %>
              <div class="sidebar-avatar-init" style="background:var(--ink-4);">🐾</div>
            <% } %>
            <a href="/explorar/pet/<%= pet.id %>" style="flex:1;min-width:0;font-size:13px;font-weight:600;color:var(--text);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;text-decoration:none;" onmouseover="this.style.color='var(--accent)'" onmouseout="this.style.color='var(--text)'"><%= pet.nome %></a>
            <button type="button" class="sidebar-follow-btn btn-seguir-pet-sidebar" data-pet-id="<%= pet.id %>">Seguir</button>
          </div>
        <% }); %>
      </div>
      <% } %>

      <!-- Petshops -->
      <% if (typeof petshopsProximos !== 'undefined' && petshopsProximos && petshopsProximos.length > 0) { %>
      <div class="sidebar-card">
        <div class="sidebar-title">Petshops próximos</div>
        <% petshopsProximos.forEach(function(ps) { %>
          <div class="sidebar-user-item">
            <% if (ps.logo_url) { %>
              <img src="<%= ps.logo_url %>" style="width:34px;height:34px;border-radius:9px;object-fit:cover;flex-shrink:0;" alt="">
            <% } else { %>
              <div class="sidebar-avatar-init" style="border-radius:9px;background:var(--ink-4);">🏪</div>
            <% } %>
            <a href="/petshops/<%= ps.slug || ps.id %>" style="flex:1;min-width:0;font-size:13px;font-weight:600;color:var(--text);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;text-decoration:none;" onmouseover="this.style.color='var(--accent)'" onmouseout="this.style.color='var(--text)'"><%= ps.nome %></a>
          </div>
        <% }); %>
      </div>
      <% } %>

      <div style="font-size:11px;color:var(--text-dim);line-height:1.6;padding:0 4px;">
        AIRPET © 2025 &nbsp;·&nbsp;
        <a href="/privacidade" style="color:var(--text-dim);text-decoration:none;" onmouseover="this.style.color='var(--accent)'" onmouseout="this.style.color='var(--text-dim)'">Privacidade</a> &nbsp;·&nbsp;
        <a href="/termos" style="color:var(--text-dim);text-decoration:none;" onmouseover="this.style.color='var(--accent)'" onmouseout="this.style.color='var(--text-dim)'">Termos</a>
      </div>
    </aside>

  </div>

  <% if (isLogado && feedAba === 'pets' && meusPets && meusPets.length) { %>
  <div id="storyComposerModal" role="dialog" aria-modal="true" aria-labelledby="storyComposerTitle">
    <div class="story-modal-card">
      <div class="story-modal-head">
        <span id="storyComposerTitle">Nova story</span>
        <button type="button" id="storyComposerClose" class="composer-tool-btn" aria-label="Fechar"><i class="fa-solid fa-xmark"></i></button>
      </div>
      <div class="story-modal-body">
        <p style="font-size:12px;color:var(--text-dim);margin:0 0 12px;">Fica visível por 24 horas para quem segue o pet.</p>
        <label style="display:block;font-size:12px;font-weight:600;margin-bottom:6px;color:var(--feed-text);">Pet</label>
        <select id="storyPetId" style="width:100%;margin-bottom:14px;padding:10px 12px;border-radius:10px;border:1px solid var(--feed-border);background:var(--feed-surface-soft);color:var(--feed-text);font-size:14px;">
          <% meusPets.forEach(function(p) { %>
            <option value="<%= p.id %>"><%= p.nome %></option>
          <% }); %>
        </select>
        <label style="display:block;font-size:12px;font-weight:600;margin-bottom:6px;color:var(--feed-text);">Foto</label>
        <input type="file" id="storyFotoInput" accept="image/*" style="margin-bottom:12px;font-size:13px;width:100%;">
        <div id="storyFotoPreviewWrap" class="hidden mb-3">
          <img id="storyFotoPreview" src="" alt="" style="max-height:180px;width:100%;object-fit:cover;border-radius:12px;">
        </div>
        <label style="display:block;font-size:12px;font-weight:600;margin-bottom:6px;color:var(--feed-text);">Legenda (opcional)</label>
        <textarea id="storyLegenda" maxlength="280" rows="2" placeholder="Uma frase…" style="width:100%;padding:10px 12px;border-radius:10px;border:1px solid var(--feed-border);resize:vertical;font-family:inherit;font-size:14px;"></textarea>
        <button type="button" id="storyEnviarBtn" class="btn-post" style="width:100%;margin-top:16px;justify-content:center;">
          <i class="fa-solid fa-circle-notch fa-spin hidden" id="storyEnviarSpinner"></i>
          <span id="storyEnviarLabel">Publicar story</span>
        </button>
        <p id="storyComposerMsg" class="hidden" style="margin-top:10px;font-size:13px;"></p>
      </div>
    </div>
  </div>
  <div id="storyViewerModal" role="dialog" aria-modal="true" aria-label="Story">
    <div class="story-viewer-inner" id="storyViewerInnerBox">
      <div id="storyProgressWrap" style="position:absolute;top:0;left:0;right:0;z-index:5;padding:10px 10px 0;display:flex;gap:3px;">
        <div id="storyProgTrack" style="flex:1;height:3px;background:rgba(255,255,255,0.35);border-radius:2px;overflow:hidden;">
          <div id="storyProgFill" style="height:100%;width:0;background:#fff;border-radius:2px;"></div>
        </div>
      </div>
      <button type="button" id="storyViewerClose" style="position:absolute;top:10px;right:10px;z-index:6;width:36px;height:36px;border-radius:50%;border:none;background:rgba(0,0,0,0.5);color:#fff;cursor:pointer;" aria-label="Fechar"><i class="fa-solid fa-xmark"></i></button>
      <button type="button" id="storyTapPrev" aria-label="Story anterior"></button>
      <button type="button" id="storyTapNext" aria-label="Próximo story"></button>
      <img id="storyViewerImg" src="" alt="">
      <div class="story-viewer-cap" style="position:relative;z-index:2;">
        <a id="storyViewerPetLink" href="#" style="color:#fb923c;font-weight:700;text-decoration:none;"></a>
        <p id="storyViewerLegenda" style="margin:8px 0 0;font-size:13px;opacity:0.9;"></p>
      </div>
    </div>
  </div>
  <% } %>

</main>

<div id="commentModal" class="airpet-modal airpet-modal--comments hidden" aria-hidden="true">
  <div class="airpet-modal__backdrop" id="commentModalBackdrop"></div>
  <div class="airpet-modal__sheet" style="background:var(--ink-2);border-color:var(--border);" role="dialog" aria-modal="true" aria-labelledby="feedCommentModalTitle">
    <div class="airpet-modal__header" style="border-color:var(--border);">
      <h3 id="feedCommentModalTitle" class="airpet-modal__title" style="font-family:var(--font-display);">Comentários</h3>
      <button id="closeCommentModal" type="button" class="airpet-modal__header-btn" aria-label="Fechar">
        <i class="fa-solid fa-xmark text-lg"></i>
      </button>
    </div>
    <div id="commentList" class="airpet-modal__body px-4 min-h-[160px]"></div>
    <div id="feedCommentModalReplyBar" class="hidden px-4 pt-2 pb-1 flex items-center justify-between gap-2 text-xs" style="border-top:1px solid var(--border);background:color-mix(in srgb,var(--accent) 8%,var(--ink-2));">
      <span style="color:var(--text-dim);" class="truncate">Respondendo a <strong id="feedCommentModalReplyToName" style="color:var(--text);"></strong></span>
      <button type="button" id="feedCommentModalReplyCancel" class="shrink-0 font-semibold" style="color:var(--accent);padding:4px 0;">Cancelar</button>
    </div>
    <div class="airpet-modal__footer flex gap-2 items-center px-4" style="border-color:var(--border);">
      <input id="commentInputModal" type="text" maxlength="500" placeholder="Adicionar comentário…" class="flex-1 rounded-xl px-3 py-2.5 text-sm" style="background:var(--input);border:1px solid var(--border);color:var(--text);">
      <button id="btnEnviarComentarioModal" type="button" class="btn-primary shrink-0" style="padding:10px 14px;" disabled>Enviar</button>
    </div>
  </div>
</div>

<%- include('partials/post-detail-modal') %>

<script>
(function () {
  'use strict';

  <% var _feedSessaoUsuario = typeof usuario !== 'undefined' && usuario ? { id: usuario.id, nome: usuario.nome || '', foto_perfil: usuario.foto_perfil || '', cor_perfil: usuario.cor_perfil || '#ec5a1c' } : null; %>
  var sessaoFeedUsuario = <%- JSON.stringify(_feedSessaoUsuario) %>;
  var meuId = sessaoFeedUsuario ? sessaoFeedUsuario.id : null;
  var meuNome = sessaoFeedUsuario ? sessaoFeedUsuario.nome : '';
  var meuFotoPerfil = sessaoFeedUsuario ? (sessaoFeedUsuario.foto_perfil || '') : '';
  var meuCorPerfil = sessaoFeedUsuario && sessaoFeedUsuario.cor_perfil ? sessaoFeedUsuario.cor_perfil : '#ec5a1c';
  function normalizePerfilFoto(raw) {
    var s = String(raw || '').trim();
    if (!s) return '';
    if (/^https?:\/\//i.test(s)) return s;
    return s.indexOf('/') === 0 ? s : '/' + s;
  }
  function buildInlineCommentAvatarHtml() {
    var cor = escapeHtml(meuCorPerfil);
    var ini = escapeHtml((meuNome.charAt(0) || 'U').toUpperCase());
    var src = normalizePerfilFoto(meuFotoPerfil);
    if (!src) {
      return '<div style="width:28px;height:28px;border-radius:50%;flex-shrink:0;background:var(--ink-4);display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:700;color:var(--text);box-shadow:0 0 0 2px ' + cor + ';">' + ini + '</div>';
    }
    return '<span style="flex-shrink:0;width:28px;height:28px;display:inline-flex;align-items:center;justify-content:center;"><img src="' + escapeHtml(src) + '" style="width:28px;height:28px;border-radius:50%;object-fit:cover;box-shadow:0 0 0 2px ' + cor + ';" alt="" onerror="this.style.display=\'none\';var n=this.nextElementSibling;if(n){n.style.display=\'flex\';n.style.alignItems=\'center\';n.style.justifyContent=\'center\';}"><div style="display:none;width:28px;height:28px;border-radius:50%;flex-shrink:0;background:var(--ink-4);box-shadow:0 0 0 2px ' + cor + ';font-size:10px;font-weight:700;color:var(--text);" class="inline-avatar-fallback">' + ini + '</div></span>';
  }
  var feedContainer = document.getElementById('feedContainer');
  var commentPostId = null;
  var commentModal = document.getElementById('commentModal');
  var commentList = document.getElementById('commentList');
  var commentInputModal = document.getElementById('commentInputModal');
  var btnEnviarComentarioModal = document.getElementById('btnEnviarComentarioModal');

  function feedCoordinator() {
    return window.AIRPET_REQ_COORDINATOR;
  }
  function feedFetchCoordinator(job, fallbackFetchPromise) {
    var c = feedCoordinator();
    if (c && typeof c.enqueue === 'function') return c.enqueue(job);
    return fallbackFetchPromise;
  }
  function feedSkeletonBlock(count) {
    var n = count || 2;
    var card = '<div class="airpet-skeleton-post"><div class="airpet-skeleton-post__head"><div class="airpet-skeleton-circle"></div><div class="airpet-skeleton-lines"><div class="airpet-skeleton-line airpet-skeleton-line--med"></div><div class="airpet-skeleton-line airpet-skeleton-line--short"></div></div></div><div class="airpet-skeleton-post__media"></div></div>';
    var i;
    var html = '<div class="airpet-skeleton-feed" data-airpet-skel="1">';
    for (i = 0; i < n; i++) html += card;
    html += '</div>';
    return html;
  }
  function feedDeferred(workFn, message) {
    var L = window.AIRPET_LOADING;
    if (L && typeof L.withDeferredOverlay === 'function') {
      return L.withDeferredOverlay(workFn, { message: message || 'Ainda a processar…' });
    }
    return Promise.resolve().then(workFn);
  }
  var repostFeedInFlight = false;
  var isPublishingPost = false;

  // ── Relative time ──
  function tempoRelativo(ts) {
    if (!ts) return '';
    var d = new Date(ts), now = Date.now(), diff = Math.floor((now - d) / 1000);
    if (diff < 60) return 'agora';
    if (diff < 3600) return Math.floor(diff/60) + 'min';
    if (diff < 86400) return Math.floor(diff/3600) + 'h';
    if (diff < 604800) return Math.floor(diff/86400) + 'd';
    return d.toLocaleDateString('pt-BR', {day:'2-digit',month:'short'});
  }

  function formatarDataHoraCompleta(dateStr) {
    if (!dateStr) return '';
    var d = new Date(dateStr);
    if (Number.isNaN(d.getTime())) return '';
    try {
      return d.toLocaleString('pt-BR', { day: 'numeric', month: 'short', year: 'numeric', hour: '2-digit', minute: '2-digit' });
    } catch (_) {
      return '';
    }
  }

  function atualizarTempos() {
    document.querySelectorAll('.tempo-relativo').forEach(function(el) {
      var t = el.getAttribute('data-time');
      if (t) el.textContent = tempoRelativo(t);
    });
  }

  function escapeHtml(s) {
    return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }

  function renderMencoesFeed(texto) {
    var esc = escapeHtml(texto);
    if (typeof window !== 'undefined' && window.AIRPET_socialTextoLinkify && typeof window.AIRPET_socialTextoLinkify.linkifyHashtagsInEscaped === 'function') {
      esc = window.AIRPET_socialTextoLinkify.linkifyHashtagsInEscaped(esc);
    }
    return esc.replace(/@(\S+)/g, '<span class="mention" data-user="$1">@$1</span>');
  }

  var postDetailCommentPostId = null;

  var feedCommentReplyParentId = null;
  var feedCommentReplyToName = '';
  function clearFeedCommentReplyTarget() {
    feedCommentReplyParentId = null;
    feedCommentReplyToName = '';
    var pd = document.getElementById('postDetailReplyBar');
    var fm = document.getElementById('feedCommentModalReplyBar');
    if (pd) pd.classList.add('hidden');
    if (fm) fm.classList.add('hidden');
  }
  function setFeedCommentReplyTarget(parentId, name) {
    feedCommentReplyParentId = parentId;
    feedCommentReplyToName = name || '';
    var n1 = document.getElementById('postDetailReplyToName');
    var n2 = document.getElementById('feedCommentModalReplyToName');
    if (n1) n1.textContent = feedCommentReplyToName;
    if (n2) n2.textContent = feedCommentReplyToName;
    var pd = document.getElementById('postDetailReplyBar');
    var fm = document.getElementById('feedCommentModalReplyBar');
    if (pd) pd.classList.remove('hidden');
    if (fm) fm.classList.remove('hidden');
  }

  function syncPostDetailRepostLayoutFeed(meta) {
    var repCtx = document.getElementById('postDetailRepostCtx');
    var quoted = document.getElementById('postDetailQuotedWrap');
    var qh = document.getElementById('postDetailQuotedHeader');
    var qt = document.getElementById('postDetailQuotedText');
    var qi = document.getElementById('postDetailQuotedImg');
    if (!repCtx || !quoted || !qh || !qt || !qi) return;
    var isRepost = meta && meta.kind === 'organic' && meta.tipo === 'repost' && meta.orig_id;
    if (!isRepost) {
      repCtx.classList.add('hidden');
      quoted.classList.add('hidden');
      qt.classList.add('hidden');
      qi.classList.add('hidden');
      qt.textContent = '';
      qi.removeAttribute('src');
      qh.innerHTML = '';
      return;
    }
    repCtx.classList.remove('hidden');
    var who = repCtx.querySelector('.post-detail-repost-who');
    if (who) who.textContent = meta.autor_nome || '';
    quoted.classList.remove('hidden');
    var origPet = meta.orig_pet_id && meta.orig_pet_nome;
    if (origPet) {
      var pav = meta.orig_pet_foto
        ? '<a href="/explorar/pet/' + meta.orig_pet_id + '" class="shrink-0"><img src="' + escapeHtml(meta.orig_pet_foto) + '" alt="" class="w-9 h-9 rounded-full object-cover ring-1 ring-gray-200"></a>'
        : '<a href="/explorar/pet/' + meta.orig_pet_id + '" class="shrink-0 w-9 h-9 rounded-full bg-primary-50 text-primary-500 flex items-center justify-center text-xs">🐾</a>';
      qh.innerHTML = pav + '<div class="min-w-0 flex-1"><a href="/explorar/pet/' + meta.orig_pet_id + '" class="font-semibold text-gray-900 truncate block">' + escapeHtml(meta.orig_pet_nome) + '</a><p class="text-xs text-gray-500 truncate">por <a href="/explorar/perfil/' + meta.orig_usuario_id + '" class="font-medium hover:text-primary-600">' + escapeHtml(meta.orig_autor_nome || '') + '</a></p></div>';
    } else {
      var av = meta.orig_foto_perfil
        ? '<img src="' + escapeHtml(meta.orig_foto_perfil) + '" alt="" class="w-9 h-9 rounded-full object-cover shrink-0 ring-1 ring-gray-200">'
        : '<span class="w-9 h-9 rounded-full shrink-0 bg-gray-200 flex items-center justify-center text-xs font-bold text-gray-600">' + escapeHtml((meta.orig_autor_nome || 'U').charAt(0).toUpperCase()) + '</span>';
      qh.innerHTML = '<div class="flex items-center gap-2 min-w-0">' + av + '<a href="/explorar/perfil/' + meta.orig_usuario_id + '" class="font-semibold text-gray-900 truncate hover:text-primary-600">' + escapeHtml(meta.orig_autor_nome || '') + '</a></div>';
    }
    var origTxt = (meta.orig_texto || meta.orig_legenda || '').trim();
    if (origTxt) {
      qt.textContent = origTxt;
      qt.classList.remove('hidden');
    } else {
      qt.textContent = '';
      qt.classList.add('hidden');
    }
    if (meta.orig_foto && String(meta.orig_foto).trim()) {
      qi.src = meta.orig_foto;
      qi.classList.remove('hidden');
    } else {
      qi.removeAttribute('src');
      qi.classList.add('hidden');
    }
  }

  function carregarComentariosPostDetail(postId) {
    var list = document.getElementById('postDetailCommentList');
    if (!list) return;
    try {
      if (feedCoordinator() && feedCoordinator().cancelGroup) feedCoordinator().cancelGroup('feedPostDetailComments');
    } catch (_) {}
    list.innerHTML = '<div class="text-center py-6 text-sm text-gray-400">Carregando…</div>';
    var pr = feedFetchCoordinator(
      {
        key: 'comentariosDetail:' + postId,
        group: 'feedPostDetailComments',
        priority: feedCoordinator() ? feedCoordinator().PRIORITY.HIGH : 'HIGH',
        fetchFn: function (signal) {
          return fetch('/explorar/post/' + postId + '/comentarios', {
            headers: { 'Accept': 'application/json' },
            credentials: 'same-origin',
            signal: signal
          }).then(function (r) { return r.json(); });
        }
      },
      fetch('/explorar/post/' + postId + '/comentarios', { headers: { 'Accept': 'application/json' }, credentials: 'same-origin' })
        .then(function (r) { return r.json(); })
    );
    feedDeferred(function () {
      return pr.then(function (data) {
        if (!data || !data.sucesso || !data.comentarios || !data.comentarios.length) {
          list.innerHTML = '<div class="text-center py-8 text-sm text-gray-400">Nenhum comentário ainda.</div>';
          return;
        }
        if (window.AIRPET_commentRender && window.AIRPET_commentRender.renderList) {
          list.innerHTML = window.AIRPET_commentRender.renderList(data.comentarios, {
            meuId: meuId,
            escapeHtml: escapeHtml,
            renderMencoes: renderMencoesFeed,
            tempoRelativo: tempoRelativo,
            useDataTimeAttr: true,
            allowReply: !!meuId
          });
        }
      }).catch(function () {
        list.innerHTML = '<div class="text-center py-8 text-sm text-red-400">Erro ao carregar.</div>';
      });
    }, 'A carregar comentários…');
  }

  function fecharPostDetailOwnerDropdown() {
    var dd = document.getElementById('postDetailOwnerDropdown');
    var btn = document.getElementById('btnPostDetailOwnerMenu');
    if (dd) dd.classList.add('hidden');
    if (btn) btn.setAttribute('aria-expanded', 'false');
  }

  function fecharPostDetailModal() {
    var el = document.getElementById('postDetailModal');
    if (!el) return;
    fecharPostDetailOwnerDropdown();
    el.classList.remove('is-open');
    setTimeout(function () {
      if (!el.classList.contains('is-open')) {
        el.classList.add('hidden');
        el.setAttribute('aria-hidden', 'true');
        if (window.AIRPET_modalUi) window.AIRPET_modalUi.refreshBodyScroll();
      }
    }, 220);
  }

  window.AIRPET_fecharPostDetailModal = fecharPostDetailModal;

  function abrirPostDetailModal() {
    var el = document.getElementById('postDetailModal');
    if (!el) return;
    var wasHidden = el.classList.contains('hidden');
    el.classList.remove('hidden');
    el.setAttribute('aria-hidden', 'false');
    if (window.AIRPET_modalUi) window.AIRPET_modalUi.refreshBodyScroll();
    requestAnimationFrame(function () {
      requestAnimationFrame(function () { el.classList.add('is-open'); });
    });
    if (wasHidden && typeof window.AIRPET_modalHistory_afterPostDetailOpen === 'function') {
      window.AIRPET_modalHistory_afterPostDetailOpen();
    }
  }

  function openPostDetailFromArticle(article) {
    if (!article) return;
    var raw = article.getAttribute('data-explorar-meta');
    if (!raw) return;
    var meta;
    try { meta = JSON.parse(decodeURIComponent(raw)); } catch (err) { return; }
    if (meta.kind !== 'organic') return;
    clearFeedCommentReplyTarget();
    postDetailCommentPostId = meta.postId;
    var titleEl = document.getElementById('postDetailTitle');
    if (titleEl) {
      titleEl.textContent = meta.pet_nome || meta.autor_nome || 'Publicação';
    }
    var imgEl = document.getElementById('postDetailImg');
    var fbEl = document.getElementById('postDetailImgFallback');
    var mediaCol = document.getElementById('postDetailMediaCol');
    var mainPhoto = '';
    if (meta.foto && String(meta.foto).trim()) mainPhoto = String(meta.foto).trim();
    else if (meta.tipo === 'repost' && meta.orig_foto && String(meta.orig_foto).trim()) {
      mainPhoto = String(meta.orig_foto).trim();
    }
    var hasFoto = !!mainPhoto;
    if (mediaCol) {
      if (hasFoto) mediaCol.classList.remove('hidden');
      else mediaCol.classList.add('hidden');
    }
    if (hasFoto && imgEl && fbEl) {
      imgEl.src = mainPhoto;
      imgEl.classList.remove('hidden');
      fbEl.classList.add('hidden');
    } else if (imgEl && fbEl) {
      imgEl.classList.add('hidden');
      imgEl.removeAttribute('src');
      fbEl.classList.add('hidden');
    }
    var row = document.getElementById('postDetailAuthorRow');
    if (row) {
      row.innerHTML = '';
      var cor = meta.cor_perfil || '#ec5a1c';
      var oHasPet = meta.pet_id && meta.pet_nome;
      if (oHasPet) {
        var pav = meta.pet_foto
          ? '<img src="' + escapeHtml(meta.pet_foto) + '" alt="" class="w-11 h-11 rounded-full object-cover shrink-0 ring-2 ring-primary-200 shadow-sm">'
          : '<span class="w-11 h-11 rounded-full flex items-center justify-center text-lg shrink-0 bg-primary-50 text-primary-500 ring-2 ring-primary-200/80">🐾</span>';
        row.innerHTML = '<div class="flex items-center gap-3 min-w-0"><a href="/explorar/pet/' + meta.pet_id + '" class="shrink-0">' + pav + '</a><div class="min-w-0 flex-1"><a href="/explorar/pet/' + meta.pet_id + '" class="explorar-card-name truncate block" style="font-weight:600;color:var(--text);">' + escapeHtml(meta.pet_nome) + '</a><p class="text-xs text-gray-500 truncate mt-0.5">por <a href="/explorar/perfil/' + meta.usuario_id + '" class="font-semibold text-gray-600 hover:underline">' + escapeHtml(meta.autor_nome) + '</a></p></div></div>';
      } else {
        var av = meta.foto_perfil
          ? '<img src="' + escapeHtml(meta.foto_perfil) + '" alt="" class="w-10 h-10 rounded-full object-cover shrink-0" style="box-shadow:0 0 0 2px ' + escapeHtml(cor) + '">'
          : '<span class="w-10 h-10 rounded-full flex items-center justify-center text-sm font-bold text-white shrink-0 bg-gray-400" style="box-shadow:0 0 0 2px ' + escapeHtml(cor) + '">' + escapeHtml((meta.autor_nome || 'U').charAt(0).toUpperCase()) + '</span>';
        row.innerHTML = '<a href="/explorar/perfil/' + meta.usuario_id + '" class="flex items-center gap-3 min-w-0">' + av + '<span class="font-semibold text-gray-900 truncate">' + escapeHtml(meta.autor_nome) + '</span></a>';
      }
    }
    var dateEl = document.getElementById('postDetailDate');
    var dateAbsEl = document.getElementById('postDetailDateAbsolute');
    var dStrFeed = meta.criado_em || '';
    if (dateEl) dateEl.textContent = dStrFeed ? tempoRelativo(dStrFeed) : '';
    if (dateAbsEl) {
      dateAbsEl.textContent = dStrFeed ? formatarDataHoraCompleta(dStrFeed) : '';
      if (!dStrFeed) dateAbsEl.classList.add('hidden');
      else dateAbsEl.classList.remove('hidden');
    }
    var shareRow = document.getElementById('postDetailShareRow');
    var shareBtn = document.getElementById('postDetailBtnCompartilhar');
    if (shareRow && shareBtn && meta.postId != null && String(meta.postId).trim() !== '') {
      shareRow.classList.remove('hidden');
      shareBtn.setAttribute('data-post-id', String(meta.postId));
      shareBtn.setAttribute('data-autor', meta.autor_nome || '');
      shareBtn.setAttribute('data-pet-nome', meta.pet_nome || '');
    } else if (shareRow && shareBtn) {
      shareRow.classList.add('hidden');
      shareBtn.removeAttribute('data-post-id');
    }
    var extra = document.getElementById('postDetailExtra');
    if (extra) extra.classList.add('hidden');
    var tw = document.getElementById('postDetailTextWrap');
    var tp = document.getElementById('postDetailText');
    var texto = meta.texto || '';
    if (tw && tp) {
      if (texto) {
        tp.innerHTML = renderMencoesFeed(texto);
        tw.classList.remove('hidden');
      } else {
        tp.innerHTML = '';
        tw.classList.add('hidden');
      }
    }
    syncPostDetailRepostLayoutFeed(meta);
    var cs = document.getElementById('postDetailCommentsSection');
    var comp = document.getElementById('postDetailCommentComposer');
    var hint = document.getElementById('postDetailLoginHint');
    var inpDetail = document.getElementById('postDetailCommentInput');
    var btnDet = document.getElementById('postDetailBtnEnviar');
    var ppc = document.getElementById('postDetailPetsContainer');
    if (ppc) ppc.classList.add('hidden');
    if (cs) cs.classList.remove('hidden');
    if (meuId && comp && hint && inpDetail && btnDet) {
      comp.classList.remove('hidden');
      hint.classList.add('hidden');
      inpDetail.disabled = false;
      inpDetail.setAttribute('data-post-id', postDetailCommentPostId);
      inpDetail.value = '';
      btnDet.disabled = true;
    } else if (comp && hint) {
      comp.classList.add('hidden');
      hint.classList.remove('hidden');
      if (inpDetail) { inpDetail.disabled = true; inpDetail.value = ''; }
      if (btnDet) btnDet.disabled = true;
    }
    carregarComentariosPostDetail(postDetailCommentPostId);
    var ownerWrap = document.getElementById('postDetailOwnerMenuWrap');
    var ownerDd = document.getElementById('postDetailOwnerDropdown');
    fecharPostDetailOwnerDropdown();
    if (ownerWrap) {
      if (meuId && Number(meta.usuario_id) === Number(meuId)) {
        ownerWrap.classList.remove('hidden');
        var bf = ownerWrap.querySelector('.btn-post-detail-fixar');
        var bd = ownerWrap.querySelector('.btn-post-detail-deletar');
        var idStr = String(meta.postId);
        if (bf) {
          bf.setAttribute('data-post-id', idStr);
          var fx = !!meta.fixada;
          bf.setAttribute('data-fixada', fx ? '1' : '0');
          var sp = bf.querySelector('span');
          if (sp) sp.textContent = fx ? 'Desafixar' : 'Fixar';
        }
        if (bd) bd.setAttribute('data-post-id', idStr);
      } else {
        ownerWrap.classList.add('hidden');
      }
    }
    if (ownerDd) ownerDd.classList.add('hidden');
    abrirPostDetailModal();
  }

  // ── Menus ──
  function fecharMenus() {
    document.querySelectorAll('.post-dropdown').forEach(function(m) { m.classList.add('hidden'); });
  }

  function toggleMenu(btn) {
    var dd = btn.nextElementSibling;
    var isHidden = dd.classList.contains('hidden');
    fecharMenus();
    if (isHidden) dd.classList.remove('hidden');
  }

  // ── Like ──
  function aplicarEstadoCurtidaBtn(btn, curtiu, total) {
    btn.setAttribute('data-curtiu', curtiu ? '1' : '0');
    btn.classList.toggle('liked', curtiu);
    var icon = btn.querySelector('i');
    if (icon) { icon.className = curtiu ? 'fa-solid fa-heart' : 'fa-regular fa-heart'; }
    var countEl = btn.querySelector('.count-curtidas');
    if (countEl) {
      countEl.textContent = (total != null && Number(total) > 0) ? String(total) : '';
    }
  }

  function curtirPost(postId, btn) {
    if (!meuId) { window.location = '/auth/login'; return; }
    if (btn.getAttribute('data-airpet-like-pending') === '1') return;
    var curtiu = btn.getAttribute('data-curtiu') === '1';
    var method = curtiu ? 'DELETE' : 'POST';
    btn.setAttribute('data-airpet-like-pending', '1');
    btn.classList.add('airpet-btn-loading');
    var c = feedCoordinator();
    var pr = c && typeof c.enqueue === 'function'
      ? c.enqueue({
        key: 'curtir:' + postId,
        group: 'feed',
        priority: c.PRIORITY.MEDIUM,
        fetchFn: function (signal) {
          return fetch('/explorar/post/' + postId + '/curtir', {
            method: method,
            headers: { 'Accept': 'application/json' },
            credentials: 'same-origin',
            signal: signal
          }).then(function (r) { return r.json(); });
        }
      })
      : fetch('/explorar/post/' + postId + '/curtir', {
        method: method,
        headers: { 'Accept': 'application/json' },
        credentials: 'same-origin'
      }).then(function (r) { return r.json(); });

    feedDeferred(function () {
      return pr.then(function (d) {
        if (d && d.sucesso) {
          aplicarEstadoCurtidaBtn(btn, !!d.curtiu, d.total);
          if (d.curtiu) {
            btn.classList.add('animate-heartPop');
            setTimeout(function () { btn.classList.remove('animate-heartPop'); }, 400);
            var heart = document.createElement('span');
            heart.className = 'float-heart';
            heart.textContent = '♥';
            heart.style.cssText = 'left:50%;top:50%;transform:translate(-50%,-50%)';
            btn.appendChild(heart);
            setTimeout(function () { heart.remove(); }, 700);
          }
        }
      }).catch(function () {});
    }, 'A atualizar gostos…').finally(function () {
      btn.removeAttribute('data-airpet-like-pending');
      btn.classList.remove('airpet-btn-loading');
    });
  }

  // ── Comments ──
  function abrirComentarios(postId) {
    clearFeedCommentReplyTarget();
    commentPostId = postId;
    if (!commentModal || !commentList) return;
    commentInputModal.value = '';
    btnEnviarComentarioModal.disabled = true;
    commentModal.classList.remove('hidden');
    commentModal.style.removeProperty('display');
    commentModal.setAttribute('aria-hidden', 'false');
    if (window.AIRPET_modalUi && typeof window.AIRPET_modalUi.refreshBodyScroll === 'function') {
      window.AIRPET_modalUi.refreshBodyScroll();
    }
    try {
      if (feedCoordinator() && feedCoordinator().cancelGroup) feedCoordinator().cancelGroup('feedComments');
    } catch (_) {}
    commentList.innerHTML = '<p style="color:var(--text-dim);font-size:14px;">Carregando comentários…</p>';
    var c = feedCoordinator();
    var pr = c && typeof c.enqueue === 'function'
      ? c.enqueue({
        key: 'comentariosModal:' + postId,
        group: 'feedComments',
        priority: c.PRIORITY.HIGH,
        fetchFn: function (signal) {
          return fetch('/explorar/post/' + postId + '/comentarios', {
            headers: { 'Accept': 'application/json' },
            credentials: 'same-origin',
            signal: signal
          }).then(function (r) { return r.json(); });
        }
      })
      : fetch('/explorar/post/' + postId + '/comentarios', {
        headers: { 'Accept': 'application/json' },
        credentials: 'same-origin'
      }).then(function (r) { return r.json(); });
    feedDeferred(function () {
      return pr.then(function (data) {
        if (!data || !data.sucesso) {
          commentList.innerHTML = '<p style="color:#ef4444;font-size:14px;">Não foi possível carregar os comentários.</p>';
          return;
        }
        renderComentariosModal(data.comentarios || []);
      }).catch(function () {
        commentList.innerHTML = '<p style="color:#ef4444;font-size:14px;">Erro ao carregar comentários.</p>';
      });
    }, 'A carregar comentários…');
  }

  function fecharComentariosModal() {
    if (!commentModal) return;
    commentModal.classList.add('hidden');
    commentModal.style.removeProperty('display');
    commentModal.setAttribute('aria-hidden', 'true');
    commentPostId = null;
    if (window.AIRPET_modalUi) window.AIRPET_modalUi.refreshBodyScroll();
  }

  window.AIRPET_fecharCommentModal = fecharComentariosModal;

  function renderComentariosModal(comentarios) {
    if (!commentList) return;
    if (!comentarios || comentarios.length === 0) {
      commentList.innerHTML = '<p style="color:var(--text-dim);font-size:14px;padding:12px;">Nenhum comentário ainda.</p>';
      return;
    }
    if (window.AIRPET_commentRender && window.AIRPET_commentRender.renderList) {
      commentList.innerHTML = window.AIRPET_commentRender.renderList(comentarios, {
        meuId: meuId,
        escapeHtml: escapeHtml,
        renderMencoes: renderMencoesFeed,
        tempoRelativo: tempoRelativo,
        useDataTimeAttr: true,
        allowReply: !!meuId
      });
      return;
    }
    var html = '';
    comentarios.forEach(function (c) {
      var nome = c.nome || c.autor_nome || 'Usuário';
      var texto = c.texto || '';
      html += '<div style="padding:10px 0;border-bottom:1px solid var(--border);">' +
        '<div style="font-size:13px;font-weight:700;color:var(--text);margin-bottom:4px;">' + escapeHtml(nome) + '</div>' +
        '<div style="font-size:14px;color:var(--text-dim);line-height:1.45;">' + escapeHtml(texto) + '</div>' +
        '</div>';
    });
    commentList.innerHTML = html;
  }

  function enviarComentario(postId, texto, inputEl, actionBtn) {
    var payload = { texto: texto };
    if (feedCommentReplyParentId) payload.parent_id = parseInt(feedCommentReplyParentId, 10);
    var sendBtn = actionBtn;
    if (!sendBtn && inputEl) {
      var row = inputEl.closest('.post-comment-row');
      if (row) sendBtn = row.querySelector('.btn-enviar-inline');
    }
    var body = JSON.stringify(payload);
    var runInner = function () {
      var c = feedCoordinator();
      if (c && typeof c.enqueue === 'function') {
        return c.enqueue({
          key: 'comentar:' + postId,
          group: 'feedComentar',
          priority: c.PRIORITY.HIGH,
          fetchFn: function (signal) {
            return fetch('/explorar/post/' + postId + '/comentar', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
              credentials: 'same-origin',
              body: body,
              signal: signal
            }).then(function (r) { return r.json(); });
          }
        });
      }
      return fetch('/explorar/post/' + postId + '/comentar', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
        credentials: 'same-origin',
        body: body
      }).then(function (r) { return r.json(); });
    };
    var run = function () {
      return feedDeferred(runInner, 'A enviar comentário…');
    };
    var p = window.AIRPET_LOADING && sendBtn
      ? window.AIRPET_LOADING.runLocked({
        button: sendBtn,
        busyText: '<span class="airpet-inline-dots">Enviando</span>'
      }, run)
      : run();
    p.then(function (d) {
      if (d && d.sucesso) {
        inputEl.value = '';
        clearFeedCommentReplyTarget();
        var card = document.getElementById('post-' + postId);
        if (card) {
          var countEl = card.querySelector('.count-comentarios');
          if (countEl) {
            var n = parseInt(countEl.textContent) || 0;
            countEl.textContent = n + 1;
          }
        }
        if (commentPostId === String(postId) || commentPostId === postId) {
          abrirComentarios(postId);
        }
        if (postDetailCommentPostId === postId || postDetailCommentPostId === String(postId)) {
          carregarComentariosPostDetail(postId);
        }
      }
    }).catch(function () {});
  }

  // ── Repost ──
  function abrirRepostModal(postId) {
    if (!meuId) { window.location = '/auth/login'; return; }
    if (repostFeedInFlight) return;
    if (!confirm('Repostar esta publicação?')) return;
    repostFeedInFlight = true;
    var c = feedCoordinator();
    var body = JSON.stringify({ texto: 'Repost' });
    var pr = c && typeof c.enqueue === 'function'
      ? c.enqueue({
        key: 'repost:' + postId,
        group: 'feed',
        priority: c.PRIORITY.MEDIUM,
        fetchFn: function (signal) {
          return fetch('/explorar/post/' + postId + '/repost', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
            credentials: 'same-origin',
            body: body,
            signal: signal
          }).then(function (r) { return r.json(); });
        }
      })
      : fetch('/explorar/post/' + postId + '/repost', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
        credentials: 'same-origin',
        body: body
      }).then(function (r) { return r.json(); });
    feedDeferred(function () {
      return pr.then(function (d) {
        if (d.sucesso) {
          var card = document.getElementById('post-' + postId);
          if (card) {
            var btn = card.querySelector('.btn-repost');
            if (btn) {
              btn.classList.add('reposted');
              var countEl = btn.querySelector('.count-reposts');
              if (countEl) countEl.textContent = (parseInt(countEl.textContent) || 0) + 1;
            }
          }
        }
      }).catch(function () {});
    }, 'A republicar…').finally(function () { repostFeedInFlight = false; });
  }

  // ── Share ──
  function compartilhar(postId, autor, petNome) {
    var url = window.location.origin + '/explorar/post/' + postId;
    var quem = (petNome && String(petNome).trim()) ? String(petNome).trim() : (autor || 'AIRPET');
    if (navigator.share) {
      navigator.share({ title: 'Publicação de ' + quem + ' no AIRPET', url: url });
    } else {
      navigator.clipboard.writeText(url).then(function() {
        alert('Link copiado!');
      });
    }
  }

  (function bindPostDetailCompartilharFeed() {
    var btn = document.getElementById('postDetailBtnCompartilhar');
    if (!btn || btn.dataset.airpetShareBoundFeed) return;
    btn.dataset.airpetShareBoundFeed = '1';
    btn.addEventListener('click', function () {
      var id = this.getAttribute('data-post-id');
      if (!id) return;
      compartilhar(id, this.getAttribute('data-autor') || '', this.getAttribute('data-pet-nome') || '');
    });
  })();

  // ── Pin / Delete ──
  function fixarPost(postId, isFixed) {
    var method = isFixed ? 'DELETE' : 'POST';
    var c = feedCoordinator();
    var pr = c && typeof c.enqueue === 'function'
      ? c.enqueue({
        key: 'fixar:' + postId,
        group: 'feed',
        priority: c.PRIORITY.MEDIUM,
        fetchFn: function (signal) {
          return fetch('/explorar/post/' + postId + '/fixar', {
            method: method,
            headers: { 'Accept': 'application/json' },
            credentials: 'same-origin',
            signal: signal
          });
        }
      })
      : fetch('/explorar/post/' + postId + '/fixar', {
        method: method,
        headers: { 'Accept': 'application/json' },
        credentials: 'same-origin'
      });
    feedDeferred(function () {
      return pr.then(function () {
        if (window.AIRPET_LOADING && typeof window.AIRPET_LOADING.showRoute === 'function') {
          window.AIRPET_LOADING.showRoute();
        }
        location.reload();
      });
    }, 'A fixar publicação…').catch(function () {});
  }

  function deletarPost(postId) {
    if (!confirm('Excluir publicação?')) return;
    var c = feedCoordinator();
    var pr = c && typeof c.enqueue === 'function'
      ? c.enqueue({
        key: 'deletePost:' + postId,
        group: 'feed',
        priority: c.PRIORITY.MEDIUM,
        fetchFn: function (signal) {
          return fetch('/explorar/post/' + postId, {
            method: 'DELETE',
            headers: { 'Accept': 'application/json' },
            credentials: 'same-origin',
            signal: signal
          }).then(function (r) { return r.json(); });
        }
      })
      : fetch('/explorar/post/' + postId, { method: 'DELETE', headers: { 'Accept': 'application/json' }, credentials: 'same-origin' })
        .then(function (r) { return r.json(); });
    feedDeferred(function () {
      return pr.then(function (d) {
        if (d.sucesso) {
          var el = document.getElementById('post-' + postId);
          if (el) {
            el.style.transition = 'opacity 0.3s, transform 0.3s';
            el.style.opacity = '0'; el.style.transform = 'translateY(-8px)';
            setTimeout(function () { el.remove(); }, 300);
          }
          requestClosePostDetailFeed();
        }
      });
    }, 'A remover publicação…').catch(function () {});
  }

  // ── Ver mais ──
  function initVerMais() {
    document.querySelectorAll('.post-text-body').forEach(function(el) {
      if (el.scrollHeight > el.clientHeight + 4) {
        var btn = el.closest('article') ? el.closest('article').querySelector('.btn-ver-mais') : null;
        if (btn) btn.classList.remove('hidden');
      }
    });
  }

  function toggleTexto(btn) {
    var el = btn.closest('article').querySelector('.post-text-body');
    if (el) {
      el.classList.toggle('line-clamp-3');
      btn.textContent = el.classList.contains('line-clamp-3') ? 'ver mais' : 'ver menos';
    }
  }

  // ── Composer ──
  var textarea = document.getElementById('novoPostTexto');
  var btnPublicar = document.getElementById('btnPublicar');
  var charCount = document.getElementById('charCount');
  var inputFoto = document.getElementById('inputFotoPost');
  var previewWrap = document.getElementById('novoPostPreview');
  var previewImg = document.getElementById('novoPostPreviewImg');
  var fotoBlob = null;

  if (textarea) {
    textarea.addEventListener('input', function() {
      var len = textarea.value.length;
      charCount.textContent = len + '/500';
      charCount.style.color = len > 450 ? '#f87171' : 'var(--text-dim)';
      btnPublicar.disabled = len === 0 && !fotoBlob;
    });
  }

  if (document.getElementById('btnAnexarFoto')) {
    document.getElementById('btnAnexarFoto').addEventListener('click', function() { inputFoto.click(); });
  }

  if (inputFoto) {
    inputFoto.addEventListener('change', function() {
      var file = this.files[0];
      if (!file) return;
      var reader = new FileReader();
      reader.onload = function(ev) {
        previewImg.src = ev.target.result;
        previewWrap.classList.remove('hidden');
        fotoBlob = file;
        btnPublicar.disabled = false;
      };
      reader.readAsDataURL(file);
    });
  }

  if (document.getElementById('removerFoto')) {
    document.getElementById('removerFoto').addEventListener('click', function() {
      previewWrap.classList.add('hidden');
      previewImg.src = '';
      fotoBlob = null;
      inputFoto.value = '';
      if (textarea) btnPublicar.disabled = textarea.value.trim() === '';
    });
  }

  if (btnPublicar) {
    btnPublicar.addEventListener('click', function() {
      if (isPublishingPost) return;
      var texto = textarea.value.trim();
      if (!texto && !fotoBlob) return;
      isPublishingPost = true;

      var petIdEl = document.getElementById('novoPetId');
      var petId = petIdEl ? String(petIdEl.value || '').trim() : '';
      if (!petId) {
        alert('Escolha um pet para publicar. Cadastre um pet em Meus pets se ainda não tiver.');
        isPublishingPost = false;
        return;
      }

      var fd = new FormData();
      if (texto) fd.append('texto', texto);
      fd.append('pet_id', petId);
      if (fotoBlob) fd.append('foto', fotoBlob);
      var moldChk = document.getElementById('feedPostFofinhosMoldura');
      if (moldChk && moldChk.checked) fd.append('fofinhos_moldura', '1');

      var busyLabel = '<i class="fa-solid fa-paw fa-bounce" aria-hidden="true"></i> <span class="airpet-inline-dots">Publicando</span>';
      var work = function () {
        return feedDeferred(function () {
          return fetch('/explorar/post', { method: 'POST', body: fd, credentials: 'same-origin' })
            .then(function (r) {
              return r.text().then(function (text) {
                var data;
                try { data = JSON.parse(text); } catch (_) {
                  data = { sucesso: false, mensagem: r.status === 401 ? 'Sessão expirada. Faça login de novo.' : 'Erro no servidor.' };
                }
                return { ok: r.ok, data: data };
              });
            });
        }, 'A publicar…');
      };
      var p = window.AIRPET_LOADING
        ? window.AIRPET_LOADING.runLocked({ button: btnPublicar, busyText: busyLabel }, work)
        : work();
      p.then(function (res) {
          var d = res.data;
          if (res.ok && d.sucesso && d.post) {
            textarea.value = ''; charCount.textContent = '0/500';
            previewWrap.classList.add('hidden'); previewImg.src = ''; fotoBlob = null;
            btnPublicar.disabled = true;
            var html = renderPostHTML(d.post);
            var temp = document.createElement('div'); temp.innerHTML = html;
            var newCard = temp.firstChild;
            feedContainer.insertBefore(newCard, feedContainer.firstChild);
            initVerMais();
          } else {
            var msg = (d && d.mensagem) || (d && d.erros && d.erros.length ? d.erros.join(' ') : '') || 'Erro ao publicar.';
            alert(msg);
          }
        })
        .catch(function () { alert('Erro de conexão. Tente novamente.'); })
        .finally(function () { isPublishingPost = false; });
    });
  }

  // ── Stories (24h): faixa + modal publicar + viewer com fila e tempo ──
  (function storiesFeedInit() {
    var strip = document.getElementById('feedStoriesStrip');
    var modal = document.getElementById('storyComposerModal');
    if (!strip || !modal) return;

    var viewer = document.getElementById('storyViewerModal');
    var storyFile = null;
    var btnNovo = document.getElementById('btnAbrirStoryComposer');
    var btnFechar = document.getElementById('storyComposerClose');
    var sf = document.getElementById('storyFotoInput');
    var pvw = document.getElementById('storyFotoPreviewWrap');
    var pimg = document.getElementById('storyFotoPreview');
    var legEl = document.getElementById('storyLegenda');
    var petSel = document.getElementById('storyPetId');
    var btnEnviar = document.getElementById('storyEnviarBtn');
    var spin = document.getElementById('storyEnviarSpinner');
    var msg = document.getElementById('storyComposerMsg');

    var storyQueue = [];
    var storyIdx = 0;
    var storyTick = null;
    var STORY_MS = 6000;

    function clearStoryTimer() {
      if (storyTick) {
        clearTimeout(storyTick);
        storyTick = null;
      }
    }

    function resetProgressBar() {
      var fill = document.getElementById('storyProgFill');
      if (!fill) return;
      fill.style.transition = 'none';
      fill.style.width = '0%';
      void fill.offsetWidth;
      fill.style.transition = 'width ' + (STORY_MS / 1000) + 's linear';
      fill.style.width = '100%';
    }

    function scheduleAdvance() {
      clearStoryTimer();
      resetProgressBar();
      storyTick = setTimeout(goNextStory, STORY_MS);
    }

    function renderStoryAt(i) {
      if (i < 0 || i >= storyQueue.length) return;
      var s = storyQueue[i];
      var imgEl = document.getElementById('storyViewerImg');
      var link = document.getElementById('storyViewerPetLink');
      var cap = document.getElementById('storyViewerLegenda');
      if (imgEl) imgEl.src = s.media_url || '';
      if (link) {
        link.textContent = s.pet_nome || 'Pet';
        link.href = s.pet_slug ? '/p/' + encodeURIComponent(s.pet_slug) : '/explorar/pet/' + s.pet_id;
      }
      if (cap) cap.textContent = s.legenda || '';
      scheduleAdvance();
    }

    function openViewerWithQueue(list, startIndex) {
      if (!viewer || !Array.isArray(list) || !list.length) return;
      storyQueue = list.slice();
      storyIdx = Math.max(0, Math.min(startIndex || 0, storyQueue.length - 1));
      viewer.classList.add('is-open');
      document.body.style.overflow = 'hidden';
      renderStoryAt(storyIdx);
    }

    function goNextStory() {
      clearStoryTimer();
      storyIdx += 1;
      if (storyIdx >= storyQueue.length) {
        closeViewer();
        return;
      }
      renderStoryAt(storyIdx);
    }

    function goPrevStory() {
      clearStoryTimer();
      if (storyIdx <= 0) {
        closeViewer();
        return;
      }
      storyIdx -= 1;
      renderStoryAt(storyIdx);
    }

    function showModal() {
      var np = document.getElementById('novoPetId');
      if (petSel && np && np.value) petSel.value = np.value;
      modal.classList.add('is-open');
      document.body.style.overflow = 'hidden';
    }
    function hideModal() {
      modal.classList.remove('is-open');
      if (!viewer || !viewer.classList.contains('is-open')) document.body.style.overflow = '';
    }

    if (btnNovo) btnNovo.addEventListener('click', showModal);
    if (btnFechar) btnFechar.addEventListener('click', hideModal);
    modal.addEventListener('click', function (e) { if (e.target === modal) hideModal(); });

    if (sf) {
      sf.addEventListener('change', function () {
        var file = this.files[0];
        storyFile = file || null;
        if (!file) {
          if (pvw) pvw.classList.add('hidden');
          if (pimg) pimg.src = '';
          return;
        }
        var reader = new FileReader();
        reader.onload = function (ev) {
          if (pimg) pimg.src = ev.target.result;
          if (pvw) pvw.classList.remove('hidden');
        };
        reader.readAsDataURL(file);
      });
    }

    if (btnEnviar) {
      btnEnviar.addEventListener('click', function () {
        if (btnEnviar.getAttribute('data-story-send') === '1') return;
        var petId = petSel ? petSel.value : '';
        if (!petId) { alert('Escolha um pet.'); return; }
        if (!storyFile) { alert('Escolha uma foto para a story.'); return; }
        var fd = new FormData();
        fd.append('pet_id', petId);
        fd.append('foto', storyFile);
        if (legEl && legEl.value.trim()) fd.append('legenda', legEl.value.trim());

        btnEnviar.setAttribute('data-story-send', '1');
        setTimeout(function () { btnEnviar.removeAttribute('data-story-send'); }, 900);

        if (msg) {
          msg.classList.add('hidden');
          msg.textContent = '';
        }
        if (spin) spin.classList.add('hidden');

        hideModal();
        if (sf) sf.value = '';
        storyFile = null;
        if (pvw) pvw.classList.add('hidden');
        if (pimg) pimg.src = '';
        if (legEl) legEl.value = '';

        fetch('/explorar/api/stories', {
          method: 'POST',
          body: fd,
          credentials: 'same-origin',
          headers: { Accept: 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
        })
          .then(function (r) { return r.json(); })
          .then(function (d) {
            if (d.sucesso) {
              loadFeedStories();
            } else {
              alert((d && d.mensagem) ? d.mensagem : 'Não foi possível publicar a story.');
            }
          })
          .catch(function () {
            alert('Erro de rede ao publicar a story. Tente de novo.');
          });
      });
    }

    function closeViewer() {
      if (!viewer) return;
      clearStoryTimer();
      var fill = document.getElementById('storyProgFill');
      if (fill) {
        fill.style.transition = 'none';
        fill.style.width = '0%';
      }
      viewer.classList.remove('is-open');
      storyQueue = [];
      if (!modal.classList.contains('is-open')) document.body.style.overflow = '';
    }

    var btnVwClose = document.getElementById('storyViewerClose');
    if (btnVwClose) btnVwClose.addEventListener('click', closeViewer);
    if (viewer) viewer.addEventListener('click', function (e) { if (e.target === viewer) closeViewer(); });

    var tapP = document.getElementById('storyTapPrev');
    var tapN = document.getElementById('storyTapNext');
    if (tapP) tapP.addEventListener('click', function (e) { e.stopPropagation(); goPrevStory(); });
    if (tapN) tapN.addEventListener('click', function (e) { e.stopPropagation(); goNextStory(); });

    document.addEventListener('keydown', function (ev) {
      if (ev.key !== 'Escape') return;
      if (viewer && viewer.classList.contains('is-open')) {
        closeViewer();
        ev.preventDefault();
        return;
      }
      if (modal.classList.contains('is-open')) {
        hideModal();
        ev.preventDefault();
      }
    });

    var lastStoriesList = [];

    function appendStoryBubble(s, idx) {
      var b = document.createElement('button');
      b.type = 'button';
      b.className = 'story-bubble';
      b.setAttribute('data-story', '1');
      b.setAttribute('title', s.pet_nome || 'Story');
      var ring = document.createElement('span');
      ring.className = 'story-ring';
      var inner = document.createElement('span');
      inner.className = 'story-ring-inner';
      if (s.media_url) {
        var im = document.createElement('img');
        im.src = s.media_url;
        im.alt = '';
        inner.appendChild(im);
      } else {
        inner.innerHTML = '<span style="font-size:20px;">🐾</span>';
      }
      ring.appendChild(inner);
      b.appendChild(ring);
      var lbl = document.createElement('span');
      lbl.style.cssText = 'display:block;max-width:72px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;';
      lbl.textContent = s.pet_nome || '';
      b.appendChild(lbl);
      b.addEventListener('click', function () {
        openViewerWithQueue(lastStoriesList, idx);
      });
      strip.appendChild(b);
    }

    function loadFeedStories() {
      fetch('/explorar/api/stories', {
        headers: { Accept: 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
        credentials: 'same-origin',
      })
        .then(function (r) { return r.json(); })
        .then(function (d) {
          if (!d.sucesso || !Array.isArray(d.stories)) return;
          lastStoriesList = d.stories;
          strip.querySelectorAll('.story-bubble[data-story]').forEach(function (b) { b.remove(); });
          d.stories.forEach(function (s, idx) { appendStoryBubble(s, idx); });
        })
        .catch(function () {});
    }

    loadFeedStories();
  })();

  function buildFeedMeta(p) {
    var pCor = p.cor_perfil || '#ec5a1c';
    return {
      kind: 'organic',
      postId: p.id,
      foto: p.foto || '',
      texto: p.texto || p.legenda || '',
      criado_em: p.criado_em || '',
      autor_nome: p.autor_nome || '',
      usuario_id: p.usuario_id,
      foto_perfil: p.foto_perfil || '',
      cor_perfil: pCor,
      pet_id: p.pet_id || null,
      pet_nome: p.pet_nome || '',
      pet_foto: p.pet_foto || '',
      comments: true,
      tipo: p.tipo || 'original',
      orig_id: p.orig_id || null,
      orig_foto: p.orig_foto || '',
      orig_texto: p.orig_texto || '',
      orig_legenda: p.orig_legenda || '',
      orig_autor_nome: p.orig_autor_nome || '',
      orig_usuario_id: p.orig_usuario_id || null,
      orig_pet_id: p.orig_pet_id || null,
      orig_pet_nome: p.orig_pet_nome || '',
      orig_pet_foto: p.orig_pet_foto || '',
      orig_foto_perfil: p.orig_foto_perfil || '',
      orig_criado_em: p.orig_criado_em || ''
    };
  }

  // ── Render post HTML (for dynamic insertion) ──
  function renderPostHTML(p) {
    var pCor = p.cor_perfil || '#ec5a1c';
    var hasPet = p.pet_id && p.pet_nome;
    var metaAttr = ' data-explorar-meta="' + encodeURIComponent(JSON.stringify(buildFeedMeta(p))) + '" tabindex="0" aria-label="Abrir publicação"';
    var wrapOpen, wrapClose, avatarInner, metaInner;
    if (hasPet) {
      wrapOpen = '<a href="/explorar/pet/' + p.pet_id + '" class="post-avatar-wrap">';
      wrapClose = '</a>';
      avatarInner = p.pet_foto
        ? '<img src="' + escapeHtml(p.pet_foto) + '" class="post-avatar post-pet-avatar" alt="">'
        : '<div class="post-avatar-initial post-pet-initial">🐾</div>';
      metaInner = '<div class="post-title-stack">' +
        '<a href="/explorar/pet/' + p.pet_id + '" class="post-pet-name"><span class="post-pet-emoji" aria-hidden="true">🐾</span>' + escapeHtml(p.pet_nome) + '</a>' +
        '<div class="post-tutor-line"><span class="post-tutor-prefix">por</span><a href="/explorar/perfil/' + p.usuario_id + '" class="post-tutor-name">' + escapeHtml(p.autor_nome) + '</a></div></div>' +
        '<span class="post-time">agora</span>';
    } else {
      wrapOpen = '<a href="/explorar/perfil/' + p.usuario_id + '" class="post-avatar-wrap">';
      wrapClose = '</a>';
      avatarInner = p.foto_perfil
        ? '<img src="' + escapeHtml(p.foto_perfil) + '" class="post-avatar post-author-avatar" style="box-shadow:0 0 0 2px ' + escapeHtml(pCor) + '" alt="">'
        : '<div class="post-avatar-initial post-author-avatar" style="box-shadow:0 0 0 2px ' + escapeHtml(pCor) + '">' + escapeHtml((p.autor_nome || 'U').charAt(0).toUpperCase()) + '</div>';
      metaInner = '<div class="post-title-stack"><a href="/explorar/perfil/' + p.usuario_id + '" class="post-author-name post-author-fallback">' + escapeHtml(p.autor_nome) + '</a>' +
        '<span class="post-tutor-line" style="font-size:11px;opacity:0.85;">Publicação do tutor</span></div><span class="post-time">agora</span>';
    }
    var txt = p.texto || p.legenda || '';
    var h = '<article class="post-card post-enter"' + metaAttr + ' data-post-id="' + p.id + '" id="post-' + p.id + '">';
    h += '<div class="post-header">' + wrapOpen + avatarInner + wrapClose;
    h += '<div class="post-meta">' + metaInner + '</div>';
    h += '<div style="position:relative;flex-shrink:0;"><button type="button" class="post-menu-btn btn-menu-post"><i class="fa-solid fa-ellipsis"></i></button>';
    h += '<div class="post-dropdown hidden"><button type="button" class="post-dropdown-item btn-fixar" data-post-id="' + p.id + '" data-fixada="0"><i class="fa-solid fa-thumbtack" style="width:16px;text-align:center;color:var(--text-dim);"></i>Fixar</button>';
    h += '<button type="button" class="post-dropdown-item danger btn-deletar" data-post-id="' + p.id + '"><i class="fa-solid fa-trash-can" style="width:16px;text-align:center;"></i>Excluir</button></div></div></div>';
    if (txt) {
      h += '<div class="post-text line-clamp-3 post-text-body">' + escapeHtml(txt) + '</div>';
      h += '<div style="padding:0 18px 10px;"><button type="button" class="btn-ver-mais hidden" style="font-size:12px;color:var(--accent);font-weight:600;background:transparent;border:none;cursor:pointer;padding:0;">ver mais</button></div>';
    }
    if (p.foto) h += '<img src="' + escapeHtml(p.foto) + '" class="post-photo' + (p.fofinhos_moldura ? ' post-photo--fofinhos' : '') + '" loading="lazy" alt="">';
    h += '<div class="post-actions">';
    h += '<button type="button" class="post-action-btn btn-comentar" data-post-id="' + p.id + '"><i class="fa-regular fa-comment"></i><span class="count-comentarios"></span></button>';
    h += '<button type="button" class="post-action-btn btn-repost" data-post-id="' + p.id + '"><i class="fa-solid fa-retweet"></i><span class="count-reposts"></span></button>';
    h += '<button type="button" class="post-action-btn btn-curtir" data-post-id="' + p.id + '" data-curtiu="0" style="position:relative;"><i class="fa-regular fa-heart"></i><span class="count-curtidas"></span></button>';
    h += '<button type="button" class="post-action-btn btn-share" data-post-id="' + p.id + '" data-autor="' + escapeHtml(p.autor_nome) + '" data-pet-nome="' + (hasPet ? escapeHtml(p.pet_nome) : '') + '"><i class="fa-solid fa-share-from-square"></i></button>';
    h += '</div>';
    if (meuId) {
      h += '<div class="post-comment-row">' + buildInlineCommentAvatarHtml() + '<input type="text" class="comment-input input-comentario-inline" data-post-id="' + p.id + '" placeholder="Adicionar comentário…" maxlength="500"><button type="button" class="comment-inline-send btn-enviar-inline" data-post-id="' + p.id + '" aria-label="Enviar comentário"><i class="fa-solid fa-paper-plane"></i></button></div>';
    }
    h += '</article>';
    return h;
  }

  // ── Event delegation ──
  feedContainer.addEventListener('click', function (e) {
    var btn;
    btn = e.target.closest('.btn-curtir'); if (btn) { curtirPost(btn.dataset.postId, btn); return; }
    btn = e.target.closest('.btn-comentar'); if (btn) { abrirComentarios(btn.dataset.postId); return; }
    btn = e.target.closest('.btn-repost'); if (btn) { abrirRepostModal(btn.dataset.postId); return; }
    btn = e.target.closest('.btn-share'); if (btn) { compartilhar(btn.dataset.postId, btn.dataset.autor, btn.dataset.petNome); return; }
    btn = e.target.closest('.btn-menu-post'); if (btn) { e.stopPropagation(); toggleMenu(btn); return; }
    btn = e.target.closest('.btn-fixar'); if (btn) { fecharMenus(); fixarPost(btn.dataset.postId, btn.dataset.fixada === '1'); return; }
    btn = e.target.closest('.btn-deletar'); if (btn) { fecharMenus(); deletarPost(btn.dataset.postId); return; }
    btn = e.target.closest('.btn-ver-mais'); if (btn) { toggleTexto(btn); return; }
    btn = e.target.closest('.btn-enviar-inline'); if (btn) {
      var row = btn.closest('.post-comment-row');
      var input = row ? row.querySelector('.input-comentario-inline') : null;
      if (!input) return;
      var txt = input.value.trim();
      if (txt) enviarComentario(btn.dataset.postId || input.dataset.postId, txt, input, btn);
      return;
    }
    var artOpen = e.target.closest('article[data-explorar-meta]');
    if (artOpen && feedContainer.contains(artOpen)) {
      if (e.target.closest('.post-dropdown')) { fecharMenus(); return; }
      if (e.target.closest('button')) return;
      if (e.target.closest('a[href]')) {
        e.preventDefault();
        e.stopPropagation();
      }
      fecharMenus();
      openPostDetailFromArticle(artOpen);
      return;
    }
    fecharMenus();
  });

  feedContainer.addEventListener('keydown', function (e) {
    if (e.key === 'Enter' && e.target.classList.contains('input-comentario-inline')) {
      e.preventDefault();
      var txt = e.target.value.trim();
      if (txt) {
        var rowK = e.target.closest('.post-comment-row');
        var sendK = rowK ? rowK.querySelector('.btn-enviar-inline') : null;
        enviarComentario(e.target.dataset.postId, txt, e.target, sendK);
      }
    }
  });

  document.addEventListener('click', function (e) {
    if (!e.target.closest('.btn-menu-post') && !e.target.closest('.post-dropdown')) fecharMenus();
  });

  if (document.getElementById('closeCommentModal')) {
    document.getElementById('closeCommentModal').addEventListener('click', fecharComentariosModal);
  }
  if (document.getElementById('commentModalBackdrop')) {
    document.getElementById('commentModalBackdrop').addEventListener('click', fecharComentariosModal);
  }
  if (btnEnviarComentarioModal && commentInputModal) {
    commentInputModal.addEventListener('input', function() {
      btnEnviarComentarioModal.disabled = !commentInputModal.value.trim();
    });
    commentInputModal.addEventListener('keydown', function(e) {
      if (e.key !== 'Enter') return;
      e.preventDefault();
      if (!commentPostId) return;
      var txt = commentInputModal.value.trim();
      if (txt) enviarComentario(commentPostId, txt, commentInputModal, btnEnviarComentarioModal);
    });
    btnEnviarComentarioModal.addEventListener('click', function() {
      if (!commentPostId) return;
      var txt = commentInputModal.value.trim();
      if (txt) enviarComentario(commentPostId, txt, commentInputModal, btnEnviarComentarioModal);
    });
  }

  document.addEventListener('click', function (e) {
    var b = e.target.closest('.btn-reply-comment');
    if (!b) return;
    var inList = b.closest('#postDetailCommentList, #commentList');
    if (!inList) return;
    e.preventDefault();
    var cid = b.getAttribute('data-comment-id');
    var nm = b.getAttribute('data-author-name') || '';
    if (!cid) return;
    setFeedCommentReplyTarget(cid, nm);
    if (inList.id === 'postDetailCommentList') {
      var pi = document.getElementById('postDetailCommentInput');
      if (pi) pi.focus();
    } else if (commentInputModal) {
      commentInputModal.focus();
    }
  });
  var postDetailReplyCancelFeed = document.getElementById('postDetailReplyCancel');
  if (postDetailReplyCancelFeed) postDetailReplyCancelFeed.addEventListener('click', clearFeedCommentReplyTarget);
  var feedCommentModalReplyCancelEl = document.getElementById('feedCommentModalReplyCancel');
  if (feedCommentModalReplyCancelEl) feedCommentModalReplyCancelEl.addEventListener('click', clearFeedCommentReplyTarget);

  function requestClosePostDetailFeed() {
    if (typeof window.AIRPET_modalHistory_closePostDetail === 'function') {
      window.AIRPET_modalHistory_closePostDetail();
    } else {
      fecharPostDetailModal();
    }
  }
  var postDetailOverlayFeed = document.getElementById('postDetailOverlayEl');
  if (postDetailOverlayFeed) postDetailOverlayFeed.addEventListener('click', requestClosePostDetailFeed);
  var closePostDetailFeed = document.getElementById('closePostDetail');
  if (closePostDetailFeed) closePostDetailFeed.addEventListener('click', requestClosePostDetailFeed);
  var closePostDetailBackFeed = document.getElementById('closePostDetailBack');
  if (closePostDetailBackFeed) closePostDetailBackFeed.addEventListener('click', requestClosePostDetailFeed);

  (function setupPostDetailOwnerMenuFeed() {
    var btn = document.getElementById('btnPostDetailOwnerMenu');
    var dd = document.getElementById('postDetailOwnerDropdown');
    var wrap = document.getElementById('postDetailOwnerMenuWrap');
    if (!btn || !dd) return;
    btn.addEventListener('click', function (e) {
      e.stopPropagation();
      var willShow = dd.classList.contains('hidden');
      if (willShow) dd.classList.remove('hidden'); else dd.classList.add('hidden');
      btn.setAttribute('aria-expanded', willShow ? 'true' : 'false');
    });
    dd.addEventListener('click', function (e) { e.stopPropagation(); });
    document.addEventListener('click', function (e) {
      if (!wrap || wrap.classList.contains('hidden')) return;
      if (e.target.closest('#postDetailOwnerMenuWrap')) return;
      fecharPostDetailOwnerDropdown();
    });
  })();

  var postDetailModalFeed = document.getElementById('postDetailModal');
  if (postDetailModalFeed) {
    postDetailModalFeed.addEventListener('click', function (e) {
      var bf = e.target.closest('.btn-post-detail-fixar');
      if (bf) {
        e.preventDefault();
        fecharPostDetailOwnerDropdown();
        fixarPost(bf.getAttribute('data-post-id'), bf.getAttribute('data-fixada') === '1');
        return;
      }
      var bdel = e.target.closest('.btn-post-detail-deletar');
      if (bdel) {
        e.preventDefault();
        fecharPostDetailOwnerDropdown();
        deletarPost(bdel.getAttribute('data-post-id'));
      }
    });
  }

  var postDetailCommentInputEl = document.getElementById('postDetailCommentInput');
  var postDetailBtnEnviarEl = document.getElementById('postDetailBtnEnviar');
  if (postDetailCommentInputEl && postDetailBtnEnviarEl) {
    postDetailCommentInputEl.addEventListener('input', function () {
      postDetailBtnEnviarEl.disabled = !postDetailCommentInputEl.value.trim();
    });
    postDetailCommentInputEl.addEventListener('keydown', function (e) {
      if (e.key !== 'Enter') return;
      e.preventDefault();
      var pid = postDetailCommentInputEl.getAttribute('data-post-id');
      var t = postDetailCommentInputEl.value.trim();
      if (pid && t) enviarComentario(pid, t, postDetailCommentInputEl, postDetailBtnEnviarEl);
    });
    postDetailBtnEnviarEl.addEventListener('click', function () {
      var pid = postDetailCommentInputEl.getAttribute('data-post-id');
      var t = postDetailCommentInputEl.value.trim();
      if (pid && t) enviarComentario(pid, t, postDetailCommentInputEl, postDetailBtnEnviarEl);
    });
  }

  var postDetailCommentListEl = document.getElementById('postDetailCommentList');
  if (postDetailCommentListEl) {
    postDetailCommentListEl.addEventListener('click', function (e) {
      var b = e.target.closest('.btn-del-comment');
      if (!b) return;
      var cid = b.getAttribute('data-comment-id');
      if (!cid || !confirm('Excluir comentário?')) return;
      var c = feedCoordinator();
      var pr = c && typeof c.enqueue === 'function'
        ? c.enqueue({
          key: 'delComment:' + cid,
          group: 'feedPostDetailComments',
          priority: c.PRIORITY.MEDIUM,
          fetchFn: function (signal) {
            return fetch('/explorar/comentario/' + cid, {
              method: 'DELETE',
              headers: { 'Accept': 'application/json' },
              credentials: 'same-origin',
              signal: signal
            }).then(function (r) { return r.json(); });
          }
        })
        : fetch('/explorar/comentario/' + cid, { method: 'DELETE', headers: { 'Accept': 'application/json' }, credentials: 'same-origin' })
          .then(function (r) { return r.json(); });
      feedDeferred(function () {
        return pr.then(function (d) {
          if (d.sucesso && postDetailCommentPostId) carregarComentariosPostDetail(postDetailCommentPostId);
        });
      }, 'A remover comentário…').catch(function () {});
    });
  }

  // ── Sidebar follow buttons ──
  document.querySelectorAll('.btn-seguir-sidebar').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var el = this;
      if (el.getAttribute('data-airpet-follow-pending') === '1') return;
      el.setAttribute('data-airpet-follow-pending', '1');
      var uid = el.dataset.userId;
      var c = feedCoordinator();
      var pr = c && typeof c.enqueue === 'function'
        ? c.enqueue({
          key: 'seguirUserSidebar:' + uid,
          group: 'feedSidebar',
          priority: c.PRIORITY.MEDIUM,
          fetchFn: function (signal) {
            return fetch('/explorar/seguir/' + uid, {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              credentials: 'same-origin',
              signal: signal
            }).then(function (r) { return r.json(); });
          }
        })
        : fetch('/explorar/seguir/' + uid, { method: 'POST', headers: { 'Content-Type': 'application/json' }, credentials: 'same-origin' })
          .then(function (r) { return r.json(); });
      feedDeferred(function () {
        return pr.then(function (d) {
          if (d.sucesso) {
            el.textContent = 'Seguindo';
            el.style.background = 'var(--accent)'; el.style.borderColor = 'var(--accent)'; el.style.color = '#fff';
            el.disabled = true;
          }
        });
      }, 'A seguir…').catch(function () {})
        .finally(function () { el.removeAttribute('data-airpet-follow-pending'); });
    });
  });

  document.querySelectorAll('.btn-seguir-pet-sidebar').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var el = this;
      if (el.getAttribute('data-airpet-follow-pending') === '1') return;
      el.setAttribute('data-airpet-follow-pending', '1');
      var pid = el.dataset.petId;
      var c = feedCoordinator();
      var pr = c && typeof c.enqueue === 'function'
        ? c.enqueue({
          key: 'seguirPetSidebar:' + pid,
          group: 'feedSidebar',
          priority: c.PRIORITY.MEDIUM,
          fetchFn: function (signal) {
            return fetch('/explorar/pet/' + pid + '/seguir', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              credentials: 'same-origin',
              signal: signal
            }).then(function (r) { return r.json(); });
          }
        })
        : fetch('/explorar/pet/' + pid + '/seguir', { method: 'POST', headers: { 'Content-Type': 'application/json' }, credentials: 'same-origin' })
          .then(function (r) { return r.json(); });
      feedDeferred(function () {
        return pr.then(function (d) {
          if (d.sucesso) {
            el.textContent = 'Seguindo';
            el.style.background = 'var(--accent)'; el.style.borderColor = 'var(--accent)'; el.style.color = '#fff';
            el.disabled = true;
          }
        });
      }, 'A seguir pet…').catch(function () {})
        .finally(function () { el.removeAttribute('data-airpet-follow-pending'); });
    });
  });

  // ── Load more ──
  var loadMoreBtn = document.getElementById('loadMoreBtn');
  if (loadMoreBtn) {
    loadMoreBtn.addEventListener('click', function() {
      var self = this;
      var page = parseInt(self.getAttribute('data-page') || '2', 10);
      self.innerHTML = '<i class="fa-solid fa-paw fa-bounce mr-2" aria-hidden="true"></i><span class="airpet-inline-dots">Carregando</span>';
      self.disabled = true;
      var wrap = document.createElement('div');
      wrap.innerHTML = feedSkeletonBlock(2);
      var skelEl = wrap.firstChild;
      feedContainer.insertBefore(skelEl, self);

      function removeSkel() {
        if (skelEl && skelEl.parentNode) skelEl.remove();
      }

      function applyFeedPage(d) {
        removeSkel();
        if (d && d.posts && d.posts.length > 0) {
          d.posts.forEach(function (p) {
            var html = renderPostHTML(p);
            var temp = document.createElement('div'); temp.innerHTML = html;
            feedContainer.insertBefore(temp.firstChild, self);
          });
          if (d.temMais) {
            self.setAttribute('data-page', page + 1);
            self.innerHTML = '<i class="fa-solid fa-arrows-rotate mr-2"></i>Carregar mais publicações';
            self.disabled = false;
          } else {
            self.remove();
          }
        } else {
          self.remove();
        }
        initVerMais();
      }

      feedDeferred(function () {
        if (typeof swrFetchGet === 'function') {
          var c2 = feedCoordinator();
          return swrFetchGet({
            key: 'feed:page:' + page,
            url: '/feed?page=' + page,
            staleTimeMs: 45000,
            cacheTimeMs: 600000,
            group: 'feedPagination',
            priority: c2 && c2.PRIORITY ? c2.PRIORITY.MEDIUM : 'MEDIUM',
            credentials: 'same-origin'
          }).then(function (res) {
            var d = res && Object.prototype.hasOwnProperty.call(res, 'data') ? res.data : res;
            applyFeedPage(d || {});
          });
        }
        return fetch('/feed?page=' + page, { headers: { 'Accept': 'application/json' }, credentials: 'same-origin' })
          .then(function (r) { return r.json(); })
          .then(function (d) { applyFeedPage(d); });
      }, 'A carregar publicações…').catch(function () {
        removeSkel();
        self.innerHTML = '<i class="fa-solid fa-arrows-rotate mr-2"></i>Carregar mais publicações';
        self.disabled = false;
      });
    });
  }

  atualizarTempos();
  setInterval(atualizarTempos, 60000);
  setTimeout(initVerMais, 100);

})();
</script>

<%- include('partials/footer') %>
