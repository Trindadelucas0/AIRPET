<%
  locals.extraHead = `
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;700;800&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,400&display=swap" rel="stylesheet">
    <style>
      :root {
        /* Mantemos apenas o que não conflita com os tokens do design system global */
        --radius-card: var(--radius);
        --radius-btn: var(--radius-sm);
        --font-display: 'Syne', sans-serif;
        --font-body: 'DM Sans', sans-serif;
      }

      /* ── TOP HEADER BAR ── */
      .feed-topbar {
        position: sticky; top: 56px; z-index: 40;
        background: rgba(255,255,255,0.78);
        backdrop-filter: blur(20px) saturate(160%);
        -webkit-backdrop-filter: blur(20px);
        border-bottom: 1px solid var(--border);
        padding: 12px 0;
      }

      .feed-topbar-inner {
        max-width: 1100px;
        margin: 0 auto;
        padding: 0 20px;
        display: flex;
        align-items: center;
        justify-content: space-between;
      }

      .feed-topbar h1 {
        font-family: var(--font-display);
        font-size: 20px;
        font-weight: 800;
        color: var(--text);
        letter-spacing: -0.01em;
      }

      /* ── LAYOUT ── */
      .feed-layout {
        max-width: 1100px;
        margin: 0 auto;
        padding: 24px 20px 80px;
        display: grid;
        grid-template-columns: minmax(0, 1fr) 300px;
        gap: 24px;
        align-items: start;
      }

      @media (max-width: 900px) { .feed-layout { grid-template-columns: 1fr; } }
      @media (max-width: 900px) { .feed-sidebar { display: none; } }

      /* ── SEARCH (mobile) ── */
      .mobile-search {
        display: flex; align-items: center; gap: 10px;
        background: var(--ink-3);
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 10px 14px;
        color: var(--text-dim);
        font-size: 13px;
        text-decoration: none;
        margin-bottom: 16px;
        transition: all 0.2s;
      }
      .mobile-search:hover { border-color: var(--border-hover); color: var(--text-dim); text-decoration: none; }

      /* ── PETSHOP DESTAQUES ── */
      .petshop-section {
        background: var(--ink-2);
        border: 1px solid var(--border);
        border-radius: var(--radius-card);
        padding: 18px;
        margin-bottom: 16px;
      }

      .petshop-header {
        display: flex; align-items: center; justify-content: space-between;
        margin-bottom: 14px;
      }

      .petshop-header h2 {
        font-family: var(--font-display);
        font-size: 13px;
        font-weight: 700;
        color: var(--text);
        letter-spacing: 0.01em;
      }

      .petshop-header a {
        font-size: 11px; font-weight: 700;
        color: var(--accent); text-decoration: none;
        letter-spacing: 0.05em; text-transform: uppercase;
      }

      .petshop-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; }

      .petshop-card {
        background: var(--ink-3);
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 10px;
        text-decoration: none;
        transition: all 0.2s;
        display: block;
      }
      .petshop-card:hover { border-color: var(--border-hover); background: var(--ink-4); text-decoration: none; }

      .petshop-card img, .petshop-card-empty {
        width: 100%; height: 64px;
        border-radius: 8px;
        object-fit: cover;
        display: flex;
        background: var(--ink-4);
        align-items: center;
        justify-content: center;
        color: var(--text-muted);
        margin-bottom: 8px;
      }

      .petshop-card p {
        font-size: 11px; font-weight: 600; color: var(--text);
        white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
      }

      /* ── COMPOSER ── */
      .composer {
        background: var(--ink-2);
        border: 1px solid var(--border);
        border-radius: var(--radius-card);
        padding: 18px;
        margin-bottom: 16px;
      }

      .composer-top {
        display: flex; gap: 12px; align-items: flex-start;
        margin-bottom: 14px;
      }

      .composer-textarea {
        flex: 1;
        background: transparent;
        border: none;
        outline: none;
        color: var(--text);
        font-family: var(--font-body);
        font-size: 15px;
        resize: none;
        min-height: 60px;
        placeholder-color: var(--text-dim);
      }

      .composer-textarea::placeholder { color: var(--text-dim); }

      .composer-actions {
        display: flex; align-items: center; justify-content: space-between;
        border-top: 1px solid var(--border);
        padding-top: 14px;
      }

      .composer-tools {
        display: flex; gap: 4px;
      }

      .composer-tool-btn {
        width: 34px; height: 34px; border-radius: 8px;
        background: transparent; border: none; cursor: pointer;
        color: var(--text-dim); font-size: 14px;
        display: flex; align-items: center; justify-content: center;
        transition: all 0.15s;
      }
      .composer-tool-btn:hover { background: var(--ink-3); color: var(--accent); }

      .btn-post {
        display: inline-flex; align-items: center; gap: 7px;
        padding: 9px 20px;
        background: var(--accent);
        color: #fff;
        border: none; border-radius: var(--radius-btn);
        font-family: var(--font-body);
        font-size: 14px; font-weight: 700;
        cursor: pointer; transition: all 0.2s;
      }
      .btn-post:hover { background: var(--accent-light); transform: translateY(-1px); }
      .btn-post:disabled { opacity: 0.5; cursor: not-allowed; transform: none; }

      /* ── POST CARD ── */
      .post-card {
        background: var(--ink-2);
        border: 1px solid var(--border);
        border-radius: var(--radius-card);
        overflow: hidden;
        margin-bottom: 12px;
        transition: border-color 0.2s;
      }

      .post-card:hover { border-color: var(--border-hover); }

      /* Repost / Pinned strip */
      .post-strip {
        display: flex; align-items: center; gap: 7px;
        padding: 8px 16px 0;
        font-size: 11px; font-weight: 600;
        letter-spacing: 0.04em;
        text-transform: uppercase;
      }
      .post-strip.repost { color: var(--green); }
      .post-strip.pinned { color: var(--text-dim); }

      /* Promo strip */
      .promo-strip {
        display: flex; align-items: center; justify-content: space-between;
        padding: 7px 16px;
        background: rgba(34,197,94,0.06);
        border-bottom: 1px solid rgba(34,197,94,0.1);
        font-size: 11px; font-weight: 700;
        color: var(--green); letter-spacing: 0.06em; text-transform: uppercase;
      }
      .promo-strip span:last-child { color: var(--text-dim); font-weight: 400; text-transform: none; letter-spacing: 0; }

      .post-header {
        display: flex; align-items: center; gap: 12px;
        padding: 14px 16px 10px;
      }

      .post-avatar-wrap { flex-shrink: 0; }

      .post-avatar {
        width: 38px; height: 38px; border-radius: 50%;
        object-fit: cover; display: block;
      }

      .post-avatar-initial {
        width: 38px; height: 38px; border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
        font-size: 14px; font-weight: 700; color: var(--text);
        background: var(--ink-4);
      }

      .post-meta { flex: 1; min-width: 0; }

      .post-author-name {
        font-weight: 700; font-size: 14px; color: var(--text);
        text-decoration: none;
      }
      .post-author-name:hover { color: var(--accent); text-decoration: none; }

      .post-pet-link {
        font-size: 11px; color: var(--text-dim); text-decoration: none;
        display: inline-flex; align-items: center; gap: 3px; margin-left: 6px;
      }
      .post-pet-link:hover { color: var(--accent); text-decoration: none; }

      .post-time {
        font-size: 11px; color: var(--text-dim); display: block; margin-top: 1px;
      }

      .post-menu-btn {
        width: 32px; height: 32px; border-radius: 8px; border: none;
        background: transparent; color: var(--text-dim); font-size: 14px;
        cursor: pointer; display: flex; align-items: center; justify-content: center;
        transition: all 0.15s;
      }
      .post-menu-btn:hover { background: var(--ink-3); color: var(--text); }

      /* Post dropdown */
      .post-dropdown {
        position: absolute; right: 0; top: calc(100% + 4px);
        min-width: 168px;
        background: var(--ink-3);
        border: 1px solid var(--border);
        border-radius: 12px;
        box-shadow: 0 18px 48px rgba(15, 23, 42, 0.12);
        overflow: hidden; z-index: 30;
        transform-origin: top right;
        animation: scale-in 0.12s ease-out;
      }

      @keyframes scale-in {
        from { opacity: 0; transform: scale(0.9); }
        to   { opacity: 1; transform: scale(1); }
      }

      .post-dropdown-item {
        display: flex; align-items: center; gap: 10px;
        padding: 11px 16px;
        font-size: 13px; font-weight: 500;
        color: var(--text); cursor: pointer;
        border: none; background: transparent;
        width: 100%; text-align: left;
        transition: background 0.1s;
      }
      .post-dropdown-item:hover { background: var(--ink-4); }
      .post-dropdown-item.danger { color: #f87171; }
      .post-dropdown-item.danger:hover { background: rgba(239,68,68,0.08); }

      /* Post body */
      .post-text {
        padding: 0 16px 12px;
        font-size: 14px; line-height: 1.65;
        color: var(--text);
        white-space: pre-wrap;
      }

      .post-photo {
        width: 100%;
        max-height: 520px;
        object-fit: cover;
        display: block;
      }

      /* Repost embed */
      .post-embed {
        margin: 0 16px 12px;
        border: 1px solid var(--border);
        border-radius: 12px;
        overflow: hidden;
        background: var(--ink-3);
      }

      .post-embed-header {
        display: flex; align-items: center; gap: 8px;
        padding: 10px 12px 6px;
      }

      .post-embed-avatar {
        width: 22px; height: 22px; border-radius: 50%;
        object-fit: cover;
      }

      .post-embed-name {
        font-size: 12px; font-weight: 700; color: var(--text);
        text-decoration: none;
      }
      .post-embed-name:hover { color: var(--accent); text-decoration: none; }

      .post-embed-text {
        padding: 0 12px 10px;
        font-size: 12px; color: var(--text-dim); line-height: 1.5;
        display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
      }

      .post-embed-img {
        width: 100%; max-height: 180px; object-fit: cover; display: block;
      }

      /* Post actions */
      .post-actions {
        display: flex;
        border-top: 1px solid var(--border);
      }

      .post-action-btn {
        flex: 1;
        display: flex; align-items: center; justify-content: center; gap: 7px;
        padding: 12px 8px;
        font-size: 13px; font-weight: 500;
        color: var(--text-dim);
        background: transparent; border: none; cursor: pointer;
        transition: all 0.15s;
        border-radius: 0;
        position: relative;
      }

      .post-action-btn:hover {
        color: var(--text);
        background: var(--ink-4);
      }

      .post-action-btn.liked { color: var(--red); }
      .post-action-btn.reposted { color: var(--green); }
      .post-action-btn:not(:last-child) { border-right: 1px solid var(--border); }

      /* Inline comment */
      .post-view-comments {
        padding: 0 16px 10px;
      }

      .post-view-comments button {
        font-size: 12px; color: var(--text-dim); font-weight: 500;
        background: transparent; border: none; cursor: pointer; padding: 0;
      }
      .post-view-comments button:hover { color: var(--accent); }

      .post-comment-row {
        display: flex; align-items: center; gap: 10px;
        padding: 10px 16px 14px;
        border-top: 1px solid var(--border);
      }

      .comment-input {
        flex: 1;
        background: var(--ink-3);
        border: 1px solid var(--border);
        border-radius: 10px;
        padding: 8px 14px;
        font-size: 13px;
        color: var(--text);
        font-family: var(--font-body);
        outline: none;
        transition: border-color 0.15s;
      }
      .comment-input::placeholder { color: var(--text-muted); }
      .comment-input:focus { border-color: rgba(242,96,32,0.4); }

      /* ── MENTION ── */
      .mention { color: var(--accent); font-weight: 600; cursor: pointer; }
      .mention:hover { text-decoration: underline; }

      .autocomplete-dropdown {
        position: absolute; bottom: 100%; left: 0; right: 0;
        max-height: 160px; overflow-y: auto;
        background: var(--ink-3);
        border: 1px solid var(--border);
        border-radius: 12px;
        box-shadow: 0 16px 44px rgba(15, 23, 42, 0.12);
        z-index: 10; margin-bottom: 4px;
      }

      .autocomplete-item {
        display: flex; align-items: center; gap: 8px;
        padding: 9px 12px; cursor: pointer; font-size: 13px;
        color: var(--text); transition: background 0.1s;
      }
      .autocomplete-item:hover { background: var(--ink-4); }

      /* ── PROMO CARD ── */
      .promo-card-body { padding: 14px 16px; }
      .promo-store-header { display: flex; align-items: center; gap: 10px; margin-bottom: 10px; }
      .promo-logo { width: 36px; height: 36px; border-radius: 10px; object-fit: cover; }
      .promo-logo-empty {
        width: 36px; height: 36px; border-radius: 10px;
        background: var(--ink-4); display: flex; align-items: center; justify-content: center;
        color: var(--text-muted); font-size: 16px;
      }
      .promo-store-name { font-size: 14px; font-weight: 700; color: var(--text); }
      .promo-status { font-size: 11px; color: var(--text-dim); }
      .promo-title { font-size: 15px; font-weight: 700; color: var(--text); margin-bottom: 4px; }
      .promo-desc { font-size: 13px; color: var(--text-dim); line-height: 1.5; }
      .promo-btns { display: flex; gap: 8px; margin-top: 14px; }
      .promo-btn-main {
        display: inline-flex; align-items: center; gap: 6px;
        padding: 8px 16px;
        background: rgba(34,197,94,0.12);
        color: var(--green); border: 1px solid rgba(34,197,94,0.2);
        border-radius: 9px; font-size: 12px; font-weight: 700;
        text-decoration: none; transition: all 0.15s;
      }
      .promo-btn-main:hover { background: rgba(34,197,94,0.2); color: #4ade80; text-decoration: none; }

      /* ── SPONSORED CARD ── */
      .sponsored-strip {
        display: flex; align-items: center; justify-content: space-between;
        padding: 7px 16px;
        background: rgba(167,139,250,0.06);
        border-bottom: 1px solid rgba(167,139,250,0.1);
        font-size: 11px; font-weight: 700;
        color: var(--purple); letter-spacing: 0.06em; text-transform: uppercase;
      }

      /* ── SIDEBAR ── */
      .feed-sidebar {
        position: sticky; top: calc(56px + 56px + 16px);
      }

      .sidebar-card {
        background: var(--ink-2);
        border: 1px solid var(--border);
        border-radius: var(--radius-card);
        padding: 18px;
        margin-bottom: 14px;
      }

      .sidebar-title {
        font-family: var(--font-display);
        font-size: 13px; font-weight: 700; color: var(--text);
        margin-bottom: 14px; letter-spacing: 0.01em;
      }

      .sidebar-user-item {
        display: flex; align-items: center; gap: 10px;
        padding: 6px 0;
      }

      .sidebar-avatar {
        width: 34px; height: 34px; border-radius: 50%;
        object-fit: cover; flex-shrink: 0;
      }

      .sidebar-avatar-init {
        width: 34px; height: 34px; border-radius: 50%;
        flex-shrink: 0; display: flex; align-items: center; justify-content: center;
        font-size: 12px; font-weight: 700; color: var(--text); background: var(--ink-4);
      }

      .sidebar-user-name {
        flex: 1; min-width: 0;
        font-size: 13px; font-weight: 600; color: var(--text);
        white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
      }

      .sidebar-follow-btn {
        padding: 5px 12px;
        background: transparent;
        border: 1px solid var(--border);
        border-radius: 7px;
        font-size: 11px; font-weight: 700; color: var(--text);
        cursor: pointer; transition: all 0.15s;
        white-space: nowrap;
      }
      .sidebar-follow-btn:hover {
        background: var(--accent); border-color: var(--accent); color: #fff;
      }

      .sidebar-divider { height: 1px; background: var(--border); margin: 4px 0 10px; }

      /* ── FLOAT HEARTS ── */
      @keyframes floatHeart { 0%{opacity:1;transform:translateY(0) scale(1)} 100%{opacity:0;transform:translateY(-60px) scale(1.4)} }
      .float-heart { position:absolute; pointer-events:none; animation:floatHeart 0.7s ease-out forwards; color:var(--red); font-size:14px; }

      /* ── SKELETON ── */
      @keyframes shimmer-dark { 0%{background-position:-200% 0} 100%{background-position:200% 0} }
      .skeleton-dark {
        background: linear-gradient(90deg, var(--ink-3) 25%, var(--ink-4) 50%, var(--ink-3) 75%);
        background-size: 200% 100%;
        animation: shimmer-dark 1.5s infinite;
        border-radius: 8px;
      }

      /* ── POST ENTER ANIM ── */
      @keyframes post-enter { from { opacity:0; transform:translateY(12px); } to { opacity:1; transform:none; } }
      .post-enter { animation: post-enter 0.35s ease-out both; }

      /* ── HEART POP ── */
      @keyframes heartPop { 0%{transform:scale(1)} 30%{transform:scale(1.35)} 60%{transform:scale(0.9)} 100%{transform:scale(1)} }
      .animate-heartPop { animation: heartPop 0.35s ease-out; }

      /* ── LOAD MORE ── */
      #loadMoreBtn {
        display: block; width: 100%;
        padding: 13px;
        background: var(--ink-2);
        border: 1px solid var(--border);
        border-radius: var(--radius-card);
        color: var(--text-dim);
        font-family: var(--font-body);
        font-size: 14px; font-weight: 500;
        cursor: pointer; transition: all 0.2s;
        text-align: center;
      }
      #loadMoreBtn:hover { border-color: var(--border-hover); color: var(--text); background: var(--ink-3); }
    </style>
  `;
%>
<%- include('partials/header') %>
<%- include('partials/flash') %>

<% var isLogado = typeof usuario !== 'undefined' && usuario; %>
<% var meusPets = typeof meusPets !== 'undefined' ? meusPets : (typeof pets !== 'undefined' ? pets : []); %>
<% var sugestoesUsuarios = typeof sugestoesUsuarios !== 'undefined' ? sugestoesUsuarios : (typeof recomendacoes !== 'undefined' ? recomendacoes : []); %>
<% var sugestoesPets = typeof sugestoesPets !== 'undefined' ? sugestoesPets : (typeof petsRecomendados !== 'undefined' ? petsRecomendados : []); %>
<% var petshopsProximos = typeof petshopsProximos !== 'undefined' ? petshopsProximos : (typeof petshopDestaques !== 'undefined' ? petshopDestaques : []); %>
<% var hasMore = typeof hasMore !== 'undefined' ? hasMore : (typeof temMais !== 'undefined' ? temMais : false); %>

<main class="flex-1 pb-24 md:pb-6">

  <!-- Top bar -->
  <div class="feed-topbar">
    <div class="feed-topbar-inner">
      <h1>Feed</h1>
      <div style="font-size:12px; color:var(--text-dim);">
        <% if (isLogado) { %>Bem-vindo, <%= usuario.nome.split(' ')[0] %><% } %>
      </div>
    </div>
  </div>

  <div class="feed-layout">

    <!-- ═══ MAIN COLUMN ═══ -->
    <div>

      <!-- Mobile search -->
      <div class="lg:hidden">
        <a href="/explorar/busca" class="mobile-search">
          <i class="fa-solid fa-magnifying-glass" style="font-size:13px;"></i>
          Buscar pets ou pessoas...
        </a>
      </div>

      <!-- Petshop destaques -->
      <% if (petshopDestaques && petshopDestaques.length > 0) { %>
      <div class="petshop-section">
        <div class="petshop-header">
          <h2>Parceiros perto de você</h2>
          <a href="/petshops/mapa"><i class="fa-solid fa-map-location-dot mr-1"></i>Mapa</a>
        </div>
        <div class="petshop-grid">
          <% petshopDestaques.slice(0, 4).forEach(function(ps) { %>
          <a href="/petshops/<%= ps.slug || ps.id %>" class="petshop-card">
            <% if (ps.logo_url) { %>
              <img src="<%= ps.logo_url %>" alt="<%= ps.nome %>">
            <% } else { %>
              <div class="petshop-card-empty"><i class="fa-solid fa-store"></i></div>
            <% } %>
            <p><%= ps.nome %></p>
          </a>
          <% }) %>
        </div>
      </div>
      <% } %>

      <!-- Composer -->
      <% if (isLogado) { %>
      <div class="composer">
        <div class="composer-top">
          <% var corMe = usuario.cor_perfil || '#ec5a1c'; %>
          <% if (usuario.foto_perfil) { %>
            <img src="<%= usuario.foto_perfil %>" class="post-avatar" style="box-shadow:0 0 0 2px <%= corMe %>; flex-shrink:0;" alt="">
          <% } else { %>
            <div class="post-avatar-initial" style="box-shadow:0 0 0 2px <%= corMe %>; flex-shrink:0;"><%= (usuario.nome || 'U').charAt(0).toUpperCase() %></div>
          <% } %>
          <div style="flex:1; min-width:0; position:relative;">
            <div id="mentionDropdownNovaPublicacao" class="autocomplete-dropdown hidden"></div>
            <textarea
              id="novoPostTexto"
              class="composer-textarea"
              rows="3"
              placeholder="O que está acontecendo com seu pet?"
              maxlength="500"
            ></textarea>
          </div>
        </div>
        <div id="novoPostPreview" class="hidden mb-3" style="position:relative;">
          <img id="novoPostPreviewImg" src="" alt="" style="max-height:200px; border-radius:12px; object-fit:cover; width:100%;">
          <button type="button" id="removerFoto" style="position:absolute;top:8px;right:8px;width:28px;height:28px;border-radius:50%;background:rgba(0,0,0,0.6);border:none;color:#fff;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:12px;">
            <i class="fa-solid fa-xmark"></i>
          </button>
        </div>

        <!-- Pet selector -->
        <% if (typeof meusPets !== 'undefined' && meusPets && meusPets.length > 0) { %>
        <div style="margin-bottom:12px;">
          <select id="novoPetId" style="background:var(--ink-3);border:1px solid var(--border);border-radius:9px;padding:7px 12px;color:var(--text);font-family:var(--font-body);font-size:13px;outline:none;width:100%;cursor:pointer;">
            <option value="">🐾 Nenhum pet</option>
            <% meusPets.forEach(function(p) { %>
              <option value="<%= p.id %>"><%= p.nome %></option>
            <% }); %>
          </select>
        </div>
        <% } %>

        <div class="composer-actions">
          <div class="composer-tools">
            <button type="button" class="composer-tool-btn" id="btnAnexarFoto" title="Foto">
              <i class="fa-solid fa-image"></i>
            </button>
            <button type="button" class="composer-tool-btn" id="btnEmoji" title="Emoji">
              <i class="fa-regular fa-face-smile"></i>
            </button>
          </div>
          <div style="display:flex;align-items:center;gap:10px;">
            <span id="charCount" style="font-size:12px;color:var(--text-dim);">0/500</span>
            <button type="button" id="btnPublicar" class="btn-post" disabled>
              <i class="fa-solid fa-paper-plane"></i>
              Publicar
            </button>
          </div>
        </div>
        <input type="file" id="inputFotoPost" accept="image/*" class="hidden">
      </div>
      <% } %>

      <!-- FEED -->
      <div id="feedContainer">
        <% if (posts && posts.length > 0) { %>
          <% posts.forEach(function(post, idx) { %>
            <% if (post.is_petshop_promo) { %>
              <article class="post-card post-enter" id="promo-<%= post.petshop_id %>" style="animation-delay:<%= Math.min(idx*50,300) %>ms">
                <div class="promo-strip">
                  <span><i class="fa-solid fa-badge-percent mr-1"></i>Promoção para você</span>
                  <span>Baseado no seu relacionamento</span>
                </div>
                <div class="promo-card-body">
                  <div class="promo-store-header">
                    <% if (post.petshop_logo_url) { %>
                      <img src="<%= post.petshop_logo_url %>" class="promo-logo" alt="">
                    <% } else { %>
                      <div class="promo-logo-empty"><i class="fa-solid fa-store"></i></div>
                    <% } %>
                    <div>
                      <div class="promo-store-name"><%= post.petshop_nome || 'Parceiro' %></div>
                      <div class="promo-status"><%= post.usuario_vinculado ? 'Vinculado' : 'Seguindo' %></div>
                    </div>
                  </div>
                  <div class="promo-title"><%= post.titulo || 'Promoção' %></div>
                  <div class="promo-desc"><%= post.descricao_curta || '' %></div>
                  <div class="promo-btns">
                    <a href="/petshops/<%= post.petshop_slug || post.petshop_id %>" class="promo-btn-main">
                      <i class="fa-solid fa-store"></i>Ver petshop
                    </a>
                    <% if (post.contato_link) { %>
                      <a href="<%= post.contato_link %>" target="_blank" rel="noopener" class="promo-btn-main" style="background:rgba(242,96,32,0.1);color:var(--accent);border-color:rgba(242,96,32,0.2);">
                        <i class="fa-solid fa-arrow-up-right-from-square"></i>Aproveitar
                      </a>
                    <% } %>
                  </div>
                </div>
              </article>

            <% } else if (post.is_sponsored) { %>
              <article class="post-card post-enter" id="sponsored-<%= post.id %>" style="animation-delay:<%= Math.min(idx*50,300) %>ms">
                <div class="sponsored-strip">
                  <span><i class="fa-solid fa-circle-dollar mr-1"></i>Patrocinado</span>
                </div>
                <div class="post-header">
                  <% if (post.pet_foto) { %>
                    <img src="<%= post.pet_foto %>" class="post-avatar" alt="">
                  <% } else { %>
                    <div class="post-avatar-initial" style="background:var(--ink-4)"><%= (post.pet_nome || 'P').charAt(0) %></div>
                  <% } %>
                  <div class="post-meta">
                    <span style="font-size:14px;font-weight:700;color:var(--text);"><%= post.pet_nome || 'Perfil pet patrocinado' %></span>
                    <span class="post-time">Patrocinado</span>
                  </div>
                </div>
                <% if (post.sponsored_label) { %>
                  <div class="post-text" style="font-weight:700;font-size:16px;padding-bottom:4px;"><%= post.sponsored_label %></div>
                <% } %>
                <% if (post.texto || post.legenda) { %>
                  <div class="post-text"><%= post.texto || post.legenda %></div>
                <% } %>
                <% if (post.foto) { %>
                  <img src="<%= post.foto %>" class="post-photo" loading="lazy" alt="">
                <% } %>
                <% if (post.pet_id) { %>
                  <div style="padding:10px 16px 14px;">
                    <a href="/explorar/pet/<%= post.pet_id %>" style="display:inline-flex;align-items:center;gap:6px;padding:9px 18px;background:var(--accent);color:#fff;border-radius:9px;font-size:13px;font-weight:700;text-decoration:none;transition:all 0.15s;" onmouseover="this.style.background='var(--accent-light)'" onmouseout="this.style.background='var(--accent)'">
                      Ver perfil do pet <i class="fa-solid fa-arrow-right" style="font-size:11px;"></i>
                    </a>
                  </div>
                <% } %>
              </article>

            <% } else { %>
              <%
                var isRepost = post.tipo === 'repost';
                var isMine = typeof usuario !== 'undefined' && usuario && post.usuario_id === usuario.id;
                var pCor = post.cor_perfil || '#ec5a1c';
              %>
              <article class="post-card post-enter" data-post-id="<%= post.id %>" data-author-id="<%= post.usuario_id %>" id="post-<%= post.id %>" style="animation-delay:<%= Math.min(idx*50,300) %>ms">

                <% if (isRepost) { %>
                  <div class="post-strip repost"><i class="fa-solid fa-retweet"></i><%= post.autor_nome %> repostou</div>
                <% } %>
                <% if (post.fixada) { %>
                  <div class="post-strip pinned"><i class="fa-solid fa-thumbtack"></i>Fixado</div>
                <% } %>

                <div class="post-header">
                  <a href="/explorar/perfil/<%= post.usuario_id %>" class="post-avatar-wrap">
                    <% if (post.foto_perfil) { %>
                      <img src="<%= post.foto_perfil %>" class="post-avatar post-author-avatar" style="box-shadow:0 0 0 2px <%= pCor %>" alt="">
                    <% } else { %>
                      <div class="post-avatar-initial post-author-avatar" style="box-shadow:0 0 0 2px <%= pCor %>"><%= (post.autor_nome || 'U').charAt(0).toUpperCase() %></div>
                    <% } %>
                  </a>
                  <div class="post-meta">
                    <div>
                      <a href="/explorar/perfil/<%= post.usuario_id %>" class="post-author-name post-author-name"><%= post.autor_nome %></a>
                      <% if (post.pet_nome && post.pet_id) { %>
                        <a href="/explorar/pet/<%= post.pet_id %>" class="post-pet-link"><i class="fa-solid fa-paw" style="font-size:9px;"></i> <%= post.pet_nome %></a>
                      <% } %>
                    </div>
                    <span class="post-time tempo-relativo" data-time="<%= post.criado_em %>"><%= post.criado_em %></span>
                  </div>
                  <% if (isMine) { %>
                  <div style="position:relative; flex-shrink:0;">
                    <button type="button" class="post-menu-btn btn-menu-post"><i class="fa-solid fa-ellipsis"></i></button>
                    <div class="post-dropdown hidden">
                      <button type="button" class="post-dropdown-item btn-fixar" data-post-id="<%= post.id %>" data-fixada="<%= post.fixada ? '1' : '0' %>">
                        <i class="fa-solid fa-thumbtack" style="width:16px;text-align:center;color:var(--text-dim);"></i>
                        <%= post.fixada ? 'Desafixar' : 'Fixar' %>
                      </button>
                      <button type="button" class="post-dropdown-item danger btn-deletar" data-post-id="<%= post.id %>">
                        <i class="fa-solid fa-trash-can" style="width:16px;text-align:center;"></i>
                        Excluir
                      </button>
                    </div>
                  </div>
                  <% } %>
                </div>

                <% if (post.texto || post.legenda) { %>
                  <div class="post-text line-clamp-3 post-text-body"><%= post.texto || post.legenda %></div>
                  <div style="padding:0 16px 10px;"><button type="button" class="btn-ver-mais hidden" style="font-size:12px;color:var(--accent);font-weight:600;background:transparent;border:none;cursor:pointer;padding:0;">ver mais</button></div>
                <% } %>

                <% if (post.foto) { %>
                  <img src="<%= post.foto %>" class="post-photo" loading="lazy" alt="">
                <% } %>

                <% if (isRepost && post.orig_id) { %>
                  <div class="post-embed">
                    <div class="post-embed-header">
                      <% if (post.orig_foto_perfil) { %>
                        <img src="<%= post.orig_foto_perfil %>" class="post-embed-avatar" alt="">
                      <% } else { %>
                        <div class="post-embed-avatar" style="background:var(--ink-4);display:flex;align-items:center;justify-content:center;font-size:9px;font-weight:700;color:var(--text);"><%= (post.orig_autor_nome || 'U').charAt(0).toUpperCase() %></div>
                      <% } %>
                      <a href="/explorar/perfil/<%= post.orig_usuario_id %>" class="post-embed-name"><%= post.orig_autor_nome %></a>
                    </div>
                    <% if (post.orig_texto || post.orig_legenda) { %>
                      <div class="post-embed-text"><%= post.orig_texto || post.orig_legenda %></div>
                    <% } %>
                    <% if (post.orig_foto) { %>
                      <img src="<%= post.orig_foto %>" class="post-embed-img" loading="lazy" alt="">
                    <% } %>
                  </div>
                <% } %>

                <div class="post-actions">
                  <button type="button" class="post-action-btn btn-comentar" data-post-id="<%= post.id %>">
                    <i class="fa-regular fa-comment"></i>
                    <span class="count-comentarios"><%= post.total_comentarios || '' %></span>
                  </button>
                  <button type="button" class="post-action-btn btn-repost <%= post.repostou ? 'reposted' : '' %>" data-post-id="<%= post.id %>">
                    <i class="fa-solid fa-retweet"></i>
                    <span class="count-reposts"><%= post.total_reposts || '' %></span>
                  </button>
                  <button type="button" class="post-action-btn btn-curtir <%= post.curtiu ? 'liked' : '' %>" data-post-id="<%= post.id %>" data-curtiu="<%= post.curtiu ? '1' : '0' %>" style="position:relative;">
                    <i class="<%= post.curtiu ? 'fa-solid' : 'fa-regular' %> fa-heart"></i>
                    <span class="count-curtidas"><%= post.total_curtidas || '' %></span>
                  </button>
                  <button type="button" class="post-action-btn btn-share" data-post-id="<%= post.id %>" data-autor="<%= post.autor_nome %>">
                    <i class="fa-solid fa-share-from-square"></i>
                  </button>
                </div>

                <% if (post.total_comentarios > 0) { %>
                <div class="post-view-comments">
                  <button type="button" class="btn-comentar" data-post-id="<%= post.id %>">
                    Ver todos os <%= post.total_comentarios %> comentários
                  </button>
                </div>
                <% } %>

                <% if (isLogado) { %>
                <div class="post-comment-row">
                  <% if (usuario.foto_perfil) { %>
                    <img src="<%= usuario.foto_perfil %>" style="width:28px;height:28px;border-radius:50%;object-fit:cover;flex-shrink:0;box-shadow:0 0 0 2px <%= usuario.cor_perfil || '#ec5a1c' %>;" alt="">
                  <% } else { %>
                    <div style="width:28px;height:28px;border-radius:50%;flex-shrink:0;background:var(--ink-4);display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:700;color:var(--text);box-shadow:0 0 0 2px <%= usuario.cor_perfil || '#ec5a1c' %>;"><%= (usuario.nome || 'U').charAt(0).toUpperCase() %></div>
                  <% } %>
                  <input type="text" class="comment-input input-comentario-inline" data-post-id="<%= post.id %>" placeholder="Adicionar comentário…" maxlength="500">
                </div>
                <% } %>

              </article>
            <% } %>
          <% }); %>
        <% } else { %>
          <div style="text-align:center; padding:80px 24px; color:var(--text-dim);">
            <div style="font-size:48px; margin-bottom:16px; opacity:0.3;">🐾</div>
            <p style="font-size:16px; font-weight:600; color:var(--text); margin-bottom:8px;">Seu feed está vazio</p>
            <p style="font-size:14px;">Siga pessoas e pets para ver publicações aqui.</p>
            <a href="/explorar" style="display:inline-flex;align-items:center;gap:8px;margin-top:20px;padding:10px 22px;background:var(--accent);color:#fff;border-radius:10px;font-size:14px;font-weight:700;text-decoration:none;">
              <i class="fa-solid fa-compass"></i>Explorar
            </a>
          </div>
        <% } %>

        <% if (typeof hasMore !== 'undefined' && hasMore) { %>
          <button id="loadMoreBtn" data-page="2">
            <i class="fa-solid fa-arrows-rotate mr-2"></i>Carregar mais publicações
          </button>
        <% } %>
      </div>
    </div>

    <!-- ═══ SIDEBAR ═══ -->
    <aside class="feed-sidebar">

      <!-- Search desktop -->
      <div style="margin-bottom:14px;">
        <a href="/explorar/busca" style="display:flex;align-items:center;gap:10px;background:var(--ink-2);border:1px solid var(--border);border-radius:12px;padding:10px 14px;color:var(--text-dim);font-size:13px;text-decoration:none;transition:all 0.2s;" onmouseover="this.style.borderColor='var(--border-hover)'" onmouseout="this.style.borderColor='var(--border)'">
          <i class="fa-solid fa-magnifying-glass" style="font-size:13px;"></i>
          Buscar pets ou pessoas...
        </a>
      </div>

      <!-- Sugestões de usuários -->
      <% if (typeof sugestoesUsuarios !== 'undefined' && sugestoesUsuarios && sugestoesUsuarios.length > 0) { %>
      <div class="sidebar-card">
        <div class="sidebar-title">Quem seguir</div>
        <% sugestoesUsuarios.forEach(function(u) { %>
          <div class="sidebar-user-item">
            <% var uCor = u.cor_perfil || '#ec5a1c'; %>
            <% if (u.foto_perfil) { %>
              <img src="<%= u.foto_perfil %>" class="sidebar-avatar" style="box-shadow:0 0 0 2px <%= uCor %>" alt="">
            <% } else { %>
              <div class="sidebar-avatar-init" style="box-shadow:0 0 0 2px <%= uCor %>"><%= (u.nome || 'U').charAt(0).toUpperCase() %></div>
            <% } %>
            <a href="/explorar/perfil/<%= u.id %>" style="flex:1;min-width:0;font-size:13px;font-weight:600;color:var(--text);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;text-decoration:none;" onmouseover="this.style.color='var(--accent)'" onmouseout="this.style.color='var(--text)'"><%= u.nome %></a>
            <button type="button" class="sidebar-follow-btn btn-seguir-sidebar" data-user-id="<%= u.id %>">Seguir</button>
          </div>
        <% }); %>
      </div>
      <% } %>

      <!-- Pets para seguir -->
      <% if (typeof sugestoesPets !== 'undefined' && sugestoesPets && sugestoesPets.length > 0) { %>
      <div class="sidebar-card">
        <div class="sidebar-title">Pets em destaque</div>
        <% sugestoesPets.forEach(function(pet) { %>
          <div class="sidebar-user-item">
            <% if (pet.foto) { %>
              <img src="<%= pet.foto %>" class="sidebar-avatar" alt="">
            <% } else { %>
              <div class="sidebar-avatar-init" style="background:var(--ink-4);">🐾</div>
            <% } %>
            <a href="/explorar/pet/<%= pet.id %>" style="flex:1;min-width:0;font-size:13px;font-weight:600;color:var(--text);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;text-decoration:none;" onmouseover="this.style.color='var(--accent)'" onmouseout="this.style.color='var(--text)'"><%= pet.nome %></a>
            <button type="button" class="sidebar-follow-btn btn-seguir-pet-sidebar" data-pet-id="<%= pet.id %>">Seguir</button>
          </div>
        <% }); %>
      </div>
      <% } %>

      <!-- Petshops -->
      <% if (typeof petshopsProximos !== 'undefined' && petshopsProximos && petshopsProximos.length > 0) { %>
      <div class="sidebar-card">
        <div class="sidebar-title">Petshops próximos</div>
        <% petshopsProximos.forEach(function(ps) { %>
          <div class="sidebar-user-item">
            <% if (ps.logo_url) { %>
              <img src="<%= ps.logo_url %>" style="width:34px;height:34px;border-radius:9px;object-fit:cover;flex-shrink:0;" alt="">
            <% } else { %>
              <div class="sidebar-avatar-init" style="border-radius:9px;background:var(--ink-4);">🏪</div>
            <% } %>
            <a href="/petshops/<%= ps.slug || ps.id %>" style="flex:1;min-width:0;font-size:13px;font-weight:600;color:var(--text);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;text-decoration:none;" onmouseover="this.style.color='var(--accent)'" onmouseout="this.style.color='var(--text)'"><%= ps.nome %></a>
          </div>
        <% }); %>
      </div>
      <% } %>

      <div style="font-size:11px;color:var(--text-dim);line-height:1.6;padding:0 4px;">
        AIRPET © 2025 &nbsp;·&nbsp;
        <a href="/privacidade" style="color:var(--text-dim);text-decoration:none;" onmouseover="this.style.color='var(--accent)'" onmouseout="this.style.color='var(--text-dim)'">Privacidade</a> &nbsp;·&nbsp;
        <a href="/termos" style="color:var(--text-dim);text-decoration:none;" onmouseover="this.style.color='var(--accent)'" onmouseout="this.style.color='var(--text-dim)'">Termos</a>
      </div>
    </aside>

  </div>
</main>

<script>
(function () {
  'use strict';

  var meuId = <%- typeof usuario !== 'undefined' && usuario ? usuario.id : 'null' %>;
  var meuNome = '<%- typeof usuario !== 'undefined' && usuario ? (usuario.nome || '').replace(/'/g, "\\'") : '' %>';
  var meuFotoPerfil = '<%- typeof usuario !== 'undefined' && usuario ? (usuario.foto_perfil || '').replace(/'/g, "\\'") : '' %>';
  var meuCorPerfil = '<%- typeof usuario !== 'undefined' && usuario ? (usuario.cor_perfil || '#ec5a1c').replace(/'/g, "\\'") : '#ec5a1c' %>';
  var feedContainer = document.getElementById('feedContainer');

  // ── Relative time ──
  function tempoRelativo(ts) {
    if (!ts) return '';
    var d = new Date(ts), now = Date.now(), diff = Math.floor((now - d) / 1000);
    if (diff < 60) return 'agora';
    if (diff < 3600) return Math.floor(diff/60) + 'min';
    if (diff < 86400) return Math.floor(diff/3600) + 'h';
    if (diff < 604800) return Math.floor(diff/86400) + 'd';
    return d.toLocaleDateString('pt-BR', {day:'2-digit',month:'short'});
  }

  function atualizarTempos() {
    document.querySelectorAll('.tempo-relativo').forEach(function(el) {
      var t = el.getAttribute('data-time');
      if (t) el.textContent = tempoRelativo(t);
    });
  }

  function escapeHtml(s) {
    return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }

  // ── Menus ──
  function fecharMenus() {
    document.querySelectorAll('.post-dropdown').forEach(function(m) { m.classList.add('hidden'); });
  }

  function toggleMenu(btn) {
    var dd = btn.nextElementSibling;
    var isHidden = dd.classList.contains('hidden');
    fecharMenus();
    if (isHidden) dd.classList.remove('hidden');
  }

  // ── Like ──
  function curtirPost(postId, btn) {
    if (!meuId) { window.location = '/auth/login'; return; }
    var curtiu = btn.getAttribute('data-curtiu') === '1';
    var newState = !curtiu;
    btn.setAttribute('data-curtiu', newState ? '1' : '0');
    btn.classList.toggle('liked', newState);
    var icon = btn.querySelector('i');
    if (icon) { icon.className = newState ? 'fa-solid fa-heart' : 'fa-regular fa-heart'; }
    var countEl = btn.querySelector('.count-curtidas');
    if (countEl) {
      var n = parseInt(countEl.textContent) || 0;
      countEl.textContent = newState ? n + 1 : Math.max(0, n - 1) || '';
    }
    if (newState) {
      btn.classList.add('animate-heartPop');
      setTimeout(function() { btn.classList.remove('animate-heartPop'); }, 400);
      var heart = document.createElement('span');
      heart.className = 'float-heart'; heart.textContent = '♥';
      heart.style.cssText = 'left:50%;top:50%;transform:translate(-50%,-50%)';
      btn.appendChild(heart);
      setTimeout(function() { heart.remove(); }, 700);
    }
    fetch('/explorar/post/' + postId + '/curtir', {
      method: newState ? 'POST' : 'DELETE',
      headers: { 'Accept': 'application/json' },
      credentials: 'same-origin'
    });
  }

  // ── Comments ──
  function abrirComentarios(postId) {
    window.location = '/explorar/post/' + postId;
  }

  function enviarComentario(postId, texto, inputEl) {
    fetch('/explorar/post/' + postId + '/comentar', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
      credentials: 'same-origin',
      body: JSON.stringify({ texto: texto })
    }).then(function(r) { return r.json(); }).then(function(d) {
      if (d.sucesso) {
        inputEl.value = '';
        var card = document.getElementById('post-' + postId);
        if (card) {
          var countEl = card.querySelector('.count-comentarios');
          if (countEl) {
            var n = parseInt(countEl.textContent) || 0;
            countEl.textContent = n + 1;
          }
        }
      }
    });
  }

  // ── Repost ──
  function abrirRepostModal(postId) {
    if (!meuId) { window.location = '/auth/login'; return; }
    if (confirm('Repostar esta publicação?')) {
      fetch('/explorar/post/' + postId + '/repost', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
        credentials: 'same-origin',
        body: JSON.stringify({ texto: 'Repost' })
      }).then(function(r) { return r.json(); }).then(function(d) {
        if (d.sucesso) {
          var card = document.getElementById('post-' + postId);
          if (card) {
            var btn = card.querySelector('.btn-repost');
            if (btn) {
              btn.classList.add('reposted');
              var countEl = btn.querySelector('.count-reposts');
              if (countEl) countEl.textContent = (parseInt(countEl.textContent) || 0) + 1;
            }
          }
        }
      });
    }
  }

  // ── Share ──
  function compartilhar(postId, autor) {
    var url = window.location.origin + '/explorar/post/' + postId;
    if (navigator.share) {
      navigator.share({ title: 'Post de ' + autor + ' no AIRPET', url: url });
    } else {
      navigator.clipboard.writeText(url).then(function() {
        alert('Link copiado!');
      });
    }
  }

  // ── Pin / Delete ──
  function fixarPost(postId, isFixed) {
    fetch('/explorar/post/' + postId + '/fixar', {
      method: isFixed ? 'DELETE' : 'POST',
      headers: { 'Accept': 'application/json' },
      credentials: 'same-origin'
    }).then(function() { location.reload(); });
  }

  function deletarPost(postId) {
    if (!confirm('Excluir publicação?')) return;
    fetch('/explorar/post/' + postId, { method: 'DELETE', headers: { 'Accept': 'application/json' }, credentials: 'same-origin' })
      .then(function(r) { return r.json(); })
      .then(function(d) {
        if (d.sucesso) {
          var el = document.getElementById('post-' + postId);
          if (el) {
            el.style.transition = 'opacity 0.3s, transform 0.3s';
            el.style.opacity = '0'; el.style.transform = 'translateY(-8px)';
            setTimeout(function() { el.remove(); }, 300);
          }
        }
      });
  }

  // ── Ver mais ──
  function initVerMais() {
    document.querySelectorAll('.post-text-body').forEach(function(el) {
      if (el.scrollHeight > el.clientHeight + 4) {
        var btn = el.closest('article') ? el.closest('article').querySelector('.btn-ver-mais') : null;
        if (btn) btn.classList.remove('hidden');
      }
    });
  }

  function toggleTexto(btn) {
    var el = btn.closest('article').querySelector('.post-text-body');
    if (el) {
      el.classList.toggle('line-clamp-3');
      btn.textContent = el.classList.contains('line-clamp-3') ? 'ver mais' : 'ver menos';
    }
  }

  // ── Composer ──
  var textarea = document.getElementById('novoPostTexto');
  var btnPublicar = document.getElementById('btnPublicar');
  var charCount = document.getElementById('charCount');
  var inputFoto = document.getElementById('inputFotoPost');
  var previewWrap = document.getElementById('novoPostPreview');
  var previewImg = document.getElementById('novoPostPreviewImg');
  var fotoBlob = null;

  if (textarea) {
    textarea.addEventListener('input', function() {
      var len = textarea.value.length;
      charCount.textContent = len + '/500';
      charCount.style.color = len > 450 ? '#f87171' : 'var(--text-dim)';
      btnPublicar.disabled = len === 0 && !fotoBlob;
    });
  }

  if (document.getElementById('btnAnexarFoto')) {
    document.getElementById('btnAnexarFoto').addEventListener('click', function() { inputFoto.click(); });
  }

  if (inputFoto) {
    inputFoto.addEventListener('change', function() {
      var file = this.files[0];
      if (!file) return;
      var reader = new FileReader();
      reader.onload = function(ev) {
        previewImg.src = ev.target.result;
        previewWrap.classList.remove('hidden');
        fotoBlob = file;
        btnPublicar.disabled = false;
      };
      reader.readAsDataURL(file);
    });
  }

  if (document.getElementById('removerFoto')) {
    document.getElementById('removerFoto').addEventListener('click', function() {
      previewWrap.classList.add('hidden');
      previewImg.src = '';
      fotoBlob = null;
      inputFoto.value = '';
      if (textarea) btnPublicar.disabled = textarea.value.trim() === '';
    });
  }

  if (btnPublicar) {
    btnPublicar.addEventListener('click', function() {
      var texto = textarea.value.trim();
      if (!texto && !fotoBlob) return;
      btnPublicar.disabled = true;
      btnPublicar.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Publicando...';

      var petIdEl = document.getElementById('novoPetId');
      var petId = petIdEl ? petIdEl.value : '';

      var fd = new FormData();
      if (texto) fd.append('texto', texto);
      if (petId) fd.append('pet_id', petId);
      if (fotoBlob) fd.append('foto', fotoBlob);

      fetch('/explorar/post', { method: 'POST', body: fd, credentials: 'same-origin' })
        .then(function(r) { return r.json(); })
        .then(function(d) {
          if (d.sucesso && d.post) {
            textarea.value = ''; charCount.textContent = '0/500';
            previewWrap.classList.add('hidden'); previewImg.src = ''; fotoBlob = null;
            btnPublicar.innerHTML = '<i class="fa-solid fa-paper-plane"></i> Publicar';
            btnPublicar.disabled = true;
            var html = renderPostHTML(d.post);
            var temp = document.createElement('div'); temp.innerHTML = html;
            var newCard = temp.firstChild;
            feedContainer.insertBefore(newCard, feedContainer.firstChild);
            initVerMais();
          } else {
            alert(d.mensagem || 'Erro ao publicar.');
            btnPublicar.disabled = false;
            btnPublicar.innerHTML = '<i class="fa-solid fa-paper-plane"></i> Publicar';
          }
        });
    });
  }

  // ── Render post HTML (for dynamic insertion) ──
  function renderPostHTML(p) {
    var pCor = p.cor_perfil || '#ec5a1c';
    var avatarHtml = p.foto_perfil
      ? '<img src="' + escapeHtml(p.foto_perfil) + '" class="post-avatar post-author-avatar" style="box-shadow:0 0 0 2px ' + escapeHtml(pCor) + '" alt="">'
      : '<div class="post-avatar-initial post-author-avatar" style="box-shadow:0 0 0 2px ' + escapeHtml(pCor) + '">' + escapeHtml((p.autor_nome || 'U').charAt(0).toUpperCase()) + '</div>';
    var txt = p.texto || p.legenda || '';
    var h = '<article class="post-card post-enter" data-post-id="' + p.id + '" id="post-' + p.id + '">';
    h += '<div class="post-header"><a href="/explorar/perfil/' + p.usuario_id + '" class="post-avatar-wrap">' + avatarHtml + '</a>';
    h += '<div class="post-meta"><div><a href="/explorar/perfil/' + p.usuario_id + '" class="post-author-name">' + escapeHtml(p.autor_nome) + '</a></div>';
    h += '<span class="post-time">agora</span></div>';
    h += '<div style="position:relative;flex-shrink:0;"><button type="button" class="post-menu-btn btn-menu-post"><i class="fa-solid fa-ellipsis"></i></button>';
    h += '<div class="post-dropdown hidden"><button type="button" class="post-dropdown-item btn-fixar" data-post-id="' + p.id + '" data-fixada="0"><i class="fa-solid fa-thumbtack" style="width:16px;text-align:center;color:var(--text-dim);"></i>Fixar</button>';
    h += '<button type="button" class="post-dropdown-item danger btn-deletar" data-post-id="' + p.id + '"><i class="fa-solid fa-trash-can" style="width:16px;text-align:center;"></i>Excluir</button></div></div></div>';
    if (txt) h += '<div class="post-text post-text-body">' + escapeHtml(txt) + '</div>';
    if (p.foto) h += '<img src="' + escapeHtml(p.foto) + '" class="post-photo" loading="lazy" alt="">';
    h += '<div class="post-actions">';
    h += '<button type="button" class="post-action-btn btn-comentar" data-post-id="' + p.id + '"><i class="fa-regular fa-comment"></i><span class="count-comentarios"></span></button>';
    h += '<button type="button" class="post-action-btn btn-repost" data-post-id="' + p.id + '"><i class="fa-solid fa-retweet"></i><span class="count-reposts"></span></button>';
    h += '<button type="button" class="post-action-btn btn-curtir" data-post-id="' + p.id + '" data-curtiu="0" style="position:relative;"><i class="fa-regular fa-heart"></i><span class="count-curtidas"></span></button>';
    h += '<button type="button" class="post-action-btn btn-share" data-post-id="' + p.id + '" data-autor="' + escapeHtml(p.autor_nome) + '"><i class="fa-solid fa-share-from-square"></i></button>';
    h += '</div>';
    if (meuId) h += '<div class="post-comment-row"><div style="width:28px;height:28px;border-radius:50%;flex-shrink:0;background:var(--ink-4);display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:700;color:var(--text);box-shadow:0 0 0 2px ' + escapeHtml(meuCorPerfil) + ';">' + escapeHtml(meuNome.charAt(0).toUpperCase()) + '</div><input type="text" class="comment-input input-comentario-inline" data-post-id="' + p.id + '" placeholder="Adicionar comentário…" maxlength="500"></div>';
    h += '</article>';
    return h;
  }

  // ── Event delegation ──
  feedContainer.addEventListener('click', function (e) {
    var btn;
    btn = e.target.closest('.btn-curtir'); if (btn) { curtirPost(btn.dataset.postId, btn); return; }
    btn = e.target.closest('.btn-comentar'); if (btn) { abrirComentarios(btn.dataset.postId); return; }
    btn = e.target.closest('.btn-repost'); if (btn) { abrirRepostModal(btn.dataset.postId); return; }
    btn = e.target.closest('.btn-share'); if (btn) { compartilhar(btn.dataset.postId, btn.dataset.autor); return; }
    btn = e.target.closest('.btn-menu-post'); if (btn) { e.stopPropagation(); toggleMenu(btn); return; }
    btn = e.target.closest('.btn-fixar'); if (btn) { fecharMenus(); fixarPost(btn.dataset.postId, btn.dataset.fixada === '1'); return; }
    btn = e.target.closest('.btn-deletar'); if (btn) { fecharMenus(); deletarPost(btn.dataset.postId); return; }
    btn = e.target.closest('.btn-ver-mais'); if (btn) { toggleTexto(btn); return; }
    fecharMenus();
  });

  feedContainer.addEventListener('keydown', function (e) {
    if (e.key === 'Enter' && e.target.classList.contains('input-comentario-inline')) {
      e.preventDefault();
      var txt = e.target.value.trim();
      if (txt) enviarComentario(e.target.dataset.postId, txt, e.target);
    }
  });

  document.addEventListener('click', function (e) {
    if (!e.target.closest('.btn-menu-post') && !e.target.closest('.post-dropdown')) fecharMenus();
  });

  // ── Sidebar follow buttons ──
  document.querySelectorAll('.btn-seguir-sidebar').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var el = this;
      fetch('/explorar/seguir/' + el.dataset.userId, { method: 'POST', headers: { 'Content-Type': 'application/json' } })
        .then(function(r) { return r.json(); })
        .then(function(d) {
          if (d.sucesso) {
            el.textContent = 'Seguindo';
            el.style.background = 'var(--accent)'; el.style.borderColor = 'var(--accent)'; el.style.color = '#fff';
            el.disabled = true;
          }
        });
    });
  });

  document.querySelectorAll('.btn-seguir-pet-sidebar').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var el = this;
      fetch('/explorar/pet/' + el.dataset.petId + '/seguir', { method: 'POST', headers: { 'Content-Type': 'application/json' } })
        .then(function(r) { return r.json(); })
        .then(function(d) {
          if (d.sucesso) {
            el.textContent = 'Seguindo';
            el.style.background = 'var(--accent)'; el.style.borderColor = 'var(--accent)'; el.style.color = '#fff';
            el.disabled = true;
          }
        });
    });
  });

  // ── Load more ──
  var loadMoreBtn = document.getElementById('loadMoreBtn');
  if (loadMoreBtn) {
    loadMoreBtn.addEventListener('click', function() {
      var page = parseInt(this.getAttribute('data-page') || '2', 10);
      this.innerHTML = '<i class="fa-solid fa-spinner fa-spin mr-2"></i>Carregando...';
      this.disabled = true;
      fetch('/feed?page=' + page, { headers: { 'Accept': 'application/json' }, credentials: 'same-origin' })
        .then(function(r) { return r.json(); })
        .then(function(d) {
          if (d.posts && d.posts.length > 0) {
            d.posts.forEach(function(p) {
              var html = renderPostHTML(p);
              var temp = document.createElement('div'); temp.innerHTML = html;
              feedContainer.insertBefore(temp.firstChild, loadMoreBtn);
            });
            if (d.temMais) {
              loadMoreBtn.setAttribute('data-page', page + 1);
              loadMoreBtn.innerHTML = '<i class="fa-solid fa-arrows-rotate mr-2"></i>Carregar mais publicações';
              loadMoreBtn.disabled = false;
            } else {
              loadMoreBtn.remove();
            }
          } else {
            loadMoreBtn.remove();
          }
          initVerMais();
        });
    });
  }

  atualizarTempos();
  setInterval(atualizarTempos, 60000);
  setTimeout(initVerMais, 100);

})();
</script>

<%- include('partials/footer') %>
