<% locals.titulo = 'Lotes de Fabricacao' %>
<%- include('../partials/header') %>
<%- include('../partials/flash') %>

<main class="flex-1">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

    <div class="flex items-center justify-between mb-6">
      <div>
        <a href="/tags/admin/lista" class="inline-flex items-center gap-1 text-sm text-gray-500 hover:text-primary-500 transition-colors mb-2">
          <i class="fa-solid fa-arrow-left text-xs"></i> Voltar para Tags
        </a>
        <h1 class="text-2xl font-bold text-gray-900">Lotes de Fabricação</h1>
      </div>
      <span class="text-sm text-gray-500"><%= lotes.length %> lotes</span>
    </div>

    <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="bg-gray-50 border-b border-gray-200">
              <th class="px-4 py-3 text-left font-semibold text-gray-600">Código do Lote</th>
              <th class="px-4 py-3 text-left font-semibold text-gray-600">Quantidade</th>
              <th class="px-4 py-3 text-left font-semibold text-gray-600">Fabricante</th>
              <th class="px-4 py-3 text-left font-semibold text-gray-600">Data</th>
              <th class="px-4 py-3 text-left font-semibold text-gray-600">Tags por Status</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            <% lotes.forEach(function(l) { %>
              <tr class="hover:bg-gray-50 transition-colors">
                <td class="px-4 py-3 font-mono text-xs font-semibold text-gray-700"><%= l.codigo_lote %></td>
                <td class="px-4 py-3 text-gray-900 font-medium"><%= l.quantidade %></td>
                <td class="px-4 py-3 text-gray-600"><%= l.fabricante || '—' %></td>
                <td class="px-4 py-3 text-gray-500 text-xs"><%= l.criado_em ? new Date(l.criado_em).toLocaleDateString('pt-BR') : '—' %></td>
                <td class="px-4 py-3">
                  <div class="flex flex-wrap gap-1.5">
                    <% if (l.stock > 0) { %>
                      <span class="inline-flex items-center px-1.5 py-0.5 rounded text-[10px] font-semibold bg-slate-100 text-slate-600">
                        stock: <%= l.stock %>
                      </span>
                    <% } %>
                    <% if (l.reserved > 0) { %>
                      <span class="inline-flex items-center px-1.5 py-0.5 rounded text-[10px] font-semibold bg-blue-100 text-blue-600">
                        reserved: <%= l.reserved %>
                      </span>
                    <% } %>
                    <% if (l.sent > 0) { %>
                      <span class="inline-flex items-center px-1.5 py-0.5 rounded text-[10px] font-semibold bg-yellow-100 text-yellow-700">
                        sent: <%= l.sent %>
                      </span>
                    <% } %>
                    <% if (l.active > 0) { %>
                      <span class="inline-flex items-center px-1.5 py-0.5 rounded text-[10px] font-semibold bg-emerald-100 text-emerald-700">
                        active: <%= l.active %>
                      </span>
                    <% } %>
                    <% if (l.blocked > 0) { %>
                      <span class="inline-flex items-center px-1.5 py-0.5 rounded text-[10px] font-semibold bg-red-100 text-red-700">
                        blocked: <%= l.blocked %>
                      </span>
                    <% } %>
                  </div>
                </td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>

      <% if (lotes.length === 0) { %>
        <div class="text-center py-12 text-gray-400">
          <i class="fa-solid fa-box text-3xl mb-2"></i>
          <p class="text-sm">Nenhum lote gerado ainda</p>
        </div>
      <% } %>
    </div>

  </div>
</main>

<%- include('../partials/footer') %>
