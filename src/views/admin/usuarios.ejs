<% locals.titulo = 'Usuários' %>
<%- include('../partials/admin-layout') %>

<main class="flex-1">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-6">
      <div>
        <a href="<%= adminPath %>" class="inline-flex items-center gap-1 text-sm text-gray-500 hover:text-primary-500 transition-colors mb-2">
          <i class="fa-solid fa-arrow-left text-xs"></i> Dashboard
        </a>
        <h1 class="text-2xl font-bold text-gray-900">Gerenciar usuários</h1>
        <p class="text-sm text-gray-500 mt-0.5">Visualize, filtre por região e bloqueie contas</p>
      </div>
      <div class="text-right">
        <span class="text-sm text-gray-500 font-medium"><%= usuarios.length %> <%= usuarios.length === 1 ? 'registro' : 'registros' %> na lista</span>
        <% if (typeof totalUsuarios !== 'undefined') { %>
          <p class="text-xs text-gray-400 mt-0.5">Total no sistema: <strong><%= totalUsuarios %></strong><% if (maxUsuarios) { %> / <%= maxUsuarios %> (limite)<% } %></p>
        <% } %>
      </div>
    </div>

    <!-- Limite do sistema (variável .env) -->
    <div class="bg-amber-50 border border-amber-200 rounded-xl px-4 py-3 mb-6">
      <p class="text-sm text-amber-800">
        <i class="fa-solid fa-info-circle mr-1"></i>
        <strong>Limite de usuários:</strong>
        <% if (maxUsuarios) { %>
          O sistema está limitado a <strong><%= maxUsuarios %></strong> usuários. Atualmente <strong><%= typeof totalUsuarios !== 'undefined' ? totalUsuarios : 0 %></strong> cadastrados.
          Para alterar, edite no arquivo <code class="bg-amber-100 px-1 rounded text-xs">.env</code> a variável <code class="bg-amber-100 px-1 rounded text-xs">MAX_USUARIOS=<%= maxUsuarios %></code> (ex.: <code class="bg-amber-100 px-1 rounded text-xs">MAX_USUARIOS=100</code>). Use <code class="bg-amber-100 px-1 rounded text-xs">0</code> ou deixe vazio para sem limite.
        <% } else { %>
          Sem limite definido. Para limitar o total de cadastros, adicione no arquivo <code class="bg-amber-100 px-1 rounded text-xs">.env</code> a variável <code class="bg-amber-100 px-1 rounded text-xs">MAX_USUARIOS=50</code> (troque 50 pelo número desejado). Reinicie o servidor após alterar.
        <% } %>
      </p>
    </div>

    <!-- Filtros -->
    <form method="GET" action="<%= adminPath %>/usuarios" class="bg-white rounded-xl shadow-sm border border-gray-100 p-4 mb-6">
      <div class="flex flex-wrap items-end gap-3">
        <div class="min-w-[120px]">
          <label for="filtro_estado" class="block text-xs font-medium text-gray-500 mb-1">Estado</label>
          <select name="estado" id="filtro_estado" class="w-full rounded-lg border border-gray-200 px-3 py-2 text-sm focus:border-primary-500 focus:ring-1 focus:ring-primary-500">
            <option value="">Todos</option>
            <% (estados || []).forEach(function(est) { %>
              <option value="<%= est %>" <%= (filtros && filtros.estado === est) ? 'selected' : '' %>><%= est %></option>
            <% }); %>
          </select>
        </div>
        <div class="min-w-[160px]">
          <label for="filtro_cidade" class="block text-xs font-medium text-gray-500 mb-1">Cidade</label>
          <input type="text" name="cidade" id="filtro_cidade" value="<%= filtros && filtros.cidade ? filtros.cidade : '' %>" placeholder="Buscar cidade..."
                 class="w-full rounded-lg border border-gray-200 px-3 py-2 text-sm focus:border-primary-500 focus:ring-1 focus:ring-primary-500">
        </div>
        <div class="min-w-[120px]">
          <label for="filtro_status" class="block text-xs font-medium text-gray-500 mb-1">Status</label>
          <select name="status" id="filtro_status" class="w-full rounded-lg border border-gray-200 px-3 py-2 text-sm focus:border-primary-500 focus:ring-1 focus:ring-primary-500">
            <option value="todos" <%= (filtros && filtros.status) === 'todos' ? 'selected' : '' %>>Todos</option>
            <option value="ativo" <%= (filtros && filtros.status) === 'ativo' ? 'selected' : '' %>>Ativos</option>
            <option value="bloqueado" <%= (filtros && filtros.status) === 'bloqueado' ? 'selected' : '' %>>Bloqueados</option>
          </select>
        </div>
        <button type="submit" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-primary-500 text-white text-sm font-medium hover:bg-primary-600 transition-colors">
          <i class="fa-solid fa-filter text-xs"></i> Filtrar
        </button>
        <% if (filtros && (filtros.estado || filtros.cidade || (filtros.status && filtros.status !== 'todos'))) { %>
          <a href="<%= adminPath %>/usuarios" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg border border-gray-200 text-gray-600 text-sm font-medium hover:bg-gray-50 transition-colors">
            Limpar
          </a>
        <% } %>
      </div>
    </form>

    <!-- Tabela de usuários -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="bg-gray-50 border-b border-gray-200">
              <th class="px-4 py-3 text-left font-semibold text-gray-600">Usuário</th>
              <th class="px-4 py-3 text-left font-semibold text-gray-600">Contato</th>
              <th class="px-4 py-3 text-left font-semibold text-gray-600">Região</th>
              <th class="px-4 py-3 text-left font-semibold text-gray-600">Perfil</th>
              <th class="px-4 py-3 text-left font-semibold text-gray-600">Status</th>
              <th class="px-4 py-3 text-left font-semibold text-gray-600">Cadastro</th>
              <th class="px-4 py-3 text-left font-semibold text-gray-600">Ações</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            <% usuarios.forEach(function(u) { %>
              <tr class="hover:bg-gray-50/80 transition-colors">
                <td class="px-4 py-3">
                  <div class="flex items-center gap-3">
                    <% if (u.foto_perfil) { %>
                      <img src="<%= u.foto_perfil %>" alt="" class="w-9 h-9 rounded-full object-cover border border-gray-200">
                    <% } else { %>
                      <div class="w-9 h-9 rounded-full flex items-center justify-center text-white text-xs font-semibold" style="background-color: <%= u.cor_perfil || '#ec5a1c' %>">
                        <%= (u.nome || '').charAt(0).toUpperCase() %>
                      </div>
                    <% } %>
                    <div>
                      <p class="font-medium text-gray-900"><%= u.nome %></p>
                      <p class="text-xs text-gray-500">ID <%= u.id %> · <%= u.email %></p>
                    </div>
                  </div>
                </td>
                <td class="px-4 py-3">
                  <p class="text-gray-600"><%= u.telefone || '—' %></p>
                </td>
                <td class="px-4 py-3">
                  <p class="text-gray-600"><%= u.cidade || '—' %></p>
                  <p class="text-xs text-gray-500"><%= u.estado || '—' %> <%= u.bairro ? ' · ' + u.bairro : '' %></p>
                </td>
                <td class="px-4 py-3">
                  <div class="flex flex-col items-start gap-1">
                    <% if (u.role === 'admin') { %>
                      <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-semibold bg-purple-100 text-purple-700">admin</span>
                    <% } else { %>
                      <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-semibold bg-gray-100 text-gray-600">usuário</span>
                    <% } %>
                    <a href="/explorar/perfil/<%= u.id %>" target="_blank" class="text-xs text-primary-600 hover:underline">Ver perfil público</a>
                  </div>
                </td>
                <td class="px-4 py-3">
                  <% if (u.bloqueado) { %>
                    <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-semibold bg-red-100 text-red-700">Bloqueado</span>
                  <% } else { %>
                    <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-semibold bg-green-100 text-green-700">Ativo</span>
                  <% } %>
                </td>
                <td class="px-4 py-3 text-gray-500 text-xs">
                  <%= u.data_criacao ? new Date(u.data_criacao).toLocaleDateString('pt-BR') : '—' %>
                </td>
                <td class="px-4 py-3">
                  <% const ehAdminEmail = typeof adminEmail !== 'undefined' && adminEmail && u.email === adminEmail; %>
                  <% if (!ehAdminEmail) { %>
                    <div class="flex flex-wrap items-center gap-1">
                      <form action="<%= adminPath %>/usuarios/<%= u.id %>/bloquear" method="POST" class="inline">
                        <button type="submit" class="inline-flex items-center gap-1 px-2 py-1 rounded-lg text-xs font-medium <%= u.bloqueado ? 'bg-green-50 text-green-700 hover:bg-green-100' : 'bg-red-50 text-red-700 hover:bg-red-100' %> transition-colors">
                          <i class="fa-solid fa-<%= u.bloqueado ? 'lock-open' : 'ban' %>"></i>
                          <%= u.bloqueado ? 'Desbloquear' : 'Bloquear' %>
                        </button>
                      </form>
                      <form action="<%= adminPath %>/usuarios/<%= u.id %>/excluir" method="POST" class="inline" onsubmit="return confirm('Tem certeza? Isso remove o usuário e todos os dados (pets, publicações, etc.) de forma permanente.');">
                        <button type="submit" class="inline-flex items-center gap-1 px-2 py-1 rounded-lg text-xs font-medium bg-red-50 text-red-700 hover:bg-red-100 transition-colors" title="Excluir cadastro">
                          <i class="fa-solid fa-trash-can"></i> Excluir
                        </button>
                      </form>
                    </div>
                  <% } else { %>
                    <span class="text-xs text-gray-400">Admin</span>
                  <% } %>
                </td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>

      <% if (usuarios.length === 0) { %>
        <div class="text-center py-16 text-gray-400">
          <i class="fa-solid fa-users text-4xl mb-3 opacity-50"></i>
          <p class="text-sm font-medium">Nenhum usuário encontrado</p>
          <p class="text-xs mt-1">Ajuste os filtros ou <a href="<%= adminPath %>/usuarios" class="text-primary-500 hover:underline">limpe</a> para ver todos.</p>
        </div>
      <% } %>
    </div>

  </div>
</main>

<%- include('../partials/admin-footer') %>
