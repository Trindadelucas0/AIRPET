<% locals.titulo = 'Usuarios' %>
<%- include('../partials/header') %>
<%- include('../partials/flash') %>

<main class="flex-1">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

    <div class="flex items-center justify-between mb-6">
      <div>
        <a href="<%= adminPath %>" class="inline-flex items-center gap-1 text-sm text-gray-500 hover:text-primary-500 transition-colors mb-2">
          <i class="fa-solid fa-arrow-left text-xs"></i> Dashboard
        </a>
        <h1 class="text-2xl font-bold text-gray-900">Usuários</h1>
      </div>
      <span class="text-sm text-gray-500"><%= usuarios.length %> registros</span>
    </div>

    <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="bg-gray-50 border-b border-gray-200">
              <th class="px-4 py-3 text-left font-semibold text-gray-600">ID</th>
              <th class="px-4 py-3 text-left font-semibold text-gray-600">Nome</th>
              <th class="px-4 py-3 text-left font-semibold text-gray-600">Email</th>
              <th class="px-4 py-3 text-left font-semibold text-gray-600">Telefone</th>
              <th class="px-4 py-3 text-left font-semibold text-gray-600">Role</th>
              <th class="px-4 py-3 text-left font-semibold text-gray-600">Status</th>
              <th class="px-4 py-3 text-left font-semibold text-gray-600">Data Criação</th>
              <th class="px-4 py-3 text-left font-semibold text-gray-600">Ações</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            <% usuarios.forEach(function(u) { %>
              <tr class="hover:bg-gray-50 transition-colors">
                <td class="px-4 py-3 font-mono text-xs text-gray-400"><%= u.id %></td>
                <td class="px-4 py-3 font-medium text-gray-900"><%= u.nome %></td>
                <td class="px-4 py-3 text-gray-600"><%= u.email %></td>
                <td class="px-4 py-3 text-gray-600"><%= u.telefone || '—' %></td>
                <td class="px-4 py-3">
                  <% if (u.role === 'admin') { %>
                    <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-semibold bg-purple-100 text-purple-700">admin</span>
                  <% } else { %>
                    <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-semibold bg-gray-100 text-gray-600">usuário</span>
                  <% } %>
                </td>
                <td class="px-4 py-3">
                  <% if (u.bloqueado) { %>
                    <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-semibold bg-red-100 text-red-700">Bloqueado</span>
                  <% } else { %>
                    <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-semibold bg-green-100 text-green-700">Ativo</span>
                  <% } %>
                </td>
                <td class="px-4 py-3 text-gray-500 text-xs"><%= u.data_criacao ? new Date(u.data_criacao).toLocaleDateString('pt-BR') : '—' %></td>
                <td class="px-4 py-3">
                  <% const ehAdminEmail = typeof adminEmail !== 'undefined' && adminEmail && u.email === adminEmail; %>
                  <% if (!ehAdminEmail) { %>
                    <form action="<%= adminPath %>/usuarios/<%= u.id %>/bloquear" method="POST" class="inline">
                      <button type="submit" class="text-xs font-medium <%= u.bloqueado ? 'text-green-600 hover:text-green-700' : 'text-red-600 hover:text-red-700' %> transition-colors">
                        <%= u.bloqueado ? 'Desbloquear' : 'Bloquear' %>
                      </button>
                    </form>
                  <% } else { %>
                    <span class="text-xs text-gray-400">—</span>
                  <% } %>
                </td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>

      <% if (usuarios.length === 0) { %>
        <div class="text-center py-12 text-gray-400">
          <i class="fa-solid fa-users text-3xl mb-2"></i>
          <p class="text-sm">Nenhum usuário encontrado</p>
        </div>
      <% } %>
    </div>

  </div>
</main>

<%- include('../partials/footer') %>
