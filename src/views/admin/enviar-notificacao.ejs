<% locals.titulo = typeof titulo !== 'undefined' ? titulo : 'Notificação em massa' %>
<%- include('../partials/admin-layout') %>
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="">
<style>
  #mapaRegiaoPerfil { width: 100%; height: 320px; min-height: 280px; border-radius: 12px; overflow: hidden; }
  .leaflet-container { z-index: 1; }
</style>

<main class="flex-1">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

    <div class="mb-8">
      <a href="<%= adminPath %>" class="inline-flex items-center gap-1.5 text-sm text-gray-500 hover:text-primary-500 transition-colors mb-3">
        <i class="fa-solid fa-arrow-left text-xs"></i> Dashboard
      </a>
      <h1 class="text-2xl font-bold text-gray-900">Notificação em massa</h1>
      <p class="text-sm text-gray-500 mt-1">Selecione a região com base no perfil dos usuários. O mapa abaixo é apenas uma visualização aproximada da área escolhida.</p>
    </div>

    <form action="<%= adminPath %>/notificacoes/enviar" method="POST" id="formEnviar" class="space-y-6 bg-white rounded-xl shadow-sm border border-gray-100 p-6">

      <input type="hidden" name="modo" id="modo" value="perfil">

      <div class="space-y-4">
        <h2 class="text-lg font-semibold text-gray-900 flex items-center gap-2">
          <i class="fa-solid fa-location-dot text-primary-500"></i>
          Como definir a região
        </h2>

        <div class="flex gap-4 border-b border-gray-200 pb-4">
          <label class="flex items-center gap-2 cursor-pointer">
            <input type="radio" name="modoRadio" value="perfil" id="modoPerfil" checked class="rounded border-gray-300 text-primary-500 focus:ring-primary-500">
            <span class="text-sm font-medium text-gray-700">Por perfil (estado, cidade, bairro)</span>
          </label>
          <label class="flex items-center gap-2 cursor-pointer">
            <input type="radio" name="modoRadio" value="geografico" id="modoGeografico" class="rounded border-gray-300 text-primary-500 focus:ring-primary-500">
            <span class="text-sm font-medium text-gray-700">Por localização (mapa + raio)</span>
          </label>
        </div>

        <!-- Painel: Por perfil -->
        <div id="painelPerfil" class="space-y-4">
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <label for="estado" class="block text-sm font-medium text-gray-700 mb-1">Estado</label>
            <select id="estado" name="estado" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-sm">
              <option value="">Selecione o estado</option>
              <% (estadosComContagem || []).forEach(function(e) { %>
              <option value="<%= e.estado %>"><%= e.estado %> (<%= e.total %>)</option>
              <% }); %>
            </select>
          </div>
          <div>
            <label for="cidade" class="block text-sm font-medium text-gray-700 mb-1">Cidade</label>
            <select id="cidade" name="cidade" disabled class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-sm disabled:bg-gray-50 disabled:text-gray-400">
              <option value="">Selecione a cidade</option>
            </select>
          </div>
          <div>
            <label for="bairro" class="block text-sm font-medium text-gray-700 mb-1">Bairro</label>
            <select id="bairro" name="bairro" disabled class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-sm disabled:bg-gray-50 disabled:text-gray-400">
              <option value="">Selecione o bairro</option>
            </select>
          </div>
          <div>
            <label for="cep" class="block text-sm font-medium text-gray-700 mb-1">CEP (opcional)</label>
            <input type="text" id="cep" name="cep" placeholder="00000-000"
                   class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-sm">
          </div>
        </div>

        <div>
          <label for="endereco" class="block text-sm font-medium text-gray-700 mb-1">Endereço / rua (opcional)</label>
          <input type="text" id="endereco" name="endereco" placeholder="Rua, avenida, número ou referência"
                 class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-sm">
        </div>

        <div class="flex items-center gap-3">
          <button type="button" id="btnPreview" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg text-sm font-medium bg-gray-100 text-gray-700 hover:bg-gray-200 transition-colors">
            <i class="fa-solid fa-users"></i>
            Ver quantos usuários receberão
          </button>
          <span id="previewResult" class="text-sm text-gray-500 hidden"></span>
        </div>
        </div>

        <!-- Painel: Por localização (lat/lng/raio) -->
        <div id="painelGeografico" class="space-y-4 hidden">
          <p class="text-sm text-gray-600">Clique no mapa para definir o centro. Usuários com última localização dentro do raio receberão a notificação.</p>
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
            <div>
              <label for="lat" class="block text-sm font-medium text-gray-700 mb-1">Latitude</label>
              <input type="text" id="lat" name="lat" placeholder="-23.5505" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 text-sm">
            </div>
            <div>
              <label for="lng" class="block text-sm font-medium text-gray-700 mb-1">Longitude</label>
              <input type="text" id="lng" name="lng" placeholder="-46.6333" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 text-sm">
            </div>
            <div>
              <label for="raio_km" class="block text-sm font-medium text-gray-700 mb-1">Raio (km)</label>
              <input type="number" id="raio_km" name="raio_km" placeholder="10" min="0.5" step="0.5" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 text-sm">
            </div>
          </div>
          <div class="flex items-center gap-3">
            <button type="button" id="btnPreviewGeo" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg text-sm font-medium bg-gray-100 text-gray-700 hover:bg-gray-200 transition-colors">
              <i class="fa-solid fa-users"></i>
              Ver quantos usuários receberão
            </button>
            <span id="previewResultGeo" class="text-sm text-gray-500 hidden"></span>
          </div>
        </div>

        <div class="rounded-xl border border-gray-200 overflow-hidden mt-4">
          <div id="mapaRegiaoPerfil"></div>
          <div class="px-3 py-2 bg-gray-50 border-t border-gray-100 text-xs text-gray-500" id="mapaLegenda">
            O mapa serve apenas para visualizar a área filtrada. O cálculo real usa os dados do perfil dos usuários.
          </div>
        </div>
      </div>

      <div class="space-y-4 border-t border-gray-100 pt-6">
        <h2 class="text-lg font-semibold text-gray-900 flex items-center gap-2">
          <i class="fa-solid fa-bell text-primary-500"></i>
          Conteúdo da notificação
        </h2>
        <div>
          <label for="titulo" class="block text-sm font-medium text-gray-700 mb-1">Título (push)</label>
          <input type="text" id="titulo" name="titulo" value="AIRPET" placeholder="AIRPET"
                 class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-sm">
        </div>
        <div>
          <label for="mensagem" class="block text-sm font-medium text-gray-700 mb-1">Mensagem <span class="text-red-500">*</span></label>
          <textarea id="mensagem" name="mensagem" rows="4" required placeholder="Digite a mensagem que será enviada..."
                    class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-sm"></textarea>
        </div>
        <div>
          <label for="link" class="block text-sm font-medium text-gray-700 mb-1">Link (opcional)</label>
          <input type="text" id="link" name="link" placeholder="/mapa ou https://..."
                 class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-sm">
        </div>
      </div>

      <div class="flex justify-end gap-3 pt-2">
        <a href="<%= adminPath %>" class="px-4 py-2.5 rounded-lg text-sm font-medium text-gray-600 hover:bg-gray-100 transition-colors">Cancelar</a>
        <button type="submit" id="btnEnviar" class="inline-flex items-center gap-2 px-6 py-2.5 bg-primary-500 hover:bg-primary-600 text-white text-sm font-semibold rounded-lg shadow-sm hover:shadow transition-all">
          <i class="fa-solid fa-paper-plane"></i>
          Enviar notificação em massa
        </button>
      </div>
    </form>

  </div>
</main>

<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
<script>
(function () {
  var adminPath = '<%= adminPath %>';

  function adminNotifyDeferred(workFn, message) {
    var L = window.AIRPET_LOADING;
    if (L && typeof L.withDeferredOverlay === 'function') {
      return L.withDeferredOverlay(workFn, { message: message || 'Ainda a processar…' });
    }
    return Promise.resolve().then(workFn);
  }

  var cidadesData = <%- JSON.stringify(cidadesComContagem || []) %>;
  var bairrosData = <%- JSON.stringify(bairrosComContagem || []) %>;

  var form = document.getElementById('formEnviar');
  var estadoInput = document.getElementById('estado');
  var cidadeInput = document.getElementById('cidade');
  var bairroInput = document.getElementById('bairro');
  var cepInput = document.getElementById('cep');
  var enderecoInput = document.getElementById('endereco');
  var btnPreview = document.getElementById('btnPreview');
  var previewResult = document.getElementById('previewResult');
  var modoInput = document.getElementById('modo');
  var modoPerfil = document.getElementById('modoPerfil');
  var modoGeografico = document.getElementById('modoGeografico');
  var painelPerfil = document.getElementById('painelPerfil');
  var painelGeografico = document.getElementById('painelGeografico');
  var latInput = document.getElementById('lat');
  var lngInput = document.getElementById('lng');
  var raioKmInput = document.getElementById('raio_km');
  var btnPreviewGeo = document.getElementById('btnPreviewGeo');
  var previewResultGeo = document.getElementById('previewResultGeo');
  var mapaLegenda = document.getElementById('mapaLegenda');

  var map = L.map('mapaRegiaoPerfil', { zoomControl: true, tap: true }).setView([-15.78, -47.93], 4);
  L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
    attribution: '&copy; OSM',
    maxZoom: 19
  }).addTo(map);
  setTimeout(function () { map.invalidateSize(); }, 300);
  window.addEventListener('resize', function () { map.invalidateSize(); });

  var mapMarker = null;
  var mapCircle = null;
  var mapCircleGeo = null;
  var geocodeRequestId = 0;

  function atualizarPainelModo() {
    var isGeo = modoInput.value === 'geografico';
    if (painelPerfil) painelPerfil.classList.toggle('hidden', isGeo);
    if (painelGeografico) painelGeografico.classList.toggle('hidden', !isGeo);
    if (mapaLegenda) mapaLegenda.textContent = isGeo ? 'Clique no mapa para definir o centro da região. O raio é informado nos campos acima.' : 'O mapa serve apenas para visualizar a área filtrada. O cálculo real usa os dados do perfil dos usuários.';
    if (isGeo) {
      if (mapMarker) { map.removeLayer(mapMarker); mapMarker = null; }
      if (mapCircle) { map.removeLayer(mapCircle); mapCircle = null; }
      if (latInput.value && lngInput.value && raioKmInput.value) {
        var lat = parseFloat(latInput.value);
        var lng = parseFloat(lngInput.value);
        var raio = parseFloat(raioKmInput.value) * 1000;
        if (!isNaN(lat) && !isNaN(lng) && !isNaN(raio)) {
          if (mapCircleGeo) map.removeLayer(mapCircleGeo);
          mapCircleGeo = L.circle([lat, lng], { radius: raio, color: '#ec5a1c', fillColor: '#ec5a1c', fillOpacity: 0.2, weight: 2 }).addTo(map);
          map.fitBounds(mapCircleGeo.getBounds(), { padding: [30, 30] });
        }
      }
    } else {
      if (mapCircleGeo) { map.removeLayer(mapCircleGeo); mapCircleGeo = null; }
      atualizarMapaVisual();
    }
  }

  if (modoPerfil) modoPerfil.addEventListener('change', function () { modoInput.value = 'perfil'; atualizarPainelModo(); });
  if (modoGeografico) modoGeografico.addEventListener('change', function () { modoInput.value = 'geografico'; atualizarPainelModo(); });

  map.on('click', function (e) {
    if (modoInput.value !== 'geografico') return;
    var lat = e.latlng.lat;
    var lng = e.latlng.lng;
    latInput.value = lat.toFixed(6);
    lngInput.value = lng.toFixed(6);
    if (mapMarker) map.removeLayer(mapMarker);
    mapMarker = L.marker([lat, lng]).addTo(map).bindPopup('Centro da região');
    var raio = parseFloat(raioKmInput.value) || 10;
    if (mapCircleGeo) map.removeLayer(mapCircleGeo);
    mapCircleGeo = L.circle([lat, lng], { radius: raio * 1000, color: '#ec5a1c', fillColor: '#ec5a1c', fillOpacity: 0.2, weight: 2 }).addTo(map);
  });

  raioKmInput.addEventListener('input', function () {
    if (modoInput.value !== 'geografico' || !latInput.value || !lngInput.value) return;
    var lat = parseFloat(latInput.value);
    var lng = parseFloat(lngInput.value);
    var raio = parseFloat(raioKmInput.value) || 0;
    if (isNaN(lat) || isNaN(lng) || raio <= 0) return;
    if (mapCircleGeo) map.removeLayer(mapCircleGeo);
    mapCircleGeo = L.circle([lat, lng], { radius: raio * 1000, color: '#ec5a1c', fillColor: '#ec5a1c', fillOpacity: 0.2, weight: 2 }).addTo(map);
  });

  function preencherSelect(select, items, placeholder, valueKey, labelBuilder) {
    var valorAtual = select.value;
    select.innerHTML = '';
    var first = document.createElement('option');
    first.value = '';
    first.textContent = placeholder;
    select.appendChild(first);

    items.forEach(function (item) {
      var option = document.createElement('option');
      option.value = item[valueKey];
      option.textContent = labelBuilder(item);
      if (valorAtual && valorAtual === option.value) option.selected = true;
      select.appendChild(option);
    });
  }

  function atualizarCidades() {
    var estado = estadoInput.value.trim();
    var cidades = cidadesData.filter(function (item) {
      return !estado || item.estado === estado;
    });

    preencherSelect(cidadeInput, cidades, 'Selecione a cidade', 'cidade', function (item) {
      return item.cidade + ' (' + item.total + ')';
    });

    cidadeInput.disabled = !cidades.length;
    atualizarBairros();
  }

  function atualizarBairros() {
    var estado = estadoInput.value.trim();
    var cidade = cidadeInput.value.trim();
    if (!estado || !cidade) {
      preencherSelect(bairroInput, [], 'Selecione o bairro', 'bairro', function (item) {
        return item.bairro + ' (' + item.total + ')';
      });
      bairroInput.disabled = true;
      return;
    }

    var bairros = bairrosData.filter(function (item) {
      return item.estado === estado && item.cidade === cidade;
    });

    preencherSelect(bairroInput, bairros, 'Selecione o bairro', 'bairro', function (item) {
      return item.bairro + ' (' + item.total + ')';
    });

    bairroInput.disabled = !bairros.length;
  }

  function montarQueryMapa() {
    var partes = [];
    if (enderecoInput.value.trim()) partes.push(enderecoInput.value.trim());
    if (bairroInput.value.trim()) partes.push(bairroInput.value.trim());
    if (cidadeInput.value.trim()) partes.push(cidadeInput.value.trim());
    if (estadoInput.value.trim()) partes.push(estadoInput.value.trim());
    if (cepInput.value.trim()) partes.push(cepInput.value.trim());
    if (!partes.length) return '';
    partes.push('Brasil');
    return partes.join(', ');
  }

  function calcularRaioVisual() {
    if (enderecoInput.value.trim() || cepInput.value.trim()) return 1200;
    if (bairroInput.value.trim()) return 3500;
    if (cidadeInput.value.trim()) return 12000;
    if (estadoInput.value.trim()) return 60000;
    return 0;
  }

  function atualizarMapaVisual() {
    var query = montarQueryMapa();
    var requestId = ++geocodeRequestId;

    if (!query) {
      if (mapMarker) { map.removeLayer(mapMarker); mapMarker = null; }
      if (mapCircle) { map.removeLayer(mapCircle); mapCircle = null; }
      map.setView([-15.78, -47.93], 4);
      return;
    }

    fetch('https://nominatim.openstreetmap.org/search?format=jsonv2&q=' + encodeURIComponent(query) + '&limit=1&countrycodes=br&accept-language=pt-BR')
      .then(function (r) { return r.json(); })
      .then(function (data) {
        if (requestId !== geocodeRequestId) return;
        if (!data || !data.length) return;

        var lat = parseFloat(data[0].lat);
        var lng = parseFloat(data[0].lon);
        var radius = calcularRaioVisual();

        if (mapMarker) map.removeLayer(mapMarker);
        if (mapCircle) map.removeLayer(mapCircle);

        mapMarker = L.marker([lat, lng]).addTo(map).bindPopup(query);
        if (radius > 0) {
          mapCircle = L.circle([lat, lng], {
            radius: radius,
            color: '#ec5a1c',
            fillColor: '#ec5a1c',
            fillOpacity: 0.18,
            weight: 2
          }).addTo(map);
          map.fitBounds(mapCircle.getBounds(), { padding: [30, 30] });
        } else {
          map.setView([lat, lng], 12);
        }
      })
      .catch(function () {});
  }

  function obterFiltros() {
    return {
      estado: estadoInput.value.trim(),
      cidade: cidadeInput.value.trim(),
      bairro: bairroInput.value.trim(),
      cep: cepInput.value.trim(),
      endereco: enderecoInput.value.trim(),
    };
  }

  function temAlgumFiltro() {
    var filtros = obterFiltros();
    return !!(filtros.estado || filtros.cidade || filtros.bairro || filtros.cep || filtros.endereco);
  }

  estadoInput.addEventListener('change', function () {
    atualizarCidades();
    atualizarMapaVisual();
  });
  cidadeInput.addEventListener('change', function () {
    atualizarBairros();
    atualizarMapaVisual();
  });
  bairroInput.addEventListener('change', atualizarMapaVisual);
  cepInput.addEventListener('blur', atualizarMapaVisual);
  enderecoInput.addEventListener('blur', atualizarMapaVisual);

  atualizarCidades();
  atualizarMapaVisual();
  atualizarPainelModo();

  if (btnPreviewGeo) {
    btnPreviewGeo.addEventListener('click', function () {
      var lat = parseFloat(latInput.value);
      var lng = parseFloat(lngInput.value);
      var raio = parseFloat(raioKmInput.value);
      if (isNaN(lat) || isNaN(lng) || isNaN(raio) || raio <= 0) {
        previewResultGeo.textContent = 'Preencha latitude, longitude e raio (km) e clique no mapa para definir o centro.';
        previewResultGeo.classList.remove('hidden');
        return;
      }
      previewResultGeo.textContent = 'Consultando...';
      previewResultGeo.classList.remove('hidden');
      var params = new URLSearchParams({ modo: 'geografico', lat: lat, lng: lng, raio_km: raio });
      var previewUrlGeo = adminPath + '/notificacoes/enviar/preview?' + params.toString();
      adminNotifyDeferred(function () {
        return fetch(previewUrlGeo, { credentials: 'same-origin' })
          .then(function (r) { return r.json(); })
          .then(function (data) {
            if (data.sucesso) previewResultGeo.textContent = data.total + ' usuário(s) com localização no raio.';
            else previewResultGeo.textContent = data.mensagem || 'Erro ao consultar.';
          })
          .catch(function () { previewResultGeo.textContent = 'Erro de conexão.'; });
      }, 'A consultar pré-visualização…');
    });
  }

  btnPreview.addEventListener('click', function () {
    if (!temAlgumFiltro()) {
      previewResult.textContent = 'Selecione ao menos um filtro de região.';
      previewResult.classList.remove('hidden');
      return;
    }

    previewResult.textContent = 'Consultando...';
    previewResult.classList.remove('hidden');

    var params = new URLSearchParams(obterFiltros());
    var previewUrl = adminPath + '/notificacoes/enviar/preview?' + params.toString();
    adminNotifyDeferred(function () {
      return fetch(previewUrl, { credentials: 'same-origin' })
        .then(function (r) { return r.json(); })
        .then(function (data) {
          if (data.sucesso) {
            previewResult.textContent = data.total + ' usuário(s) com perfil na região filtrada.';
          } else {
            previewResult.textContent = data.mensagem || 'Erro ao consultar.';
          }
        })
        .catch(function () {
          previewResult.textContent = 'Erro de conexão.';
        });
    }, 'A consultar pré-visualização…');
  });

  form.addEventListener('submit', function (e) {
    if (modoInput.value === 'geografico') {
      var lat = parseFloat(latInput.value);
      var lng = parseFloat(lngInput.value);
      var raio = parseFloat(raioKmInput.value);
      if (isNaN(lat) || isNaN(lng) || isNaN(raio) || raio <= 0) {
        e.preventDefault();
        previewResultGeo.textContent = 'Preencha latitude, longitude e raio (km) válidos. Clique no mapa para definir o centro.';
        previewResultGeo.classList.remove('hidden');
      }
      return;
    }
    if (!temAlgumFiltro()) {
      e.preventDefault();
      previewResult.textContent = 'Selecione ao menos um filtro de região antes de enviar.';
      previewResult.classList.remove('hidden');
    }
  });
})();
</script>

<%- include('../partials/admin-footer') %>
