<% locals.titulo = typeof titulo !== 'undefined' ? titulo : 'Notificação em massa' %>
<%- include('../partials/admin-layout') %>
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="">
<style>
  #mapaRegiao { width: 100%; height: 320px; min-height: 280px; border-radius: 12px; overflow: hidden; }
  .leaflet-container { z-index: 1; }
</style>

<main class="flex-1">
  <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

    <div class="mb-8">
      <a href="<%= adminPath %>" class="inline-flex items-center gap-1.5 text-sm text-gray-500 hover:text-primary-500 transition-colors mb-3">
        <i class="fa-solid fa-arrow-left text-xs"></i> Dashboard
      </a>
      <h1 class="text-2xl font-bold text-gray-900">Notificação em massa</h1>
      <p class="text-sm text-gray-500 mt-1">Envie notificações por região: escolha o centro (lat/lng), o raio em km e o conteúdo. Apenas usuários com localização ativa no app receberão.</p>
    </div>

    <form action="<%= adminPath %>/notificacoes/enviar" method="POST" class="space-y-6 bg-white rounded-xl shadow-sm border border-gray-100 p-6">

      <!-- Região -->
      <div class="space-y-4">
        <h2 class="text-lg font-semibold text-gray-900 flex items-center gap-2">
          <i class="fa-solid fa-map-location-dot text-primary-500"></i>
          Região
        </h2>
        <p class="text-sm text-gray-500">Clique no mapa para definir o centro da região; o círculo mostra o raio em km.</p>
        <div id="mapaRegiao"></div>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
          <div>
            <label for="latitude" class="block text-sm font-medium text-gray-700 mb-1">Latitude (centro)</label>
            <input type="text" id="latitude" name="latitude" value="-23.5505" placeholder="-23.5505"
                   class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-sm">
          </div>
          <div>
            <label for="longitude" class="block text-sm font-medium text-gray-700 mb-1">Longitude (centro)</label>
            <input type="text" id="longitude" name="longitude" value="-46.6333" placeholder="-46.6333"
                   class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-sm">
          </div>
          <div>
            <label for="raio_km" class="block text-sm font-medium text-gray-700 mb-1">Raio (km)</label>
            <input type="number" id="raio_km" name="raio_km" value="10" min="0.1" step="0.5" placeholder="10"
                   class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-sm">
          </div>
        </div>
        <div class="flex items-center gap-3">
          <button type="button" id="btnPreview" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg text-sm font-medium bg-gray-100 text-gray-700 hover:bg-gray-200 transition-colors">
            <i class="fa-solid fa-users"></i>
            Ver quantos usuários receberão
          </button>
          <span id="previewResult" class="text-sm text-gray-500 hidden"></span>
        </div>
      </div>

      <!-- Conteúdo -->
      <div class="space-y-4 border-t border-gray-100 pt-6">
        <h2 class="text-lg font-semibold text-gray-900 flex items-center gap-2">
          <i class="fa-solid fa-bell text-primary-500"></i>
          Conteúdo da notificação
        </h2>
        <div>
          <label for="titulo" class="block text-sm font-medium text-gray-700 mb-1">Título (push)</label>
          <input type="text" id="titulo" name="titulo" value="AIRPET" placeholder="AIRPET"
                 class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-sm">
        </div>
        <div>
          <label for="mensagem" class="block text-sm font-medium text-gray-700 mb-1">Mensagem <span class="text-red-500">*</span></label>
          <textarea id="mensagem" name="mensagem" rows="4" required placeholder="Digite a mensagem que será enviada..."
                    class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-sm"></textarea>
        </div>
        <div>
          <label for="link" class="block text-sm font-medium text-gray-700 mb-1">Link (opcional)</label>
          <input type="text" id="link" name="link" placeholder="/mapa ou https://..."
                 class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-sm">
        </div>
      </div>

      <div class="flex justify-end gap-3 pt-2">
        <a href="<%= adminPath %>" class="px-4 py-2.5 rounded-lg text-sm font-medium text-gray-600 hover:bg-gray-100 transition-colors">Cancelar</a>
        <button type="submit" id="btnEnviar" class="inline-flex items-center gap-2 px-6 py-2.5 bg-primary-500 hover:bg-primary-600 text-white text-sm font-semibold rounded-lg shadow-sm hover:shadow transition-all">
          <i class="fa-solid fa-paper-plane"></i>
          Enviar notificação em massa
        </button>
      </div>
    </form>

  </div>
</main>

<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
<script>
(function () {
  var latInput = document.getElementById('latitude');
  var lngInput = document.getElementById('longitude');
  var raioInput = document.getElementById('raio_km');
  var btnPreview = document.getElementById('btnPreview');
  var previewResult = document.getElementById('previewResult');

  function parseCenter() {
    var lat = parseFloat(latInput && latInput.value);
    var lng = parseFloat(lngInput && lngInput.value);
    if (isNaN(lat) || isNaN(lng)) return null;
    return L.latLng(lat, lng);
  }

  function parseRaioKm() {
    var r = parseFloat(raioInput && raioInput.value);
    return (isNaN(r) || r <= 0) ? 10 : Math.min(500, r);
  }

  var defaultCenter = [-23.5505, -46.6333];
  var map = L.map('mapaRegiao', { zoomControl: true, tap: true }).setView(defaultCenter, 11);
  L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', { attribution: '&copy; OSM', maxZoom: 19 }).addTo(map);

  setTimeout(function () { map.invalidateSize(); }, 300);
  window.addEventListener('resize', function () { map.invalidateSize(); });

  var centerMarker = null;
  var radiusCircle = null;

  function atualizarDoMapa(latlng) {
    if (!latInput || !lngInput) return;
    latInput.value = latlng.lat.toFixed(6);
    lngInput.value = latlng.lng.toFixed(6);
    if (centerMarker) {
      centerMarker.setLatLng(latlng);
    } else {
      centerMarker = L.marker(latlng, { draggable: true }).addTo(map).bindPopup('Centro da região');
      centerMarker.on('dragend', function (ev) { atualizarDoMapa(ev.target.getLatLng()); });
    }
    desenharCirculo();
  }

  function desenharCirculo() {
    var center = parseCenter();
    if (!center) return;
    var raioKm = parseRaioKm();
    if (raioInput) raioInput.value = raioKm;
    var radiusM = raioKm * 1000;
    if (radiusCircle) map.removeLayer(radiusCircle);
    radiusCircle = L.circle(center, {
      radius: radiusM,
      color: '#ec5a1c',
      fillColor: '#ec5a1c',
      fillOpacity: 0.2,
      weight: 2
    }).addTo(map);
  }

  function atualizarDoRaio() {
    var raioKm = parseRaioKm();
    if (raioInput) raioInput.value = raioKm;
    desenharCirculo();
  }

  function atualizarDoInputs() {
    var center = parseCenter();
    if (!center) return;
    if (centerMarker) {
      centerMarker.setLatLng(center);
    } else {
      centerMarker = L.marker(center, { draggable: true }).addTo(map).bindPopup('Centro da região');
      centerMarker.on('dragend', function (ev) { atualizarDoMapa(ev.target.getLatLng()); });
    }
    desenharCirculo();
    map.setView(center, map.getZoom());
  }

  map.on('click', function (e) { atualizarDoMapa(e.latlng); });

  if (raioInput) {
    raioInput.addEventListener('input', atualizarDoRaio);
    raioInput.addEventListener('change', atualizarDoRaio);
  }
  if (latInput) { latInput.addEventListener('blur', atualizarDoInputs); latInput.addEventListener('change', atualizarDoInputs); }
  if (lngInput) { lngInput.addEventListener('blur', atualizarDoInputs); lngInput.addEventListener('change', atualizarDoInputs); }

  var initialCenter = parseCenter();
  if (initialCenter) {
    map.setView(initialCenter, 11);
    atualizarDoInputs();
  } else {
    atualizarDoMapa(L.latLng(defaultCenter[0], defaultCenter[1]));
  }

  if (btnPreview && previewResult) {
    btnPreview.addEventListener('click', function () {
      var lat = parseFloat(latInput && latInput.value);
      var lng = parseFloat(lngInput && lngInput.value);
      var raio = parseFloat(raioInput && raioInput.value);
      if (isNaN(lat) || isNaN(lng) || isNaN(raio) || raio <= 0) {
        previewResult.textContent = 'Preencha latitude, longitude e raio válidos.';
        previewResult.classList.remove('hidden');
        return;
      }
      previewResult.textContent = 'Consultando...';
      previewResult.classList.remove('hidden');
      var params = new URLSearchParams({ lat: lat, lng: lng, raio_km: raio });
      fetch('<%= adminPath %>/notificacoes/enviar/preview?' + params.toString(), { credentials: 'same-origin' })
        .then(function (r) { return r.json(); })
        .then(function (data) {
          if (data.sucesso) {
            previewResult.textContent = data.total + ' usuário(s) na região com localização ativa.';
          } else {
            previewResult.textContent = data.mensagem || 'Erro ao consultar.';
          }
        })
        .catch(function () {
          previewResult.textContent = 'Erro de conexão.';
        });
    });
  }
})();
</script>

<%- include('../partials/admin-footer') %>
