<% locals.titulo = titulo %>
<%- include('../partials/admin-layout') %>
<%
function fmtData(d) {
  if (!d) return '—';
  try { return new Date(d).toLocaleString('pt-BR'); } catch (_) { return '—'; }
}
function statusPetClass(s) {
  if (s === 'perdido') return 'bg-red-100 text-red-700';
  if (s === 'seguro') return 'bg-emerald-100 text-emerald-700';
  return 'bg-gray-100 text-gray-600';
}
function statusAlertaClass(s) {
  if (s === 'pendente') return 'bg-yellow-100 text-yellow-700';
  if (s === 'aprovado') return 'bg-red-100 text-red-700';
  if (s === 'resolvido') return 'bg-emerald-100 text-emerald-700';
  return 'bg-gray-100 text-gray-600';
}
var fotoPet = pet.foto || pet.foto_url || '';
%>

<main class="flex-1">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 space-y-6">

    <div class="rounded-xl border border-primary-200 bg-primary-50/80 px-4 py-3 text-sm text-primary-900 flex items-start gap-3">
      <i class="fa-solid fa-circle-info text-primary-600 mt-0.5"></i>
      <span>Esta é a ficha administrativa do pet: aqui você vê <strong>alertas</strong>, <strong>leituras NFC</strong> e botões para abrir cada ponto no <strong>Google Maps</strong>.</span>
    </div>

    <header class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4">
      <div>
        <a href="<%= adminPath %>/pets" class="inline-flex items-center gap-1 text-sm text-gray-500 hover:text-primary-500 transition-colors mb-2">
          <i class="fa-solid fa-arrow-left text-xs"></i> Todos os pets
        </a>
        <div class="flex items-center gap-4">
          <% if (fotoPet) { %>
            <img src="<%= fotoPet %>" alt="" class="w-16 h-16 rounded-2xl object-cover border border-gray-100 shadow-sm">
          <% } else { %>
            <span class="w-16 h-16 rounded-2xl bg-orange-50 text-orange-400 flex items-center justify-center text-2xl border border-orange-100">
              <i class="fa-solid fa-paw"></i>
            </span>
          <% } %>
          <div>
            <h1 class="text-2xl font-bold text-gray-900"><%= pet.nome %></h1>
            <p class="text-sm text-gray-500 mt-0.5">
              ID <span class="font-mono text-xs"><%= pet.id %></span>
              <% if (pet.slug) { %>
                · <a href="/p/<%= pet.slug %>" target="_blank" rel="noopener" class="text-primary-600 hover:underline">Perfil público</a>
              <% } %>
            </p>
          </div>
        </div>
      </div>
      <span class="inline-flex items-center self-start px-3 py-1 rounded-full text-sm font-semibold <%= statusPetClass(pet.status) %>">
        <%= pet.status || 'ativo' %>
      </span>
    </header>

    <section class="grid grid-cols-1 md:grid-cols-4 gap-4">
      <article class="bg-white rounded-xl shadow-sm border border-gray-100 p-4">
        <p class="text-xs text-gray-500 font-semibold uppercase tracking-wide">Tipo / Raça</p>
        <p class="mt-1 text-sm font-bold text-gray-900 capitalize"><%= pet.tipo || '—' %> · <%= pet.raca || '—' %></p>
      </article>
      <article class="bg-white rounded-xl shadow-sm border border-gray-100 p-4">
        <p class="text-xs text-gray-500 font-semibold uppercase tracking-wide">Tutor</p>
        <p class="mt-1 text-sm font-bold text-gray-900"><%= pet.dono_nome || '—' %></p>
        <% if (dono && dono.email) { %>
          <p class="text-xs text-gray-500 mt-0.5 truncate"><%= dono.email %></p>
        <% } %>
      </article>
      <article class="bg-white rounded-xl shadow-sm border border-gray-100 p-4">
        <p class="text-xs text-gray-500 font-semibold uppercase tracking-wide">Alertas</p>
        <p class="mt-1 text-lg font-bold text-gray-900"><%= alertas.length %></p>
        <% if (alertaAtivo) { %>
          <p class="text-xs text-red-600 font-semibold mt-0.5">Ativo #<%= alertaAtivo.id %></p>
        <% } %>
      </article>
      <article class="bg-white rounded-xl shadow-sm border border-gray-100 p-4">
        <p class="text-xs text-gray-500 font-semibold uppercase tracking-wide">Leituras NFC</p>
        <p class="mt-1 text-lg font-bold text-gray-900"><%= scans.length %></p>
      </article>
    </section>

    <section class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
      <div class="px-5 py-4 border-b border-gray-100 flex items-center justify-between">
        <h2 class="text-base font-semibold text-gray-900">
          <i class="fa-solid fa-triangle-exclamation text-red-500 mr-1"></i> Alertas de pet perdido
        </h2>
        <a href="<%= adminPath %>/pets-perdidos" class="text-xs font-semibold text-primary-600 hover:text-primary-800">Ver todos</a>
      </div>
      <% if (alertas.length === 0) { %>
        <p class="px-5 py-8 text-sm text-gray-400 text-center">Nenhum alerta registrado para este pet.</p>
      <% } else { %>
        <div class="divide-y divide-gray-100">
          <% alertas.forEach(function(a) { %>
            <div class="px-5 py-4">
              <div class="flex flex-wrap items-start justify-between gap-3 mb-2">
                <div>
                  <span class="text-sm font-bold text-gray-900">Alerta #<%= a.id %></span>
                  <span class="ml-2 inline-flex px-2 py-0.5 rounded-full text-xs font-semibold <%= statusAlertaClass(a.status) %>"><%= a.status %></span>
                  <% if (a.nivel_alerta) { %>
                    <span class="ml-1 text-xs text-gray-500">nível <%= a.nivel_alerta %> · ciclo <%= Number(a.ciclo_alerta || 1) %></span>
                  <% } %>
                </div>
                <span class="text-xs text-gray-500"><%= fmtData(a.data || a.criado_em) %></span>
              </div>
              <% if (a.descricao) { %>
                <p class="text-sm text-gray-600 mb-2 whitespace-pre-wrap line-clamp-3"><%= a.descricao %></p>
              <% } %>
              <div class="flex flex-wrap items-center gap-3 text-sm">
                <span class="text-gray-700">
                  <i class="fa-solid fa-location-dot text-primary-500 mr-1"></i>
                  <% if (a.hasMaps) { %>
                    <a href="<%= a.mapsUrl %>" target="_blank" rel="noopener" class="font-semibold text-primary-700 hover:underline"><%= a.locLabel %></a>
                  <% } else { %>
                    <%= a.locLabel %>
                  <% } %>
                </span>
                <% if (a.hasMaps) { %>
                  <a href="<%= a.mapsUrl %>" target="_blank" rel="noopener"
                     class="inline-flex items-center gap-1 text-xs font-bold text-primary-700 bg-primary-50 border border-primary-200 px-2.5 py-1 rounded-lg hover:bg-primary-100">
                    <i class="fa-solid fa-map-location-dot"></i> Google Maps
                  </a>
                  <a href="<%= a.mapsDirectionsUrl %>" target="_blank" rel="noopener"
                     class="inline-flex items-center gap-1 text-xs font-bold text-white bg-primary-600 px-2.5 py-1 rounded-lg hover:bg-primary-700">
                    <i class="fa-solid fa-diamond-turn-right"></i> Como chegar
                  </a>
                <% } %>
                <% if (a.status === 'aprovado') { %>
                  <a href="/alerta/<%= a.id %>" target="_blank" rel="noopener" class="text-xs font-semibold text-gray-600 hover:text-primary-600">
                    <i class="fa-solid fa-eye"></i> Página pública
                  </a>
                <% } %>
              </div>
              <div class="flex flex-wrap gap-2 mt-3">
                <% if (a.status === 'pendente') { %>
                  <form action="<%= adminPath %>/pets-perdidos/<%= a.id %>/aprovar" method="POST">
                    <button type="submit" class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-xs font-semibold text-white bg-red-500 hover:bg-red-600">
                      <i class="fa-solid fa-bullhorn"></i> Aprovar
                    </button>
                  </form>
                <% } else if (a.status === 'aprovado') { %>
                  <form action="<%= adminPath %>/pets-perdidos/<%= a.id %>/escalar" method="POST">
                    <button type="submit" class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-xs font-semibold text-white bg-primary-500 hover:bg-primary-600">
                      <i class="fa-solid fa-arrow-up-right-dots"></i> Escalar
                    </button>
                  </form>
                <% } %>
              </div>
            </div>
          <% }); %>
        </div>
      <% } %>
    </section>

    <section class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
      <div class="px-5 py-4 border-b border-gray-100">
        <h2 class="text-base font-semibold text-gray-900">
          <i class="fa-solid fa-wifi text-orange-500 mr-1"></i> Leituras da tag NFC
        </h2>
        <p class="text-xs text-gray-500 mt-1">Histórico com localização clicável quando há GPS.</p>
      </div>
      <% if (scans.length === 0) { %>
        <p class="px-5 py-8 text-sm text-gray-400 text-center">Nenhuma leitura registrada.</p>
      <% } else { %>
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead>
              <tr class="bg-gray-50 border-b border-gray-200 text-left">
                <th class="px-4 py-3 font-semibold text-gray-600">Data</th>
                <th class="px-4 py-3 font-semibold text-gray-600">Tag</th>
                <th class="px-4 py-3 font-semibold text-gray-600">Local</th>
                <th class="px-4 py-3 font-semibold text-gray-600">Mapa</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
              <% scans.forEach(function(s) { %>
                <tr class="hover:bg-gray-50">
                  <td class="px-4 py-3 text-gray-600 text-xs whitespace-nowrap"><%= fmtData(s.data) %></td>
                  <td class="px-4 py-3 font-mono text-xs text-gray-500"><%= s.tag_code || '—' %></td>
                  <td class="px-4 py-3 font-medium text-gray-900">
                    <% if (s.hasMaps) { %>
                      <a href="<%= s.mapsUrl %>" target="_blank" rel="noopener" class="text-primary-700 hover:underline"><%= s.locLabel %></a>
                    <% } else { %>
                      <span class="text-gray-500"><%= s.locLabel %></span>
                    <% } %>
                  </td>
                  <td class="px-4 py-3">
                    <% if (s.hasMaps) { %>
                      <a href="<%= s.mapsUrl %>" target="_blank" rel="noopener"
                         class="inline-flex items-center gap-1 text-xs font-bold text-primary-700 hover:text-primary-900">
                        <i class="fa-solid fa-map-location-dot"></i> Abrir
                      </a>
                    <% } else { %>
                      <span class="text-gray-300 text-xs">—</span>
                    <% } %>
                  </td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      <% } %>
    </section>

  </div>
</main>

<%- include('../partials/admin-footer') %>
