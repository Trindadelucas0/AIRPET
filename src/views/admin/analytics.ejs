<% locals.titulo = 'Analytics avançado' %>
<%- include('../partials/admin-layout') %>

<main class="flex-1">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 space-y-6">
    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-4">
      <div>
        <h1 class="text-2xl font-bold text-gray-900">Analytics da Rede</h1>
        <p class="text-sm text-gray-500 mt-1">Visão executiva de crescimento, engajamento e risco.</p>
      </div>
      <form method="GET" class="flex items-end gap-2">
        <div>
          <label class="block text-xs text-gray-500 mb-1">Período</label>
          <select name="periodo" class="border border-gray-300 rounded-lg text-sm px-3 py-2 bg-white">
            <option value="today" <%= periodoGlobal === 'today' ? 'selected' : '' %>>Hoje</option>
            <option value="week" <%= periodoGlobal === 'week' ? 'selected' : '' %>>Últimos 7 dias</option>
            <option value="month" <%= periodoGlobal === 'month' ? 'selected' : '' %>>Últimos 30 dias</option>
          </select>
        </div>
        <button type="submit" class="inline-flex items-center gap-2 px-3 py-2 rounded-lg bg-gray-900 text-white text-sm font-medium">
          <i class="fa-solid fa-rotate-right"></i> Atualizar
        </button>
      </form>
    </div>

    <section class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-3">
      <div class="bg-white border rounded-xl p-4"><p class="text-xs text-gray-500 uppercase">Posts vistos</p><p class="text-2xl font-semibold"><%= (postsVistos || []).length %></p></div>
      <div class="bg-white border rounded-xl p-4"><p class="text-xs text-gray-500 uppercase">Risco</p><p class="text-2xl font-semibold text-red-600"><%= (perigosos.riscos || []).length %></p></div>
      <div class="bg-white border rounded-xl p-4"><p class="text-xs text-gray-500 uppercase">Viral</p><p class="text-2xl font-semibold"><%= (viralHoje.posts || []).length %></p></div>
      <div class="bg-white border rounded-xl p-4"><p class="text-xs text-gray-500 uppercase">Raças</p><p class="text-2xl font-semibold"><%= (trendingRacas.racas || []).length %></p></div>
      <div class="bg-white border rounded-xl p-4"><p class="text-xs text-gray-500 uppercase">Orgânico</p><p class="text-2xl font-semibold"><%= Number((resumoViews && resumoViews.total_organico) || 0) %></p></div>
      <div class="bg-white border rounded-xl p-4"><p class="text-xs text-gray-500 uppercase">Boost</p><p class="text-2xl font-semibold"><%= Number((resumoViews && resumoViews.total_boost_janela_ativa) || 0) + Number((resumoViews && resumoViews.total_boost_card_patrocinado) || 0) %></p></div>
    </section>

    <section class="grid grid-cols-1 lg:grid-cols-2 gap-6">
      <div class="bg-white border rounded-xl p-5">
        <h2 class="text-lg font-semibold mb-3"><i class="fa-solid fa-chart-line text-indigo-500 mr-2"></i>Crescimento (30 dias)</h2>
        <div class="relative min-h-[260px]"><canvas id="growthChart" class="w-full h-full"></canvas></div>
      </div>
      <div class="bg-white border rounded-xl p-5">
        <h2 class="text-lg font-semibold mb-3"><i class="fa-solid fa-fire text-orange-500 mr-2"></i>Conteúdo viral</h2>
        <div class="overflow-x-auto">
          <table class="min-w-full text-sm">
            <thead><tr class="text-left text-gray-500 border-b"><th class="py-2">#</th><th>Post</th><th>Autor</th><th>Score</th></tr></thead>
            <tbody>
              <% (viralHoje.posts || []).slice(0, 8).forEach(function(p, idx) { %>
                <tr class="border-b border-gray-50">
                  <td class="py-2">#<%= idx + 1 %></td>
                  <td>Post <%= p.id %></td>
                  <td>Usuário <%= p.usuario_id %></td>
                  <td><%= p.engagement_score || p.engagement_score_sum || 0 %></td>
                </tr>
              <% }) %>
              <% if (!(viralHoje.posts || []).length) { %><tr><td colspan="4" class="py-3 text-xs text-gray-400">Sem dados.</td></tr><% } %>
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <section class="bg-white border rounded-xl p-5">
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-lg font-semibold"><i class="fa-solid fa-crown text-yellow-500 mr-2"></i>Usuários mais influentes</h2>
        <span class="text-xs text-gray-500">Seguidores · Curtidas · Comentários · Views</span>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 text-sm">
        <div>
          <h3 class="font-semibold text-gray-700 mb-2">Seguidores</h3>
          <ul class="space-y-2">
            <% (influentes.seguidores || []).slice(0, 6).forEach(function(r, idx) { %><li class="flex justify-between"><span>#<%= idx + 1 %> <%= r.nome || ('Usuário ' + r.usuario_id) %></span><strong><%= r.total %></strong></li><% }) %>
          </ul>
        </div>
        <div>
          <h3 class="font-semibold text-gray-700 mb-2">Curtidas</h3>
          <ul class="space-y-2">
            <% (influentes.likes || []).slice(0, 6).forEach(function(r, idx) { %><li class="flex justify-between"><span>#<%= idx + 1 %> <%= r.nome || ('Usuário ' + r.usuario_id) %></span><strong><%= r.total %></strong></li><% }) %>
          </ul>
        </div>
        <div>
          <h3 class="font-semibold text-gray-700 mb-2">Comentários</h3>
          <ul class="space-y-2">
            <% (influentes.comentarios || []).slice(0, 6).forEach(function(r, idx) { %><li class="flex justify-between"><span>#<%= idx + 1 %> <%= r.nome || ('Usuário ' + r.usuario_id) %></span><strong><%= r.total %></strong></li><% }) %>
          </ul>
        </div>
        <div>
          <h3 class="font-semibold text-gray-700 mb-2">Views</h3>
          <ul class="space-y-2">
            <% (influentes.views || []).slice(0, 6).forEach(function(r, idx) { %><li class="flex justify-between"><span>#<%= idx + 1 %> <%= r.nome || ('Usuário ' + r.usuario_id) %></span><strong><%= r.views %></strong></li><% }) %>
          </ul>
        </div>
      </div>
    </section>

    <section class="grid grid-cols-1 lg:grid-cols-2 gap-6">
      <div class="bg-white border rounded-xl p-5">
        <h2 class="text-lg font-semibold mb-3"><i class="fa-solid fa-triangle-exclamation text-red-500 mr-2"></i>Usuários com risco</h2>
        <div class="overflow-x-auto">
          <table class="min-w-full text-sm">
            <thead><tr class="text-left text-gray-500 border-b"><th class="py-2">Usuário</th><th>Reports</th><th>Blocks</th><th>Spam</th></tr></thead>
            <tbody>
              <% const denunciasMap = new Map(); (perigosos.denuncias || []).forEach(d => denunciasMap.set(d.usuario_id, d.total_reports)); %>
              <% const bloqueiosMap = new Map(); (perigosos.bloqueios || []).forEach(b => bloqueiosMap.set(b.usuario_id, b.total_blocks)); %>
              <% (perigosos.riscos || []).forEach(function(r) { %>
                <tr class="border-b border-gray-50">
                  <td class="py-2">Usuário <%= r.user_id %></td>
                  <td><%= denunciasMap.get(r.user_id) || 0 %></td>
                  <td><%= bloqueiosMap.get(r.user_id) || 0 %></td>
                  <td><%= r.spam_probability %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
      <div class="bg-white border rounded-xl p-5">
        <h2 class="text-lg font-semibold mb-3"><i class="fa-solid fa-eye text-purple-500 mr-2"></i>Posts mais visualizados</h2>
        <div class="overflow-x-auto">
          <table class="min-w-full text-sm">
            <thead><tr class="text-left text-gray-500 border-b"><th class="py-2">#</th><th>Post</th><th>Views</th><th>Únicos</th></tr></thead>
            <tbody>
              <% (postsVistos || []).slice(0, 8).forEach(function(p, idx) { %>
                <tr class="border-b border-gray-50"><td class="py-2">#<%= idx + 1 %></td><td>Post <%= p.post_id %></td><td><%= p.total_views %></td><td><%= p.usuarios_unicos %></td></tr>
              <% }) %>
              <% if (!(postsVistos || []).length) { %><tr><td colspan="4" class="py-3 text-xs text-gray-400">Sem visualizações no período.</td></tr><% } %>
            </tbody>
          </table>
        </div>
      </div>
    </section>
  </div>
</main>

<script>window.analyticsTimeline = <%- JSON.stringify(timeline || []) %>;</script>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
  (function () {
    if (!window.analyticsTimeline || !window.analyticsTimeline.length) return;
    var canvas = document.getElementById("growthChart");
    if (!canvas || !window.Chart) return;
    var labels = window.analyticsTimeline.map(function (p) { return new Date(p.day).toLocaleDateString("pt-BR"); });
    var novosUsuarios = window.analyticsTimeline.map(function (p) { return p.novos_usuarios || 0; });
    var novosPosts = window.analyticsTimeline.map(function (p) { return p.novos_posts || 0; });
    new Chart(canvas.getContext("2d"), {
      type: "line",
      data: {
        labels: labels,
        datasets: [
          { label: "Novos usuários", data: novosUsuarios, borderColor: "#1a1917", backgroundColor: "rgba(26,25,23,0.05)", borderWidth: 1.5, tension: 0.35, pointRadius: 0, fill: true },
          { label: "Novos posts", data: novosPosts, borderColor: "#d97706", backgroundColor: "rgba(217,119,6,0.08)", borderWidth: 1.5, tension: 0.35, pointRadius: 0, fill: true }
        ]
      },
      options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { position: "bottom" } }, scales: { y: { beginAtZero: true, ticks: { precision: 0 } } } }
    });
  })();
</script>

<%- include('../partials/admin-footer') %>

