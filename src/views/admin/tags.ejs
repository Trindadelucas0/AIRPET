<% locals.titulo = 'Gerenciar Tags' %>
<%- include('../partials/admin-layout') %>

<main class="flex-1">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

    <div class="mb-6">
      <a href="<%= adminPath %>" class="inline-flex items-center gap-1 text-sm text-gray-500 hover:text-primary-500 transition-colors mb-2">
        <i class="fa-solid fa-arrow-left text-xs"></i> Dashboard
      </a>
      <div class="flex items-center justify-between">
        <h1 class="text-2xl font-bold text-gray-900">Gerenciar Tags</h1>
        <a href="/tags/admin/lotes" class="text-sm text-primary-500 hover:text-primary-600 font-medium">
          <i class="fa-solid fa-box mr-1"></i> Ver Lotes
        </a>
      </div>
    </div>

    <% const inv = inventoryResumo || {}; const s = inv.porStatus || {}; %>
    <section class="grid grid-cols-2 md:grid-cols-6 gap-3 mb-6">
      <article class="card"><p class="text-xs text-gray-500">Stock</p><p class="text-xl font-bold"><%= Number(s.stock || 0) %></p></article>
      <article class="card"><p class="text-xs text-gray-500">Reserved</p><p class="text-xl font-bold text-blue-600"><%= Number(s.reserved || 0) %></p></article>
      <article class="card"><p class="text-xs text-gray-500">Sent</p><p class="text-xl font-bold text-yellow-600"><%= Number(s.sent || 0) %></p></article>
      <article class="card"><p class="text-xs text-gray-500">Active</p><p class="text-xl font-bold text-emerald-600"><%= Number(s.active || 0) %></p></article>
      <article class="card"><p class="text-xs text-gray-500">Blocked</p><p class="text-xl font-bold text-red-600"><%= Number(s.blocked || 0) %></p></article>
      <article class="card"><p class="text-xs text-gray-500">Vendidas</p><p class="text-xl font-bold"><%= Number(inv.vendidas || 0) %></p></article>
    </section>

    <!-- Gerar Novo Lote -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 mb-6">
      <h2 class="text-base font-semibold text-gray-900 mb-4">
        <i class="fa-solid fa-plus-circle text-primary-500 mr-1"></i> Gerar Novo Lote
      </h2>
      <form action="/tags/admin/gerar" method="POST" class="grid grid-cols-1 sm:grid-cols-4 gap-4 items-end">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Quantidade</label>
          <input type="number" name="quantidade" min="1" max="1000" required placeholder="Ex: 50"
                 class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-primary-500 focus:border-primary-500 outline-none">
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Fabricante</label>
          <input type="text" name="fabricante" placeholder="Nome do fabricante"
                 class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-primary-500 focus:border-primary-500 outline-none">
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Observações</label>
          <input type="text" name="observacoes" placeholder="Observações opcionais"
                 class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-primary-500 focus:border-primary-500 outline-none">
        </div>
        <button type="submit"
                class="px-4 py-2 bg-primary-500 hover:bg-primary-600 text-white text-sm font-semibold rounded-lg transition-colors">
          <i class="fa-solid fa-wand-magic-sparkles mr-1"></i> Gerar
        </button>
      </form>
    </div>

    <section class="bg-white rounded-xl shadow-sm border border-gray-100 p-4 mb-6">
      <h2 class="text-sm font-semibold text-gray-900 mb-3">Últimos scans de tag</h2>
      <div class="overflow-x-auto">
        <table class="w-full text-xs">
          <thead>
            <tr class="border-b border-gray-100 text-gray-500">
              <th class="text-left py-2">Tag</th>
              <th class="text-left py-2">Pet</th>
              <th class="text-left py-2">Usuário</th>
              <th class="text-left py-2">Cidade</th>
              <th class="text-left py-2">Data</th>
            </tr>
          </thead>
          <tbody>
            <% if (!(ultimosScans || []).length) { %>
              <tr><td colspan="5" class="py-3 text-gray-400">Nenhum scan recente.</td></tr>
            <% } %>
            <% (ultimosScans || []).forEach(function(scan) { %>
              <tr class="border-b border-gray-50">
                <td class="py-2 font-mono"><%= scan.tag_code %></td>
                <td class="py-2"><%= scan.pet_nome || '-' %></td>
                <td class="py-2"><%= scan.usuario_nome || '-' %></td>
                <td class="py-2"><%= scan.cidade || '-' %></td>
                <td class="py-2"><%= scan.data ? new Date(scan.data).toLocaleString('pt-BR') : '-' %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </section>

    <!-- Filter Tabs -->
    <div class="flex flex-wrap gap-2 mb-6">
      <%
        var filtros = [
          { val: '', label: 'Todas' },
          { val: 'stock', label: 'Stock' },
          { val: 'reserved', label: 'Reserved' },
          { val: 'sent', label: 'Sent' },
          { val: 'active', label: 'Active' },
          { val: 'blocked', label: 'Blocked' }
        ];
        var currentFilter = typeof filtroAtual !== 'undefined' ? (filtroAtual === 'todos' ? '' : filtroAtual) : '';
      %>
      <% filtros.forEach(function(f) { %>
        <a href="/tags/admin/lista<%= f.val ? '?status=' + f.val : '' %>"
           class="px-4 py-1.5 rounded-full text-sm font-medium transition-colors
             <%= currentFilter === f.val ? 'bg-primary-500 text-white' : 'bg-gray-100 text-gray-600 hover:bg-gray-200' %>">
          <%= f.label %>
        </a>
      <% }); %>
    </div>

    <!-- Tags Table -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="bg-gray-50 border-b border-gray-200">
              <th class="px-4 py-3 text-left font-semibold text-gray-600">Tag Code</th>
              <th class="px-4 py-3 text-left font-semibold text-gray-600">URL de Scan</th>
              <th class="px-4 py-3 text-left font-semibold text-gray-600">Activation Code</th>
              <th class="px-4 py-3 text-left font-semibold text-gray-600">Status</th>
              <th class="px-4 py-3 text-left font-semibold text-gray-600">Usuário</th>
              <th class="px-4 py-3 text-left font-semibold text-gray-600">Pet</th>
              <th class="px-4 py-3 text-left font-semibold text-gray-600">Data</th>
              <th class="px-4 py-3 text-left font-semibold text-gray-600">Ações</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            <% tags.forEach(function(t) { %>
              <%
                var statusBadge = 'bg-gray-100 text-gray-600';
                if (t.status === 'stock') statusBadge = 'bg-slate-100 text-slate-600';
                else if (t.status === 'reserved') statusBadge = 'bg-blue-100 text-blue-600';
                else if (t.status === 'sent') statusBadge = 'bg-yellow-100 text-yellow-700';
                else if (t.status === 'active') statusBadge = 'bg-emerald-100 text-emerald-700';
                else if (t.status === 'blocked') statusBadge = 'bg-red-100 text-red-700';
              %>
              <tr class="hover:bg-gray-50 transition-colors">
                <td class="px-4 py-3 font-mono text-xs text-gray-700"><%= t.tag_code %></td>
                <td class="px-4 py-3">
                  <div class="flex items-center gap-1">
                    <a href="<%= BASE_URL %>/tag/<%= t.tag_code %>" target="_blank"
                       class="font-mono text-[10px] text-blue-600 hover:text-blue-800 underline truncate max-w-[160px]"
                       title="<%= BASE_URL %>/tag/<%= t.tag_code %>"><%= BASE_URL %>/tag/<%= t.tag_code %></a>
                    <button onclick="copiarCodigo('<%= BASE_URL %>/tag/<%= t.tag_code %>', this)"
                            class="p-0.5 text-gray-400 hover:text-blue-500 rounded transition-colors flex-shrink-0"
                            title="Copiar URL">
                      <i class="fa-regular fa-copy text-[10px]"></i>
                    </button>
                  </div>
                </td>
                <td class="px-4 py-3">
                  <div class="flex items-center gap-1.5">
                    <span class="font-mono text-xs font-semibold text-primary-600 bg-primary-50 px-2 py-0.5 rounded border border-primary-100"
                          id="act-<%= t.id %>"><%= t.activation_code || '—' %></span>
                    <% if (t.activation_code) { %>
                      <button onclick="copiarCodigo('<%= t.activation_code %>', this)"
                              class="p-1 text-gray-400 hover:text-primary-500 rounded transition-colors"
                              title="Copiar código de ativação">
                        <i class="fa-regular fa-copy text-[10px]"></i>
                      </button>
                    <% } %>
                  </div>
                </td>
                <td class="px-4 py-3">
                  <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-semibold <%= statusBadge %>">
                    <%= t.status %>
                  </span>
                </td>
                <td class="px-4 py-3 text-gray-600 text-xs"><%= t.usuario_email || '—' %></td>
                <td class="px-4 py-3 text-gray-600 text-xs"><%= t.pet_nome || '—' %></td>
                <td class="px-4 py-3 text-gray-500 text-xs"><%= t.data_criacao ? new Date(t.data_criacao).toLocaleDateString('pt-BR') : '—' %></td>
                <td class="px-4 py-3">
                  <% if (t.status === 'stock') { %>
                    <form action="/tags/admin/<%= t.id %>/reservar" method="POST" class="flex items-center gap-2">
                      <input type="email" name="email" required placeholder="email@usuario.com"
                             class="w-36 px-2 py-1 border border-gray-300 rounded text-xs focus:ring-1 focus:ring-primary-500 outline-none">
                      <button type="submit" class="px-2 py-1 bg-blue-500 hover:bg-blue-600 text-white text-xs font-semibold rounded transition-colors">
                        Reservar
                      </button>
                    </form>
                  <% } else if (t.status === 'reserved') { %>
                    <form action="/tags/admin/<%= t.id %>/enviar" method="POST" class="inline">
                      <button type="submit" class="px-2 py-1 bg-yellow-500 hover:bg-yellow-600 text-white text-xs font-semibold rounded transition-colors">
                        Marcar Enviada
                      </button>
                    </form>
                  <% } else if (t.status === 'sent') { %>
                    <span class="text-xs text-gray-400 italic">Aguardando ativação</span>
                  <% } else if (t.status === 'active') { %>
                    <form action="/tags/admin/<%= t.id %>/bloquear" method="POST" class="inline">
                      <button type="submit" class="px-2 py-1 bg-red-500 hover:bg-red-600 text-white text-xs font-semibold rounded transition-colors">
                        Bloquear
                      </button>
                    </form>
                  <% } else if (t.status === 'blocked') { %>
                    <form action="/tags/admin/<%= t.id %>/desbloquear" method="POST" class="inline">
                      <button type="submit" class="px-2 py-1 bg-emerald-500 hover:bg-emerald-600 text-white text-xs font-semibold rounded transition-colors">
                        Desbloquear
                      </button>
                    </form>
                  <% } %>
                </td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>

      <% if (tags.length === 0) { %>
        <div class="text-center py-12 text-gray-400">
          <i class="fa-solid fa-tag text-3xl mb-2"></i>
          <p class="text-sm">Nenhuma tag encontrada para este filtro</p>
        </div>
      <% } %>
    </div>

  </div>
</main>

<script>
function copiarCodigo(codigo, btn) {
  navigator.clipboard.writeText(codigo).then(function() {
    var icone = btn.querySelector('i');
    icone.className = 'fa-solid fa-check text-[10px] text-emerald-500';
    setTimeout(function() {
      icone.className = 'fa-regular fa-copy text-[10px]';
    }, 2000);
  });
}
</script>

<%- include('../partials/admin-footer') %>
