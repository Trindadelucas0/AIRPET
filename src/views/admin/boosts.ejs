<% locals.titulo = 'Boosts' %>
<%- include('../partials/admin-layout') %>

<main class="flex-1">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-8 space-y-8">

    <div>
      <h1 class="text-2xl font-bold text-gray-900">Patrocinado de Perfil Pet</h1>
      <p class="text-sm text-gray-500 mt-1">
        Criação guiada de anúncios para perfis pet. O conteúdo aparece no `/feed` e no `/explorar` como card diferenciado com selo de patrocinado.
      </p>
    </div>

    <section class="bg-indigo-50 border border-indigo-100 rounded-xl p-4 text-sm text-indigo-900 space-y-2">
      <p class="font-semibold">Como funciona entrega e engajamento</p>
      <p>Este painel não altera curtidas/comentários reais. O boost apenas aumenta prioridade de exibição do perfil pet durante a janela ativa.</p>
      <p>O card patrocinado é identificado visualmente para transparência e entra de forma adaptativa: mais presença no início do consumo e redução progressiva.</p>
    </section>

    <section class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
      <h2 class="text-lg font-semibold text-gray-900 mb-3 flex items-center gap-2">
        <i class="fa-solid fa-bolt text-yellow-500"></i>
        Criar patrocinado de pet
      </h2>
      <p class="text-xs text-gray-400 mb-4">
        Fluxo: buscar tutor, escolher pet e configurar valor/duração.
      </p>

      <form id="boostForm" method="POST" action="<%= adminPath %>/boosts" class="grid grid-cols-1 md:grid-cols-2 gap-4 text-sm">
        <input type="hidden" name="target_type" value="pet">
        <input type="hidden" name="target_id" id="targetIdInput" value="">
        <input type="hidden" name="selected_user_id" id="selectedUserInput" value="">
        <input type="hidden" name="selected_pet_id" id="selectedPetInput" value="">

        <div class="md:col-span-2">
          <label class="block text-xs font-medium text-gray-600 mb-1">1) Buscar tutor</label>
          <input type="text" id="buscarTutorInput" class="w-full border border-gray-300 rounded-lg px-3 py-2" placeholder="Digite nome do tutor (mín. 2 letras)">
          <div id="usuariosResultado" class="mt-2 border border-gray-100 rounded-lg divide-y divide-gray-100 max-h-56 overflow-y-auto hidden"></div>
          <p class="text-xs text-gray-400 mt-1">Você seleciona o tutor e o sistema já carrega os pets disponíveis.</p>
        </div>

        <div class="md:col-span-2 hidden" id="userSelecionadoCard"></div>

        <div class="md:col-span-2 hidden" id="petsStep">
          <label class="block text-xs font-medium text-gray-600 mb-1">2) Escolher pet alvo</label>
          <div id="petsResultado" class="grid grid-cols-1 md:grid-cols-2 gap-2"></div>
        </div>

        <div class="md:col-span-2 hidden" id="petSelecionadoCard"></div>

        <div>
          <label class="block text-xs font-medium text-gray-600 mb-1">3) Valor do boost (pontos)</label>
          <input type="number" name="boost_value" required min="1" max="1000" class="w-full border border-gray-300 rounded-lg px-3 py-2" placeholder="Ex: 200">
        </div>
        <div>
          <label class="block text-xs font-medium text-gray-600 mb-1">Duração (horas)</label>
          <select name="duracao_horas" class="w-full border border-gray-300 rounded-lg px-3 py-2">
            <option value="2">2 horas</option>
            <option value="6">6 horas</option>
            <option value="12">12 horas</option>
            <option value="24">24 horas</option>
            <option value="48">48 horas</option>
          </select>
        </div>
        <div class="md:col-span-2">
          <label class="block text-xs font-medium text-gray-600 mb-1">Motivo (opcional)</label>
          <textarea name="motivo" rows="2" class="w-full border border-gray-300 rounded-lg px-3 py-2" placeholder="Campanha local, parceria, destaque sazonal etc."></textarea>
          <p class="text-xs text-gray-400 mt-1">Use valores entre 80 e 300 para campanhas normais com duração curta.</p>
        </div>
        <div class="md:col-span-2 flex justify-end">
          <button type="submit" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-primary-500 text-white text-sm font-medium hover:bg-primary-600">
            <i class="fa-solid fa-rocket"></i>
            Aplicar patrocinado
          </button>
        </div>
      </form>
    </section>

    <section class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
      <h2 class="text-lg font-semibold text-gray-900 mb-3 flex items-center gap-2">
        <i class="fa-solid fa-list text-gray-600"></i>
        Patrocinados recentes
      </h2>
      <p class="text-xs text-gray-400 mb-4">
        Patrocinados ativos influenciam a entrega enquanto estiverem dentro da janela entre início e fim.
      </p>
      <div class="overflow-x-auto">
        <table class="min-w-full text-xs md:text-sm">
          <thead>
          <tr class="text-left text-gray-500 border-b border-gray-100">
            <th class="pb-2 font-medium">ID</th>
            <th class="pb-2 font-medium">Alvo pet</th>
            <th class="pb-2 font-medium">Tutor</th>
            <th class="pb-2 font-medium">Valor</th>
            <th class="pb-2 font-medium">Início</th>
            <th class="pb-2 font-medium">Fim</th>
            <th class="pb-2 font-medium">Criado em</th>
            <th class="pb-2 font-medium text-right">Ações</th>
          </tr>
          </thead>
          <tbody>
          <% if (boosts && boosts.length) { %>
            <% boosts.forEach(function(b) { %>
              <tr class="border-b border-gray-50 hover:bg-gray-50/50">
                <td class="py-2 text-gray-700"><%= b.id %></td>
                <td class="py-2 text-gray-600">
                  <div class="flex items-center gap-2">
                    <% if (b.pet_foto) { %>
                      <img src="<%= b.pet_foto %>" alt="" class="w-8 h-8 rounded-full object-cover">
                    <% } %>
                    <div>
                      <p class="text-gray-800"><%= b.pet_nome || ('Pet ' + b.target_id) %></p>
                      <a href="/explorar/pet/<%= b.target_id %>" target="_blank" class="text-primary-600 hover:underline">Ver perfil pet</a>
                    </div>
                  </div>
                </td>
                <td class="py-2 text-gray-600">
                  <% if (b.dono_id) { %>
                    <a href="/explorar/perfil/<%= b.dono_id %>" target="_blank" class="inline-flex items-center gap-2 text-primary-600 hover:underline">
                      <% if (b.dono_foto) { %>
                        <img src="<%= b.dono_foto %>" alt="" class="w-5 h-5 rounded-full object-cover">
                      <% } %>
                      <span><%= b.dono_nome || ('Usuário ' + b.dono_id) %></span>
                    </a>
                  <% } else { %>
                    <span class="text-gray-400">—</span>
                  <% } %>
                </td>
                <td class="py-2 font-semibold text-gray-900">+<%= b.boost_value %></td>
                <td class="py-2 text-gray-500"><%= b.starts_at ? new Date(b.starts_at).toLocaleString('pt-BR') : '—' %></td>
                <td class="py-2 text-gray-500"><%= b.ends_at ? new Date(b.ends_at).toLocaleString('pt-BR') : '—' %></td>
                <td class="py-2 text-gray-500"><%= b.created_at ? new Date(b.created_at).toLocaleString('pt-BR') : '—' %></td>
                <td class="py-2 text-right">
                  <% const aindaAtivo = !b.ends_at || new Date(b.ends_at) > new Date(); %>
                  <% if (aindaAtivo) { %>
                    <form method="POST" action="<%= adminPath %>/boosts/<%= b.id %>/cancelar" onsubmit="return confirm('Cancelar este patrocinado?');">
                      <button type="submit" class="inline-flex items-center gap-1 px-2 py-1 rounded-md border border-red-200 text-red-600 text-xs hover:bg-red-50">
                        <i class="fa-solid fa-ban"></i> Cancelar
                      </button>
                    </form>
                  <% } else { %>
                    <span class="inline-flex items-center gap-1 px-2 py-1 rounded-md bg-gray-100 text-gray-500 text-xs">Expirado</span>
                  <% } %>
                </td>
              </tr>
            <% }) %>
          <% } else { %>
            <tr>
              <td colspan="8" class="py-4 text-center text-xs text-gray-400">Nenhum patrocinado cadastrado ainda.</td>
            </tr>
          <% } %>
          </tbody>
        </table>
      </div>
      <div class="mt-4 bg-gray-50 border border-gray-100 rounded-lg p-3 text-xs text-gray-600 space-y-1">
        <p><strong>Como entrega no feed/explorar:</strong> sempre que houver boost ativo, o sistema insere pelo menos 1 card patrocinado por página, mesmo com feed curto.</p>
        <p><strong>Com publicação:</strong> o card mostra foto/legenda em formato de propaganda identificada.</p>
        <p><strong>Sem publicação:</strong> o card vira sugestão de perfil pet + tutor para seguir.</p>
        <p><strong>Métricas:</strong> boost altera prioridade de entrega, não altera curtidas/comentários reais.</p>
      </div>
    </section>

  </div>
</main>

<script>
  (function () {
    var form = document.getElementById('boostForm');
    if (!form) return;

    var targetIdInput = document.getElementById('targetIdInput');
    var selectedUserInput = document.getElementById('selectedUserInput');
    var selectedPetInput = document.getElementById('selectedPetInput');
    var buscarTutorInput = document.getElementById('buscarTutorInput');
    var usuariosResultado = document.getElementById('usuariosResultado');
    var petsStep = document.getElementById('petsStep');
    var petsResultado = document.getElementById('petsResultado');
    var userSelecionadoCard = document.getElementById('userSelecionadoCard');
    var petSelecionadoCard = document.getElementById('petSelecionadoCard');
    var debounceRef = null;
    var usuarioSelecionado = null;

    function adminBoostDeferred(workFn, message) {
      var L = window.AIRPET_LOADING;
      if (L && typeof L.withDeferredOverlay === 'function') {
        return L.withDeferredOverlay(workFn, { message: message || 'Ainda a processar…' });
      }
      return Promise.resolve().then(workFn);
    }

    function esc(texto) {
      return String(texto || '')
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;');
    }

    function avatar(nome, foto, sizeClass) {
      if (foto) return '<img src="' + esc(foto) + '" class="' + sizeClass + ' rounded-full object-cover">';
      return '<div class="' + sizeClass + ' rounded-full bg-gray-200 text-gray-600 text-xs font-semibold flex items-center justify-center">' + esc((nome || 'U').charAt(0).toUpperCase()) + '</div>';
    }

    function renderTutorSelecionado(usuario) {
      userSelecionadoCard.classList.remove('hidden');
      userSelecionadoCard.innerHTML =
        '<div class="border border-green-200 bg-green-50 rounded-lg p-3 flex items-center justify-between gap-3">' +
          '<div class="flex items-center gap-2 min-w-0">' +
            avatar(usuario.nome, usuario.foto_perfil, 'w-9 h-9') +
            '<div class="min-w-0">' +
              '<p class="text-sm font-semibold text-green-900 truncate">' + esc(usuario.nome || ('Usuário ' + usuario.id)) + '</p>' +
              '<p class="text-xs text-green-700 truncate">ID ' + esc(usuario.id) + ' · ' + esc((usuario.cidade || 'Sem cidade') + ' / ' + (usuario.estado || '—')) + '</p>' +
            '</div>' +
          '</div>' +
          '<a href="/explorar/perfil/' + esc(usuario.id) + '" target="_blank" class="text-xs text-primary-700 hover:underline">Ver perfil</a>' +
        '</div>';
    }

    function renderPetSelecionado(pet) {
      petSelecionadoCard.classList.remove('hidden');
      petSelecionadoCard.innerHTML =
        '<div class="border border-primary-200 bg-primary-50 rounded-lg p-3 flex items-center justify-between gap-3">' +
          '<div class="flex items-center gap-2 min-w-0">' +
            avatar(pet.nome, pet.foto, 'w-10 h-10') +
            '<div class="min-w-0">' +
              '<p class="text-sm font-semibold text-primary-900 truncate">' + esc(pet.nome || ('Pet ' + pet.id)) + '</p>' +
              '<p class="text-xs text-primary-700 truncate">' + esc((pet.tipo || 'Tipo não informado') + (pet.raca ? ' · ' + pet.raca : '')) + '</p>' +
            '</div>' +
          '</div>' +
          '<a href="/explorar/pet/' + esc(pet.id) + '" target="_blank" class="text-xs text-primary-700 hover:underline">Ver perfil pet</a>' +
        '</div>';
    }

    function renderUsuarios(usuarios) {
      if (!usuarios.length) {
        usuariosResultado.classList.remove('hidden');
        usuariosResultado.innerHTML = '<div class="px-3 py-2 text-xs text-gray-400">Nenhum tutor encontrado.</div>';
        return;
      }

      var html = '';
      usuarios.forEach(function (u) {
        html += '<button type="button" class="w-full text-left px-3 py-2 hover:bg-gray-50 transition-colors user-result-item" data-id="' + esc(u.id) + '" data-nome="' + esc(u.nome || '') + '" data-foto="' + esc(u.foto_perfil || '') + '" data-cidade="' + esc(u.cidade || '') + '" data-estado="' + esc(u.estado || '') + '"><div class="flex items-center justify-between gap-3"><div class="flex items-center gap-2 min-w-0">' + avatar(u.nome, u.foto_perfil, 'w-8 h-8') + '<div class="min-w-0"><p class="text-sm text-gray-800 truncate">' + esc(u.nome || ('Usuário ' + u.id)) + '</p><p class="text-xs text-gray-400 truncate">' + esc((u.cidade || 'Sem cidade') + ' / ' + (u.estado || '—')) + '</p></div></div><span class="text-xs text-primary-600">Selecionar</span></div></button>';
      });
      usuariosResultado.classList.remove('hidden');
      usuariosResultado.innerHTML = html;
    }

    function renderPets(pets) {
      if (!pets.length) {
        petsResultado.innerHTML = '<div class="col-span-full text-xs text-gray-400">Este tutor não possui pets cadastrados.</div>';
        return;
      }

      var html = '';
      pets.forEach(function (p) {
        html += '<label class="border border-gray-200 rounded-lg p-3 flex items-center justify-between gap-3 cursor-pointer hover:border-primary-400"><div class="flex items-center gap-2 min-w-0">' + avatar(p.nome, p.foto, 'w-10 h-10') + '<div class="min-w-0"><p class="text-sm text-gray-800 truncate">' + esc(p.nome || ('Pet ' + p.id)) + '</p><p class="text-xs text-gray-400 truncate">' + esc((p.tipo || 'Tipo não informado') + (p.raca ? ' · ' + p.raca : '')) + '</p></div></div><input type="radio" name="petSelecionado" value="' + esc(p.id) + '" data-pet="' + esc(JSON.stringify(p)) + '" class="pet-radio"></label>';
      });
      petsResultado.innerHTML = html;
    }

    async function buscarUsuarios(q) {
      var resp = await fetch('<%= adminPath %>/boosts/buscar-usuarios?q=' + encodeURIComponent(q), {
        headers: { Accept: 'application/json' },
        credentials: 'same-origin',
      });
      var data = await resp.json();
      if (!data || !data.sucesso) return [];
      return data.usuarios || [];
    }

    async function buscarPets(usuarioId) {
      var resp = await fetch('<%= adminPath %>/boosts/buscar-pets?usuarioId=' + encodeURIComponent(usuarioId), {
        headers: { Accept: 'application/json' },
        credentials: 'same-origin',
      });
      var data = await resp.json();
      if (!data || !data.sucesso) return [];
      return data.pets || [];
    }

    buscarTutorInput.addEventListener('input', function () {
      var q = (this.value || '').trim();
      clearTimeout(debounceRef);
      if (q.length < 2) {
        usuariosResultado.classList.add('hidden');
        usuariosResultado.innerHTML = '';
        return;
      }
      debounceRef = setTimeout(async function () {
        try {
          renderUsuarios(await buscarUsuarios(q));
        } catch (_) {
          usuariosResultado.classList.remove('hidden');
          usuariosResultado.innerHTML = '<div class="px-3 py-2 text-xs text-red-500">Erro ao buscar tutores.</div>';
        }
      }, 250);
    });

    usuariosResultado.addEventListener('click', async function (event) {
      var el = event.target.closest('.user-result-item');
      if (!el) return;

      usuarioSelecionado = {
        id: parseInt(el.getAttribute('data-id'), 10),
        nome: el.getAttribute('data-nome'),
        foto_perfil: el.getAttribute('data-foto'),
        cidade: el.getAttribute('data-cidade'),
        estado: el.getAttribute('data-estado'),
      };

      selectedUserInput.value = String(usuarioSelecionado.id);
      selectedPetInput.value = '';
      targetIdInput.value = '';
      petSelecionadoCard.classList.add('hidden');
      petSelecionadoCard.innerHTML = '';
      renderTutorSelecionado(usuarioSelecionado);
      usuariosResultado.classList.add('hidden');
      usuariosResultado.innerHTML = '';
      petsStep.classList.remove('hidden');

      try {
        var pets = await adminBoostDeferred(function () {
          return buscarPets(usuarioSelecionado.id);
        }, 'A carregar pets…');
        renderPets(pets);
      } catch (_) {
        petsResultado.innerHTML = '<div class="col-span-full text-xs text-red-500">Erro ao carregar pets do tutor.</div>';
      }
    });

    petsResultado.addEventListener('change', function (event) {
      var el = event.target;
      if (!el.classList.contains('pet-radio')) return;

      var pet = null;
      try { pet = JSON.parse(el.getAttribute('data-pet') || '{}'); } catch (_) { pet = {}; }
      selectedPetInput.value = String(el.value);
      targetIdInput.value = String(el.value);
      renderPetSelecionado(pet);
    });

    form.addEventListener('submit', function (event) {
      if (!selectedUserInput.value) {
        event.preventDefault();
        alert('Selecione um tutor antes de aplicar o patrocinado.');
        return;
      }
      if (!selectedPetInput.value) {
        event.preventDefault();
        alert('Selecione um pet para impulsionar.');
      }
    });
  })();
</script>

<%- include('../partials/admin-footer') %>

