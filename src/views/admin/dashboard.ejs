<% locals.titulo = 'Admin Dashboard' %>
<%- include('../partials/header') %>
<%- include('../partials/flash') %>

<main class="flex-1">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

    <div class="mb-8">
      <h1 class="text-2xl font-bold text-gray-900">Painel Administrativo</h1>
      <p class="text-sm text-gray-500 mt-1">Visão geral do sistema AIRPET</p>
    </div>

    <!-- Stat Cards -->
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4 mb-10">

      <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-5 hover:shadow-md transition-shadow">
        <div class="flex items-center justify-center w-10 h-10 rounded-lg bg-blue-50 text-blue-500 mb-3">
          <i class="fa-solid fa-users text-lg"></i>
        </div>
        <p class="text-2xl font-bold text-gray-900"><%= stats.usuarios %></p>
        <p class="text-xs font-medium text-gray-500 mt-1">Usuários</p>
      </div>

      <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-5 hover:shadow-md transition-shadow">
        <div class="flex items-center justify-center w-10 h-10 rounded-lg bg-orange-50 text-orange-500 mb-3">
          <i class="fa-solid fa-paw text-lg"></i>
        </div>
        <p class="text-2xl font-bold text-gray-900"><%= stats.pets %></p>
        <p class="text-xs font-medium text-gray-500 mt-1">Pets</p>
      </div>

      <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-5 hover:shadow-md transition-shadow">
        <div class="flex items-center justify-center w-10 h-10 rounded-lg bg-red-50 text-red-500 mb-3">
          <i class="fa-solid fa-triangle-exclamation text-lg"></i>
        </div>
        <p class="text-2xl font-bold text-gray-900"><%= stats.perdidos %></p>
        <p class="text-xs font-medium text-gray-500 mt-1">Pets Perdidos</p>
      </div>

      <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-5 hover:shadow-md transition-shadow">
        <div class="flex items-center justify-center w-10 h-10 rounded-lg bg-emerald-50 text-emerald-500 mb-3">
          <i class="fa-solid fa-store text-lg"></i>
        </div>
        <p class="text-2xl font-bold text-gray-900"><%= stats.petshops %></p>
        <p class="text-xs font-medium text-gray-500 mt-1">Petshops</p>
      </div>

      <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-5 hover:shadow-md transition-shadow">
        <div class="flex items-center justify-center w-10 h-10 rounded-lg bg-yellow-50 text-yellow-500 mb-3">
          <i class="fa-solid fa-envelope text-lg"></i>
        </div>
        <p class="text-2xl font-bold text-gray-900"><%= stats.mensagens %></p>
        <p class="text-xs font-medium text-gray-500 mt-1">Msg Pendentes</p>
      </div>

      <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-5 hover:shadow-md transition-shadow">
        <div class="flex items-center justify-center w-10 h-10 rounded-lg bg-purple-50 text-purple-500 mb-3">
          <i class="fa-solid fa-tag text-lg"></i>
        </div>
        <p class="text-2xl font-bold text-gray-900"><%= stats.tags %></p>
        <p class="text-xs font-medium text-gray-500 mt-1">Tags Ativas</p>
      </div>

    </div>

    <!-- Quick Links -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
      <h2 class="text-lg font-semibold text-gray-900 mb-4">Acesso Rápido</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-3">

        <a href="<%= adminPath %>/pets-perdidos"
           class="flex items-center gap-3 px-4 py-3 rounded-lg border border-gray-200 hover:border-red-300 hover:bg-red-50 transition-all group">
          <i class="fa-solid fa-triangle-exclamation text-red-400 group-hover:text-red-500"></i>
          <span class="text-sm font-medium text-gray-700 group-hover:text-red-700">Pets Perdidos Pendentes</span>
        </a>

        <a href="<%= adminPath %>/moderacao"
           class="flex items-center gap-3 px-4 py-3 rounded-lg border border-gray-200 hover:border-yellow-300 hover:bg-yellow-50 transition-all group">
          <i class="fa-solid fa-comment-dots text-yellow-400 group-hover:text-yellow-500"></i>
          <span class="text-sm font-medium text-gray-700 group-hover:text-yellow-700">Moderar Mensagens</span>
        </a>

        <a href="/tags/admin/lista"
           class="flex items-center gap-3 px-4 py-3 rounded-lg border border-gray-200 hover:border-purple-300 hover:bg-purple-50 transition-all group">
          <i class="fa-solid fa-tag text-purple-400 group-hover:text-purple-500"></i>
          <span class="text-sm font-medium text-gray-700 group-hover:text-purple-700">Gerenciar Tags</span>
        </a>

        <a href="<%= adminPath %>/gerenciar-mapa"
           class="flex items-center gap-3 px-4 py-3 rounded-lg border border-gray-200 hover:border-emerald-300 hover:bg-emerald-50 transition-all group">
          <i class="fa-solid fa-map-location-dot text-emerald-400 group-hover:text-emerald-500"></i>
          <span class="text-sm font-medium text-gray-700 group-hover:text-emerald-700">Gerenciar Mapa</span>
        </a>

        <a href="<%= adminPath %>/configuracoes"
           class="flex items-center gap-3 px-4 py-3 rounded-lg border border-gray-200 hover:border-blue-300 hover:bg-blue-50 transition-all group">
          <i class="fa-solid fa-gear text-blue-400 group-hover:text-blue-500"></i>
          <span class="text-sm font-medium text-gray-700 group-hover:text-blue-700">Configurações</span>
        </a>

      </div>
    </div>

  </div>
</main>

<%- include('../partials/footer') %>
