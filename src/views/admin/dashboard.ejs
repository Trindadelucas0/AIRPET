<% locals.titulo = 'Admin Dashboard' %>
<%- include('../partials/admin-layout') %>

<main class="flex-1 app-shell">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

    <div class="mb-8">
      <h1 class="text-2xl font-bold text-gray-900">Painel Administrativo</h1>
      <p class="text-sm text-gray-500 mt-1">Visão geral do sistema AIRPET</p>
    </div>

    <!-- Stat Cards -->
    <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-8 gap-4 mb-10">

      <a href="<%= adminPath %>/usuarios" class="card hover:shadow-md hover:border-blue-200 transition-all block">
        <div class="flex items-center justify-center w-10 h-10 rounded-lg bg-blue-50 text-blue-500 mb-3">
          <i class="fa-solid fa-users text-lg"></i>
        </div>
        <p class="text-2xl font-bold text-gray-900">
          <%= stats.usuarios %><% if (stats.maxUsuarios) { %> <span class="text-lg font-normal text-gray-400">/ <%= stats.maxUsuarios %></span><% } %>
        </p>
        <p class="text-xs font-medium text-gray-500 mt-1">Usuários</p>
      </a>

      <a href="<%= adminPath %>/pets" class="card hover:shadow-md hover:border-orange-200 transition-all block">
        <div class="flex items-center justify-center w-10 h-10 rounded-lg bg-orange-50 text-orange-500 mb-3">
          <i class="fa-solid fa-paw text-lg"></i>
        </div>
        <p class="text-2xl font-bold text-gray-900"><%= stats.pets %></p>
        <p class="text-xs font-medium text-gray-500 mt-1">Pets</p>
      </a>

      <a href="<%= adminPath %>/pets-perdidos" class="card hover:shadow-md hover:border-red-200 transition-all block">
        <div class="flex items-center justify-center w-10 h-10 rounded-lg bg-red-50 text-red-500 mb-3">
          <i class="fa-solid fa-triangle-exclamation text-lg"></i>
        </div>
        <p class="text-2xl font-bold text-gray-900"><%= stats.perdidos %></p>
        <p class="text-xs font-medium text-gray-500 mt-1">Pets Perdidos</p>
      </a>

      <a href="<%= adminPath %>/petshops" class="card hover:shadow-md hover:border-emerald-200 transition-all block">
        <div class="flex items-center justify-center w-10 h-10 rounded-lg bg-emerald-50 text-emerald-500 mb-3">
          <i class="fa-solid fa-store text-lg"></i>
        </div>
        <p class="text-2xl font-bold text-gray-900"><%= stats.petshops %></p>
        <p class="text-xs font-medium text-gray-500 mt-1">Petshops</p>
      </a>

      <a href="<%= adminPath %>/moderacao" class="card hover:shadow-md hover:border-yellow-200 transition-all block">
        <div class="flex items-center justify-center w-10 h-10 rounded-lg bg-yellow-50 text-yellow-500 mb-3">
          <i class="fa-solid fa-envelope text-lg"></i>
        </div>
        <p class="text-2xl font-bold text-gray-900"><%= stats.mensagens %></p>
        <p class="text-xs font-medium text-gray-500 mt-1">Msg Pendentes</p>
      </a>

      <a href="<%= adminPath %>/pets-perdidos" class="card hover:shadow-md hover:border-purple-200 transition-all block">
        <div class="flex items-center justify-center w-10 h-10 rounded-lg bg-purple-50 text-purple-500 mb-3">
          <i class="fa-solid fa-bell text-lg"></i>
        </div>
        <p class="text-2xl font-bold text-gray-900"><%= stats.alertasPendentes %></p>
        <p class="text-xs font-medium text-gray-500 mt-1">Alertas pendentes</p>
      </a>

      <a href="<%= adminPath %>/pedidos" class="card hover:shadow-md hover:border-indigo-200 transition-all block">
        <div class="flex items-center justify-center w-10 h-10 rounded-lg bg-indigo-50 text-indigo-500 mb-3">
          <i class="fa-solid fa-cart-shopping text-lg"></i>
        </div>
        <p class="text-2xl font-bold text-gray-900"><%= Number(stats.tagsVendidas || 0) %></p>
        <p class="text-xs font-medium text-gray-500 mt-1">Tags vendidas</p>
      </a>

      <a href="<%= adminPath %>/tags" class="card hover:shadow-md hover:border-emerald-200 transition-all block">
        <div class="flex items-center justify-center w-10 h-10 rounded-lg bg-emerald-50 text-emerald-500 mb-3">
          <i class="fa-solid fa-tag text-lg"></i>
        </div>
        <p class="text-2xl font-bold text-gray-900"><%= Number(stats.tagsAtivas || 0) %></p>
        <p class="text-xs font-medium text-gray-500 mt-1">Tags ativas</p>
      </a>

    </div>

    <div class="card mb-10">
      <h2 class="text-lg font-semibold text-gray-900 mb-1">Taxa de conversão (usuário → compra)</h2>
      <p class="text-sm text-gray-500 mb-3">Base: usuários com pedido pago, enviado ou entregue.</p>
      <div class="flex items-center gap-4">
        <span class="text-3xl font-bold text-gray-900"><%= Number(stats.taxaConversaoCompra || 0).toFixed(2) %>%</span>
        <div class="flex-1 h-3 rounded-full bg-gray-100 overflow-hidden">
          <div class="h-3 bg-primary-500 rounded-full" style="width:<%= Math.max(0, Math.min(100, Number(stats.taxaConversaoCompra || 0))) %>%"></div>
        </div>
      </div>
    </div>

    <!-- Usuários: por região e últimos cadastros -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-10">
      <div class="card">
        <h2 class="text-lg font-semibold text-gray-900 mb-4 flex items-center gap-2">
          <i class="fa-solid fa-map-marker-alt text-blue-500"></i>
          Usuários por região
        </h2>
        <% if (typeof usuariosPorEstado !== 'undefined' && usuariosPorEstado && usuariosPorEstado.length) { %>
          <ul class="space-y-2 max-h-48 overflow-y-auto">
            <% usuariosPorEstado.forEach(function(r) { %>
              <li class="flex items-center justify-between text-sm">
                <span class="font-medium text-gray-700"><%= r.estado || '—' %></span>
                <span class="text-gray-500"><%= r.total %> usuários</span>
              </li>
            <% }); %>
          </ul>
        <% } else { %>
          <p class="text-sm text-gray-400">Nenhum usuário com região informada.</p>
        <% } %>
      </div>
      <div class="card">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-lg font-semibold text-gray-900 flex items-center gap-2">
            <i class="fa-solid fa-user-clock text-blue-500"></i>
            Últimos cadastros
          </h2>
          <a href="<%= adminPath %>/usuarios" class="text-sm font-medium text-primary-500 hover:text-primary-600">Ver todos</a>
        </div>
        <% if (typeof ultimosUsuarios !== 'undefined' && ultimosUsuarios && ultimosUsuarios.length) { %>
          <div class="overflow-x-auto">
            <table class="w-full text-sm">
              <thead>
                <tr class="text-left text-gray-500 border-b border-gray-100">
                  <th class="pb-2 font-medium">Nome</th>
                  <th class="pb-2 font-medium">Região</th>
                  <th class="pb-2 font-medium">Data</th>
                </tr>
              </thead>
              <tbody>
                <% ultimosUsuarios.forEach(function(u) { %>
                  <tr class="border-b border-gray-50 hover:bg-gray-50/50">
                    <td class="py-2 font-medium text-gray-900"><%= u.nome %></td>
                    <td class="py-2 text-gray-600"><%= (u.cidade || '') + (u.estado ? ' / ' + u.estado : '') || '—' %></td>
                    <td class="py-2 text-gray-500 text-xs"><%= u.data_criacao ? new Date(u.data_criacao).toLocaleDateString('pt-BR') : '—' %></td>
                  </tr>
                <% }); %>
              </tbody>
            </table>
          </div>
        <% } else { %>
          <p class="text-sm text-gray-400">Nenhum usuário cadastrado.</p>
        <% } %>
      </div>
    </div>

    <div class="card mb-10">
      <h2 class="text-lg font-semibold text-gray-900 mb-4">Evolução diária (14 dias)</h2>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="text-left text-gray-500 border-b border-gray-100">
              <th class="pb-2 font-medium">Dia</th>
              <th class="pb-2 font-medium">Novos usuários</th>
              <th class="pb-2 font-medium">Pedidos pagos</th>
            </tr>
          </thead>
          <tbody>
            <% if (!(serieDashboard || []).length) { %>
              <tr><td colspan="3" class="py-3 text-gray-400">Sem dados de evolução para o período.</td></tr>
            <% } %>
            <% (serieDashboard || []).forEach(function(item) { %>
              <tr class="border-b border-gray-50">
                <td class="py-2 text-gray-600"><%= item.dia ? new Date(item.dia).toLocaleDateString('pt-BR') : '-' %></td>
                <td class="py-2 font-medium text-gray-900"><%= item.novos_usuarios %></td>
                <td class="py-2 font-medium text-indigo-700"><%= item.pedidos_pagos %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>

    <!-- Quick Links -->
    <div class="card">
      <h2 class="text-lg font-semibold text-gray-900 mb-4">Acesso Rápido</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-3">

        <a href="<%= adminPath %>/analytics"
           class="flex items-center gap-3 px-4 py-3 rounded-lg border border-gray-200 hover:border-indigo-300 hover:bg-indigo-50 transition-all group">
          <i class="fa-solid fa-chart-pie text-indigo-400 group-hover:text-indigo-500"></i>
          <span class="text-sm font-medium text-gray-700 group-hover:text-indigo-700">Analytics</span>
        </a>

        <a href="<%= adminPath %>/usuarios"
           class="flex items-center gap-3 px-4 py-3 rounded-lg border border-gray-200 hover:border-blue-300 hover:bg-blue-50 transition-all group">
          <i class="fa-solid fa-users text-blue-400 group-hover:text-blue-500"></i>
          <span class="text-sm font-medium text-gray-700 group-hover:text-blue-700">Gerenciar usuários</span>
        </a>

        <a href="<%= adminPath %>/pets-perdidos"
           class="flex items-center gap-3 px-4 py-3 rounded-lg border border-gray-200 hover:border-red-300 hover:bg-red-50 transition-all group">
          <i class="fa-solid fa-triangle-exclamation text-red-400 group-hover:text-red-500"></i>
          <span class="text-sm font-medium text-gray-700 group-hover:text-red-700">Pets Perdidos Pendentes</span>
        </a>

        <a href="<%= adminPath %>/petshops/solicitacoes"
           class="flex items-center gap-3 px-4 py-3 rounded-lg border border-gray-200 hover:border-emerald-300 hover:bg-emerald-50 transition-all group">
          <i class="fa-solid fa-store text-emerald-400 group-hover:text-emerald-500"></i>
          <span class="text-sm font-medium text-gray-700 group-hover:text-emerald-700">Cadastros de Petshop</span>
        </a>

        <a href="<%= adminPath %>/notificacoes/enviar"
           class="flex items-center gap-3 px-4 py-3 rounded-lg border border-gray-200 hover:border-amber-300 hover:bg-amber-50 transition-all group">
          <i class="fa-solid fa-bell text-amber-400 group-hover:text-amber-500"></i>
          <span class="text-sm font-medium text-gray-700 group-hover:text-amber-700">Notificação em massa</span>
        </a>

        <a href="<%= adminPath %>/moderacao"
           class="flex items-center gap-3 px-4 py-3 rounded-lg border border-gray-200 hover:border-yellow-300 hover:bg-yellow-50 transition-all group">
          <i class="fa-solid fa-comment-dots text-yellow-400 group-hover:text-yellow-500"></i>
          <span class="text-sm font-medium text-gray-700 group-hover:text-yellow-700">Moderar Mensagens</span>
        </a>

        <a href="<%= adminPath %>/tags"
           class="flex items-center gap-3 px-4 py-3 rounded-lg border border-gray-200 hover:border-purple-300 hover:bg-purple-50 transition-all group">
          <i class="fa-solid fa-tag text-purple-400 group-hover:text-purple-500"></i>
          <span class="text-sm font-medium text-gray-700 group-hover:text-purple-700">Gerenciar Tags</span>
        </a>

        <a href="<%= adminPath %>/pedidos"
           class="flex items-center gap-3 px-4 py-3 rounded-lg border border-gray-200 hover:border-indigo-300 hover:bg-indigo-50 transition-all group">
          <i class="fa-solid fa-cart-shopping text-indigo-400 group-hover:text-indigo-500"></i>
          <span class="text-sm font-medium text-gray-700 group-hover:text-indigo-700">Gerenciar Pedidos</span>
        </a>

        <a href="<%= adminPath %>/gerenciar-mapa"
           class="flex items-center gap-3 px-4 py-3 rounded-lg border border-gray-200 hover:border-teal-300 hover:bg-teal-50 transition-all group">
          <i class="fa-solid fa-map-location-dot text-teal-400 group-hover:text-teal-500"></i>
          <span class="text-sm font-medium text-gray-700 group-hover:text-teal-700">Gerenciar Mapa</span>
        </a>

        <a href="<%= adminPath %>/configuracoes"
           class="flex items-center gap-3 px-4 py-3 rounded-lg border border-gray-200 hover:border-blue-300 hover:bg-blue-50 transition-all group">
          <i class="fa-solid fa-gear text-blue-400 group-hover:text-blue-500"></i>
          <span class="text-sm font-medium text-gray-700 group-hover:text-blue-700">Configurações</span>
        </a>

        <a href="<%= adminPath %>/aparencia"
           class="flex items-center gap-3 px-4 py-3 rounded-lg border border-gray-200 hover:border-orange-300 hover:bg-orange-50 transition-all group">
          <i class="fa-solid fa-palette text-orange-400 group-hover:text-orange-500"></i>
          <span class="text-sm font-medium text-gray-700 group-hover:text-orange-700">Aparência</span>
        </a>

        <a href="<%= adminPath %>/boosts"
           class="flex items-center gap-3 px-4 py-3 rounded-lg border border-gray-200 hover:border-yellow-400 hover:bg-yellow-50 transition-all group">
          <i class="fa-solid fa-bolt text-yellow-500 group-hover:text-yellow-600"></i>
          <span class="text-sm font-medium text-gray-700 group-hover:text-yellow-700">Boosts</span>
        </a>

      </div>
    </div>
    <p class="mt-4 text-xs text-gray-400">
      Limite de usuários: defina <code class="bg-gray-100 px-1 rounded">MAX_USUARIOS</code> no <code class="bg-gray-100 px-1 rounded">.env</code> (ex.: 50). O total é verificado automaticamente no cadastro; 0 ou vazio = sem limite.
    </p>

  </div>
</main>

<%- include('../partials/admin-footer') %>
