<% locals.titulo = 'Pets Perdidos' %>
<%- include('../partials/admin-layout') %>

<main class="flex-1">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

    <div class="mb-6">
      <a href="<%= adminPath %>" class="inline-flex items-center gap-1 text-sm text-gray-500 hover:text-primary-500 transition-colors mb-2">
        <i class="fa-solid fa-arrow-left text-xs"></i> Dashboard
      </a>
      <h1 class="text-2xl font-bold text-gray-900">Pets Perdidos</h1>
      <p class="text-sm text-gray-500 mt-1"><%= perdidos.length %> registros</p>
      <p class="text-sm text-gray-500 mt-2 max-w-2xl">
        Para ver <strong class="text-gray-700">scans NFC e localização no mapa</strong>, abra a ficha do pet (botão na card ou menu lateral <strong>Pets</strong>).
      </p>
    </div>

    <!-- Hub de alertas: status do cron, links e log -->
    <div class="mb-8 p-5 bg-white rounded-xl shadow-sm border border-gray-100">
      <h2 class="text-sm font-semibold text-gray-700 mb-3 flex items-center gap-2">
        <i class="fa-solid fa-cog text-primary-500"></i>
        Notificações e alertas
      </h2>
      <p class="text-xs text-gray-500 mb-4">Configure o tempo e o raio (km) para o envio automático de notificações quando um pet está perdido, ou envie uma notificação em massa por região.</p>

      <!-- Status do cron -->
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 mb-4">
        <div class="bg-gray-50 rounded-lg p-3 border border-gray-100">
          <p class="text-[10px] font-semibold text-gray-500 uppercase tracking-wide">Última execução</p>
          <p class="text-sm font-medium text-gray-900 mt-0.5">
            <% if (typeof cronUltima !== 'undefined' && cronUltima && cronUltima.finalizado_em) { %>
              <%= new Date(cronUltima.finalizado_em).toLocaleString('pt-BR') %>
            <% } else { %>
              —
            <% } %>
          </p>
        </div>
        <div class="bg-gray-50 rounded-lg p-3 border border-gray-100">
          <p class="text-[10px] font-semibold text-gray-500 uppercase tracking-wide">Próxima (estimada)</p>
          <p class="text-sm font-medium text-gray-900 mt-0.5">
            <% if (typeof proximaExecucaoEm !== 'undefined' && proximaExecucaoEm !== null) { %>
              em <%= proximaExecucaoEm %> min
            <% } else { %>
              —
            <% } %>
          </p>
        </div>
        <div class="bg-gray-50 rounded-lg p-3 border border-gray-100">
          <p class="text-[10px] font-semibold text-gray-500 uppercase tracking-wide">Status</p>
          <p class="text-sm font-medium mt-0.5">
            <% if (typeof cronUltima !== 'undefined' && cronUltima) { %>
              <span class="<%= cronUltima.status === 'ok' ? 'text-emerald-600' : 'text-red-600' %>">
                <%= cronUltima.status === 'ok' ? 'OK' : 'Erro' %>
              </span>
            <% } else { %>
              <span class="text-gray-500">—</span>
            <% } %>
          </p>
        </div>
      </div>

      <div class="flex flex-wrap gap-3 mb-4">
        <a href="<%= adminPath %>/configuracoes" class="inline-flex items-center gap-2 px-4 py-2.5 rounded-lg text-sm font-medium bg-primary-50 text-primary-700 hover:bg-primary-100 border border-primary-200 transition-colors">
          <i class="fa-solid fa-clock"></i>
          Configurações de alertas (tempo e raio)
        </a>
        <a href="<%= adminPath %>/notificacoes/enviar" class="inline-flex items-center gap-2 px-4 py-2.5 rounded-lg text-sm font-medium bg-amber-50 text-amber-700 hover:bg-amber-100 border border-amber-200 transition-colors">
          <i class="fa-solid fa-bell"></i>
          Notificação em massa (região e raio)
        </a>
      </div>
      <p class="text-xs text-gray-400 mb-4">O cron roda a cada <strong><%= typeof intervaloMin !== 'undefined' ? intervaloMin : '30' %> min</strong>: a partir do momento em que o pet está perdido, o sistema cronometra e reenvia notificações conforme as horas e raios configurados (Nível 1 → 2 → 3).</p>

      <!-- Log recente de execuções -->
      <% if (typeof cronRecentes !== 'undefined' && cronRecentes && cronRecentes.length > 0) { %>
      <div class="border-t border-gray-100 pt-4">
        <h3 class="text-xs font-semibold text-gray-600 mb-2">Últimas execuções do cron</h3>
        <div class="overflow-x-auto">
          <table class="w-full text-xs">
            <thead>
              <tr class="text-left text-gray-500 border-b border-gray-100">
                <th class="pb-2 font-medium">Iniciado</th>
                <th class="pb-2 font-medium">Status</th>
                <th class="pb-2 font-medium">Alertas escalados</th>
                <th class="pb-2 font-medium">Notificações</th>
                <th class="pb-2 font-medium">Erro</th>
              </tr>
            </thead>
            <tbody>
              <% cronRecentes.forEach(function(r) { %>
              <tr class="border-b border-gray-50">
                <td class="py-1.5 text-gray-700"><%= r.iniciado_em ? new Date(r.iniciado_em).toLocaleString('pt-BR') : '—' %></td>
                <td class="py-1.5">
                  <span class="<%= r.status === 'ok' ? 'text-emerald-600' : (r.status === 'erro' ? 'text-red-600' : 'text-amber-600') %> font-medium">
                    <%= r.status === 'em_andamento' ? 'Em andamento' : (r.status === 'ok' ? 'OK' : 'Erro') %>
                  </span>
                </td>
                <td class="py-1.5 text-gray-700"><%= r.alertas_escalados != null ? r.alertas_escalados : '—' %></td>
                <td class="py-1.5 text-gray-700"><%= r.notificacoes_enviadas != null ? r.notificacoes_enviadas : '—' %></td>
                <td class="py-1.5 text-gray-500 max-w-[120px] truncate" title="<%= r.erro || '' %>"><%= r.erro ? r.erro : '—' %></td>
              </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      </div>
      <% } %>
    </div>

    <% if (perdidos.length === 0) { %>
      <div class="bg-white rounded-xl shadow-sm border border-gray-100 text-center py-16 text-gray-400">
        <i class="fa-solid fa-paw text-4xl mb-3"></i>
        <p class="text-sm">Nenhum registro de pet perdido</p>
      </div>
    <% } else { %>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
        <% perdidos.forEach(function(p) { %>
          <%
            var statusClass = 'bg-gray-100 text-gray-600';
            if (p.status === 'pendente') statusClass = 'bg-yellow-100 text-yellow-700';
            else if (p.status === 'aprovado') statusClass = 'bg-red-100 text-red-700';
            else if (p.status === 'resolvido') statusClass = 'bg-emerald-100 text-emerald-700';
          %>
          <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
            <% if (p.pet_foto) { %>
              <div class="h-44 bg-gray-100">
                <img src="<%= p.pet_foto %>" alt="<%= p.pet_nome %>" class="w-full h-full object-cover">
              </div>
            <% } else { %>
              <div class="h-44 bg-gray-100 flex items-center justify-center text-gray-300">
                <i class="fa-solid fa-image text-4xl"></i>
              </div>
            <% } %>

            <div class="p-5">
              <div class="flex items-start justify-between mb-3">
                <div>
                  <h3 class="font-semibold text-gray-900">
                    <a href="<%= adminPath %>/pets/<%= p.pet_id %>" class="hover:text-primary-600 hover:underline"><%= p.pet_nome || 'Pet #' + p.pet_id %></a>
                  </h3>
                  <p class="text-xs text-gray-500 mt-0.5"><%= p.criado_em ? new Date(p.criado_em).toLocaleDateString('pt-BR') : '' %></p>
                </div>
                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-semibold <%= statusClass %>">
                  <%= p.status %>
                </span>
              </div>

              <% if (p.nivel_alerta) { %>
                <div class="flex items-center gap-1.5 mb-3">
                  <span class="text-xs text-gray-500">Nível de alerta:</span>
                  <span class="text-xs font-bold text-red-600"><%= p.nivel_alerta %></span>
                  <span class="text-xs text-gray-400">• ciclo <%= Number(p.ciclo_alerta || 1) %></span>
                </div>
              <% } %>

              <% if (p.descricao) { %>
                <p class="text-sm text-gray-600 mb-3 line-clamp-2"><%= p.descricao %></p>
              <% } %>

              <a href="<%= adminPath %>/pets/<%= p.pet_id %>"
                 class="w-full flex items-center justify-center gap-2 px-4 py-2 mb-3 rounded-lg text-sm font-semibold text-primary-700 bg-primary-50 border border-primary-200 hover:bg-primary-100 transition-colors">
                <i class="fa-solid fa-map-location-dot"></i> Ficha do pet (alertas + scans)
              </a>

              <% if (p.status === 'pendente') { %>
                <form action="<%= adminPath %>/pets-perdidos/<%= p.id %>/aprovar" method="POST">
                  <button type="submit"
                    class="w-full flex items-center justify-center gap-2 px-4 py-2 rounded-lg text-sm font-semibold text-white bg-red-500 hover:bg-red-600 transition-colors">
                    <i class="fa-solid fa-bullhorn"></i> Aprovar e Notificar
                  </button>
                </form>
              <% } else if (p.status === 'aprovado') { %>
                <form action="<%= adminPath %>/pets-perdidos/<%= p.id %>/escalar" method="POST">
                  <button type="submit"
                    class="w-full flex items-center justify-center gap-2 px-4 py-2 rounded-lg text-sm font-semibold text-white bg-primary-500 hover:bg-primary-600 transition-colors">
                    <i class="fa-solid fa-arrow-up-right-dots"></i> Escalar / Reiniciar ciclo
                  </button>
                </form>
              <% } else if (p.status === 'resolvido') { %>
                <div class="flex items-center gap-2 text-emerald-600 text-sm font-medium">
                  <i class="fa-solid fa-circle-check"></i> Resolvido
                </div>
              <% } %>
            </div>
          </div>
        <% }); %>
      </div>
    <% } %>

  </div>
</main>

<%- include('../partials/admin-footer') %>
