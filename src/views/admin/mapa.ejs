<% locals.titulo = 'Mapa Admin' %>
<%- include('../partials/admin-layout') %>
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" crossorigin="">
<div class="max-w-7xl mx-auto px-4 py-2 flex justify-end">
  <a href="<%= adminPath %>/gerenciar-mapa" class="inline-flex items-center gap-2 px-3 py-2 rounded-lg text-sm font-medium text-gray-600 bg-white border border-gray-200 hover:bg-gray-50 transition-colors">
    <i class="fa-solid fa-pen-to-square"></i> Gerenciar pontos
  </a>
</div>
<link rel="stylesheet" href="https://unpkg.com/leaflet.markercluster@1.5.3/dist/MarkerCluster.css">
<link rel="stylesheet" href="https://unpkg.com/leaflet.markercluster@1.5.3/dist/MarkerCluster.Default.css">
<style>
  #adminFullMap { height: calc(100vh - 8rem); }
  #concentracaoPanel {
    position: absolute; bottom: 24px; left: 12px; z-index: 1000;
    max-height: 220px; overflow-y: auto;
    background: #fff; border-radius: 8px; box-shadow: 0 2px 10px rgba(0,0,0,.2);
    padding: 10px 14px; font-size: 12px; max-width: 240px;
  }
  #concentracaoPanel h4 { margin: 0 0 8px 0; font-size: 13px; }
  #concentracaoPanel ul { margin: 0; padding-left: 18px; }
  #concentracaoPanel li { margin: 4px 0; }
</style>

<div id="adminFullMap">
  <% if (typeof concentracaoCidades !== 'undefined' && concentracaoCidades && concentracaoCidades.length > 0) { %>
  <div id="concentracaoPanel">
    <h4>Concentração de pets por cidade</h4>
    <ul>
      <% concentracaoCidades.forEach(function(row) { %>
      <li><strong><%= row.cidade %></strong>: <%= row.total %> localizações</li>
      <% }); %>
    </ul>
  </div>
  <% } %>
</div>

<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
<script src="https://unpkg.com/leaflet.markercluster@1.5.3/dist/leaflet.markercluster.js"></script>
<script>
(function () {
  var map = L.map('adminFullMap').setView([-15.78, -47.93], 5);

  L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
    attribution: '&copy; OpenStreetMap'
  }).addTo(map);

  var clusterGroup = L.markerClusterGroup();
  map.addLayer(clusterGroup);

  var iconColors = {
    petshop: '#10b981',
    veterinario: '#3b82f6',
    hospital_pet: '#ef4444',
    abrigo: '#8b5cf6',
    ponto_de_apoio: '#f59e0b',
    pet_perdido: '#dc2626',
    avistamento: '#f97316'
  };

  function makeIcon(color) {
    return L.divIcon({
      className: 'custom-marker',
      html: '<div style="background:' + color + ';width:12px;height:12px;border-radius:50%;border:2px solid #fff;box-shadow:0 1px 4px rgba(0,0,0,.3)"></div>',
      iconSize: [16, 16],
      iconAnchor: [8, 8]
    });
  }

  function makePhotoIcon(photoUrl) {
    if (!photoUrl) return makeIcon(iconColors.avistamento);
    var src = photoUrl.indexOf('/') === 0 ? (window.location.origin + photoUrl) : photoUrl;
    return L.divIcon({
      className: 'custom-marker-photo',
      html: '<div style="width:36px;height:36px;border-radius:50%;border:2px solid #fff;box-shadow:0 1px 4px rgba(0,0,0,.3);overflow:hidden;background:#eee"><img src="' + src + '" alt="" style="width:100%;height:100%;object-fit:cover" onerror="this.parentNode.style.background:#f97316"></div>',
      iconSize: [36, 36],
      iconAnchor: [18, 18]
    });
  }

  var layers = {};

  function addDataLayer(name, items, color, usePhoto) {
    var layer = L.layerGroup();
    items.forEach(function (item) {
      if (!item.latitude || !item.longitude) return;
      var photoUrl = (item.foto_url || item.pet_foto) ? (item.foto_url || item.pet_foto) : null;
      var icon = (usePhoto && photoUrl) ? makePhotoIcon(photoUrl) : makeIcon(color);
      var m = L.marker([item.latitude, item.longitude], { icon: icon });
      var popup = '<strong>' + (item.nome || item.pet_nome || 'Ponto') + '</strong>';
      if (item.categoria) popup += '<br><small>' + item.categoria + '</small>';
      if (item.status) popup += '<br><small>Status: ' + item.status + '</small>';
      if (item.cidade) popup += '<br><small>Cidade: ' + item.cidade + '</small>';
      if (item.data) popup += '<br><small>Data: ' + new Date(item.data).toLocaleString('pt-BR') + '</small>';
      m.bindPopup(popup);
      clusterGroup.addLayer(m);
      layer.addLayer(m);
    });
    layers[name] = layer;
  }

  <% if (typeof pontos !== 'undefined' && pontos) { %>
    addDataLayer('Pontos do Mapa', <%- JSON.stringify(pontos) %>, iconColors.petshop);
  <% } %>

  <% if (typeof petshops !== 'undefined' && petshops) { %>
    addDataLayer('Petshops', <%- JSON.stringify(petshops) %>, iconColors.petshop);
  <% } %>

  <% if (typeof perdidos !== 'undefined' && perdidos) { %>
    addDataLayer('Pets Perdidos', <%- JSON.stringify(perdidos) %>, iconColors.pet_perdido, true);
  <% } %>

  <% if (typeof avistamentos !== 'undefined' && avistamentos) { %>
    addDataLayer('Avistamentos', <%- JSON.stringify(avistamentos) %>, iconColors.avistamento, true);
  <% } %>

  if (Object.keys(layers).length > 0) {
    L.control.layers(null, layers, { collapsed: false, position: 'topright' }).addTo(map);
  }

  L.control.custom = L.Control.extend({
    options: { position: 'topleft' },
    onAdd: function () {
      var div = L.DomUtil.create('div', 'leaflet-bar');
      div.innerHTML = '<a href="<%= adminPath %>/gerenciar-mapa" title="Gerenciar Pontos" style="display:flex;align-items:center;justify-content:center;width:34px;height:34px;background:#fff;font-size:16px">&#9881;</a>';
      return div;
    }
  });
  new L.control.custom().addTo(map);
})();
</script>

<%- include('../partials/admin-footer') %>
