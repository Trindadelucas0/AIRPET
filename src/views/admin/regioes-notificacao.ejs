<% locals.titulo = typeof titulo !== 'undefined' ? titulo : 'Regiões' %>
<%- include('../partials/admin-layout') %>
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="">
<style>
  #mapaRegiao { width: 100%; height: 240px; border-radius: 12px; overflow: hidden; }
  .leaflet-container { z-index: 1; }
</style>

<main class="flex-1">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="mb-6">
      <a href="<%= adminPath %>" class="inline-flex items-center gap-1.5 text-sm text-gray-500 hover:text-primary-500 transition-colors mb-3">
        <i class="fa-solid fa-arrow-left text-xs"></i> Dashboard
      </a>
      <h1 class="text-2xl font-bold text-gray-900">Regiões para notificação</h1>
      <p class="text-sm text-gray-500 mt-1">Cadastre regiões (nome + centro + raio) para reutilizar no envio de notificações em massa.</p>
    </div>

    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 mb-6">
      <h2 class="text-lg font-semibold text-gray-900 mb-4" id="formTitle">Nova região</h2>
      <form action="<%= adminPath %>/regioes-notificacao" method="POST" id="formRegiao" class="space-y-4">
        <input type="hidden" name="id" id="regiaoId" value="">
        <div>
          <label for="nome" class="block text-sm font-medium text-gray-700 mb-1">Nome</label>
          <input type="text" id="nome" name="nome" required placeholder="Ex: Zona Sul SP" maxlength="150"
                 class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-sm">
        </div>
        <p class="text-sm text-gray-500">Clique no mapa para definir o centro; ajuste o raio em km.</p>
        <div id="mapaRegiao"></div>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
          <div>
            <label for="latitude" class="block text-sm font-medium text-gray-700 mb-1">Latitude</label>
            <input type="text" id="latitude" name="latitude" value="-23.5505" required
                   class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 text-sm">
          </div>
          <div>
            <label for="longitude" class="block text-sm font-medium text-gray-700 mb-1">Longitude</label>
            <input type="text" id="longitude" name="longitude" value="-46.6333" required
                   class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 text-sm">
          </div>
          <div>
            <label for="raio_km" class="block text-sm font-medium text-gray-700 mb-1">Raio (km)</label>
            <input type="number" id="raio_km" name="raio_km" value="10" min="0.1" step="0.5" required
                   class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 text-sm">
          </div>
        </div>
        <div class="flex gap-3">
          <button type="submit" id="btnSubmit" class="inline-flex items-center gap-2 px-4 py-2.5 bg-primary-500 hover:bg-primary-600 text-white text-sm font-semibold rounded-lg">
            <i class="fa-solid fa-plus"></i> Criar região
          </button>
          <button type="button" id="btnCancelar" class="hidden px-4 py-2.5 border border-gray-300 text-gray-700 text-sm font-medium rounded-lg hover:bg-gray-50">Cancelar</button>
        </div>
      </form>
    </div>

    <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
      <div class="px-4 py-3 border-b border-gray-100 flex items-center justify-between">
        <h2 class="text-lg font-semibold text-gray-900">Regiões salvas</h2>
        <a href="<%= adminPath %>/notificacoes/enviar" class="text-sm text-primary-500 hover:text-primary-600 font-medium">Enviar notificação</a>
      </div>
      <% if (regioes && regioes.length) { %>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="bg-gray-50 border-b border-gray-200">
              <th class="px-4 py-3 text-left font-semibold text-gray-600">Nome</th>
              <th class="px-4 py-3 text-left font-semibold text-gray-600">Centro (lat, lng)</th>
              <th class="px-4 py-3 text-left font-semibold text-gray-600">Raio</th>
              <th class="px-4 py-3 text-right font-semibold text-gray-600">Ações</th>
            </tr>
          </thead>
          <tbody>
            <% regioes.forEach(function(r) { %>
            <tr class="border-b border-gray-100 hover:bg-gray-50/50">
              <td class="px-4 py-3 font-medium text-gray-900"><%= r.nome %></td>
              <td class="px-4 py-3 text-gray-600"><%= Number(r.latitude).toFixed(5) %>, <%= Number(r.longitude).toFixed(5) %></td>
              <td class="px-4 py-3 text-gray-600"><%= r.raio_km %> km</td>
              <td class="px-4 py-3 text-right">
                <button type="button" class="editar-regiao px-2 py-1.5 text-primary-600 hover:bg-primary-50 rounded-lg text-xs font-medium" data-id="<%= r.id %>" data-nome="<%= r.nome %>" data-lat="<%= r.latitude %>" data-lng="<%= r.longitude %>" data-raio="<%= r.raio_km %>">Editar</button>
                <form action="<%= adminPath %>/regioes-notificacao/<%= r.id %>/excluir" method="POST" class="inline" onsubmit="return confirm('Remover esta região?');">
                  <button type="submit" class="px-2 py-1.5 text-red-600 hover:bg-red-50 rounded-lg text-xs font-medium">Excluir</button>
                </form>
              </td>
            </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
      <% } else { %>
      <p class="px-4 py-8 text-center text-gray-500 text-sm">Nenhuma região cadastrada. Crie uma acima para usar no envio por região salva.</p>
      <% } %>
    </div>
  </div>
</main>

<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
<script>
(function () {
  var form = document.getElementById('formRegiao');
  var regiaoId = document.getElementById('regiaoId');
  var nomeInput = document.getElementById('nome');
  var latInput = document.getElementById('latitude');
  var lngInput = document.getElementById('longitude');
  var raioInput = document.getElementById('raio_km');
  var formTitle = document.getElementById('formTitle');
  var btnSubmit = document.getElementById('btnSubmit');
  var btnCancelar = document.getElementById('btnCancelar');
  var adminPath = '<%= adminPath %>';

  var map = L.map('mapaRegiao', { zoomControl: true, tap: true }).setView([-23.5505, -46.6333], 11);
  L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', { attribution: '&copy; OSM', maxZoom: 19 }).addTo(map);
  setTimeout(function () { map.invalidateSize(); }, 300);
  window.addEventListener('resize', function () { map.invalidateSize(); });

  var marker = null;
  var circle = null;

  function updateMapFromInputs() {
    var lat = parseFloat(latInput.value);
    var lng = parseFloat(lngInput.value);
    var raio = parseFloat(raioInput.value);
    if (isNaN(lat) || isNaN(lng)) return;
    if (isNaN(raio) || raio <= 0) raio = 10;
    var center = L.latLng(lat, lng);
    if (marker) marker.setLatLng(center); else marker = L.marker(center).addTo(map).bindPopup('Centro');
    if (circle) map.removeLayer(circle);
    circle = L.circle(center, { radius: raio * 1000, color: '#ec5a1c', fillColor: '#ec5a1c', fillOpacity: 0.2, weight: 2 }).addTo(map);
  }

  function setFormFromInputs() {
    var lat = parseFloat(latInput.value);
    var lng = parseFloat(lngInput.value);
    if (!isNaN(lat) && !isNaN(lng)) map.setView([lat, lng], map.getZoom());
    updateMapFromInputs();
  }

  map.on('click', function (e) {
    latInput.value = e.latlng.lat.toFixed(6);
    lngInput.value = e.latlng.lng.toFixed(6);
    updateMapFromInputs();
  });
  raioInput.addEventListener('input', updateMapFromInputs);
  raioInput.addEventListener('change', updateMapFromInputs);
  latInput.addEventListener('blur', setFormFromInputs);
  lngInput.addEventListener('blur', setFormFromInputs);

  setFormFromInputs();

  document.querySelectorAll('.editar-regiao').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var id = this.getAttribute('data-id');
      var nome = this.getAttribute('data-nome');
      var lat = this.getAttribute('data-lat');
      var lng = this.getAttribute('data-lng');
      var raio = this.getAttribute('data-raio');
      regiaoId.value = id;
      nomeInput.value = nome;
      latInput.value = lat;
      lngInput.value = lng;
      raioInput.value = raio;
      form.action = adminPath + '/regioes-notificacao/' + id;
      var m = form.querySelector('input[name="_method"]');
      if (!m) { m = document.createElement('input'); m.type = 'hidden'; m.name = '_method'; form.appendChild(m); }
      m.value = 'PUT';
      formTitle.textContent = 'Editar região';
      btnSubmit.innerHTML = '<i class="fa-solid fa-check"></i> Atualizar';
      btnCancelar.classList.remove('hidden');
      setFormFromInputs();
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
  });

  btnCancelar.addEventListener('click', function () {
    regiaoId.value = '';
    form.action = adminPath + '/regioes-notificacao';
    var m = form.querySelector('input[name="_method"]');
    if (m) m.remove();
    formTitle.textContent = 'Nova região';
    btnSubmit.innerHTML = '<i class="fa-solid fa-plus"></i> Criar região';
    btnCancelar.classList.add('hidden');
    nomeInput.value = '';
    latInput.value = '-23.5505';
    lngInput.value = '-46.6333';
    raioInput.value = '10';
    setFormFromInputs();
  });
})();
</script>

<%- include('../partials/admin-footer') %>
