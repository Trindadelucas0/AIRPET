<% locals.titulo = 'Gerar Lote de Tags' %>
<%- include('../partials/header') %>
<%- include('../partials/flash') %>

<main class="flex-1">
  <div class="max-w-xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

    <div class="mb-6">
      <a href="/tags/admin/lista" class="inline-flex items-center gap-1 text-sm text-gray-500 hover:text-primary-500 transition-colors mb-2">
        <i class="fa-solid fa-arrow-left text-xs"></i> Voltar para Tags
      </a>
      <h1 class="text-2xl font-bold text-gray-900">Gerar Lote de Tags</h1>
      <p class="text-sm text-gray-500 mt-1">Crie um novo lote de tags NFC para fabricação</p>
    </div>

    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
      <form action="/tags/admin/gerar" method="POST" class="space-y-5">

        <div>
          <label for="quantidade" class="block text-sm font-medium text-gray-700 mb-1">Quantidade de Tags</label>
          <input type="number" name="quantidade" id="quantidade" min="1" max="1000" required
                 placeholder="Ex: 100"
                 class="w-full px-3 py-2.5 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-primary-500 focus:border-primary-500 outline-none">
          <p class="text-xs text-gray-400 mt-1">Máximo de 1000 tags por lote</p>
        </div>

        <div>
          <label for="fabricante" class="block text-sm font-medium text-gray-700 mb-1">Fabricante</label>
          <input type="text" name="fabricante" id="fabricante"
                 placeholder="Nome do fabricante"
                 class="w-full px-3 py-2.5 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-primary-500 focus:border-primary-500 outline-none">
        </div>

        <div>
          <label for="observacoes" class="block text-sm font-medium text-gray-700 mb-1">Observações</label>
          <textarea name="observacoes" id="observacoes" rows="3"
                    placeholder="Observações sobre o lote (opcional)"
                    class="w-full px-3 py-2.5 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-primary-500 focus:border-primary-500 outline-none resize-none"></textarea>
        </div>

        <button type="submit"
                class="w-full flex items-center justify-center gap-2 px-4 py-2.5 bg-primary-500 hover:bg-primary-600 text-white text-sm font-semibold rounded-lg transition-colors">
          <i class="fa-solid fa-wand-magic-sparkles"></i> Gerar Lote
        </button>

      </form>
    </div>

  </div>
</main>

<%- include('../partials/footer') %>
