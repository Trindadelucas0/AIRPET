<% locals.titulo = 'Aparência / PWA' %>
<%- include('../partials/admin-layout') %>

<%
  const themeColor = (aparencia && aparencia.pwa_theme_color) || '#f26020';
  const backgroundColor = (aparencia && aparencia.pwa_background_color) || '#ffffff';
  const primaryColor = (aparencia && aparencia.app_primary_color) || '#f26020';
  const primaryHoverColor = (aparencia && aparencia.app_primary_hover_color) || '#ff7a3d';
  const accentGlow = (aparencia && aparencia.app_accent_glow) || 'rgba(242,96,32,0.12)';
  const greenColor = (aparencia && aparencia.app_green_color) || '#22c55e';
  const redColor = (aparencia && aparencia.app_red_color) || '#ef4444';
  const purpleColor = (aparencia && aparencia.app_purple_color) || '#a78bfa';
  const blueColor = (aparencia && aparencia.app_blue_color) || '#60a5fa';
  const yellowColor = (aparencia && aparencia.app_yellow_color) || '#facc15';
  const appName = (aparencia && aparencia.app_name) || 'AIRPET';
  const icon192 = (aparencia && aparencia.pwa_icon_192) || '/images/icons/icon-192.png';
  const icon512 = (aparencia && aparencia.pwa_icon_512) || '/images/icons/icon-512.png';
%>

<main class="flex-1">
  <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

    <div class="mb-8">
      <a href="<%= adminPath %>" class="inline-flex items-center gap-1.5 text-sm text-gray-500 hover:text-primary-500 transition-colors mb-3">
        <i class="fa-solid fa-arrow-left text-xs"></i> Dashboard
      </a>
      <h1 class="text-2xl font-bold text-gray-900">Aparência / PWA</h1>
      <p class="text-sm text-gray-500 mt-1">Ícone do app, cores do tema e cor principal do site. Alterações refletem no instalável (PWA) e nas páginas.</p>
    </div>

    <form action="<%= adminPath %>/aparencia" method="POST" enctype="multipart/form-data" class="space-y-8">

      <!-- Ícones PWA -->
      <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-1 flex items-center gap-2">
          <i class="fa-solid fa-image text-primary-500"></i>
          Ícone do aplicativo (PWA)
        </h2>
        <p class="text-sm text-gray-500 mb-4">Recomendado: PNG ou SVG. Tamanhos 192×192 e 512×512 pixels. Se enviar só um, ele será usado nos dois.</p>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Ícone 192×192</label>
            <input type="file" name="icon_192" accept=".png,.svg,image/png,image/svg+xml" class="block w-full text-sm text-gray-500 file:mr-3 file:py-2 file:px-3 file:rounded-lg file:border-0 file:bg-primary-50 file:text-primary-600 file:font-medium hover:file:bg-primary-100">
            <% if (icon192 && !icon192.includes('icon-192.png')) { %>
              <p class="mt-1 text-xs text-gray-500">Atual: <span class="font-mono"><%= icon192 %></span></p>
            <% } %>
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Ícone 512×512</label>
            <input type="file" name="icon_512" accept=".png,.svg,image/png,image/svg+xml" class="block w-full text-sm text-gray-500 file:mr-3 file:py-2 file:px-3 file:rounded-lg file:border-0 file:bg-primary-50 file:text-primary-600 file:font-medium hover:file:bg-primary-100">
            <% if (icon512 && !icon512.includes('icon-512.png')) { %>
              <p class="mt-1 text-xs text-gray-500">Atual: <span class="font-mono"><%= icon512 %></span></p>
            <% } %>
          </div>
        </div>
        <div class="mt-3 flex items-center gap-3">
          <% if (icon192) { %>
            <img src="<%= icon192 %>" alt="Ícone 192" class="w-12 h-12 rounded-xl border border-gray-200 object-contain bg-gray-50">
          <% } %>
          <% if (icon512 && icon512 !== icon192) { %>
            <img src="<%= icon512 %>" alt="Ícone 512" class="w-12 h-12 rounded-xl border border-gray-200 object-contain bg-gray-50">
          <% } %>
        </div>
      </div>

      <!-- Cores -->
      <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-1 flex items-center gap-2">
          <i class="fa-solid fa-palette text-primary-500"></i>
          Cores
        </h2>
        <p class="text-sm text-gray-500 mb-4">Definem a barra do navegador (PWA), a tela de splash e a cor principal dos botões e links do site.</p>
        <div class="space-y-4">
          <div class="flex flex-wrap items-center gap-3">
            <label class="text-sm font-medium text-gray-700 w-48">Cor do tema PWA</label>
            <input type="color" id="pwa_theme_color" value="<%= themeColor %>" class="h-10 w-14 rounded-lg border border-gray-300 cursor-pointer">
            <input type="text" name="pwa_theme_color" value="<%= themeColor %>" maxlength="7" class="px-3 py-2 border border-gray-300 rounded-lg text-sm font-mono w-28" pattern="^#[0-9A-Fa-f]{6}$" title="Ex.: #ec5a1c">
          </div>
          <div class="flex flex-wrap items-center gap-3">
            <label class="text-sm font-medium text-gray-700 w-48">Cor de fundo PWA</label>
            <input type="color" id="pwa_background_color" value="<%= backgroundColor %>" class="h-10 w-14 rounded-lg border border-gray-300 cursor-pointer">
            <input type="text" name="pwa_background_color" value="<%= backgroundColor %>" maxlength="7" class="px-3 py-2 border border-gray-300 rounded-lg text-sm font-mono w-28" pattern="^#[0-9A-Fa-f]{6}$" title="Ex.: #ffffff">
          </div>
          <div class="flex flex-wrap items-center gap-3">
            <label class="text-sm font-medium text-gray-700 w-48">Cor principal do site</label>
            <input type="color" id="app_primary_color" value="<%= primaryColor %>" class="h-10 w-14 rounded-lg border border-gray-300 cursor-pointer">
            <input type="text" name="app_primary_color" value="<%= primaryColor %>" maxlength="7" class="px-3 py-2 border border-gray-300 rounded-lg text-sm font-mono w-28" pattern="^#[0-9A-Fa-f]{6}$" title="Botões, links, destaque">
          </div>
          <div class="flex flex-wrap items-center gap-3">
            <label class="text-sm font-medium text-gray-700 w-48">Hover da cor primária</label>
            <input type="color" id="app_primary_hover_color" value="<%= primaryHoverColor %>" class="h-10 w-14 rounded-lg border border-gray-300 cursor-pointer">
            <input type="text" name="app_primary_hover_color" value="<%= primaryHoverColor %>" maxlength="7" class="px-3 py-2 border border-gray-300 rounded-lg text-sm font-mono w-28" pattern="^#[0-9A-Fa-f]{6}$" title="Hover dos botões e CTAs">
          </div>
          <div class="flex flex-wrap items-center gap-3">
            <label class="text-sm font-medium text-gray-700 w-48">Glow do accent (rgba)</label>
            <input type="text" name="app_accent_glow" value="<%= accentGlow %>" class="px-3 py-2 border border-gray-300 rounded-lg text-sm font-mono min-w-[220px]" title="Ex.: rgba(242,96,32,0.12)">
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 pt-1">
            <div class="flex items-center gap-3">
              <label class="text-sm font-medium text-gray-700 w-28">Verde</label>
              <input type="color" id="app_green_color" value="<%= greenColor %>" class="h-10 w-14 rounded-lg border border-gray-300 cursor-pointer">
              <input type="text" name="app_green_color" value="<%= greenColor %>" maxlength="7" class="px-3 py-2 border border-gray-300 rounded-lg text-sm font-mono w-28" pattern="^#[0-9A-Fa-f]{6}$">
            </div>
            <div class="flex items-center gap-3">
              <label class="text-sm font-medium text-gray-700 w-28">Vermelho</label>
              <input type="color" id="app_red_color" value="<%= redColor %>" class="h-10 w-14 rounded-lg border border-gray-300 cursor-pointer">
              <input type="text" name="app_red_color" value="<%= redColor %>" maxlength="7" class="px-3 py-2 border border-gray-300 rounded-lg text-sm font-mono w-28" pattern="^#[0-9A-Fa-f]{6}$">
            </div>
            <div class="flex items-center gap-3">
              <label class="text-sm font-medium text-gray-700 w-28">Roxo</label>
              <input type="color" id="app_purple_color" value="<%= purpleColor %>" class="h-10 w-14 rounded-lg border border-gray-300 cursor-pointer">
              <input type="text" name="app_purple_color" value="<%= purpleColor %>" maxlength="7" class="px-3 py-2 border border-gray-300 rounded-lg text-sm font-mono w-28" pattern="^#[0-9A-Fa-f]{6}$">
            </div>
            <div class="flex items-center gap-3">
              <label class="text-sm font-medium text-gray-700 w-28">Azul</label>
              <input type="color" id="app_blue_color" value="<%= blueColor %>" class="h-10 w-14 rounded-lg border border-gray-300 cursor-pointer">
              <input type="text" name="app_blue_color" value="<%= blueColor %>" maxlength="7" class="px-3 py-2 border border-gray-300 rounded-lg text-sm font-mono w-28" pattern="^#[0-9A-Fa-f]{6}$">
            </div>
            <div class="flex items-center gap-3">
              <label class="text-sm font-medium text-gray-700 w-28">Amarelo</label>
              <input type="color" id="app_yellow_color" value="<%= yellowColor %>" class="h-10 w-14 rounded-lg border border-gray-300 cursor-pointer">
              <input type="text" name="app_yellow_color" value="<%= yellowColor %>" maxlength="7" class="px-3 py-2 border border-gray-300 rounded-lg text-sm font-mono w-28" pattern="^#[0-9A-Fa-f]{6}$">
            </div>
          </div>
        </div>
      </div>

      <!-- Nome do app -->
      <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-1 flex items-center gap-2">
          <i class="fa-solid fa-signature text-primary-500"></i>
          Nome do aplicativo
        </h2>
        <p class="text-sm text-gray-500 mb-3">Nome curto exibido na tela inicial e no instalável (PWA).</p>
        <input type="text" name="app_name" value="<%= appName %>" maxlength="30" class="w-full px-4 py-2.5 border border-gray-300 rounded-xl text-sm focus:ring-2 focus:ring-primary-500/20 focus:border-primary-500 outline-none" placeholder="AIRPET">
      </div>

      <div class="flex justify-end gap-3">
        <a href="<%= adminPath %>" class="px-5 py-2.5 rounded-xl text-sm font-medium text-gray-600 hover:bg-gray-100 transition-colors">Cancelar</a>
        <button type="submit" class="px-5 py-2.5 rounded-xl text-sm font-semibold text-white bg-primary-500 hover:bg-primary-600 transition-colors shadow-lg shadow-primary-500/20">
          <i class="fa-solid fa-check mr-1"></i> Salvar aparência
        </button>
      </div>
    </form>
  </div>
</main>

<script>
  (function () {
    function syncColor(pickerId, inputName) {
      var picker = document.getElementById(pickerId);
      var input = document.querySelector('input[name="' + inputName + '"]');
      if (!picker || !input) return;
      picker.addEventListener('input', function () { input.value = picker.value; });
      input.addEventListener('input', function () {
        if (/^#[0-9A-Fa-f]{6}$/.test(input.value)) picker.value = input.value;
      });
    }
    syncColor('pwa_theme_color', 'pwa_theme_color');
    syncColor('pwa_background_color', 'pwa_background_color');
    syncColor('app_primary_color', 'app_primary_color');
    syncColor('app_primary_hover_color', 'app_primary_hover_color');
    syncColor('app_green_color', 'app_green_color');
    syncColor('app_red_color', 'app_red_color');
    syncColor('app_purple_color', 'app_purple_color');
    syncColor('app_blue_color', 'app_blue_color');
    syncColor('app_yellow_color', 'app_yellow_color');
  })();
</script>

<%- include('../partials/admin-footer') %>
