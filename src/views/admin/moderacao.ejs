<% locals.titulo = 'Moderacao' %>
<%- include('../partials/admin-layout') %>

<main class="flex-1">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

    <div class="flex items-center justify-between mb-6">
      <div>
        <a href="<%= adminPath %>" class="inline-flex items-center gap-1 text-sm text-gray-500 hover:text-primary-500 transition-colors mb-2">
          <i class="fa-solid fa-arrow-left text-xs"></i> Dashboard
        </a>
        <h1 class="text-2xl font-bold text-gray-900">
          Moderação de Mensagens
          <span id="pendingCount" class="ml-2 inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-bold bg-yellow-100 text-yellow-700">
            <%= mensagens.length %>
          </span>
        </h1>
      </div>
    </div>

    <div id="moderacaoContainer">
      <% if (mensagens.length === 0) { %>
        <div id="emptyState" class="bg-white rounded-xl shadow-sm border border-gray-100 text-center py-16 text-gray-400">
          <i class="fa-solid fa-check-double text-4xl mb-3"></i>
          <p class="text-sm">Nenhuma mensagem pendente de moderação</p>
        </div>
      <% } %>

      <div class="space-y-4" id="mensagensList">
        <% mensagens.forEach(function(m) { %>
          <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-5 msg-card" data-id="<%= m.id %>">
            <div class="flex items-start justify-between gap-4">
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-3 mb-2">
                  <span class="text-xs font-mono text-gray-400">Conversa #<%= m.conversa_id %></span>
                  <span class="text-xs text-gray-300">|</span>
                  <span class="text-sm font-medium text-gray-700"><%= m.remetente_nome || 'Usuário #' + m.remetente_id %></span>
                  <span class="inline-flex items-center px-1.5 py-0.5 rounded text-[10px] font-semibold uppercase
                    <%= m.tipo === 'foto' ? 'bg-blue-100 text-blue-600' : 'bg-gray-100 text-gray-500' %>">
                    <%= m.tipo %>
                  </span>
                </div>

                <% if (m.tipo === 'foto' && m.conteudo) { %>
                  <div class="mb-3">
                    <img src="<%= m.conteudo %>" alt="Foto" class="max-h-40 rounded-lg border border-gray-200">
                  </div>
                <% } else { %>
                  <p class="text-sm text-gray-800 bg-gray-50 rounded-lg px-4 py-3 mb-3"><%= m.conteudo %></p>
                <% } %>

                <p class="text-xs text-gray-400"><%= m.criado_em ? new Date(m.criado_em).toLocaleString('pt-BR') : '' %></p>
              </div>

              <div class="flex flex-col gap-2 flex-shrink-0">
                <form action="<%= adminPath %>/moderacao/<%= m.id %>/aprovar" method="POST" class="inline">
                  <button type="submit"
                    class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-xs font-semibold text-white bg-emerald-500 hover:bg-emerald-600 transition-colors btn-aprovar">
                    <i class="fa-solid fa-check"></i> Aprovar
                  </button>
                </form>
                <form action="<%= adminPath %>/moderacao/<%= m.id %>/rejeitar" method="POST" class="inline">
                  <button type="submit"
                    class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-xs font-semibold text-white bg-red-500 hover:bg-red-600 transition-colors btn-rejeitar">
                    <i class="fa-solid fa-xmark"></i> Rejeitar
                  </button>
                </form>
              </div>
            </div>
          </div>
        <% }); %>
      </div>
    </div>

  </div>
</main>

<% locals.extraScripts = '<script src="/socket.io/socket.io.js"></script><script src="/js/admin-moderacao.js"></script>' %>
<%- include('../partials/admin-footer') %>
