<% locals.titulo = 'Petshops Parceiros' %>
<% locals.extraHead = `
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
  body{font-family:'DM Sans',sans-serif;}
  .lista-wrap{max-width:1060px;margin:0 auto;padding:24px 20px 80px;}
  .page-topbar{position:sticky;top:56px;z-index:40;background:rgba(255,255,255,0.88);backdrop-filter:blur(20px);border-bottom:1px solid var(--border);padding:14px 0;}
  .topbar-inner{max-width:1060px;margin:0 auto;padding:0 20px;display:flex;align-items:center;justify-content:space-between;}
  .page-title{font-family:'Syne',sans-serif;font-size:20px;font-weight:800;color:var(--text);}
  .page-sub{font-size:12px;color:var(--text-dim);margin-top:2px;}
  .btn-map{display:inline-flex;align-items:center;gap:8px;padding:9px 18px;background:var(--ink-3);border:1px solid var(--border);border-radius:10px;color:var(--text-dim);font-size:13px;font-weight:600;text-decoration:none;transition:all 0.15s;}
  .btn-map:hover{border-color:var(--accent);color:var(--accent);text-decoration:none;}
  /* Grid */
  .ps-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;}
  @media(max-width:900px){.ps-grid{grid-template-columns:repeat(2,1fr);}}
  @media(max-width:540px){.ps-grid{grid-template-columns:1fr;}}
  /* Card */
  .ps-card{background:var(--ink-2);border:1px solid var(--border);border-radius:18px;overflow:hidden;text-decoration:none;display:block;transition:all 0.25s;animation:slide-up 0.4s ease-out both;}
  .ps-card:hover{border-color:var(--border-hover);transform:translateY(-4px);box-shadow:0 20px 40px rgba(0,0,0,0.4);text-decoration:none;}
  @keyframes slide-up{from{opacity:0;transform:translateY(16px);}to{opacity:1;transform:none;}}
  .ps-card-cover{width:100%;height:148px;object-fit:cover;display:block;background:var(--ink-3);}
  .ps-card-cover-empty{width:100%;height:148px;background:var(--ink-3);display:flex;align-items:center;justify-content:center;}
  .ps-card-cover-empty i{font-size:36px;color:var(--text-muted);}
  .ps-badge-apoio{position:absolute;top:10px;left:10px;display:inline-flex;align-items:center;gap:5px;padding:4px 10px;border-radius:100px;background:rgba(34,197,94,0.9);backdrop-filter:blur(4px);font-size:10px;font-weight:700;color:#fff;text-transform:uppercase;letter-spacing:0.08em;}
  .ps-card-body{padding:16px;}
  .ps-card-name{font-family:'Syne',sans-serif;font-size:16px;font-weight:800;color:var(--text);margin-bottom:8px;transition:color 0.15s;}
  .ps-card:hover .ps-card-name{color:var(--accent);}
  .ps-card-info{font-size:12px;color:var(--text-dim);display:flex;align-items:flex-start;gap:7px;margin-bottom:5px;}
  .ps-card-info i{color:var(--text-muted);width:14px;text-align:center;flex-shrink:0;margin-top:1px;}
  .ps-dist{display:inline-flex;align-items:center;gap:5px;font-size:12px;font-weight:700;color:var(--accent);margin-top:8px;}
  .ps-tags{display:flex;flex-wrap:wrap;gap:5px;margin-top:8px;}
  .ps-tag{padding:3px 8px;border-radius:100px;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.06em;}
  .ps-tag.green{background:rgba(34,197,94,0.1);color:var(--green);}
  .ps-tag.blue{background:rgba(96,165,250,0.1);color:var(--blue);}
  .ps-tag.purple{background:rgba(167,139,250,0.1);color:var(--purple);}
  /* Empty */
  .ps-empty{text-align:center;padding:80px 24px;color:var(--text-dim);}
  .ps-empty-icon{font-size:52px;opacity:0.15;display:block;margin-bottom:16px;}
  .ps-empty h2{font-family:'Syne',sans-serif;font-size:22px;font-weight:800;color:var(--text);margin-bottom:8px;}
</style>
` %>
<%- include('../partials/header') %>
<%- include('../partials/flash') %>

<div class="page-topbar">
  <div class="topbar-inner">
    <div>
      <div class="page-title">Petshops Parceiros</div>
      <div class="page-sub">Encontre serviços e pontos de apoio</div>
    </div>
    <a href="/mapa?layer=petshops" class="btn-map">
      <i class="fa-solid fa-map-location-dot"></i>
      <span class="hidden sm:inline">Ver no mapa</span>
    </a>
  </div>
</div>

<main class="flex-1">
  <div class="lista-wrap">
    <% if (typeof petshops !== 'undefined' && petshops.length > 0) { %>
      <div class="ps-grid">
        <% petshops.forEach(function(ps, idx) { %>
          <a href="/petshops/<%= ps.slug || ps.id %>" class="ps-card" style="animation-delay:<%= idx * 50 %>ms">
            <div style="position:relative;">
              <% if (ps.foto_capa) { %>
                <img src="/images/petshops/<%= ps.foto_capa %>" class="ps-card-cover" alt="<%= ps.nome %>" loading="lazy">
              <% } else { %>
                <div class="ps-card-cover-empty"><i class="fa-solid fa-store"></i></div>
              <% } %>
              <% if (ps.ponto_de_apoio) { %>
                <span class="ps-badge-apoio"><i class="fa-solid fa-shield-check"></i> Ponto de Apoio</span>
              <% } %>
            </div>
            <div class="ps-card-body">
              <div class="ps-card-name"><%= ps.nome %></div>
              <% if (ps.endereco) { %>
                <div class="ps-card-info"><i class="fa-solid fa-location-dot"></i><span style="overflow:hidden;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;"><%= ps.endereco %></span></div>
              <% } %>
              <% if (ps.telefone) { %>
                <div class="ps-card-info"><i class="fa-solid fa-phone"></i><%= ps.telefone %></div>
              <% } %>
              <% if (typeof ps.distancia !== 'undefined' && ps.distancia !== null) { %>
                <div class="ps-dist"><i class="fa-solid fa-route"></i><%= ps.distancia < 1 ? (ps.distancia*1000).toFixed(0)+'m' : ps.distancia.toFixed(1)+'km' %></div>
              <% } %>
              <div class="ps-tags">
                <% if (ps.ponto_de_apoio) { %><span class="ps-tag green">Apoio</span><% } %>
                <% if (ps.tipo_servico) { %><span class="ps-tag blue"><%= ps.tipo_servico %></span><% } %>
              </div>
            </div>
          </a>
        <% }); %>
      </div>
    <% } else { %>
      <div class="ps-empty">
        <span class="ps-empty-icon">🏪</span>
        <h2>Nenhum petshop cadastrado</h2>
        <p style="font-size:14px;line-height:1.6;">Parceiros aparecerão aqui quando disponíveis na sua região.</p>
      </div>
    <% } %>
  </div>
</main>

<%- include('../partials/footer') %>
