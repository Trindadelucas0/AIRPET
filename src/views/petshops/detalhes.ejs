<% locals.titulo = petshop.nome %>
<% locals.extraHead = `
<link href="https://fonts.googleapis.com/css2?family=Rubik+Doodle+Shadow&family=Syne:wght@700;800&family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css">
<style>
  body { font-family:'DM Sans',sans-serif; }
  .det-wrap { max-width: 760px; margin: 0 auto; padding: 24px 20px 80px; }
  .page-topbar { position: sticky; top: 56px; z-index: 40; background: rgba(255,255,255,0.88); backdrop-filter: blur(20px); border-bottom: 1px solid var(--border); padding: 12px 0; }
  .topbar-inner { max-width: 760px; margin: 0 auto; padding: 0 20px; }
  .back-link { color: var(--text-dim); font-size: 13px; text-decoration: none; display: inline-flex; align-items: center; gap: 6px; }
  .back-link:hover { color: var(--accent); }
  .hero-card { background: var(--ink-2); border: 1px solid var(--border); border-radius: 18px; overflow: hidden; margin-bottom: 14px; }
  .hero-banner { height: 180px; background: linear-gradient(135deg, rgba(242,96,32,0.18) 0%, rgba(13,13,15,0.25) 100%); display: flex; align-items: flex-end; padding: 20px; }
  .tipo-chip { display: inline-flex; align-items: center; gap: 6px; padding: 5px 12px; border-radius: 100px; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: .08em; background: rgba(242,96,32,0.12); border: 1px solid rgba(242,96,32,0.24); color: var(--accent); }
  .hero-body { padding: 20px; }
  .hero-title { font-family: var(--font-display); font-size: 24px; font-weight: 800; color: var(--text); margin-bottom: 14px; }
  .info-row { display: flex; align-items: flex-start; gap: 12px; padding: 12px 0; border-bottom: 1px solid var(--border); }
  .info-row:last-child { border-bottom: none; }
  .info-icon { width: 36px; height: 36px; border-radius: 10px; background: var(--ink-3); display: flex; align-items: center; justify-content: center; flex-shrink: 0; color: var(--text-dim); }
  .info-label { font-size: 10px; font-weight: 700; color: var(--text-muted); text-transform: uppercase; letter-spacing: .08em; margin-bottom: 3px; }
  .info-val { font-size: 14px; color: var(--text); }
  .info-val a { color: var(--accent); text-decoration: none; }
  .actions-row { display: flex; gap: 10px; margin-top: 14px; flex-wrap: wrap; }
  .btn-action { flex: 1; display: inline-flex; align-items: center; justify-content: center; gap: 8px; padding: 12px 16px; border-radius: 11px; font-size: 14px; font-weight: 700; text-decoration: none; transition: all .2s; border: none; cursor: pointer; }
  .btn-action.primary { background: var(--accent); color: #fff; }
  .btn-action.primary:hover { background: var(--accent-light); transform: translateY(-1px); }
  .btn-action.ghost { background: var(--ink-3); color: var(--text-dim); border: 1px solid var(--border); }
  .btn-action.ghost:hover { border-color: var(--border-hover); color: var(--text); }
  .btn-action.secondary { background: rgba(242,96,32,.12); color: var(--accent); border: 1px solid rgba(242,96,32,.28); }
  .btn-action.secondary:hover { background: rgba(242,96,32,.2); }
  #mapPonto {
    height: 240px; border-radius: 14px; overflow: hidden; border: 1px solid var(--border);
    position: relative; z-index: 0; isolation: isolate;
  }
  #mapPonto .leaflet-container { z-index: 1; }
  .modal-shell {
    position: fixed; inset: 0; z-index: 10000; display: none;
    isolation: isolate;
  }
  .modal-shell.show { display: block; }
  .modal-overlay { position: absolute; inset: 0; z-index: 0; background: rgba(0,0,0,.45); backdrop-filter: blur(3px); }
  .modal-card {
    position: absolute; left: 50%; top: 50%; transform: translate(-50%, -50%);
    z-index: 1;
    width: min(94vw, 460px);
    background: var(--ink-2);
    border-radius: 18px;
    border: 1px solid var(--border);
    box-shadow: 0 24px 60px rgba(2, 6, 23, .25);
    padding: 16px;
  }
  .modal-title { font-size: 18px; font-weight: 900; color: var(--text); }
  .modal-hint { color: var(--text-dim); font-size: 13px; margin-top: 4px; }
  .toast-msg { font-size: 13px; margin-top: 8px; }
  .profile-bio { font-size: 14px; color: var(--text-dim); line-height: 1.7; margin-bottom: 12px; }
  .profile-stats { display: flex; gap: 16px; margin-bottom: 14px; }
  .profile-stats .item { min-width: 84px; }
  .profile-stats .num { color: var(--text); font-size: 18px; font-weight: 900; line-height: 1; }
  .profile-stats .lbl { color: var(--text-dim); font-size: 11px; text-transform: uppercase; letter-spacing: .08em; margin-top: 4px; }
  .section-card { background: var(--ink-2); border: 1px solid var(--border); border-radius: 18px; padding: 16px; margin-bottom: 14px; }
  .section-title { font-size: 13px; font-weight: 800; text-transform: uppercase; letter-spacing: .08em; color: var(--text-dim); margin-bottom: 10px; }
  .insta-grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 6px; }
  .insta-grid .cell { border-radius: 12px; overflow: hidden; background: var(--ink-3); border: 1px solid var(--border); aspect-ratio: 1/1; }
  .insta-grid .cell img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .promo-list { display: grid; grid-template-columns: 1fr; gap: 10px; }
  .promo-card { border: 1px solid var(--border); border-radius: 14px; overflow: hidden; background: var(--ink-3); }
  .promo-media { width: 100%; aspect-ratio: 16/9; background: var(--ink-2); }
  .promo-media img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .promo-body { padding: 12px; }
  .promo-preco { font-size: 18px; font-weight: 900; color: var(--accent); margin-top: 4px; }
  .list-clean { display: grid; gap: 10px; }
  .list-item { border: 1px solid var(--border); border-radius: 12px; padding: 11px; background: var(--ink-3); }
</style>
` %>
<%- include('../partials/header') %>
<%- include('../partials/flash') %>

<div class="page-topbar">
  <div class="topbar-inner">
    <a href="/petshops" class="back-link"><i class="fa-solid fa-arrow-left"></i> Voltar aos petshops</a>
  </div>
</div>

<main class="flex-1">
  <div class="det-wrap">
    <% const bioCurta = (profile && profile.descricao_curta) || petshop.descricao || ''; %>
    <% const totalFotos = (postsComFoto || []).length; %>
    <% const totalPromos = (promocoes || []).length; %>
    <div class="hero-card">
      <div class="hero-banner">
        <span class="tipo-chip"><i class="fa-solid fa-store"></i> Petshop parceiro</span>
      </div>
      <div class="hero-body">
        <h1 class="hero-title"><%= petshop.nome %></h1>
        <% if (profile && profile.slogan) { %>
          <p class="profile-bio"><strong><%= profile.slogan %></strong></p>
        <% } %>
        <% if (bioCurta) { %>
          <p class="profile-bio"><%= bioCurta %></p>
        <% } %>
        <div class="profile-stats">
          <div class="item"><p class="num"><%= totalFotos %></p><p class="lbl">Fotos</p></div>
          <div class="item"><p class="num"><%= totalPromos %></p><p class="lbl">Promoções</p></div>
          <div class="item"><p class="num"><%= followerCount || 0 %></p><p class="lbl">Seguidores</p></div>
        </div>

        <% if (petshop.descricao) { %>
          <p style="font-size:14px;color:var(--text-dim);line-height:1.7;margin-bottom:16px;"><%= petshop.descricao %></p>
        <% } %>

        <div>
          <% if (petshop.endereco) { %>
            <div class="info-row">
              <div class="info-icon"><i class="fa-solid fa-location-dot"></i></div>
              <div><div class="info-label">Endereço</div><div class="info-val"><%= petshop.endereco %></div></div>
            </div>
          <% } %>
          <% if (petshop.telefone) { %>
            <div class="info-row">
              <div class="info-icon"><i class="fa-solid fa-phone"></i></div>
              <div><div class="info-label">Telefone</div><div class="info-val"><a href="tel:<%= petshop.telefone %>"><%= petshop.telefone %></a></div></div>
            </div>
          <% } %>
          <% if (petshop.horario) { %>
            <div class="info-row">
              <div class="info-icon"><i class="fa-regular fa-clock"></i></div>
              <div><div class="info-label">Horário</div><div class="info-val"><%= petshop.horario %></div></div>
            </div>
          <% } %>
          <% if (petshop.website) { %>
            <div class="info-row">
              <div class="info-icon"><i class="fa-solid fa-globe"></i></div>
              <div><div class="info-label">Website</div><div class="info-val"><a href="<%= petshop.website %>" target="_blank" rel="noopener"><%= petshop.website.replace(/^https?:\/\//, '') %></a></div></div>
            </div>
          <% } %>
        </div>

        <div class="actions-row">
          <% if (typeof usuario !== 'undefined' && usuario) { %>
            <form action="/petshops/<%= petshop.id %>/seguir" method="POST" class="flex-1">
              <button class="btn-action ghost w-full" type="submit">
                <i class="fa-solid fa-heart"></i> <%= userSegue ? 'Seguindo' : 'Seguir perfil' %>
              </button>
            </form>
          <% } else { %>
            <a href="/auth/login" class="btn-action ghost">
              <i class="fa-solid fa-heart"></i> Entrar para seguir
            </a>
          <% } %>
          <% if (typeof usuario !== 'undefined' && usuario) { %>
            <button type="button" id="btnOpenLinkRequest" class="btn-action secondary">
              <i class="fa-solid fa-link"></i> Solicitar vínculo
            </button>
          <% } else { %>
            <a href="/auth/login" class="btn-action secondary">
              <i class="fa-solid fa-link"></i> Entrar para vincular
            </a>
          <% } %>
          <% if (petshop.latitude && petshop.longitude) { %>
            <a href="https://maps.google.com/?q=<%= petshop.latitude %>,<%= petshop.longitude %>" target="_blank" rel="noopener" class="btn-action primary">
              <i class="fa-solid fa-diamond-turn-right"></i> Como chegar
            </a>
          <% } %>
          <% if (petshop.telefone) { %>
            <a href="tel:<%= petshop.telefone %>" class="btn-action ghost">
              <i class="fa-solid fa-phone"></i> Ligar
            </a>
          <% } %>
          <% if (whatsappPerfilUrl) { %>
            <a href="<%= whatsappPerfilUrl %>" target="_blank" rel="noopener" class="btn-action primary">
              <i class="fa-brands fa-whatsapp"></i> WhatsApp
            </a>
          <% } %>
          <% if (profile && profile.instagram_url) { %>
            <a href="<%= profile.instagram_url %>" target="_blank" rel="noopener" class="btn-action ghost">
              <i class="fa-brands fa-instagram"></i> Instagram
            </a>
          <% } %>
        </div>
      </div>
    </div>

    <% if (petshop.latitude && petshop.longitude) { %>
      <div class="hero-card" style="padding:16px;">
        <div style="font-family:var(--font-display);font-size:13px;font-weight:700;color:var(--text-dim);text-transform:uppercase;letter-spacing:.08em;margin-bottom:12px;">Localização</div>
        <div id="mapPonto"></div>
      </div>
    <% } %>

    <section class="section-card">
      <h2 class="section-title">Fotos do dia a dia</h2>
      <% if (!totalFotos) { %>
        <p class="text-sm text-gray-500">Este parceiro ainda não publicou fotos do feed.</p>
      <% } else { %>
        <div class="insta-grid">
          <% (postsComFoto || []).forEach(function(post) { %>
            <div class="cell">
              <img src="<%= post.foto_url %>" alt="<%= post.titulo || 'Foto do petshop' %>">
            </div>
          <% }) %>
        </div>
      <% } %>
    </section>

    <section class="section-card">
      <h2 class="section-title">Promoções</h2>
      <% if (!totalPromos) { %>
        <p class="text-sm text-gray-500">Nenhuma promoção ativa no momento.</p>
      <% } else { %>
        <div class="promo-list">
          <% (promocoes || []).forEach(function(pr) { %>
            <article class="promo-card">
              <% if (pr.foto_url) { %>
                <div class="promo-media"><img src="<%= pr.foto_url %>" alt="<%= pr.nome || 'Promoção' %>"></div>
              <% } %>
              <div class="promo-body">
                <p class="font-bold text-gray-900"><%= pr.nome || 'Promoção' %></p>
                <% if (pr.preco_label) { %><p class="promo-preco"><%= pr.preco_label %></p><% } %>
                <% if (pr.descricao) { %><p class="text-sm text-gray-600 mt-1"><%= pr.descricao %></p><% } %>
                <% if (pr.whatsapp_link) { %>
                  <a href="<%= pr.whatsapp_link %>" target="_blank" rel="noopener" class="btn-action primary !mt-3 !text-sm !py-2.5">
                    <i class="fa-brands fa-whatsapp"></i> Comprar no WhatsApp
                  </a>
                <% } else { %>
                  <p class="text-xs text-gray-500 mt-2">Este parceiro ainda não configurou WhatsApp público.</p>
                <% } %>
              </div>
            </article>
          <% }) %>
        </div>
      <% } %>
    </section>

    <section class="section-card">
      <h2 class="section-title">Módulos profissionais</h2>
      <% if ((servicos || []).length) { %>
        <div class="list-clean mb-3">
          <% (servicos || []).forEach(function(s) { %>
            <div class="list-item">
              <p class="font-semibold text-gray-900"><%= s.nome %></p>
              <p class="text-sm text-gray-500"><%= s.duracao_minutos || '-' %> min <% if (s.preco_base != null) { %>· R$ <%= Number(s.preco_base).toFixed(2).replace('.', ',') %><% } %></p>
            </div>
          <% }) %>
        </div>
      <% } else { %>
        <p class="text-sm text-gray-500 mb-3">Serviços ainda não cadastrados.</p>
      <% } %>
      <div class="list-item">
        <p class="text-sm text-gray-600">Avaliação média</p>
        <p class="font-bold text-gray-900"><%= reviewSummary && reviewSummary.rating_medio ? Number(reviewSummary.rating_medio).toFixed(1).replace('.', ',') : 'Sem avaliações' %></p>
      </div>
      <% if ((reviews || []).length) { %>
        <div class="list-clean mt-3">
          <% (reviews || []).slice(0, 3).forEach(function(r) { %>
            <div class="list-item">
              <p class="font-semibold text-gray-900"><%= r.usuario_nome || 'Tutor' %></p>
              <p class="text-xs text-gray-500">Nota <%= r.rating %>/5</p>
              <% if (r.comentario) { %><p class="text-sm text-gray-600 mt-1"><%= r.comentario %></p><% } %>
            </div>
          <% }) %>
        </div>
      <% } %>
    </section>
  </div>
</main>

<% if (typeof usuario !== 'undefined' && usuario) { %>
<div id="modalLinkRequest" class="modal-shell" aria-hidden="true" role="dialog" aria-modal="true" aria-labelledby="modalLinkRequestTitle">
  <div class="modal-overlay" id="closeLinkOverlay"></div>
  <div class="modal-card">
    <div class="flex items-center justify-between gap-2">
      <h3 id="modalLinkRequestTitle" class="modal-title">Solicitar vínculo com PetParceiro</h3>
      <button type="button" id="closeLinkModal" class="text-gray-400 hover:text-gray-700" aria-label="Fechar">
        <i class="fa-solid fa-xmark"></i>
      </button>
    </div>
    <p class="modal-hint">Selecione um pet seu para pedir vínculo com <strong><%= petshop.nome %></strong>.</p>
    <div class="mt-3 space-y-2">
      <label class="text-xs font-semibold uppercase tracking-wide text-gray-400">Seu pet</label>
      <select id="petSelectForLink" class="input w-full">
        <option value="">Escolha um pet</option>
        <% (meusPets || []).forEach(function(p) { %>
          <% const statusV = (statusSolicitacoesPorPet && statusSolicitacoesPorPet[p.id]) || 'disponivel'; %>
          <option value="<%= p.id %>" data-status="<%= statusV %>">
            <%= p.nome %> · <%= statusV === 'aprovada' ? 'vinculado' : statusV === 'pendente' ? 'pendente' : 'disponível' %>
          </option>
        <% }) %>
      </select>
      <label class="text-xs font-semibold uppercase tracking-wide text-gray-400">Mensagem (opcional)</label>
      <textarea id="linkRequestMessage" class="input w-full min-h-20" maxlength="280" placeholder="Ex: já atendemos nesse petshop e queremos exibir no perfil do pet."></textarea>
    </div>
    <div class="mt-4 flex gap-2 justify-end">
      <button type="button" id="cancelLinkRequest" class="btn-action ghost !flex-none !px-4 !py-2">Cancelar</button>
      <button type="button" id="submitLinkRequest" class="btn-action primary !flex-none !px-4 !py-2">
        <i class="fa-solid fa-paper-plane"></i> Enviar solicitação
      </button>
    </div>
    <p id="linkRequestToast" class="toast-msg text-gray-500"></p>
  </div>
</div>
<% } %>

<% if (petshop.latitude && petshop.longitude) { %>
<% locals.extraScripts = `
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script>
(function(){
  var map = L.map('mapPonto',{ zoomControl:false }).setView([${petshop.latitude}, ${petshop.longitude}], 15);
  L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png',{ attribution:'© OSM' }).addTo(map);
  var icon = L.divIcon({
    html:'<div style="width:36px;height:36px;border-radius:50%;background:#f26020;border:3px solid #fff;display:flex;align-items:center;justify-content:center;box-shadow:0 4px 12px rgba(0,0,0,.25);"><i class="fa-solid fa-store" style="color:#fff;font-size:13px;"></i></div>',
    className:'',
    iconSize:[36,36],
    iconAnchor:[18,18]
  });
  L.marker([${petshop.latitude}, ${petshop.longitude}], { icon:icon }).addTo(map).bindPopup('<strong>${String(petshop.nome || '').replace(/'/g, "\\'")}</strong>').openPopup();
})();
</script>
` %>
<% } %>

<% if (typeof usuario !== 'undefined' && usuario) { %>
<script>
(function () {
  var petshopId = '<%= petshop.id %>';
  var modal = document.getElementById('modalLinkRequest');
  var btnOpen = document.getElementById('btnOpenLinkRequest');
  var btnClose = document.getElementById('closeLinkModal');
  var btnCancel = document.getElementById('cancelLinkRequest');
  var overlay = document.getElementById('closeLinkOverlay');
  var btnSubmit = document.getElementById('submitLinkRequest');
  var select = document.getElementById('petSelectForLink');
  var textarea = document.getElementById('linkRequestMessage');
  var toast = document.getElementById('linkRequestToast');
  var prevBodyOverflow = '';
  var lastFocusEl = null;

  function petshopDetalhesDeferred(workFn, message) {
    var L = window.AIRPET_LOADING;
    if (L && typeof L.withDeferredOverlay === 'function') {
      return L.withDeferredOverlay(workFn, { message: message || 'Ainda a processar…' });
    }
    return Promise.resolve().then(workFn);
  }

  function openModal() {
    if (!modal) return;
    lastFocusEl = document.activeElement;
    prevBodyOverflow = document.body.style.overflow;
    document.body.style.overflow = 'hidden';
    modal.classList.add('show');
    modal.setAttribute('aria-hidden', 'false');
    if (btnClose) {
      setTimeout(function () { btnClose.focus(); }, 0);
    }
  }
  function closeModal() {
    if (!modal || !modal.classList.contains('show')) return;
    modal.classList.remove('show');
    modal.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = prevBodyOverflow;
    if (lastFocusEl && typeof lastFocusEl.focus === 'function') {
      try { lastFocusEl.focus(); } catch (e) {}
    }
    lastFocusEl = null;
  }
  function setToast(msg, isError) {
    toast.textContent = msg || '';
    toast.className = 'toast-msg ' + (isError ? 'text-red-600' : 'text-emerald-600');
  }

  document.addEventListener('keydown', function (e) {
    if (e.key !== 'Escape') return;
    if (modal && modal.classList.contains('show')) closeModal();
  });

  if (btnOpen) btnOpen.addEventListener('click', openModal);
  if (btnClose) btnClose.addEventListener('click', closeModal);
  if (btnCancel) btnCancel.addEventListener('click', closeModal);
  if (overlay) overlay.addEventListener('click', closeModal);

  btnSubmit.addEventListener('click', function () {
    var petId = select.value ? parseInt(select.value, 10) : null;
    if (!petId) {
      setToast('Escolha um pet para solicitar vínculo.', true);
      return;
    }
    var currentStatus = select.options[select.selectedIndex].getAttribute('data-status');
    if (currentStatus === 'aprovada') {
      setToast('Esse pet já está vinculado a este PetParceiro.', true);
      return;
    }
    if (currentStatus === 'pendente') {
      setToast('Já existe solicitação pendente para esse pet.', true);
      return;
    }
    var body = JSON.stringify({ pet_id: petId, mensagem: (textarea.value || '').trim() });
    var busy = '<i class="fa-solid fa-spinner fa-spin"></i> <span class="airpet-inline-dots">Enviando</span>';
    var work = function () {
      return petshopDetalhesDeferred(function () {
        return fetch('/petshops/' + petshopId + '/solicitar-vinculo', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
          credentials: 'same-origin',
          body: body
        })
          .then(function (r) { return r.json().then(function (d) { return { ok: r.ok, data: d }; }); })
          .then(function (result) {
            if (!result.ok || !result.data.sucesso) {
              setToast((result.data && result.data.mensagem) || 'Não foi possível enviar a solicitação.', true);
              return result;
            }
            setToast('Solicitação enviada com sucesso.', false);
            select.options[select.selectedIndex].setAttribute('data-status', 'pendente');
            closeModal();
            return result;
          })
          .catch(function () {
            setToast('Erro de conexão ao enviar solicitação.', true);
            throw new Error('network');
          });
      }, 'A enviar solicitação…');
    };
    var p = window.AIRPET_LOADING
      ? window.AIRPET_LOADING.runLocked({ button: btnSubmit, busyText: busy }, work)
      : work();
    p.catch(function () {});
  });
})();
</script>
<% } %>

<%- include('../partials/footer') %>
