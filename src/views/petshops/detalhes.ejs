<% locals.titulo = petshop.nome %>
<% locals.extraHead = `
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css">
<style>
  body { font-family:'DM Sans',sans-serif; }
  .det-wrap { max-width: 760px; margin: 0 auto; padding: 24px 20px 80px; }
  .page-topbar { position: sticky; top: 56px; z-index: 40; background: rgba(255,255,255,0.88); backdrop-filter: blur(20px); border-bottom: 1px solid var(--border); padding: 12px 0; }
  .topbar-inner { max-width: 760px; margin: 0 auto; padding: 0 20px; }
  .back-link { color: var(--text-dim); font-size: 13px; text-decoration: none; display: inline-flex; align-items: center; gap: 6px; }
  .back-link:hover { color: var(--accent); }
  .hero-card { background: var(--ink-2); border: 1px solid var(--border); border-radius: 18px; overflow: hidden; margin-bottom: 14px; }
  .hero-banner { height: 180px; background: linear-gradient(135deg, rgba(242,96,32,0.18) 0%, rgba(13,13,15,0.25) 100%); display: flex; align-items: flex-end; padding: 20px; }
  .tipo-chip { display: inline-flex; align-items: center; gap: 6px; padding: 5px 12px; border-radius: 100px; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: .08em; background: rgba(242,96,32,0.12); border: 1px solid rgba(242,96,32,0.24); color: var(--accent); }
  .hero-body { padding: 20px; }
  .hero-title { font-family: 'Syne',sans-serif; font-size: 24px; font-weight: 800; color: var(--text); margin-bottom: 14px; }
  .info-row { display: flex; align-items: flex-start; gap: 12px; padding: 12px 0; border-bottom: 1px solid var(--border); }
  .info-row:last-child { border-bottom: none; }
  .info-icon { width: 36px; height: 36px; border-radius: 10px; background: var(--ink-3); display: flex; align-items: center; justify-content: center; flex-shrink: 0; color: var(--text-dim); }
  .info-label { font-size: 10px; font-weight: 700; color: var(--text-muted); text-transform: uppercase; letter-spacing: .08em; margin-bottom: 3px; }
  .info-val { font-size: 14px; color: var(--text); }
  .info-val a { color: var(--accent); text-decoration: none; }
  .actions-row { display: flex; gap: 10px; margin-top: 14px; flex-wrap: wrap; }
  .btn-action { flex: 1; display: inline-flex; align-items: center; justify-content: center; gap: 8px; padding: 12px 16px; border-radius: 11px; font-size: 14px; font-weight: 700; text-decoration: none; transition: all .2s; border: none; cursor: pointer; }
  .btn-action.primary { background: var(--accent); color: #fff; }
  .btn-action.primary:hover { background: var(--accent-light); transform: translateY(-1px); }
  .btn-action.ghost { background: var(--ink-3); color: var(--text-dim); border: 1px solid var(--border); }
  .btn-action.ghost:hover { border-color: var(--border-hover); color: var(--text); }
  #mapPonto { height: 240px; border-radius: 14px; overflow: hidden; border: 1px solid var(--border); }
</style>
` %>
<%- include('../partials/header') %>
<%- include('../partials/flash') %>

<div class="page-topbar">
  <div class="topbar-inner">
    <a href="/petshops" class="back-link"><i class="fa-solid fa-arrow-left"></i> Voltar aos petshops</a>
  </div>
</div>

<main class="flex-1">
  <div class="det-wrap">
    <div class="hero-card">
      <div class="hero-banner">
        <span class="tipo-chip"><i class="fa-solid fa-store"></i> Petshop parceiro</span>
      </div>
      <div class="hero-body">
        <h1 class="hero-title"><%= petshop.nome %></h1>

        <% if (petshop.descricao) { %>
          <p style="font-size:14px;color:var(--text-dim);line-height:1.7;margin-bottom:16px;"><%= petshop.descricao %></p>
        <% } %>

        <div>
          <% if (petshop.endereco) { %>
            <div class="info-row">
              <div class="info-icon"><i class="fa-solid fa-location-dot"></i></div>
              <div><div class="info-label">Endereço</div><div class="info-val"><%= petshop.endereco %></div></div>
            </div>
          <% } %>
          <% if (petshop.telefone) { %>
            <div class="info-row">
              <div class="info-icon"><i class="fa-solid fa-phone"></i></div>
              <div><div class="info-label">Telefone</div><div class="info-val"><a href="tel:<%= petshop.telefone %>"><%= petshop.telefone %></a></div></div>
            </div>
          <% } %>
          <% if (petshop.horario) { %>
            <div class="info-row">
              <div class="info-icon"><i class="fa-regular fa-clock"></i></div>
              <div><div class="info-label">Horário</div><div class="info-val"><%= petshop.horario %></div></div>
            </div>
          <% } %>
          <% if (petshop.website) { %>
            <div class="info-row">
              <div class="info-icon"><i class="fa-solid fa-globe"></i></div>
              <div><div class="info-label">Website</div><div class="info-val"><a href="<%= petshop.website %>" target="_blank" rel="noopener"><%= petshop.website.replace(/^https?:\/\//, '') %></a></div></div>
            </div>
          <% } %>
        </div>

        <div class="actions-row">
          <% if (petshop.latitude && petshop.longitude) { %>
            <a href="https://maps.google.com/?q=<%= petshop.latitude %>,<%= petshop.longitude %>" target="_blank" rel="noopener" class="btn-action primary">
              <i class="fa-solid fa-diamond-turn-right"></i> Como chegar
            </a>
          <% } %>
          <% if (petshop.telefone) { %>
            <a href="tel:<%= petshop.telefone %>" class="btn-action ghost">
              <i class="fa-solid fa-phone"></i> Ligar
            </a>
          <% } %>
        </div>
      </div>
    </div>

    <% if (petshop.latitude && petshop.longitude) { %>
      <div class="hero-card" style="padding:16px;">
        <div style="font-family:'Syne',sans-serif;font-size:13px;font-weight:700;color:var(--text-dim);text-transform:uppercase;letter-spacing:.08em;margin-bottom:12px;">Localização</div>
        <div id="mapPonto"></div>
      </div>
    <% } %>
  </div>
</main>

<% if (petshop.latitude && petshop.longitude) { %>
<% locals.extraScripts = `
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script>
(function(){
  var map = L.map('mapPonto',{ zoomControl:false }).setView([${petshop.latitude}, ${petshop.longitude}], 15);
  L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png',{ attribution:'© OSM' }).addTo(map);
  var icon = L.divIcon({
    html:'<div style="width:36px;height:36px;border-radius:50%;background:#f26020;border:3px solid #fff;display:flex;align-items:center;justify-content:center;box-shadow:0 4px 12px rgba(0,0,0,.25);"><i class="fa-solid fa-store" style="color:#fff;font-size:13px;"></i></div>',
    className:'',
    iconSize:[36,36],
    iconAnchor:[18,18]
  });
  L.marker([${petshop.latitude}, ${petshop.longitude}], { icon:icon }).addTo(map).bindPopup('<strong>${String(petshop.nome || '').replace(/'/g, "\\'")}</strong>').openPopup();
})();
</script>
` %>
<% } %>

<%- include('../partials/footer') %>
