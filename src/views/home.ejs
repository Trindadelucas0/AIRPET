<% locals.titulo = 'AIRPET — Proteja seu pet' %>
<%- include('partials/header') %>
<%- include('partials/flash') %>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,700;1,9..40,400&display=swap');

  :root {
    --ink: #fff7ed;
    --ink-2: #ffffff;
    --ink-3: #fff3e8;
    --surface: #ffffff;
    --muted: #6b7280;
    --subtle: #9ca3af;
    --text: #1f2937;
    --text-dim: #6b7280;
    --accent: #f26020;
    --accent-light: #ff7a3d;
    --accent-glow: rgba(242,96,32,0.14);
    --green: #22c55e;
    --radius: 20px;
  }

  * { box-sizing: border-box; }

  body.home-page {
    background: var(--ink);
    color: var(--text);
    font-family: 'DM Sans', sans-serif;
  }

  .display-font { font-family: 'Bebas Neue', sans-serif; letter-spacing: 0.02em; }

  /* ── NOISE OVERLAY ── */
  body.home-page::before {
    content: '';
    position: fixed; inset: 0; z-index: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.03'/%3E%3C/svg%3E");
    pointer-events: none;
  }

  /* ── HERO ── */
  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    position: relative;
    overflow: hidden;
    padding: 0;
    margin-top: -56px;
  }

  .hero-grid {
    position: absolute; inset: 0;
    background-image:
      linear-gradient(rgba(242,96,32,0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(242,96,32,0.04) 1px, transparent 1px);
    background-size: 60px 60px;
    mask-image: radial-gradient(ellipse 80% 60% at 50% 0%, black 40%, transparent 100%);
  }

  .hero-glow-1 {
    position: absolute;
    width: 700px; height: 700px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(242,96,32,0.12) 0%, transparent 70%);
    top: -200px; right: -200px;
    pointer-events: none;
  }

  .hero-glow-2 {
    position: absolute;
    width: 400px; height: 400px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(100,80,255,0.06) 0%, transparent 70%);
    bottom: 0; left: -100px;
    pointer-events: none;
  }

  .hero-inner {
    position: relative; z-index: 2;
    max-width: 1200px;
    margin: 0 auto;
    padding: 120px 24px 80px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: center;
  }

  @media (max-width: 900px) {
    .hero-inner { grid-template-columns: 1fr; gap: 48px; }
    .hero-visual { display: none; }
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 6px 14px;
    background: rgba(242,96,32,0.1);
    border: 1px solid rgba(242,96,32,0.25);
    border-radius: 100px;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent-light);
    margin-bottom: 28px;
  }

  .hero-dot {
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--green);
    box-shadow: 0 0 0 3px rgba(34,197,94,0.25);
    animation: pulse-dot 2s ease-in-out infinite;
  }

  @keyframes pulse-dot {
    0%, 100% { box-shadow: 0 0 0 3px rgba(34,197,94,0.25); }
    50% { box-shadow: 0 0 0 6px rgba(34,197,94,0.1); }
  }

  .hero-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(72px, 8vw, 108px);
    line-height: 0.95;
    letter-spacing: 0.01em;
    color: var(--text);
    margin: 0 0 24px;
  }

  .hero-title .accent-word {
    color: var(--accent);
    position: relative;
    display: inline-block;
  }

  .hero-title .accent-word::after {
    content: '';
    position: absolute;
    bottom: 4px; left: 0; right: 0;
    height: 3px;
    background: var(--accent);
    border-radius: 2px;
    transform: scaleX(0);
    transform-origin: left;
    animation: line-reveal 0.8s 0.6s cubic-bezier(0.4,0,0.2,1) forwards;
  }

  @keyframes line-reveal { to { transform: scaleX(1); } }

  .hero-sub {
    font-size: 17px;
    font-weight: 400;
    color: var(--text-dim);
    line-height: 1.7;
    max-width: 440px;
    margin: 0 0 40px;
  }

  .hero-cta-row {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    align-items: center;
  }

  .btn-primary-dark {
    display: inline-flex; align-items: center; gap: 10px;
    padding: 14px 28px;
    background: var(--accent);
    color: #fff;
    border-radius: 12px;
    font-weight: 700;
    font-size: 15px;
    transition: all 0.2s;
    border: none; cursor: pointer;
    text-decoration: none;
    box-shadow: 0 0 0 0 var(--accent-glow);
  }
  .btn-primary-dark:hover {
    background: var(--accent-light);
    transform: translateY(-2px);
    box-shadow: 0 8px 32px rgba(242,96,32,0.3);
    color: #fff; text-decoration: none;
  }

  .btn-ghost-dark {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 14px 24px;
    background: transparent;
    color: var(--text-dim);
    border-radius: 12px;
    font-weight: 500;
    font-size: 15px;
    border: 1px solid var(--muted);
    transition: all 0.2s;
    text-decoration: none;
  }
  .btn-ghost-dark:hover {
    border-color: var(--subtle);
    color: var(--text);
    background: var(--ink-2);
    text-decoration: none;
  }

  .btn-partner {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 14px 24px;
    background: rgba(34,197,94,0.1);
    color: var(--green);
    border-radius: 12px;
    font-weight: 600;
    font-size: 14px;
    border: 1px solid rgba(34,197,94,0.2);
    transition: all 0.2s;
    text-decoration: none;
  }
  .btn-partner:hover {
    background: rgba(34,197,94,0.18);
    color: #4ade80; text-decoration: none;
    transform: translateY(-1px);
  }

  /* ── HERO VISUAL ── */
  .hero-visual {
    position: relative;
    display: flex;
    justify-content: center;
  }

  .phone-mockup {
    width: 280px;
    height: 560px;
    background: var(--ink-2);
    border-radius: 36px;
    border: 1.5px solid var(--ink-3);
    position: relative;
    overflow: hidden;
    box-shadow:
      0 0 0 1px rgba(255,255,255,0.04),
      0 40px 80px rgba(0,0,0,0.6),
      0 0 80px var(--accent-glow);
    animation: float-phone 6s ease-in-out infinite;
  }

  @keyframes float-phone {
    0%, 100% { transform: translateY(0px) rotate(2deg); }
    50% { transform: translateY(-16px) rotate(2deg); }
  }

  .phone-notch {
    width: 100px; height: 28px;
    background: var(--ink);
    border-radius: 0 0 20px 20px;
    margin: 0 auto;
    position: relative; z-index: 2;
  }

  .phone-screen {
    padding: 0 14px;
    position: relative;
  }

  .phone-story-row {
    display: flex; gap: 8px; padding: 12px 0 8px;
    overflow: hidden;
  }

  .phone-story-item {
    width: 44px; flex-shrink: 0;
    display: flex; flex-direction: column; align-items: center; gap: 4px;
  }

  .phone-story-ring {
    width: 44px; height: 44px;
    border-radius: 50%;
    background: var(--ink-3);
    border: 2px solid var(--accent);
    display: flex; align-items: center; justify-content: center;
    font-size: 18px;
  }

  .phone-story-name {
    font-size: 8px; color: var(--text-dim);
    font-family: 'DM Sans', sans-serif;
  }

  .phone-post {
    background: var(--ink-3);
    border-radius: 14px;
    overflow: hidden;
    margin-bottom: 10px;
  }

  .phone-post-header {
    display: flex; align-items: center; gap: 8px; padding: 10px 12px 6px;
  }

  .phone-avatar {
    width: 28px; height: 28px; border-radius: 50%;
    background: var(--accent); opacity: 0.7;
  }

  .phone-post-name {
    font-size: 10px; font-weight: 700; color: var(--text);
    font-family: 'DM Sans', sans-serif;
  }

  .phone-post-img {
    width: 100%; height: 120px;
    background: linear-gradient(135deg, #2a2020 0%, #3d2d1a 100%);
    display: flex; align-items: center; justify-content: center;
    font-size: 36px;
  }

  .phone-post-actions {
    display: flex; gap: 12px; padding: 8px 12px;
  }

  .phone-action-btn {
    font-size: 12px; color: var(--text-dim);
    display: flex; align-items: center; gap: 4px;
    font-family: 'DM Sans', sans-serif;
  }

  .phone-post-2 .phone-post-img {
    background: linear-gradient(135deg, #1a2a20 0%, #0d3020 100%);
  }

  /* ── STAT STRIP ── */
  .stat-strip {
    background: var(--ink-2);
    border-top: 1px solid var(--ink-3);
    border-bottom: 1px solid var(--ink-3);
  }

  .stat-strip-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 32px 24px;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background: var(--ink-3);
  }

  @media (max-width: 600px) { .stat-strip-inner { grid-template-columns: repeat(2, 1fr); } }

  .stat-item {
    background: var(--ink-2);
    padding: 28px 24px;
    text-align: center;
  }

  .stat-number {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 48px;
    line-height: 1;
    color: var(--text);
    letter-spacing: 0.02em;
  }

  .stat-label {
    font-size: 12px;
    font-weight: 500;
    color: var(--subtle);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-top: 4px;
  }

  /* ── HOW IT WORKS ── */
  .section-dark {
    background: var(--ink);
    padding: 100px 24px;
    position: relative;
  }

  .section-label {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 16px;
  }

  .section-label::before {
    content: '';
    width: 24px; height: 1px;
    background: var(--accent);
  }

  .section-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(44px, 5vw, 72px);
    color: var(--text);
    line-height: 1;
    margin: 0 0 16px;
    letter-spacing: 0.01em;
  }

  .section-sub {
    font-size: 16px;
    color: var(--text-dim);
    max-width: 500px;
    line-height: 1.7;
  }

  .steps-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2px;
    margin-top: 64px;
    background: var(--ink-3);
    border-radius: 20px;
    overflow: hidden;
  }

  @media (max-width: 700px) { .steps-grid { grid-template-columns: 1fr; } }

  .step-card {
    background: var(--ink-2);
    padding: 44px 36px;
    position: relative;
    overflow: hidden;
    transition: background 0.3s;
  }

  .step-card:hover { background: var(--ink-3); }

  .step-card::before {
    content: attr(data-num);
    font-family: 'Bebas Neue', sans-serif;
    font-size: 120px;
    color: rgba(255,255,255,0.025);
    position: absolute;
    bottom: -20px; right: 16px;
    line-height: 1;
    pointer-events: none;
  }

  .step-icon {
    width: 52px; height: 52px;
    border-radius: 14px;
    background: var(--accent-glow);
    border: 1px solid rgba(242,96,32,0.2);
    display: flex; align-items: center; justify-content: center;
    font-size: 22px;
    margin-bottom: 24px;
    color: var(--accent-light);
  }

  .step-num {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 10px;
  }

  .step-title {
    font-size: 20px;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 10px;
  }

  .step-desc {
    font-size: 14px;
    color: var(--text-dim);
    line-height: 1.7;
  }

  /* ── FEATURES ── */
  .features-section {
    background: var(--ink-2);
    padding: 100px 24px;
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2px;
    margin-top: 64px;
    background: var(--ink-3);
    border-radius: 20px;
    overflow: hidden;
  }

  @media (max-width: 700px) { .features-grid { grid-template-columns: 1fr; } }

  .feature-card {
    background: var(--ink-2);
    padding: 40px 36px;
    transition: background 0.3s;
  }

  .feature-card:hover { background: var(--ink-3); }

  .feature-pill {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 4px 12px;
    border-radius: 100px;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 20px;
  }

  .pill-orange { background: rgba(242,96,32,0.12); color: var(--accent-light); }
  .pill-blue   { background: rgba(100,80,255,0.12); color: #a78bfa; }
  .pill-green  { background: rgba(34,197,94,0.12); color: #4ade80; }
  .pill-pink   { background: rgba(236,72,153,0.12); color: #f472b6; }

  .feature-title {
    font-size: 22px;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 10px;
    line-height: 1.3;
  }

  .feature-desc {
    font-size: 14px;
    color: var(--text-dim);
    line-height: 1.7;
  }

  .feature-icon-large {
    font-size: 40px;
    margin-bottom: 24px;
    display: block;
  }

  /* ── LOST PETS ── */
  .lost-section {
    background: var(--ink);
    padding: 100px 24px;
  }

  .lost-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    margin-top: 48px;
  }

  @media (max-width: 700px) { .lost-grid { grid-template-columns: repeat(2, 1fr); } }

  .lost-card {
    background: var(--ink-2);
    border-radius: 16px;
    overflow: hidden;
    border: 1px solid var(--ink-3);
    transition: all 0.3s;
    position: relative;
  }

  .lost-card:hover {
    border-color: var(--muted);
    transform: translateY(-4px);
    box-shadow: 0 20px 40px rgba(0,0,0,0.4);
  }

  .lost-img {
    width: 100%; height: 160px;
    object-fit: cover;
    background: var(--ink-3);
    display: flex; align-items: center; justify-content: center;
    color: var(--muted);
    font-size: 32px;
  }

  .lost-badge {
    position: absolute; top: 10px; left: 10px;
    display: inline-flex; align-items: center; gap: 6px;
    padding: 4px 10px;
    background: rgba(239,68,68,0.9);
    backdrop-filter: blur(8px);
    border-radius: 100px;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #fff;
  }

  .lost-ping {
    width: 6px; height: 6px; border-radius: 50%; background: #fff;
    animation: ping 1s ease-in-out infinite;
  }

  @keyframes ping {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(1.3); }
  }

  .lost-info { padding: 16px; }

  .lost-name {
    font-size: 16px; font-weight: 700; color: var(--text); margin-bottom: 4px;
  }

  .lost-raca {
    font-size: 12px; color: var(--text-dim); margin-bottom: 12px;
  }

  .lost-btn {
    display: block; text-align: center;
    padding: 9px;
    background: rgba(239,68,68,0.1);
    color: #f87171;
    border: 1px solid rgba(239,68,68,0.2);
    border-radius: 10px;
    font-size: 13px;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.2s;
  }
  .lost-btn:hover { background: rgba(239,68,68,0.18); color: #fca5a5; text-decoration: none; }

  /* ── CTA ── */
  .cta-section {
    background: var(--ink-2);
    padding: 100px 24px;
    position: relative;
    overflow: hidden;
  }

  .cta-section::before {
    content: '';
    position: absolute;
    top: 50%; left: 50%; transform: translate(-50%, -50%);
    width: 600px; height: 600px;
    background: radial-gradient(circle, rgba(242,96,32,0.08) 0%, transparent 70%);
    pointer-events: none;
  }

  .cta-inner {
    max-width: 600px;
    margin: 0 auto;
    text-align: center;
    position: relative; z-index: 1;
  }

  .cta-icon {
    width: 80px; height: 80px;
    border-radius: 24px;
    background: var(--accent-glow);
    border: 1px solid rgba(242,96,32,0.2);
    display: flex; align-items: center; justify-content: center;
    font-size: 36px;
    color: var(--accent);
    margin: 0 auto 32px;
  }

  .cta-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(52px, 6vw, 80px);
    color: var(--text);
    line-height: 1;
    margin-bottom: 16px;
  }

  .cta-sub {
    font-size: 16px;
    color: var(--text-dim);
    line-height: 1.7;
    margin-bottom: 40px;
  }

  /* ── SCROLL REVEAL ── */
  .reveal {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.7s ease-out, transform 0.7s ease-out;
  }
  .reveal.visible { opacity: 1; transform: none; }
  .reveal-delay-1 { transition-delay: 0.1s; }
  .reveal-delay-2 { transition-delay: 0.2s; }
  .reveal-delay-3 { transition-delay: 0.3s; }

  /* ── ANIMATE ON LOAD ── */
  @keyframes fade-up {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .anim-1 { animation: fade-up 0.6s 0.1s both; }
  .anim-2 { animation: fade-up 0.6s 0.25s both; }
  .anim-3 { animation: fade-up 0.6s 0.4s both; }
  .anim-4 { animation: fade-up 0.6s 0.55s both; }
</style>

<script>document.body.classList.add('home-page');</script>

<!-- ═══════════════ HERO ═══════════════ -->
<section class="hero">
  <div class="hero-grid"></div>
  <div class="hero-glow-1"></div>
  <div class="hero-glow-2"></div>

  <div class="hero-inner">
    <!-- Left: Copy -->
    <div>
      <div class="hero-badge anim-1">
        <span class="hero-dot"></span>
        NFC + Rede Social para Pets
      </div>

      <h1 class="hero-title anim-2">
        A REDE QUE<br>
        <span class="accent-word">PROTEGE</span><br>
        SEU PET
      </h1>

      <p class="hero-sub anim-3">
        Tags NFC inteligentes, localização em tempo real e uma comunidade apaixonada por pets. Tudo para manter seu companheiro sempre seguro.
      </p>

      <div class="hero-cta-row anim-4">
        <a href="/auth/registro" class="btn-primary-dark">
          <i class="fa-solid fa-paw"></i>
          Criar Conta Grátis
        </a>
        <a href="/auth/login" class="btn-ghost-dark">
          <i class="fa-solid fa-right-to-bracket"></i>
          Entrar
        </a>
        <a href="/parceiros/cadastro" class="btn-partner">
          <i class="fa-solid fa-store"></i>
          Ser parceiro
        </a>
      </div>

      <p style="margin-top: 20px; font-size: 12px; color: var(--subtle);">
        Sem cartão de crédito &nbsp;·&nbsp; Cadastro em 30 segundos
      </p>
    </div>

    <!-- Right: Phone mockup -->
    <div class="hero-visual">
      <div class="phone-mockup">
        <div class="phone-notch"></div>
        <div class="phone-screen">
          <div class="phone-story-row">
            <div class="phone-story-item">
              <div class="phone-story-ring">🐶</div>
              <span class="phone-story-name">Rex</span>
            </div>
            <div class="phone-story-item">
              <div class="phone-story-ring" style="border-color:#a78bfa">🐱</div>
              <span class="phone-story-name">Mimi</span>
            </div>
            <div class="phone-story-item">
              <div class="phone-story-ring" style="border-color:#4ade80">🐩</div>
              <span class="phone-story-name">Bolinha</span>
            </div>
            <div class="phone-story-item">
              <div class="phone-story-ring" style="border-color:#f472b6">🦜</div>
              <span class="phone-story-name">Loro</span>
            </div>
          </div>

          <div class="phone-post">
            <div class="phone-post-header">
              <div class="phone-avatar"></div>
              <div>
                <div class="phone-post-name">João & Buddy</div>
              </div>
            </div>
            <div class="phone-post-img">🐾</div>
            <div class="phone-post-actions">
              <span class="phone-action-btn"><i class="fa-regular fa-heart"></i> 42</span>
              <span class="phone-action-btn"><i class="fa-regular fa-comment"></i> 7</span>
              <span class="phone-action-btn"><i class="fa-solid fa-retweet"></i> 3</span>
            </div>
