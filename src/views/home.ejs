<% locals.titulo = 'AIRPET — Cadastre seu pet e nunca mais o perca' %>
<%- include('partials/header') %>
<%- include('partials/flash') %>

<style>
  :root {
    --ink: #fff7ed;
    --ink-2: #ffffff;
    --ink-3: #fff3e8;
    --surface: #ffffff;
    --muted: #6b7280;
    --subtle: #9ca3af;
    --text: #1f2937;
    --text-dim: #6b7280;
    --accent: #f26020;
    --accent-light: #ff7a3d;
    --accent-glow: rgba(242,96,32,0.14);
    --green: #22c55e;
    --red: #ef4444;
    --radius: 20px;
  }

  * { box-sizing: border-box; }

  body.home-page {
    background: var(--ink);
    color: var(--text);
    font-family: 'DM Sans', sans-serif;
  }

  body.home-page #mobileMenuBtn,
  body.home-page #mobileMenu {
    display: none !important;
  }

  .display-font { font-family: var(--font-display); letter-spacing: 0.02em; }

  /* ── NOISE OVERLAY ── */
  body.home-page::before {
    content: '';
    position: fixed; inset: 0; z-index: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.03'/%3E%3C/svg%3E");
    pointer-events: none;
  }

  /* ── HERO ── */
  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    position: relative;
    overflow: hidden;
    padding: 0;
    margin-top: -56px;
  }

  .hero-grid {
    position: absolute; inset: 0;
    background-image:
      linear-gradient(rgba(242,96,32,0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(242,96,32,0.04) 1px, transparent 1px);
    background-size: 60px 60px;
    mask-image: radial-gradient(ellipse 80% 60% at 50% 0%, black 40%, transparent 100%);
  }

  .hero-glow-1 {
    position: absolute;
    width: 700px; height: 700px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(242,96,32,0.12) 0%, transparent 70%);
    top: -200px; right: -200px;
    pointer-events: none;
  }

  .hero-glow-2 {
    position: absolute;
    width: 400px; height: 400px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(100,80,255,0.06) 0%, transparent 70%);
    bottom: 0; left: -100px;
    pointer-events: none;
  }

  .hero-inner {
    position: relative; z-index: 2;
    max-width: 1200px;
    margin: 0 auto;
    padding: 120px 24px 80px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: center;
  }

  @media (max-width: 900px) {
    .hero-inner { grid-template-columns: 1fr; gap: 48px; }
    .hero-visual { display: none; }
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 6px 14px;
    background: rgba(239,68,68,0.1);
    border: 1px solid rgba(239,68,68,0.25);
    border-radius: 100px;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #f87171;
    margin-bottom: 28px;
  }

  .hero-dot {
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--red);
    box-shadow: 0 0 0 3px rgba(239,68,68,0.25);
    animation: pulse-dot 2s ease-in-out infinite;
  }

  @keyframes pulse-dot {
    0%, 100% { box-shadow: 0 0 0 3px rgba(239,68,68,0.25); }
    50% { box-shadow: 0 0 0 6px rgba(239,68,68,0.1); }
  }

  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(52px, 6.5vw, 96px);
    line-height: 0.97;
    letter-spacing: 0.01em;
    color: var(--text);
    margin: 0 0 24px;
  }

  .hero-title .accent-word {
    color: var(--accent);
    position: relative;
    display: inline-block;
  }

  .hero-title .accent-word::after {
    content: '';
    position: absolute;
    bottom: 4px; left: 0; right: 0;
    height: 3px;
    background: var(--accent);
    border-radius: 2px;
    transform: scaleX(0);
    transform-origin: left;
    animation: line-reveal 0.8s 0.6s cubic-bezier(0.4,0,0.2,1) forwards;
  }

  @keyframes line-reveal { to { transform: scaleX(1); } }

  .hero-sub {
    font-size: 17px;
    font-weight: 400;
    color: var(--text-dim);
    line-height: 1.7;
    max-width: 460px;
    margin: 0 0 36px;
  }

  .hero-cta-stack {
    display: flex;
    flex-direction: column;
    gap: 12px;
    align-items: flex-start;
  }

  .hero-cta-row {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    align-items: center;
  }

  .hero-microcopy {
    font-size: 12px;
    color: var(--subtle);
    margin: 0;
    line-height: 1.5;
  }

  .hero-scan-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 13px;
    color: var(--text-dim);
    text-decoration: none;
    border-bottom: 1px dashed var(--muted);
    padding-bottom: 1px;
    transition: color 0.2s;
  }
  .hero-scan-link:hover { color: var(--text); text-decoration: none; }

  .btn-primary {
    display: inline-flex; align-items: center; gap: 10px;
    padding: 15px 30px;
    background: var(--accent);
    color: #fff;
    border-radius: 12px;
    font-weight: 700;
    font-size: 16px;
    transition: all 0.2s;
    border: none; cursor: pointer;
    text-decoration: none;
    box-shadow: 0 4px 20px rgba(242,96,32,0.25);
  }
  .btn-primary:hover {
    background: var(--accent-light);
    transform: translateY(-2px);
    box-shadow: 0 8px 32px rgba(242,96,32,0.35);
    color: #fff; text-decoration: none;
  }

  .btn-outline {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 14px 24px;
    background: transparent;
    color: var(--text-dim);
    border-radius: 12px;
    font-weight: 500;
    font-size: 15px;
    border: 1px solid var(--muted);
    transition: all 0.2s;
    text-decoration: none;
  }
  .btn-outline:hover {
    border-color: var(--subtle);
    color: var(--text);
    background: var(--ink-2);
    text-decoration: none;
  }

  .btn-ghost {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 14px 24px;
    background: transparent;
    color: var(--text-dim);
    border-radius: 12px;
    font-weight: 500;
    font-size: 15px;
    border: 1px solid var(--muted);
    transition: all 0.2s;
    text-decoration: none;
  }
  .btn-ghost:hover {
    border-color: var(--subtle);
    color: var(--text);
    background: var(--ink-2);
    text-decoration: none;
  }

  /* ── HERO VISUAL: phone mostrando scan/alerta ── */
  .hero-visual {
    position: relative;
    display: flex;
    justify-content: center;
  }

  .phone-mockup {
    width: 272px;
    height: 540px;
    background: #111827;
    border-radius: 36px;
    border: 1.5px solid rgba(255,255,255,0.08);
    position: relative;
    overflow: hidden;
    box-shadow:
      0 0 0 1px rgba(255,255,255,0.04),
      0 40px 80px rgba(0,0,0,0.55),
      0 0 80px var(--accent-glow);
    animation: float-phone 6s ease-in-out infinite;
  }

  @keyframes float-phone {
    0%, 100% { transform: translateY(0px) rotate(1.5deg); }
    50% { transform: translateY(-14px) rotate(1.5deg); }
  }

  .phone-notch {
    width: 90px; height: 26px;
    background: #111827;
    border-radius: 0 0 18px 18px;
    margin: 0 auto;
    position: relative; z-index: 2;
  }

  .phone-screen {
    padding: 6px 14px 14px;
  }

  /* Alerta no topo */
  .phone-alert-bar {
    background: rgba(239,68,68,0.15);
    border: 1px solid rgba(239,68,68,0.3);
    border-radius: 12px;
    padding: 10px 12px;
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 12px;
  }

  .phone-alert-icon {
    width: 32px; height: 32px;
    border-radius: 50%;
    background: rgba(239,68,68,0.2);
    display: flex; align-items: center; justify-content: center;
    font-size: 16px;
    flex-shrink: 0;
  }

  .phone-alert-text-title {
    font-size: 10px;
    font-weight: 700;
    color: #fca5a5;
    font-family: 'DM Sans', sans-serif;
    line-height: 1.3;
  }

  .phone-alert-text-sub {
    font-size: 9px;
    color: rgba(252,165,165,0.7);
    font-family: 'DM Sans', sans-serif;
    margin-top: 1px;
  }

  /* Mapa simulado */
  .phone-map {
    background: linear-gradient(135deg, #1a2234 0%, #1e2d3d 100%);
    border-radius: 12px;
    height: 130px;
    position: relative;
    overflow: hidden;
    margin-bottom: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .phone-map-grid {
    position: absolute; inset: 0;
    background-image:
      linear-gradient(rgba(255,255,255,0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.04) 1px, transparent 1px);
    background-size: 20px 20px;
  }

  .phone-map-pin {
    position: relative; z-index: 2;
    width: 36px; height: 36px;
    background: var(--red);
    border-radius: 50% 50% 50% 0;
    transform: rotate(-45deg);
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 0 0 6px rgba(239,68,68,0.2);
    animation: pin-pulse 2s ease-in-out infinite;
  }

  .phone-map-pin::after {
    content: '🐶';
    transform: rotate(45deg);
    font-size: 14px;
    position: absolute;
  }

  @keyframes pin-pulse {
    0%, 100% { box-shadow: 0 0 0 6px rgba(239,68,68,0.2); }
    50% { box-shadow: 0 0 0 12px rgba(239,68,68,0.08); }
  }

  .phone-map-label {
    position: absolute;
    bottom: 10px; left: 10px;
    background: rgba(0,0,0,0.6);
    backdrop-filter: blur(8px);
    border-radius: 8px;
    padding: 4px 8px;
    font-size: 9px;
    color: #e5e7eb;
    font-family: 'DM Sans', sans-serif;
    font-weight: 600;
  }

  /* Botão CTA scan */
  .phone-cta-btn {
    background: var(--accent);
    border-radius: 12px;
    padding: 14px;
    text-align: center;
    margin-bottom: 10px;
  }

  .phone-cta-btn-text {
    font-size: 12px;
    font-weight: 800;
    color: #fff;
    letter-spacing: 0.02em;
    font-family: 'DM Sans', sans-serif;
  }

  .phone-cta-btn-sub {
    font-size: 9px;
    color: rgba(255,255,255,0.75);
    font-family: 'DM Sans', sans-serif;
    margin-top: 2px;
  }

  /* Ações rápidas */
  .phone-actions-row {
    display: flex;
    gap: 8px;
  }

  .phone-action {
    flex: 1;
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 10px;
    padding: 10px 6px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
  }

  .phone-action-icon {
    font-size: 16px;
  }

  .phone-action-label {
    font-size: 8px;
    color: rgba(255,255,255,0.5);
    font-family: 'DM Sans', sans-serif;
    text-align: center;
    line-height: 1.3;
  }

  /* Flutuante: notificação lateral */
  .phone-float-notif {
    position: absolute;
    top: 110px; right: -80px;
    width: 160px;
    background: var(--ink-2);
    border: 1px solid var(--ink-3);
    border-radius: 14px;
    padding: 10px 12px;
    box-shadow: 0 8px 32px rgba(0,0,0,0.2);
    animation: float-notif 6s ease-in-out infinite 1s;
  }

  @keyframes float-notif {
    0%, 100% { transform: translateY(0px); }
    50% { transform: translateY(-8px); }
  }

  .phone-float-notif-title {
    font-size: 10px;
    font-weight: 700;
    color: var(--text);
    font-family: 'DM Sans', sans-serif;
    margin-bottom: 3px;
  }

  .phone-float-notif-sub {
    font-size: 9px;
    color: var(--text-dim);
    font-family: 'DM Sans', sans-serif;
    line-height: 1.4;
  }

  .phone-float-notif-dot {
    display: inline-block;
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--green);
    margin-right: 4px;
    vertical-align: middle;
  }

  /* ── PROOF STRIP ── */
  .proof-strip {
    background: var(--ink-2);
    border-top: 1px solid var(--ink-3);
    border-bottom: 1px solid var(--ink-3);
  }

  .proof-strip-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 28px 24px;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--ink-3);
  }

  @media (max-width: 600px) { .proof-strip-inner { grid-template-columns: 1fr; } }

  .proof-item {
    background: var(--ink-2);
    padding: 24px 28px;
    display: flex;
    align-items: flex-start;
    gap: 14px;
  }

  .proof-icon {
    width: 40px; height: 40px;
    border-radius: 10px;
    display: flex; align-items: center; justify-content: center;
    font-size: 18px;
    flex-shrink: 0;
  }

  .proof-icon-red { background: rgba(239,68,68,0.1); }
  .proof-icon-orange { background: rgba(242,96,32,0.1); }
  .proof-icon-green { background: rgba(34,197,94,0.1); }

  .proof-text-title {
    font-size: 14px;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 3px;
    line-height: 1.3;
  }

  .proof-text-sub {
    font-size: 12px;
    color: var(--text-dim);
    line-height: 1.5;
  }

  /* ── STAT STRIP ── */
  .stat-strip {
    background: var(--ink);
    border-bottom: 1px solid var(--ink-3);
  }

  .stat-strip-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 32px 24px;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background: var(--ink-3);
    border-radius: 20px;
    overflow: hidden;
  }

  @media (max-width: 600px) { .stat-strip-inner { grid-template-columns: repeat(2, 1fr); } }

  .stat-item {
    background: var(--ink);
    padding: 28px 24px;
    text-align: center;
  }

  .stat-number {
    font-family: var(--font-display);
    font-size: 48px;
    line-height: 1;
    color: var(--text);
    letter-spacing: 0.02em;
  }

  .stat-label {
    font-size: 12px;
    font-weight: 500;
    color: var(--subtle);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-top: 4px;
  }

  /* ── SHARED SECTION ── */
  .section-dark {
    background: var(--ink);
    padding: 100px 24px;
    position: relative;
  }

  .section-light {
    background: var(--ink-2);
    padding: 100px 24px;
  }

  .section-label {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 16px;
  }

  .section-label::before {
    content: '';
    width: 24px; height: 1px;
    background: var(--accent);
  }

  .section-title {
    font-family: var(--font-display);
    font-size: clamp(44px, 5vw, 72px);
    color: var(--text);
    line-height: 1;
    margin: 0 0 16px;
    letter-spacing: 0.01em;
  }

  .section-sub {
    font-size: 16px;
    color: var(--text-dim);
    max-width: 500px;
    line-height: 1.7;
  }

  /* ── HOW IT WORKS ── */
  .steps-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2px;
    margin-top: 64px;
    background: var(--ink-3);
    border-radius: 20px;
    overflow: hidden;
  }

  @media (max-width: 700px) { .steps-grid { grid-template-columns: 1fr; } }

  .step-card {
    background: var(--ink-2);
    padding: 44px 36px;
    position: relative;
    overflow: hidden;
    transition: background 0.3s;
  }

  .step-card:hover { background: var(--ink-3); }

  .step-card::before {
    content: attr(data-num);
    font-family: var(--font-display);
    font-size: 120px;
    color: rgba(242,96,32,0.04);
    position: absolute;
    bottom: -20px; right: 16px;
    line-height: 1;
    pointer-events: none;
  }

  .step-icon {
    width: 52px; height: 52px;
    border-radius: 14px;
    background: var(--accent-glow);
    border: 1px solid rgba(242,96,32,0.2);
    display: flex; align-items: center; justify-content: center;
    font-size: 22px;
    margin-bottom: 24px;
    color: var(--accent-light);
  }

  .step-num {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 10px;
  }

  .step-title {
    font-size: 20px;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 10px;
  }

  .step-desc {
    font-size: 14px;
    color: var(--text-dim);
    line-height: 1.7;
  }

  /* ── EMOTIONAL SECTION ── */
  .emotional-section {
    background: var(--ink);
    padding: 100px 24px;
    position: relative;
    overflow: hidden;
  }

  .emotional-section::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(239,68,68,0.3), transparent);
  }

  .emotional-inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  .emotional-title {
    font-family: var(--font-display);
    font-size: clamp(38px, 4.5vw, 64px);
    line-height: 1.05;
    color: var(--text);
    margin: 0 0 56px;
    max-width: 700px;
    letter-spacing: 0.01em;
  }

  .emotional-title .accent-red {
    color: #f87171;
  }

  .emotional-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2px;
    background: var(--ink-3);
    border-radius: 20px;
    overflow: hidden;
  }

  @media (max-width: 700px) { .emotional-grid { grid-template-columns: 1fr; } }

  .emotional-card {
    padding: 44px 40px;
  }

  .emotional-card-pain {
    background: #1c1010;
  }

  .emotional-card-solution {
    background: var(--ink-2);
  }

  .emotional-card-label {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    border-radius: 100px;
    padding: 4px 12px;
    margin-bottom: 24px;
  }

  .label-pain {
    background: rgba(239,68,68,0.15);
    color: #fca5a5;
    border: 1px solid rgba(239,68,68,0.2);
  }

  .label-solution {
    background: rgba(34,197,94,0.1);
    color: #4ade80;
    border: 1px solid rgba(34,197,94,0.2);
  }

  .emotional-card-title {
    font-size: 22px;
    font-weight: 700;
    margin-bottom: 14px;
    line-height: 1.3;
  }

  .emotional-card-pain .emotional-card-title { color: #fca5a5; }
  .emotional-card-solution .emotional-card-title { color: var(--text); }

  .emotional-card-body {
    font-size: 15px;
    line-height: 1.75;
  }

  .emotional-card-pain .emotional-card-body { color: rgba(252,165,165,0.65); }
  .emotional-card-solution .emotional-card-body { color: var(--text-dim); }

  .emotional-steps {
    margin-top: 20px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .emotional-step {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 14px;
    color: var(--text-dim);
  }

  .emotional-step-num {
    width: 22px; height: 22px;
    border-radius: 50%;
    background: rgba(34,197,94,0.15);
    border: 1px solid rgba(34,197,94,0.25);
    display: flex; align-items: center; justify-content: center;
    font-size: 10px;
    font-weight: 700;
    color: #4ade80;
    flex-shrink: 0;
  }

  /* ── DIFFERENTIALS ── */
  .diff-section {
    background: var(--ink-2);
    padding: 100px 24px;
  }

  .diff-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2px;
    margin-top: 64px;
    background: var(--ink-3);
    border-radius: 20px;
    overflow: hidden;
  }

  @media (max-width: 700px) { .diff-grid { grid-template-columns: 1fr; } }

  .diff-card {
    background: var(--ink-2);
    padding: 40px 36px;
    transition: background 0.3s;
    position: relative;
    overflow: hidden;
  }

  .diff-card:hover { background: var(--ink-3); }

  .diff-pill {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 4px 12px;
    border-radius: 100px;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 20px;
  }

  .pill-red    { background: rgba(239,68,68,0.1); color: #f87171; }
  .pill-orange { background: rgba(242,96,32,0.12); color: var(--accent-light); }
  .pill-green  { background: rgba(34,197,94,0.12); color: #4ade80; }
  .pill-blue   { background: rgba(100,80,255,0.12); color: #a78bfa; }

  .diff-icon-large {
    font-size: 38px;
    margin-bottom: 20px;
    display: block;
  }

  .diff-title {
    font-size: 21px;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 10px;
    line-height: 1.3;
  }

  .diff-desc {
    font-size: 14px;
    color: var(--text-dim);
    line-height: 1.7;
  }

  /* ── LOST PETS ── */
  .lost-section {
    background: var(--ink);
    padding: 100px 24px;
  }

  .lost-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    margin-top: 48px;
  }

  @media (max-width: 700px) { .lost-grid { grid-template-columns: repeat(2, 1fr); } }

  .lost-card {
    background: var(--ink-2);
    border-radius: 16px;
    overflow: hidden;
    border: 1px solid var(--ink-3);
    transition: all 0.3s;
    position: relative;
  }

  .lost-card:hover {
    border-color: var(--muted);
    transform: translateY(-4px);
    box-shadow: 0 20px 40px rgba(0,0,0,0.4);
  }

  .lost-img {
    width: 100%; height: 160px;
    object-fit: cover;
    background: var(--ink-3);
    display: flex; align-items: center; justify-content: center;
    color: var(--muted);
    font-size: 32px;
  }

  .lost-badge {
    position: absolute; top: 10px; left: 10px;
    display: inline-flex; align-items: center; gap: 6px;
    padding: 4px 10px;
    background: rgba(239,68,68,0.9);
    backdrop-filter: blur(8px);
    border-radius: 100px;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #fff;
  }

  .lost-ping {
    width: 6px; height: 6px; border-radius: 50%; background: #fff;
    animation: ping 1s ease-in-out infinite;
  }

  @keyframes ping {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(1.3); }
  }

  .lost-info { padding: 16px; }

  .lost-name {
    font-size: 16px; font-weight: 700; color: var(--text); margin-bottom: 4px;
  }

  .lost-raca {
    font-size: 12px; color: var(--text-dim); margin-bottom: 12px;
  }

  .lost-btn {
    display: block; text-align: center;
    padding: 9px;
    background: rgba(239,68,68,0.1);
    color: #f87171;
    border: 1px solid rgba(239,68,68,0.2);
    border-radius: 10px;
    font-size: 13px;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.2s;
  }
  .lost-btn:hover { background: rgba(239,68,68,0.18); color: #fca5a5; text-decoration: none; }

  /* ── PARTNER (compacto) ── */
  .partner-compact-section {
    background: var(--ink-2);
    padding: 64px 24px;
    border-top: 1px solid var(--ink-3);
    border-bottom: 1px solid var(--ink-3);
  }

  .partner-compact-inner {
    max-width: 900px;
    margin: 0 auto;
    background: var(--ink);
    border: 1px solid var(--ink-3);
    border-radius: 20px;
    padding: 36px 40px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    flex-wrap: wrap;
  }

  .partner-compact-text {}

  .partner-compact-title {
    font-size: 20px;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 6px;
  }

  .partner-compact-sub {
    font-size: 14px;
    color: var(--text-dim);
    line-height: 1.6;
    max-width: 460px;
  }

  .btn-partner {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 13px 22px;
    background: rgba(34,197,94,0.1);
    color: var(--green);
    border-radius: 12px;
    font-weight: 600;
    font-size: 14px;
    border: 1px solid rgba(34,197,94,0.2);
    transition: all 0.2s;
    text-decoration: none;
    white-space: nowrap;
  }
  .btn-partner:hover {
    background: rgba(34,197,94,0.18);
    color: #4ade80; text-decoration: none;
    transform: translateY(-1px);
  }

  /* ── CTA FINAL ── */
  .cta-section {
    background: var(--ink-2);
    padding: 100px 24px;
    position: relative;
    overflow: hidden;
  }

  .cta-section::before {
    content: '';
    position: absolute;
    top: 50%; left: 50%; transform: translate(-50%, -50%);
    width: 600px; height: 600px;
    background: radial-gradient(circle, rgba(242,96,32,0.08) 0%, transparent 70%);
    pointer-events: none;
  }

  .cta-inner {
    max-width: 600px;
    margin: 0 auto;
    text-align: center;
    position: relative; z-index: 1;
  }

  .cta-icon {
    width: 80px; height: 80px;
    border-radius: 24px;
    background: var(--accent-glow);
    border: 1px solid rgba(242,96,32,0.2);
    display: flex; align-items: center; justify-content: center;
    font-size: 36px;
    color: var(--accent);
    margin: 0 auto 32px;
  }

  .cta-title {
    font-family: var(--font-display);
    font-size: clamp(44px, 5.5vw, 72px);
    color: var(--text);
    line-height: 1;
    margin-bottom: 16px;
  }

  .cta-sub {
    font-size: 16px;
    color: var(--text-dim);
    line-height: 1.7;
    margin-bottom: 40px;
  }

  /* ── SCROLL REVEAL ── */
  .reveal {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.7s ease-out, transform 0.7s ease-out;
  }
  .reveal.visible { opacity: 1; transform: none; }
  .reveal-delay-1 { transition-delay: 0.1s; }
  .reveal-delay-2 { transition-delay: 0.2s; }
  .reveal-delay-3 { transition-delay: 0.3s; }

  /* ── ANIMATE ON LOAD ── */
  @keyframes fade-up {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .anim-1 { animation: fade-up 0.6s 0.1s both; }
  .anim-2 { animation: fade-up 0.6s 0.25s both; }
  .anim-3 { animation: fade-up 0.6s 0.4s both; }
  .anim-4 { animation: fade-up 0.6s 0.55s both; }
  .anim-5 { animation: fade-up 0.6s 0.7s both; }

  /* ── INSTALL CTA ── */
  .install-section {
    background: var(--ink);
    padding: 56px 24px 100px;
  }

  .install-inner {
    max-width: 760px;
    margin: 0 auto;
    background: var(--ink-2);
    border: 1px solid var(--ink-3);
    border-radius: 20px;
    padding: 28px;
  }

  .install-title {
    font-size: 28px;
    font-weight: 700;
    color: var(--text);
    margin: 0 0 8px;
  }

  .install-sub {
    font-size: 14px;
    color: var(--text-dim);
    line-height: 1.6;
    margin: 0 0 18px;
  }

  .install-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }

  .install-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 12px 18px;
    border-radius: 12px;
    border: 1px solid var(--ink-3);
    background: transparent;
    color: var(--text);
    font-size: 14px;
    font-weight: 700;
    cursor: pointer;
    transition: all 0.2s;
  }

  .install-btn:hover {
    background: var(--ink-3);
    transform: translateY(-1px);
  }

  .install-status {
    margin-top: 14px;
    font-size: 13px;
    color: var(--subtle);
    min-height: 20px;
  }
</style>

<script>document.body.classList.add('home-page');</script>

