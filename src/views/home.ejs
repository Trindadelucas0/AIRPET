<% locals.titulo = 'Bem-vindo' %>
<%- include('partials/header') %>
<%- include('partials/flash') %>

<style>
  @keyframes float { 0%,100% { transform: translateY(0) rotate(0deg); } 50% { transform: translateY(-18px) rotate(6deg); } }
  @keyframes floatSlow { 0%,100% { transform: translateY(0) rotate(0deg); } 50% { transform: translateY(-12px) rotate(-4deg); } }
  @keyframes pawWalk { 0% { opacity:0; transform: translateY(10px) rotate(-20deg); } 30% { opacity:1; } 70% { opacity:1; } 100% { opacity:0; transform: translateY(-20px) rotate(20deg); } }
  @keyframes pulse-ring { 0% { transform: scale(0.8); opacity: 0.5; } 100% { transform: scale(1.6); opacity: 0; } }
  @keyframes countUp { from { opacity:0; transform: translateY(12px); } to { opacity:1; transform: translateY(0); } }
  .anim-float { animation: float 6s ease-in-out infinite; }
  .anim-float-slow { animation: floatSlow 8s ease-in-out infinite; }
  .anim-float-delay { animation: float 7s ease-in-out 1s infinite; }
  .anim-paw { animation: pawWalk 3s ease-in-out infinite; }
  .anim-paw-2 { animation: pawWalk 3s ease-in-out 1s infinite; }
  .anim-paw-3 { animation: pawWalk 3s ease-in-out 2s infinite; }
  .pulse-ring { animation: pulse-ring 2s cubic-bezier(0.4,0,0.6,1) infinite; }
  .hero-gradient { background: linear-gradient(135deg, #ec5a1c 0%, #c44415 40%, #a33610 100%); }
  .feature-glass { background: rgba(255,255,255,0.7); backdrop-filter: blur(24px); -webkit-backdrop-filter: blur(24px); border: 1px solid rgba(255,255,255,0.6); }
  .stat-gradient { background: linear-gradient(135deg, #1e1b4b 0%, #312e81 50%, #3730a3 100%); }
  .cta-gradient { background: linear-gradient(135deg, #ec5a1c 0%, #d4500f 50%, #b8430d 100%); }
  .scroll-reveal { opacity: 0; transform: translateY(30px); transition: opacity 0.7s ease-out, transform 0.7s ease-out; }
  .scroll-reveal.revealed { opacity: 1; transform: translateY(0); }
  .step-line { position: relative; }
  .step-line::after { content:''; position:absolute; top:64px; left:50%; width:2px; height:calc(100% - 64px); background: linear-gradient(to bottom, #ec5a1c, transparent); }
  @media(min-width:768px) { .step-line::after { display:none; } }
</style>

<!-- ═══════════════ HERO ═══════════════ -->
<section class="relative min-h-screen hero-gradient overflow-hidden flex items-center -mt-14">

  <!-- Decorative shapes -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none" aria-hidden="true">
    <div class="absolute -top-24 -right-24 w-96 h-96 rounded-full bg-white/5 anim-float"></div>
    <div class="absolute top-1/3 -left-16 w-72 h-72 rounded-full bg-white/5 anim-float-slow"></div>
    <div class="absolute bottom-20 right-1/4 w-48 h-48 rounded-full bg-white/[0.04] anim-float-delay"></div>
    <div class="absolute top-1/2 right-10 w-32 h-32 rounded-full bg-orange-300/10 anim-float-slow"></div>
    <div class="absolute bottom-32 left-10 w-20 h-20 rounded-full bg-yellow-300/10 anim-float"></div>

    <!-- Paw prints floating -->
    <svg class="absolute top-[18%] left-[12%] w-10 h-10 text-white/10 anim-paw" fill="currentColor" viewBox="0 0 512 512"><path d="M226.5 92.9c14.3 42.9-.3 86.2-32.6 96.8s-70.1-15.6-84.4-58.5s.3-86.2 32.6-96.8s70.1 15.6 84.4 58.5zM100.4 198.6c18.9 32.4 14.3 70.1-10.2 84.1s-59.7-.9-78.5-33.3S-2.7 179.3 21.8 165.3s59.7 .9 78.5 33.3zM69.2 401.2C121.6 259.9 214.7 224 256 224s134.4 35.9 186.8 177.2c3.6 9.7 5.2 20.1 5.2 30.5v1.6c0 25.8-20.9 46.7-46.7 46.7c-11.5 0-22.9-1.4-34-4.2l-88-22c-15.3-3.8-31.3-3.8-46.6 0l-88 22c-11.1 2.8-22.5 4.2-34 4.2C84.9 480 64 459.1 64 433.3v-1.6c0-10.4 1.6-20.8 5.2-30.5zM421.8 282.7c-24.5-14-29.1-51.7-10.2-84.1s54-47.3 78.5-33.3s29.1 51.7 10.2 84.1s-54 47.3-78.5 33.3zM310.1 189.7c-32.3-10.6-46.9-53.9-32.6-96.8s52.1-69.1 84.4-58.5s46.9 53.9 32.6 96.8s-52.1 69.1-84.4 58.5z"/></svg>
    <svg class="absolute top-[40%] right-[15%] w-8 h-8 text-white/[0.07] anim-paw-2" fill="currentColor" viewBox="0 0 512 512"><path d="M226.5 92.9c14.3 42.9-.3 86.2-32.6 96.8s-70.1-15.6-84.4-58.5s.3-86.2 32.6-96.8s70.1 15.6 84.4 58.5zM100.4 198.6c18.9 32.4 14.3 70.1-10.2 84.1s-59.7-.9-78.5-33.3S-2.7 179.3 21.8 165.3s59.7 .9 78.5 33.3zM69.2 401.2C121.6 259.9 214.7 224 256 224s134.4 35.9 186.8 177.2c3.6 9.7 5.2 20.1 5.2 30.5v1.6c0 25.8-20.9 46.7-46.7 46.7c-11.5 0-22.9-1.4-34-4.2l-88-22c-15.3-3.8-31.3-3.8-46.6 0l-88 22c-11.1 2.8-22.5 4.2-34 4.2C84.9 480 64 459.1 64 433.3v-1.6c0-10.4 1.6-20.8 5.2-30.5zM421.8 282.7c-24.5-14-29.1-51.7-10.2-84.1s54-47.3 78.5-33.3s29.1 51.7 10.2 84.1s-54 47.3-78.5 33.3zM310.1 189.7c-32.3-10.6-46.9-53.9-32.6-96.8s52.1-69.1 84.4-58.5s46.9 53.9 32.6 96.8s-52.1 69.1-84.4 58.5z"/></svg>
    <svg class="absolute bottom-[25%] left-[30%] w-6 h-6 text-white/[0.06] anim-paw-3" fill="currentColor" viewBox="0 0 512 512"><path d="M226.5 92.9c14.3 42.9-.3 86.2-32.6 96.8s-70.1-15.6-84.4-58.5s.3-86.2 32.6-96.8s70.1 15.6 84.4 58.5zM100.4 198.6c18.9 32.4 14.3 70.1-10.2 84.1s-59.7-.9-78.5-33.3S-2.7 179.3 21.8 165.3s59.7 .9 78.5 33.3zM69.2 401.2C121.6 259.9 214.7 224 256 224s134.4 35.9 186.8 177.2c3.6 9.7 5.2 20.1 5.2 30.5v1.6c0 25.8-20.9 46.7-46.7 46.7c-11.5 0-22.9-1.4-34-4.2l-88-22c-15.3-3.8-31.3-3.8-46.6 0l-88 22c-11.1 2.8-22.5 4.2-34 4.2C84.9 480 64 459.1 64 433.3v-1.6c0-10.4 1.6-20.8 5.2-30.5zM421.8 282.7c-24.5-14-29.1-51.7-10.2-84.1s54-47.3 78.5-33.3s29.1 51.7 10.2 84.1s-54 47.3-78.5 33.3zM310.1 189.7c-32.3-10.6-46.9-53.9-32.6-96.8s52.1-69.1 84.4-58.5s46.9 53.9 32.6 96.8s-52.1 69.1-84.4 58.5z"/></svg>
  </div>

  <div class="relative z-10 max-w-5xl mx-auto px-4 sm:px-6 py-20 pt-28 text-center">
    <!-- Badge -->
    <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-white/15 backdrop-blur-sm text-white/90 text-xs font-semibold tracking-wide mb-8 animate-fadeIn">
      <span class="relative flex h-2 w-2">
        <span class="absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75 pulse-ring"></span>
        <span class="relative inline-flex rounded-full h-2 w-2 bg-green-400"></span>
      </span>
      Proteção NFC + Rede Social para Pets
    </div>

    <h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-black text-white leading-[1.1] tracking-tight mb-6 animate-slideUp">
      A rede social que<br>
      <span class="relative inline-block">
        <span class="relative z-10">protege seu pet</span>
        <span class="absolute bottom-1 left-0 right-0 h-3 sm:h-4 bg-white/20 rounded-full -skew-x-3"></span>
      </span>
    </h1>

    <p class="text-lg sm:text-xl text-white/80 max-w-2xl mx-auto mb-10 animate-slideUp font-medium leading-relaxed" style="animation-delay: 0.15s">
      Tags NFC inteligentes, localização em tempo real e uma comunidade apaixonada por pets.
      Tudo para manter seu companheiro <strong class="text-white">sempre seguro</strong>.
    </p>

    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 animate-slideUp" style="animation-delay: 0.3s">
      <a href="/auth/registro"
         class="group flex items-center gap-2.5 px-8 py-4 bg-white text-primary-600 rounded-2xl font-bold text-base shadow-2xl shadow-black/20 hover:shadow-xl hover:-translate-y-1 transition-all duration-300">
        <i class="fa-solid fa-rocket group-hover:rotate-12 transition-transform duration-300"></i>
        Criar Conta Grátis
      </a>
      <a href="/auth/login"
         class="flex items-center gap-2.5 px-8 py-4 bg-white/15 backdrop-blur-sm text-white rounded-2xl font-semibold text-base border border-white/25 hover:bg-white/25 hover:-translate-y-1 transition-all duration-300">
        <i class="fa-solid fa-right-to-bracket"></i>
        Já tenho conta
      </a>
    </div>

    <!-- Scroll indicator -->
    <div class="mt-16 animate-fadeIn" style="animation-delay: 1s">
      <div class="inline-flex flex-col items-center gap-2 text-white/40">
        <span class="text-xs font-medium tracking-widest uppercase">Descubra mais</span>
        <i class="fa-solid fa-chevron-down text-sm animate-bounce"></i>
      </div>
    </div>
  </div>
</section>


<!-- ═══════════════ COMO FUNCIONA ═══════════════ -->
<section class="py-20 sm:py-28 bg-white relative overflow-hidden">
  <div class="absolute top-0 left-0 right-0 h-24 bg-gradient-to-b from-gray-50/50 to-transparent"></div>

  <div class="max-w-5xl mx-auto px-4 sm:px-6 relative">
    <div class="text-center mb-16 scroll-reveal">
      <span class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-primary-50 text-primary-600 text-xs font-bold tracking-wide mb-4">
        <i class="fa-solid fa-wand-magic-sparkles"></i> SIMPLES E RÁPIDO
      </span>
      <h2 class="text-3xl sm:text-4xl font-black text-gray-900 mb-4">Como funciona?</h2>
      <p class="text-gray-500 max-w-xl mx-auto">Em apenas 3 passos seu pet estará protegido com tecnologia NFC de ponta.</p>
    </div>

    <div class="grid md:grid-cols-3 gap-8 md:gap-6 relative">
      <!-- Connector line desktop -->
      <div class="hidden md:block absolute top-16 left-[20%] right-[20%] h-0.5 bg-gradient-to-r from-primary-200 via-primary-400 to-primary-200 rounded-full"></div>

      <!-- Step 1 -->
      <div class="scroll-reveal text-center relative z-10" data-delay="0">
        <div class="relative inline-flex mb-6">
          <div class="w-28 h-28 rounded-3xl bg-gradient-to-br from-primary-500 to-primary-600 flex items-center justify-center shadow-2xl shadow-primary-500/30 rotate-3 hover:rotate-0 transition-transform duration-500">
            <i class="fa-solid fa-tag text-4xl text-white"></i>
          </div>
          <span class="absolute -top-3 -right-3 w-10 h-10 rounded-xl bg-white shadow-lg flex items-center justify-center text-primary-600 font-black text-lg border-2 border-primary-100">1</span>
        </div>
        <h3 class="text-xl font-bold text-gray-900 mb-2">Adquira a Tag NFC</h3>
        <p class="text-gray-500 text-sm leading-relaxed max-w-xs mx-auto">Receba sua tag inteligente resistente à água e prenda na coleira do seu pet.</p>
      </div>

      <!-- Step 2 -->
      <div class="scroll-reveal text-center relative z-10" data-delay="150">
        <div class="relative inline-flex mb-6">
          <div class="w-28 h-28 rounded-3xl bg-gradient-to-br from-blue-500 to-blue-600 flex items-center justify-center shadow-2xl shadow-blue-500/30 -rotate-3 hover:rotate-0 transition-transform duration-500">
            <i class="fa-solid fa-qrcode text-4xl text-white"></i>
          </div>
          <span class="absolute -top-3 -right-3 w-10 h-10 rounded-xl bg-white shadow-lg flex items-center justify-center text-blue-600 font-black text-lg border-2 border-blue-100">2</span>
        </div>
        <h3 class="text-xl font-bold text-gray-900 mb-2">Ative pelo App</h3>
        <p class="text-gray-500 text-sm leading-relaxed max-w-xs mx-auto">Escaneie a tag com seu celular e vincule ao perfil completo do seu pet.</p>
      </div>

      <!-- Step 3 -->
      <div class="scroll-reveal text-center relative z-10" data-delay="300">
        <div class="relative inline-flex mb-6">
          <div class="w-28 h-28 rounded-3xl bg-gradient-to-br from-emerald-500 to-emerald-600 flex items-center justify-center shadow-2xl shadow-emerald-500/30 rotate-3 hover:rotate-0 transition-transform duration-500">
            <i class="fa-solid fa-shield-heart text-4xl text-white"></i>
          </div>
          <span class="absolute -top-3 -right-3 w-10 h-10 rounded-xl bg-white shadow-lg flex items-center justify-center text-emerald-600 font-black text-lg border-2 border-emerald-100">3</span>
        </div>
        <h3 class="text-xl font-bold text-gray-900 mb-2">Proteção Ativa</h3>
        <p class="text-gray-500 text-sm leading-relaxed max-w-xs mx-auto">Qualquer pessoa pode escanear a tag e você recebe alerta com localização em tempo real.</p>
      </div>
    </div>
  </div>
</section>


<!-- ═══════════════ FEATURES ═══════════════ -->
<section class="py-20 sm:py-28 bg-gradient-to-b from-gray-50 to-white relative">
  <div class="max-w-5xl mx-auto px-4 sm:px-6">
    <div class="text-center mb-16 scroll-reveal">
      <span class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-blue-50 text-blue-600 text-xs font-bold tracking-wide mb-4">
        <i class="fa-solid fa-star"></i> FUNCIONALIDADES
      </span>
      <h2 class="text-3xl sm:text-4xl font-black text-gray-900 mb-4">Tudo que seu pet merece</h2>
      <p class="text-gray-500 max-w-xl mx-auto">Tecnologia de ponta e muito amor reunidos em uma única plataforma.</p>
    </div>

    <div class="grid sm:grid-cols-2 gap-5">
      <!-- Card 1 - Tag NFC -->
      <div class="scroll-reveal feature-glass rounded-3xl p-7 hover:shadow-2xl hover:-translate-y-1 transition-all duration-500 group" data-delay="0">
        <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-primary-500 to-primary-600 flex items-center justify-center mb-5 shadow-lg shadow-primary-500/25 group-hover:scale-110 group-hover:rotate-3 transition-all duration-500">
          <i class="fa-solid fa-tag text-xl text-white"></i>
        </div>
        <h3 class="text-lg font-bold text-gray-900 mb-2">Tag NFC Inteligente</h3>
        <p class="text-gray-500 text-sm leading-relaxed">Qualquer pessoa com um smartphone pode escanear a tag e acessar o perfil do pet instantaneamente, sem precisar de app.</p>
      </div>

      <!-- Card 2 - Feed Social -->
      <div class="scroll-reveal feature-glass rounded-3xl p-7 hover:shadow-2xl hover:-translate-y-1 transition-all duration-500 group" data-delay="100">
        <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-blue-500 to-blue-600 flex items-center justify-center mb-5 shadow-lg shadow-blue-500/25 group-hover:scale-110 group-hover:rotate-3 transition-all duration-500">
          <i class="fa-solid fa-heart text-xl text-white"></i>
        </div>
        <h3 class="text-lg font-bold text-gray-900 mb-2">Feed Social</h3>
        <p class="text-gray-500 text-sm leading-relaxed">Compartilhe momentos, faça amigos peludos e acompanhe o diário do seu pet com fotos e vídeos incríveis.</p>
      </div>

      <!-- Card 3 - Mapa ao Vivo -->
      <div class="scroll-reveal feature-glass rounded-3xl p-7 hover:shadow-2xl hover:-translate-y-1 transition-all duration-500 group" data-delay="200">
        <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-emerald-500 to-emerald-600 flex items-center justify-center mb-5 shadow-lg shadow-emerald-500/25 group-hover:scale-110 group-hover:rotate-3 transition-all duration-500">
          <i class="fa-solid fa-map-location-dot text-xl text-white"></i>
        </div>
        <h3 class="text-lg font-bold text-gray-900 mb-2">Mapa ao Vivo</h3>
        <p class="text-gray-500 text-sm leading-relaxed">Encontre petshops, parques, veterinários e pontos pet-friendly perto de você com nosso mapa interativo.</p>
      </div>

      <!-- Card 4 - Alertas -->
      <div class="scroll-reveal feature-glass rounded-3xl p-7 hover:shadow-2xl hover:-translate-y-1 transition-all duration-500 group" data-delay="300">
        <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-amber-500 to-orange-500 flex items-center justify-center mb-5 shadow-lg shadow-amber-500/25 group-hover:scale-110 group-hover:rotate-3 transition-all duration-500">
          <i class="fa-solid fa-bell text-xl text-white"></i>
        </div>
        <h3 class="text-lg font-bold text-gray-900 mb-2">Alertas Inteligentes</h3>
        <p class="text-gray-500 text-sm leading-relaxed">Receba notificações em tempo real quando alguém encontrar seu pet, com localização exata e chat direto.</p>
      </div>
    </div>
  </div>
</section>


<!-- ═══════════════ STATS ═══════════════ -->
<section class="py-20 sm:py-24 stat-gradient relative overflow-hidden">
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <div class="absolute -top-20 -left-20 w-80 h-80 rounded-full bg-indigo-500/10 anim-float-slow"></div>
    <div class="absolute -bottom-16 -right-16 w-64 h-64 rounded-full bg-purple-500/10 anim-float"></div>
  </div>

  <div class="max-w-5xl mx-auto px-4 sm:px-6 relative z-10">
    <div class="text-center mb-14 scroll-reveal">
      <span class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-white/10 text-indigo-200 text-xs font-bold tracking-wide mb-4">
        <i class="fa-solid fa-chart-line"></i> NÚMEROS QUE IMPORTAM
      </span>
      <h2 class="text-3xl sm:text-4xl font-black text-white mb-3">Uma comunidade que cresce</h2>
      <p class="text-indigo-200/80 max-w-lg mx-auto">Cada número representa um pet mais seguro e um dono mais tranquilo.</p>
    </div>

    <div class="grid grid-cols-3 gap-4 sm:gap-8 scroll-reveal">
      <div class="text-center group">
        <div class="inline-flex items-center justify-center w-16 h-16 sm:w-20 sm:h-20 rounded-3xl bg-white/10 backdrop-blur-sm mb-4 group-hover:scale-110 group-hover:bg-white/15 transition-all duration-500">
          <i class="fa-solid fa-paw text-2xl sm:text-3xl text-primary-400"></i>
        </div>
        <div class="text-3xl sm:text-5xl font-black text-white mb-1 stat-number" data-target="<%= stats.pets %>">0</div>
        <div class="text-indigo-300/80 text-xs sm:text-sm font-medium">Pets Protegidos</div>
      </div>

      <div class="text-center group">
        <div class="inline-flex items-center justify-center w-16 h-16 sm:w-20 sm:h-20 rounded-3xl bg-white/10 backdrop-blur-sm mb-4 group-hover:scale-110 group-hover:bg-white/15 transition-all duration-500">
          <i class="fa-solid fa-users text-2xl sm:text-3xl text-blue-400"></i>
        </div>
        <div class="text-3xl sm:text-5xl font-black text-white mb-1 stat-number" data-target="<%= stats.usuarios %>">0</div>
        <div class="text-indigo-300/80 text-xs sm:text-sm font-medium">Usuários Ativos</div>
      </div>

      <div class="text-center group">
        <div class="inline-flex items-center justify-center w-16 h-16 sm:w-20 sm:h-20 rounded-3xl bg-white/10 backdrop-blur-sm mb-4 group-hover:scale-110 group-hover:bg-white/15 transition-all duration-500">
          <i class="fa-solid fa-store text-2xl sm:text-3xl text-emerald-400"></i>
        </div>
        <div class="text-3xl sm:text-5xl font-black text-white mb-1 stat-number" data-target="<%= stats.petshops %>">0</div>
        <div class="text-indigo-300/80 text-xs sm:text-sm font-medium">Petshops Parceiros</div>
      </div>
    </div>
  </div>
</section>


<!-- ═══════════════ PETS PERDIDOS ═══════════════ -->
<% if (typeof petsPerdidosRecentes !== 'undefined' && petsPerdidosRecentes && petsPerdidosRecentes.length > 0) { %>
<section class="py-20 sm:py-28 bg-white relative">
  <div class="max-w-5xl mx-auto px-4 sm:px-6">
    <div class="text-center mb-14 scroll-reveal">
      <span class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-red-50 text-red-500 text-xs font-bold tracking-wide mb-4">
        <i class="fa-solid fa-triangle-exclamation"></i> ALERTA COMUNITÁRIO
      </span>
      <h2 class="text-3xl sm:text-4xl font-black text-gray-900 mb-4">Pets que precisam de ajuda</h2>
      <p class="text-gray-500 max-w-xl mx-auto">Esses pets foram reportados como perdidos recentemente. Você pode ajudar!</p>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
      <% petsPerdidosRecentes.forEach(function(pet, idx) { %>
      <div class="scroll-reveal bg-white rounded-3xl border border-gray-100 shadow-lg shadow-gray-200/50 overflow-hidden hover:shadow-2xl hover:-translate-y-1 transition-all duration-500 group" data-delay="<%= idx * 100 %>">
        <div class="relative h-48 bg-gray-100 overflow-hidden">
          <% if (pet.pet_foto) { %>
            <img src="<%= pet.pet_foto %>" alt="<%= pet.pet_nome %>"
                 class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
                 loading="lazy">
          <% } else { %>
            <div class="w-full h-full flex items-center justify-center bg-gradient-to-br from-gray-100 to-gray-200">
              <i class="fa-solid fa-paw text-5xl text-gray-300"></i>
            </div>
          <% } %>
          <div class="absolute top-3 left-3">
            <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-red-500 text-white text-xs font-bold shadow-lg">
              <span class="relative flex h-1.5 w-1.5"><span class="absolute inline-flex h-full w-full rounded-full bg-white opacity-75 animate-ping"></span><span class="relative inline-flex rounded-full h-1.5 w-1.5 bg-white"></span></span>
              Perdido
            </span>
          </div>
        </div>
        <div class="p-5">
          <h3 class="text-lg font-bold text-gray-900 mb-1"><%= pet.pet_nome %></h3>
          <% if (pet.pet_raca) { %>
            <p class="text-gray-400 text-sm mb-4"><i class="fa-solid fa-dna mr-1"></i> <%= pet.pet_raca %></p>
          <% } %>
          <a href="/auth/registro"
             class="inline-flex items-center gap-2 px-5 py-2.5 rounded-xl bg-red-50 text-red-600 text-sm font-semibold hover:bg-red-100 transition-colors duration-300 w-full justify-center">
            <i class="fa-solid fa-hands-holding-heart"></i> Quero Ajudar
          </a>
        </div>
      </div>
      <% }); %>
    </div>
  </div>
</section>
<% } %>


