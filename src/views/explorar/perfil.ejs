<% locals.titulo = typeof titulo !== 'undefined' ? titulo : 'Perfil' %>
<% locals.extraHead = `
<style>
  @keyframes profileReveal { from { opacity: 0; transform: translateY(16px); } to { opacity: 1; transform: translateY(0); } }
  @keyframes postEnter { from { opacity: 0; transform: translateY(12px); } to { opacity: 1; transform: translateY(0); } }
  @keyframes heartPop { 0% { transform: scale(1); } 30% { transform: scale(1.35); } 60% { transform: scale(0.9); } 100% { transform: scale(1); } }
  @keyframes floatHeart { 0% { opacity: 1; transform: translateY(0) scale(1); } 100% { opacity: 0; transform: translateY(-80px) scale(1.6); } }
  @keyframes bannerGlow { 0%, 100% { opacity: .6; } 50% { opacity: .9; } }

  .profile-reveal { animation: profileReveal .5s ease-out both; }
  .post-enter { animation: postEnter .4s ease-out both; }
  .heart-pop { animation: heartPop .45s cubic-bezier(.17,.67,.35,1.5); }
  .float-heart { animation: floatHeart .8s ease-out forwards; pointer-events: none; }

  .banner-gradient { position: relative; overflow: hidden; }
  .banner-gradient::after {
    content: '';
    position: absolute; inset: 0;
    background: radial-gradient(ellipse at 30% 0%, rgba(255,255,255,.15) 0%, transparent 70%);
    animation: bannerGlow 6s ease-in-out infinite;
  }

  .pet-scroll::-webkit-scrollbar { display: none; }
  .pet-scroll { -ms-overflow-style: none; scrollbar-width: none; }

  .follow-btn { transition: all .3s cubic-bezier(.4,0,.2,1); }

  .tab-active { color: #111827; }
  .tab-inactive { color: #9ca3af; border-bottom-color: transparent; }
  .tab-inactive:hover { color: #6b7280; background: rgba(0,0,0,.02); }

  .progress-bar { transition: width .6s cubic-bezier(.4,0,.2,1); }

  .caption-expanded .line-clamp-3 { -webkit-line-clamp: unset !important; }

  .menu-dropdown { transform-origin: top right; transition: opacity .15s, transform .15s; }
  .menu-dropdown.hidden { opacity: 0; transform: scale(.95); pointer-events: none; }

  .repost-quote { border-left: 3px solid #e5e7eb; transition: border-color .2s; }
  .repost-quote:hover { border-color: #ec5a1c; }

  .action-btn { transition: all .15s ease; }
  .action-btn:active { transform: scale(.92); }

  #postDetailModal #postDetailOverlayEl { opacity: 0; transition: opacity 0.2s ease; }
  #postDetailModal.is-open #postDetailOverlayEl { opacity: 1 !important; }
  #postDetailModal #postDetailPanelEl { opacity: 0; transform: scale(0.96); transition: opacity 0.22s ease, transform 0.22s ease; }
  #postDetailModal.is-open #postDetailPanelEl { opacity: 1 !important; transform: scale(1) !important; }
  #postDetailModal .mention { color: var(--accent); font-weight: 600; }
</style>
` %>
<%- include('../partials/header') %>
<%- include('../partials/flash') %>

<%
  var corPerfil = perfil.cor_perfil || '#ec5a1c';

  function hexToHSL(hex) {
    hex = hex.replace('#', '');
    var r = parseInt(hex.substring(0, 2), 16) / 255;
    var g = parseInt(hex.substring(2, 4), 16) / 255;
    var b = parseInt(hex.substring(4, 6), 16) / 255;
    var max = Math.max(r, g, b), min = Math.min(r, g, b);
    var h, s, l = (max + min) / 2;
    if (max === min) { h = s = 0; }
    else {
      var d = max - min;
      s = l > 0.5 ? d / (2 - max - min) : d / (max + min);
      if (max === r) h = ((g - b) / d + (g < b ? 6 : 0)) / 6;
      else if (max === g) h = ((b - r) / d + 2) / 6;
      else h = ((r - g) / d + 4) / 6;
    }
    return { h: Math.round(h * 360), s: Math.round(s * 100), l: Math.round(l * 100) };
  }

  var hsl = hexToHSL(corPerfil);
  var bannerFrom = corPerfil;
  var bannerTo = 'hsl(' + hsl.h + ', ' + Math.min(hsl.s + 10, 100) + '%, ' + Math.max(hsl.l - 25, 8) + '%)';

  var mesesPT = ['jan.', 'fev.', 'mar.', 'abr.', 'mai.', 'jun.', 'jul.', 'ago.', 'set.', 'out.', 'nov.', 'dez.'];
  var dataCriacao = perfil.data_criacao ? new Date(perfil.data_criacao) : null;
  var mesCriacao = dataCriacao ? mesesPT[dataCriacao.getMonth()] : '';
  var anoCriacao = dataCriacao ? dataCriacao.getFullYear() : '';
%>

<main class="flex-1 pb-24 md:pb-6">
  <div class="max-w-2xl mx-auto">

    <!-- ═══ Banner (capa ou gradiente) ═══ -->
    <% if (perfil.foto_capa) { %>
    <div class="h-[150px] sm:h-[200px] bg-gray-200 overflow-hidden">
      <img src="<%= perfil.foto_capa %>" alt="" class="w-full h-full object-cover">
    </div>
    <% } else { %>
    <div class="banner-gradient h-[150px] sm:h-[200px]"
         style="background: linear-gradient(135deg, <%= bannerFrom %> 0%, <%= bannerTo %> 100%);">
    </div>
    <% } %>

    <div class="px-4">

      <!-- ═══ Avatar row + Follow button ═══ -->
      <div class="flex items-end justify-between -mt-12 sm:-mt-14 mb-3 profile-reveal">
        <div class="flex-shrink-0">
          <% if (perfil.foto_perfil) { %>
            <img src="<%= perfil.foto_perfil %>" alt="<%= perfil.nome %>"
                 class="w-24 h-24 sm:w-28 sm:h-28 rounded-full object-cover shadow-xl" style="box-shadow: 0 0 0 4px <%= corPerfil %>">
          <% } else { %>
            <span class="w-24 h-24 sm:w-28 sm:h-28 rounded-full flex items-center justify-center text-3xl sm:text-4xl font-black text-white bg-gray-400"
                  style="box-shadow: 0 0 0 4px <%= corPerfil %>">
              <%= perfil.nome ? perfil.nome.charAt(0).toUpperCase() : 'U' %>
            </span>
          <% } %>
        </div>

        <div class="flex items-center gap-2 pb-1">
          <% if (eMeuPerfil) { %>
            <a href="/perfil"
               class="flex items-center gap-2 px-5 py-2 rounded-full border border-gray-300 hover:bg-gray-50 text-sm font-bold text-gray-800 transition-all duration-200">
              Editar perfil
            </a>
          <% } else if (!soPets) { %>
            <button type="button" id="btnFollow"
                    data-user-id="<%= perfil.id %>"
                    data-following="<%= estaSeguindo ? 'true' : 'false' %>"
                    class="follow-btn flex items-center gap-2 px-5 py-2 rounded-full text-sm font-bold
                      <%= estaSeguindo
                        ? 'bg-white border border-gray-300 text-gray-800 hover:border-red-300 hover:bg-red-50 hover:text-red-600'
                        : 'bg-gradient-to-r from-primary-500 to-primary-600 text-white shadow-lg shadow-primary-500/20 hover:shadow-xl hover:-translate-y-0.5'
                      %>">
              <i class="fa-solid <%= estaSeguindo ? 'fa-user-check' : 'fa-user-plus' %> text-xs"></i>
              <span><%= estaSeguindo ? 'Seguindo' : 'Seguir' %></span>
            </button>
          <% } %>
          <% if (!soPets) { %>
          <button type="button" class="btn-share-profile flex items-center justify-center w-9 h-9 rounded-full border border-gray-300 hover:bg-gray-50 text-gray-600 transition-all duration-200"
                  title="Compartilhar perfil">
            <i class="fa-solid fa-arrow-up-from-bracket text-sm"></i>
          </button>
          <% } %>
        </div>
      </div>

      <!-- ═══ Name & Bio ═══ -->
      <section class="profile-reveal" style="animation-delay: .05s">
        <h1 class="text-2xl font-black text-gray-900 leading-tight"><%= perfil.nome %></h1>
        <% if (perfil.email) { %>
          <p class="text-sm text-gray-500 mt-0.5">@<%= perfil.email.split('@')[0] %></p>
        <% } %>

        <% if (perfil.bio) { %>
          <p class="text-[15px] text-gray-800 leading-relaxed mt-3"><%= perfil.bio %></p>
        <% } %>

        <!-- Info row -->
        <div class="flex items-center gap-4 mt-3 text-sm text-gray-500">
          <% if (dataCriacao) { %>
            <span class="flex items-center gap-1.5">
              <i class="fa-regular fa-calendar text-xs"></i>
              Entrou em <%= mesCriacao %> <%= anoCriacao %>
            </span>
          <% } %>
        </div>

        <!-- Stats row -->
        <div class="flex items-center gap-5 mt-3">
          <span class="text-sm text-gray-500">
            <strong class="text-gray-900 font-black"><%= totalPosts %></strong> posts
          </span>
          <% if (!soPets) { %>
            <span class="text-sm text-gray-500 cursor-pointer hover:text-primary-500 transition-colors" id="btnVerSeguidores" title="Ver seguidores">
              <strong class="text-gray-900 font-black" id="seguidoresCount"><%= seguidores %></strong> seguidores
            </span>
            <span class="text-sm text-gray-500 cursor-pointer hover:text-primary-500 transition-colors" id="btnVerSeguindo" title="Ver seguindo">
              <strong class="text-gray-900 font-black"><%= seguindo %></strong> seguindo
            </span>
          <% } %>
        </div>

        <!-- Capacity indicators -->
        <% if (eMeuPerfil && !soPets) { %>
          <div class="flex items-center gap-4 mt-4 profile-reveal" style="animation-delay: .1s">
            <div class="flex-1">
              <div class="flex items-center justify-between mb-1">
                <span class="text-[11px] font-semibold text-gray-500"><%= totalPosts %>/10 publicações</span>
              </div>
              <div class="h-1.5 bg-gray-100 rounded-full overflow-hidden">
                <div class="h-full rounded-full progress-bar"
                     style="width: <%= Math.min(totalPosts * 10, 100) %>%; background: linear-gradient(90deg, <%= corPerfil %>, <%= bannerTo %>);"></div>
              </div>
            </div>
            <div class="flex-1">
              <div class="flex items-center justify-between mb-1">
                <span class="text-[11px] font-semibold text-gray-500"><%= totalFixadas %>/3 fixados</span>
              </div>
              <div class="h-1.5 bg-gray-100 rounded-full overflow-hidden">
                <div class="h-full rounded-full progress-bar"
                     style="width: <%= Math.min(totalFixadas * 33.33, 100) %>%; background: linear-gradient(90deg, #f59e0b, #d97706);"></div>
              </div>
            </div>
          </div>
        <% } %>
      </section>

      <!-- ═══ Pets (UX minimalista) ═══ -->
      <section class="mt-5 mb-2 profile-reveal" style="animation-delay: .12s">
        <div class="rounded-2xl border border-gray-100 bg-white p-3.5 sm:p-4">
          <div class="flex items-center justify-between gap-2">
            <h3 class="text-xs font-bold text-gray-400 uppercase tracking-wider">
              <i class="fa-solid fa-paw mr-1"></i> Pets
            </h3>
            <span class="text-[11px] text-gray-500">
              <strong class="text-gray-900 font-black"><%= totalPosts %></strong> publicações
            </span>
          </div>

          <% if (typeof pets !== 'undefined' && pets.length > 0) { %>
            <div class="mt-3 space-y-2.5">
              <% pets.forEach(function(pet) { %>
                <div class="flex items-center justify-between gap-3 rounded-xl border border-gray-100 px-2.5 py-2">
                  <a href="/explorar/pet/<%= pet.id %>" class="flex items-center gap-2.5 min-w-0">
                    <div class="w-10 h-10 rounded-full overflow-hidden ring-1 ring-gray-200 flex-shrink-0">
                      <% if (pet.foto) { %>
                        <img src="<%= pet.foto %>" alt="<%= pet.nome %>" class="w-full h-full object-cover">
                      <% } else { %>
                        <div class="w-full h-full bg-gradient-to-br from-orange-100 to-orange-50 flex items-center justify-center">
                          <i class="fa-solid fa-paw text-orange-300 text-xs"></i>
                        </div>
                      <% } %>
                    </div>
                    <div class="min-w-0">
                      <p class="text-sm font-bold text-gray-800 truncate"><%= pet.nome %></p>
                      <p class="text-[11px] text-gray-500 truncate"><%= pet.raca || 'Raça não informada' %></p>
                    </div>
                  </a>
                  <% if (eMeuPerfil) { %>
                    <a href="/pets/<%= pet.id %>"
                       class="inline-flex items-center gap-1.5 px-2.5 py-1.5 rounded-full border border-primary-200 bg-primary-50 text-[11px] font-semibold text-primary-700 hover:bg-primary-100 hover:border-primary-300 transition-all whitespace-nowrap">
                      <i class="fa-solid fa-up-right-from-square text-[10px]"></i>
                      Abrir painel
                    </a>
                  <% } %>
                </div>
              <% }); %>
            </div>
          <% } else { %>
            <p class="text-sm text-gray-500 mt-3">Nenhum pet cadastrado.</p>
            <% if (eMeuPerfil) { %>
              <a href="/pets/cadastro" class="inline-flex items-center gap-1.5 text-xs font-semibold text-primary-600 mt-2 hover:text-primary-700">
                <i class="fa-solid fa-plus"></i> Cadastrar pet
              </a>
            <% } %>
          <% } %>
        </div>
      </section>

      <!-- ═══ Fotos dos pets (galeria por pet) ═══ -->
      <% if (typeof galeriaPorPet !== 'undefined' && galeriaPorPet && galeriaPorPet.length > 0) { %>
        <section class="mt-6 mb-2 profile-reveal" style="animation-delay: .14s">
          <h3 class="text-xs font-bold text-gray-400 uppercase tracking-wider mb-3">
            <i class="fa-solid fa-images mr-1"></i> Fotos dos pets
          </h3>
          <div class="space-y-4">
            <% galeriaPorPet.forEach(function(item) { %>
              <div class="rounded-xl border border-gray-100 overflow-hidden">
                <div class="px-3 py-2 bg-gray-50 border-b border-gray-100 flex items-center gap-2">
                  <% if (item.pet_foto) { %>
                    <img src="<%= item.pet_foto %>" alt="" class="w-6 h-6 rounded-full object-cover">
                  <% } else { %>
                    <span class="w-6 h-6 rounded-full bg-primary-100 flex items-center justify-center text-[10px] text-primary-600"><i class="fa-solid fa-paw"></i></span>
                  <% } %>
                  <span class="text-sm font-bold text-gray-800"><%= item.pet_nome %></span>
                </div>
                <div class="grid grid-cols-3 sm:grid-cols-4 gap-1 p-2">
                  <% (item.fotos || []).forEach(function(f) { %>
                    <a href="<%= f.foto %>" target="_blank" rel="noopener" class="block aspect-square rounded-lg overflow-hidden bg-gray-100">
                      <img src="<%= f.foto %>" alt="" class="w-full h-full object-cover">
                    </a>
                  <% }); %>
                </div>
              </div>
            <% }); %>
          </div>
        </section>
      <% } %>
    </div>

    <!-- ═══ Tabs (ocultos quando perfil só pets) ═══ -->
    <% if (!soPets) { %>
    <nav class="sticky top-14 z-40 bg-white/80 backdrop-blur-xl border-b border-gray-100 mt-4 profile-reveal" style="animation-delay: .15s">
      <style>.tab-active { border-bottom-color: <%= corPerfil %>; }</style>
      <div class="flex">
        <a href="/explorar/perfil/<%= perfil.id %>?tab=posts"
           class="flex-1 py-3.5 text-center text-sm font-bold border-b-2 transition-all duration-200
             <%= perfilTab === 'posts' ? 'tab-active' : 'tab-inactive' %>">
          Posts
        </a>
        <a href="/explorar/perfil/<%= perfil.id %>?tab=reposts"
           class="flex-1 py-3.5 text-center text-sm font-bold border-b-2 transition-all duration-200
             <%= perfilTab === 'reposts' ? 'tab-active' : 'tab-inactive' %>">
          Reposts
        </a>
        <a href="/explorar/perfil/<%= perfil.id %>?tab=curtidas"
           class="flex-1 py-3.5 text-center text-sm font-bold border-b-2 transition-all duration-200
             <%= perfilTab === 'curtidas' ? 'tab-active' : 'tab-inactive' %>">
          Curtidas
        </a>
      </div>
    </nav>
    <% } %>

    <!-- ═══ Posts List (Twitter-style vertical) ou só mensagem quando soPets ═══ -->
    <div class="px-4 pt-3" id="postsContainer">
    <% if (soPets) { %>
      <div class="text-center py-12 profile-reveal">
        <p class="text-sm text-gray-500">Conheça os perfis dos pets acima para ver publicações e seguidores.</p>
      </div>
    <% } else { %>

      <% if (posts.length === 0) { %>
        <div class="text-center py-16 profile-reveal" style="animation-delay: .2s">
          <div class="w-20 h-20 mx-auto mb-4 rounded-full bg-gray-50 flex items-center justify-center">
            <% if (perfilTab === 'posts') { %>
              <i class="fa-solid fa-feather-pointed text-3xl text-gray-300"></i>
            <% } else if (perfilTab === 'reposts') { %>
              <i class="fa-solid fa-retweet text-3xl text-gray-300"></i>
            <% } else { %>
              <i class="fa-regular fa-heart text-3xl text-gray-300"></i>
            <% } %>
          </div>
          <h3 class="text-lg font-bold text-gray-800 mb-1">
            <% if (perfilTab === 'posts') { %>
              Nenhuma publicação ainda
            <% } else if (perfilTab === 'reposts') { %>
              Nenhum repost
            <% } else { %>
              Nenhuma curtida
            <% } %>
          </h3>
          <p class="text-sm text-gray-400 max-w-xs mx-auto">
            <% if (eMeuPerfil) { %>
              <% if (perfilTab === 'posts') { %>
                Compartilhe um momento com seu pet!
              <% } else if (perfilTab === 'reposts') { %>
                Reposte publicações que você gostar.
              <% } else { %>
                Curta publicações para vê-las aqui.
              <% } %>
            <% } else { %>
              <% if (perfilTab === 'posts') { %>
                <%= perfil.nome.split(' ')[0] %> ainda não publicou nada.
              <% } else if (perfilTab === 'reposts') { %>
                <%= perfil.nome.split(' ')[0] %> ainda não repostou nada.
              <% } else { %>
                As curtidas não estão visíveis.
              <% } %>
            <% } %>
          </p>
        </div>
      <% } %>

      <% posts.forEach(function(post, idx) { %>
        <% var exibirFotoMeta = (post.foto && String(post.foto).trim()) ? post.foto : (((post.tipo === 'repost' || post.repost_id) && post.orig_foto) ? post.orig_foto : ''); %>
        <% var textoMeta = post.texto || post.legenda || ''; %>
        <% var metaExplorarPerfil = {
          kind: 'organic',
          postId: post.id,
          foto: exibirFotoMeta || '',
          texto: textoMeta,
          criado_em: post.criado_em || '',
          autor_nome: post.autor_nome || '',
          usuario_id: post.usuario_id,
          foto_perfil: post.foto_perfil || '',
          cor_perfil: post.cor_perfil || '#ec5a1c',
          pet_id: post.pet_id || null,
          pet_nome: post.pet_nome || '',
          pet_foto: post.pet_foto || '',
          fixada: !!post.fixada,
          comments: true
        }; %>
        <article class="bg-white rounded-2xl shadow-sm border border-gray-100/80 mb-4 overflow-hidden post-enter"
                 id="post-<%= post.id %>"
                 data-post-id="<%= post.id %>"
                 data-author-id="<%= post.usuario_id %>"
                 data-explorar-meta="<%= encodeURIComponent(JSON.stringify(metaExplorarPerfil)) %>"
                 style="animation-delay: <%= (idx * 50) + 200 %>ms">

          <!-- Repost badge -->
          <% if (post.tipo === 'repost' || post.repost_id) { %>
            <div class="flex items-center gap-2 px-4 pt-3 pb-0 text-xs text-gray-400 font-semibold">
              <i class="fa-solid fa-retweet text-green-500"></i>
              <span><%= post.autor_nome %> repostou</span>
            </div>
          <% } %>

          <!-- Pinned badge -->
          <% if (post.fixada) { %>
            <div class="flex items-center gap-2 px-4 pt-3 pb-0 text-xs text-amber-500 font-semibold">
              <i class="fa-solid fa-thumbtack text-[10px]"></i>
              <span>Fixado</span>
            </div>
          <% } %>

          <!-- Post header: pet em destaque, tutor secundário -->
          <% var perfilFeedHasPet = post.pet_id && post.pet_nome; %>
          <div class="flex items-center gap-3 px-4 pt-3 pb-2">
            <% if (perfilFeedHasPet) { %>
            <a href="/explorar/pet/<%= post.pet_id %>" class="flex-shrink-0 rounded-full transition-transform active:scale-95">
              <% if (post.pet_foto) { %>
                <img src="<%= post.pet_foto %>" alt="" class="w-11 h-11 rounded-full object-cover ring-2 ring-primary-200 shadow-sm">
              <% } else { %>
                <span class="w-11 h-11 rounded-full flex items-center justify-center text-lg bg-primary-50 text-primary-500 ring-2 ring-primary-200/80">🐾</span>
              <% } %>
            </a>
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-1.5 flex-wrap">
                <a href="/explorar/pet/<%= post.pet_id %>" class="font-display font-extrabold text-[15px] text-gray-900 hover:text-primary-600 transition-colors truncate tracking-tight">
                  <span class="mr-1" aria-hidden="true">🐾</span><%= post.pet_nome %>
                </a>
                <span class="text-gray-300 hidden sm:inline">·</span>
                <span class="post-time text-xs text-gray-400 flex-shrink-0" data-time="<%= post.criado_em %>"></span>
              </div>
              <p class="text-xs text-gray-500 truncate mt-0.5">por <a href="/explorar/perfil/<%= post.usuario_id %>" class="font-semibold text-gray-600 hover:text-primary-600"><%= post.autor_nome %></a></p>
            </div>
            <% } else { %>
            <a href="/explorar/perfil/<%= post.usuario_id %>" class="flex-shrink-0">
              <% if (post.foto_perfil) { %>
                <img src="<%= post.foto_perfil %>" alt="" class="w-10 h-10 rounded-full object-cover transition-all" style="box-shadow: 0 0 0 2px <%= post.cor_perfil || '#ec5a1c' %>">
              <% } else { %>
                <span class="w-10 h-10 rounded-full flex items-center justify-center text-sm font-bold text-white bg-gray-400 hover:scale-105 transition-transform"
                      style="box-shadow: 0 0 0 2px <%= post.cor_perfil || '#ec5a1c' %>">
                  <%= post.autor_nome ? post.autor_nome.charAt(0).toUpperCase() : 'U' %>
                </span>
              <% } %>
            </a>
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-1.5 flex-wrap">
                <a href="/explorar/perfil/<%= post.usuario_id %>" class="font-display font-extrabold text-sm text-gray-900 hover:text-primary-600 transition-colors truncate">
                  <%= post.autor_nome %>
                </a>
                <span class="text-gray-300">·</span>
                <span class="post-time text-xs text-gray-400 flex-shrink-0" data-time="<%= post.criado_em %>"></span>
              </div>
              <span class="text-[11px] text-gray-400">Publicação do tutor</span>
            </div>
            <% } %>
            <div class="relative">
              <button type="button" class="post-menu-btn p-2 -mr-2 text-gray-300 hover:text-gray-500 transition-colors rounded-full hover:bg-gray-50"
                      data-post-id="<%= post.id %>">
                <i class="fa-solid fa-ellipsis"></i>
              </button>
              <div class="menu-dropdown hidden absolute right-0 top-full mt-1 w-48 bg-white rounded-xl shadow-2xl shadow-black/10 ring-1 ring-black/5 py-1.5 z-30"
                   id="menu-<%= post.id %>">
                <% if (typeof usuario !== 'undefined' && usuario && post.usuario_id === usuario.id) { %>
                  <% if (post.fixada) { %>
                    <button type="button" class="btn-desafixar w-full flex items-center gap-2.5 px-4 py-2.5 text-sm text-gray-700 hover:bg-gray-50 transition-colors" data-id="<%= post.id %>">
                      <i class="fa-solid fa-thumbtack w-4 text-center text-gray-400"></i> Desafixar
                    </button>
                  <% } else { %>
                    <button type="button" class="btn-fixar w-full flex items-center gap-2.5 px-4 py-2.5 text-sm text-gray-700 hover:bg-gray-50 transition-colors" data-id="<%= post.id %>">
                      <i class="fa-solid fa-thumbtack w-4 text-center text-gray-400"></i> Fixar post
                    </button>
                  <% } %>
                  <button type="button" class="btn-deletar-post w-full flex items-center gap-2.5 px-4 py-2.5 text-sm text-red-500 hover:bg-red-50 transition-colors" data-id="<%= post.id %>">
                    <i class="fa-solid fa-trash-can w-4 text-center"></i> Excluir
                  </button>
                <% } else { %>
                  <button type="button" class="btn-share w-full flex items-center gap-2.5 px-4 py-2.5 text-sm text-gray-700 hover:bg-gray-50 transition-colors" data-id="<%= post.id %>">
                    <i class="fa-solid fa-share-from-square w-4 text-center text-gray-400"></i> Compartilhar
                  </button>
                <% } %>
              </div>
            </div>
          </div>

          <!-- Text content -->
          <% if (post.texto || post.legenda) { %>
            <div class="px-4 pb-2 caption-area" data-post-id="<%= post.id %>">
              <p class="text-[15px] text-gray-800 leading-relaxed">
                <span class="caption-text line-clamp-3"><%= post.texto || post.legenda %></span>
              </p>
              <button type="button" class="btn-ver-mais text-xs text-primary-500 hover:text-primary-600 font-semibold mt-1 hidden">ver mais</button>
            </div>
          <% } %>

          <!-- Photo -->
          <% if (post.foto) { %>
            <div class="relative mx-4 mb-3 rounded-2xl overflow-hidden">
              <img src="<%= post.foto %>" alt="" class="post-photo w-full rounded-2xl object-cover max-h-[500px] cursor-zoom-in" loading="lazy"
                   ondblclick="toggleLike(this, '<%= post.id %>')">
              <div class="dbl-heart-overlay absolute inset-0 flex items-center justify-center pointer-events-none"></div>
            </div>
          <% } %>

          <!-- Quoted repost (original post embed) -->
          <% if (post.orig_id) { %>
            <div class="mx-4 mb-3 repost-quote rounded-xl border border-gray-100 overflow-hidden bg-gray-50/50 hover:bg-gray-50 transition-colors">
              <div class="p-3">
                <div class="flex items-start gap-2 mb-2">
                  <% var perfilOrigPet = post.orig_pet_id && post.orig_pet_nome; %>
                  <% if (perfilOrigPet) { %>
                    <a href="/explorar/pet/<%= post.orig_pet_id %>" class="shrink-0">
                      <% if (post.orig_pet_foto) { %>
                        <img src="<%= post.orig_pet_foto %>" alt="" class="w-8 h-8 rounded-full object-cover ring-1 ring-primary-200">
                      <% } else { %>
                        <span class="w-8 h-8 rounded-full flex items-center justify-center text-sm bg-primary-50 text-primary-500 ring-1 ring-primary-200">🐾</span>
                      <% } %>
                    </a>
                    <div class="min-w-0 flex-1">
                      <a href="/explorar/pet/<%= post.orig_pet_id %>" class="font-display font-extrabold text-xs text-gray-900 block truncate"><%= post.orig_pet_nome %></a>
                      <span class="text-[10px] text-gray-500">por <a href="/explorar/perfil/<%= post.orig_usuario_id %>" class="font-medium text-gray-600 hover:text-primary-600"><%= post.orig_autor_nome %></a></span>
                    </div>
                  <% } else { %>
                  <% if (post.orig_foto_perfil) { %>
                    <img src="<%= post.orig_foto_perfil %>" alt="" class="w-5 h-5 rounded-full object-cover" style="box-shadow: 0 0 0 1px <%= post.orig_cor_perfil || '#ec5a1c' %>">
                  <% } else { %>
                    <span class="w-5 h-5 rounded-full flex items-center justify-center text-[9px] font-bold text-white bg-gray-400"
                          style="box-shadow: 0 0 0 1px <%= post.orig_cor_perfil || '#ec5a1c' %>">
                      <%= post.orig_autor_nome ? post.orig_autor_nome.charAt(0).toUpperCase() : 'U' %>
                    </span>
                  <% } %>
                  <span class="text-xs font-bold text-gray-700"><%= post.orig_autor_nome %></span>
                  <% } %>
                </div>
                <% if (post.orig_texto || post.orig_legenda) { %>
                  <p class="text-sm text-gray-700 leading-relaxed line-clamp-3 mb-2"><%= post.orig_texto || post.orig_legenda %></p>
                <% } %>
                <% if (post.orig_foto) { %>
                  <img src="<%= post.orig_foto %>" alt="" class="post-embed-img w-full rounded-lg object-cover max-h-[200px] cursor-zoom-in" loading="lazy">
                <% } %>
              </div>
            </div>
          <% } %>

          <!-- Action bar -->
          <div class="px-4 pb-3">
            <div class="flex items-center justify-between max-w-md">
              <!-- Comment -->
              <button type="button" class="btn-open-comments action-btn group flex items-center gap-1.5 text-gray-500 hover:text-accent-500 transition-colors"
                      data-post-id="<%= post.id %>">
                <div class="p-1.5 rounded-full group-hover:bg-blue-50 transition-colors">
                  <i class="fa-regular fa-comment text-[15px]"></i>
                </div>
                <span class="text-xs"><%= post.total_comentarios || '' %></span>
              </button>

              <!-- Repost -->
              <button type="button" class="btn-repost action-btn group flex items-center gap-1.5 transition-colors
                        <%= post.repostou ? 'text-green-500' : 'text-gray-500 hover:text-green-500' %>"
                      data-post-id="<%= post.id %>" data-reposted="<%= post.repostou ? 'true' : 'false' %>">
                <div class="p-1.5 rounded-full group-hover:bg-green-50 transition-colors">
                  <i class="fa-solid fa-retweet text-[15px]"></i>
                </div>
                <span class="text-xs repost-count"><%= post.total_reposts || '' %></span>
              </button>

              <!-- Like -->
              <button type="button" class="btn-like action-btn group flex items-center gap-1.5 transition-colors
                        <%= post.curtiu ? 'text-red-500' : 'text-gray-500 hover:text-red-500' %>"
                      data-post-id="<%= post.id %>" data-liked="<%= post.curtiu ? 'true' : 'false' %>">
                <div class="p-1.5 rounded-full group-hover:bg-red-50 transition-colors">
                  <i class="<%= post.curtiu ? 'fa-solid' : 'fa-regular' %> fa-heart text-[15px]"></i>
                </div>
                <span class="text-xs likes-count"><%= post.total_curtidas || '' %></span>
              </button>

              <!-- Share -->
              <button type="button" class="btn-share-post action-btn group flex items-center gap-1.5 text-gray-500 hover:text-primary-500 transition-colors"
                      data-post-id="<%= post.id %>" data-legenda="<%= post.legenda ? post.legenda.substring(0, 80) : '' %>">
                <div class="p-1.5 rounded-full group-hover:bg-orange-50 transition-colors">
                  <i class="fa-solid fa-arrow-up-from-bracket text-[13px]"></i>
                </div>
              </button>
            </div>
          </div>
        </article>
      <% }); %>
    <% } %>

    </div>

  </div>

  <!-- ═══ Comments Modal ═══ -->
  <div id="commentsModal" class="airpet-modal hidden z-[60]">
    <div class="airpet-modal__backdrop" id="commentsOverlay"></div>
    <div class="airpet-modal__sheet bg-white animate-slideUp" role="dialog" aria-modal="true" aria-labelledby="commentsModalTitle">
      <div class="airpet-modal__header border-b border-gray-100">
        <h3 id="commentsModalTitle" class="airpet-modal__title">Comentários</h3>
        <button type="button" id="closeComments" class="airpet-modal__header-btn" aria-label="Fechar">
          <i class="fa-solid fa-xmark text-lg"></i>
        </button>
      </div>
      <div id="commentsBody" class="airpet-modal__body px-0 min-h-[120px]">
        <div class="flex flex-col items-center justify-center py-10 text-gray-300">
          <i class="fa-solid fa-spinner fa-spin text-xl"></i>
        </div>
      </div>
      <form id="modalCommentForm" class="airpet-modal__footer border-t border-gray-100 flex items-center gap-2 px-5 pt-3">
        <input type="text" id="modalCommentInput" placeholder="Escreva um comentário..." maxlength="300"
               class="flex-1 text-sm bg-gray-50 rounded-full px-4 py-2.5 border-0 outline-none focus:ring-2 focus:ring-primary-500/20 placeholder-gray-400">
        <button type="submit" class="w-9 h-9 rounded-full bg-gradient-to-r from-primary-500 to-primary-600 text-white flex items-center justify-center hover:shadow-lg hover:shadow-primary-500/25 transition-all shrink-0">
          <i class="fa-solid fa-paper-plane text-xs"></i>
        </button>
      </form>
    </div>
  </div>

  <!-- ═══ Repost Modal ═══ -->
  <div id="repostModal" class="fixed inset-0 z-[60] hidden">
    <div class="absolute inset-0 bg-black/40 backdrop-blur-sm" id="repostOverlay"></div>
    <div class="absolute bottom-0 left-0 right-0 bg-white rounded-t-3xl flex flex-col animate-slideUp safe-bottom md:relative md:top-1/2 md:-translate-y-1/2 md:max-w-lg md:mx-auto md:rounded-2xl">
      <div class="flex items-center justify-between px-5 py-4 border-b border-gray-100">
        <h3 class="font-bold text-gray-900">Repostar</h3>
        <button type="button" id="closeRepost" class="p-1 text-gray-400 hover:text-gray-600 transition-colors">
          <i class="fa-solid fa-xmark text-lg"></i>
        </button>
      </div>
      <div class="px-5 py-4 space-y-3">
        <textarea id="repostTexto" rows="3" maxlength="500" placeholder="Adicione um comentário ao repost..."
                  class="w-full text-sm bg-gray-50 rounded-xl px-4 py-3 border-0 outline-none resize-none focus:ring-2 focus:ring-primary-500/20 placeholder-gray-400"></textarea>
        <button type="button" id="submitRepost"
                class="w-full py-3 rounded-xl bg-gradient-to-r from-green-500 to-green-600 text-white font-bold text-sm shadow-lg shadow-green-500/20 hover:shadow-xl hover:-translate-y-0.5 disabled:opacity-40 disabled:pointer-events-none transition-all duration-300"
                disabled>
          <i class="fa-solid fa-retweet mr-1.5"></i> Repostar
        </button>
      </div>
    </div>
  </div>

  <!-- ═══ Modal Lista Seguidores/Seguindo ═══ -->
  <div id="listaSegModal" class="fixed inset-0 z-[60] hidden">
    <div class="absolute inset-0 bg-black/40 backdrop-blur-sm" id="listaSegOverlay"></div>
    <div class="absolute bottom-0 left-0 right-0 bg-white rounded-t-3xl max-h-[70vh] flex flex-col animate-slideUp safe-bottom md:relative md:top-1/2 md:-translate-y-1/2 md:max-w-md md:mx-auto md:rounded-2xl md:max-h-[60vh]">
      <div class="flex items-center justify-between px-5 py-4 border-b border-gray-100">
        <h3 class="font-bold text-gray-900" id="listaSegTitulo">Seguidores</h3>
        <button type="button" id="closeListaSeg" class="p-1 text-gray-400 hover:text-gray-600"><i class="fa-solid fa-xmark text-lg"></i></button>
      </div>
      <div id="listaSegBody" class="flex-1 overflow-y-auto px-5 py-3 space-y-2"></div>
    </div>
  </div>

<%- include('../partials/post-detail-modal') %>

</main>

<%- include('../partials/footer') %>

<script src="/js/airpet-post-detail-organic.js"></script>
<script>
(function () {
  'use strict';

  var perfilId = '<%= perfil.id %>';
  var myUserId = document.body.dataset.usuarioId ? parseInt(document.body.dataset.usuarioId) : null;
  var repostTargetId = null;

  /* ── Utilities ── */
  function tempoRelativo(dateStr) {
    var d = new Date(dateStr);
    var diff = Date.now() - d.getTime();
    var seg = Math.floor(diff / 1000);
    if (seg < 60) return 'agora';
    var min = Math.floor(seg / 60);
    if (min < 60) return min + 'min';
    var hrs = Math.floor(min / 60);
    if (hrs < 24) return hrs + 'h';
    var dias = Math.floor(hrs / 24);
    if (dias < 7) return dias + 'd';
    return d.toLocaleDateString('pt-BR', { day: 'numeric', month: 'short' });
  }

  function escapeHtml(str) {
    if (!str) return '';
    var div = document.createElement('div');
    div.textContent = str;
    return div.innerHTML;
  }

  function renderMentions(text) {
    if (!text) return '';
    return escapeHtml(text).replace(/@(\w[\w\s]*?\w)/g, '<a href="#" class="text-accent-500 font-semibold hover:underline">@$1</a>');
  }

  /* ── Relative times ── */
  function atualizarTempos() {
    document.querySelectorAll('.post-time[data-time]').forEach(function (el) {
      el.textContent = tempoRelativo(el.dataset.time);
    });
  }
  atualizarTempos();
  setInterval(atualizarTempos, 30000);

  /* ── Caption expand ── */
  document.querySelectorAll('.caption-area').forEach(function (area) {
    var text = area.querySelector('.caption-text');
    var btn = area.querySelector('.btn-ver-mais');
    if (text && btn) {
      requestAnimationFrame(function () {
        if (text.scrollHeight > text.clientHeight + 2) {
          btn.classList.remove('hidden');
          btn.addEventListener('click', function () {
            text.classList.remove('line-clamp-3');
            btn.classList.add('hidden');
          });
        }
      });
    }
  });

  /* ── Follow / Unfollow ── */
  var btnFollow = document.getElementById('btnFollow');
  if (btnFollow) {
    btnFollow.addEventListener('mouseenter', function () {
      if (btnFollow.dataset.following === 'true') {
        btnFollow.querySelector('span').textContent = 'Deixar de seguir';
        btnFollow.querySelector('i').className = 'fa-solid fa-user-xmark text-xs';
      }
    });
    btnFollow.addEventListener('mouseleave', function () {
      if (btnFollow.dataset.following === 'true') {
        btnFollow.querySelector('span').textContent = 'Seguindo';
        btnFollow.querySelector('i').className = 'fa-solid fa-user-check text-xs';
      }
    });

    btnFollow.addEventListener('click', function () {
      var following = btnFollow.dataset.following === 'true';
      var method = following ? 'DELETE' : 'POST';
      btnFollow.style.pointerEvents = 'none';

      fetch('/explorar/seguir/' + perfilId, {
        method: method,
        headers: { 'Accept': 'application/json' },
        credentials: 'same-origin'
      })
      .then(function (r) { return r.json(); })
      .then(function (data) {
        if (data.sucesso) {
          var nowFollowing = data.seguindo;
          btnFollow.dataset.following = nowFollowing ? 'true' : 'false';
          var icon = btnFollow.querySelector('i');
          var label = btnFollow.querySelector('span');

          if (nowFollowing) {
            btnFollow.className = 'follow-btn flex items-center gap-2 px-5 py-2 rounded-full text-sm font-bold bg-white border border-gray-300 text-gray-800 hover:border-red-300 hover:bg-red-50 hover:text-red-600';
            icon.className = 'fa-solid fa-user-check text-xs';
            label.textContent = 'Seguindo';
          } else {
            btnFollow.className = 'follow-btn flex items-center gap-2 px-5 py-2 rounded-full text-sm font-bold bg-gradient-to-r from-primary-500 to-primary-600 text-white shadow-lg shadow-primary-500/20 hover:shadow-xl hover:-translate-y-0.5';
            icon.className = 'fa-solid fa-user-plus text-xs';
            label.textContent = 'Seguir';
          }

          if (typeof data.totalSeguidores !== 'undefined') {
            document.getElementById('seguidoresCount').textContent = data.totalSeguidores;
          }
        }
        btnFollow.style.pointerEvents = '';
      })
      .catch(function () { btnFollow.style.pointerEvents = ''; });
    });
  }

  /* ── Share profile ── */
  var btnShareProfile = document.querySelector('.btn-share-profile');
  if (btnShareProfile) {
    btnShareProfile.addEventListener('click', function () {
      var url = window.location.origin + '/explorar/perfil/' + perfilId;
      var text = 'Veja o perfil de <%= perfil.nome.replace(/'/g, "\\'") %> no AIRPET! ' + url;
      if (navigator.share) {
        navigator.share({ title: '<%= perfil.nome.replace(/'/g, "\\'") %> — AIRPET', url: url }).catch(function () {});
      } else {
        window.open('https://wa.me/?text=' + encodeURIComponent(text), '_blank');
      }
    });
  }

  /* ── Modal lista seguidores / seguindo ── */
  var listaSegModal = document.getElementById('listaSegModal');
  var listaSegBody = document.getElementById('listaSegBody');
  var listaSegTitulo = document.getElementById('listaSegTitulo');
  function openListaSeg(tipo) {
    var url = tipo === 'seguidores' ? '/explorar/perfil/' + perfilId + '/seguidores' : '/explorar/perfil/' + perfilId + '/seguindo';
    listaSegTitulo.textContent = tipo === 'seguidores' ? 'Seguidores' : 'Seguindo';
    listaSegBody.innerHTML = '<div class="text-center py-8 text-gray-400"><i class="fa-solid fa-spinner fa-spin text-xl"></i></div>';
    listaSegModal.classList.remove('hidden');
    fetch(url, { headers: { 'Accept': 'application/json' }, credentials: 'same-origin' })
      .then(function (r) { return r.json(); })
      .then(function (data) {
        var lista = data.lista || [];
        if (lista.length === 0) {
          listaSegBody.innerHTML = '<p class="text-sm text-gray-500 text-center py-6">Nenhum resultado.</p>';
          return;
        }
        listaSegBody.innerHTML = lista.map(function (u) {
          var cor = u.cor_perfil || '#ec5a1c';
          var avatar = u.foto_perfil
            ? '<img src="' + escapeHtml(u.foto_perfil) + '" alt="" class="w-10 h-10 rounded-full object-cover" style="box-shadow:0 0 0 2px ' + escapeHtml(cor) + '">'
            : '<span class="w-10 h-10 rounded-full flex items-center justify-center text-sm font-bold text-white bg-gray-400" style="box-shadow:0 0 0 2px ' + escapeHtml(cor) + '">' + escapeHtml((u.nome || 'U').charAt(0).toUpperCase()) + '</span>';
          return '<a href="/explorar/perfil/' + u.id + '" class="flex items-center gap-3 p-2 rounded-xl hover:bg-gray-50 transition-colors">' + avatar + '<span class="font-semibold text-gray-900">' + escapeHtml(u.nome) + '</span></a>';
        }).join('');
      })
      .catch(function () { listaSegBody.innerHTML = '<p class="text-sm text-red-500 text-center py-6">Erro ao carregar.</p>'; });
  }
  var btnVerSeg = document.getElementById('btnVerSeguidores');
  var btnVerSegu = document.getElementById('btnVerSeguindo');
  if (btnVerSeg) btnVerSeg.addEventListener('click', function () { openListaSeg('seguidores'); });
  if (btnVerSegu) btnVerSegu.addEventListener('click', function () { openListaSeg('seguindo'); });
  document.getElementById('closeListaSeg').addEventListener('click', function () { listaSegModal.classList.add('hidden'); });
  document.getElementById('listaSegOverlay').addEventListener('click', function () { listaSegModal.classList.add('hidden'); });

  /* ── Like toggle ── */
  function doLike(postId, btn) {
    var liked = btn.dataset.liked === 'true';
    var method = liked ? 'DELETE' : 'POST';
    var icon = btn.querySelector('i');
    var countEl = btn.querySelector('.likes-count');

    btn.dataset.liked = liked ? 'false' : 'true';
    icon.className = (liked ? 'fa-regular' : 'fa-solid') + ' fa-heart text-[15px]';
    btn.className = btn.className.replace(liked ? 'text-red-500' : 'text-gray-500 hover:text-red-500', liked ? 'text-gray-500 hover:text-red-500' : 'text-red-500');
    if (!liked) btn.classList.add('heart-pop');
    setTimeout(function () { btn.classList.remove('heart-pop'); }, 500);

    fetch('/explorar/post/' + postId + '/curtir', {
      method: method,
      headers: { 'Accept': 'application/json' },
      credentials: 'same-origin'
    })
    .then(function (r) { return r.json(); })
    .then(function (data) {
      if (data.sucesso && countEl) {
        countEl.textContent = data.total || '';
      }
    })
    .catch(function () {});
  }

  document.addEventListener('click', function (e) {
    var btn = e.target.closest('.btn-like');
    if (btn) { e.preventDefault(); doLike(btn.dataset.postId, btn); }
  });

  window.toggleLike = function (img, postId) {
    var article = img.closest('article');
    if (!article) return;
    var btn = article.querySelector('.btn-like[data-post-id="' + postId + '"]');
    if (btn) doLike(postId, btn);
    var overlay = article.querySelector('.dbl-heart-overlay');
    if (overlay) {
      var heart = document.createElement('i');
      heart.className = 'fa-solid fa-heart text-white text-6xl float-heart drop-shadow-lg';
      overlay.appendChild(heart);
      setTimeout(function () { heart.remove(); }, 900);
    }
  };

  /* ── Post menus ── */
  document.addEventListener('click', function (e) {
    var menuBtn = e.target.closest('.post-menu-btn');
    if (menuBtn) {
      e.stopPropagation();
      var menu = document.getElementById('menu-' + menuBtn.dataset.postId);
      document.querySelectorAll('.menu-dropdown').forEach(function (m) { if (m !== menu) m.classList.add('hidden'); });
      if (menu) menu.classList.toggle('hidden');
      return;
    }
    document.querySelectorAll('.menu-dropdown').forEach(function (m) { m.classList.add('hidden'); });
  });

  /* ── Pin / Unpin ── */
  document.addEventListener('click', function (e) {
    var btn = e.target.closest('.btn-fixar');
    if (btn) {
      fetch('/explorar/post/' + btn.dataset.id + '/fixar', { method: 'POST', headers: { 'Accept': 'application/json' }, credentials: 'same-origin' })
        .then(function (r) { return r.json(); })
        .then(function (d) { if (d.sucesso) location.reload(); else alert(d.mensagem || 'Erro'); });
    }
    var btn2 = e.target.closest('.btn-desafixar');
    if (btn2) {
      fetch('/explorar/post/' + btn2.dataset.id + '/fixar', { method: 'DELETE', headers: { 'Accept': 'application/json' }, credentials: 'same-origin' })
        .then(function (r) { return r.json(); })
        .then(function (d) { if (d.sucesso) location.reload(); else alert(d.mensagem || 'Erro'); });
    }
  });

  /* ── Delete post ── */
  document.addEventListener('click', function (e) {
    var btn = e.target.closest('.btn-deletar-post');
    if (btn && confirm('Tem certeza que deseja excluir este post?')) {
      fetch('/explorar/post/' + btn.dataset.id, { method: 'DELETE', headers: { 'Accept': 'application/json' }, credentials: 'same-origin' })
        .then(function (r) { return r.json(); })
        .then(function (d) {
          if (d.sucesso) {
            var article = document.querySelector('article[data-post-id="' + btn.dataset.id + '"]');
            if (article) {
              article.style.transition = 'all .3s ease';
              article.style.opacity = '0';
              article.style.transform = 'scale(0.95)';
              setTimeout(function () { article.remove(); }, 300);
            }
          }
        });
    }
  });

  /* ── Share post ── */
  document.addEventListener('click', function (e) {
    var btn = e.target.closest('.btn-share-post') || e.target.closest('.btn-share');
    if (btn) {
      var id = btn.dataset.postId || btn.dataset.id;
      var legenda = btn.dataset.legenda || '';
      var url = window.location.origin + '/explorar?post=' + id;
      var text = legenda ? '🐾 ' + legenda + ' — ' + url : '🐾 Veja esse post no AIRPET! ' + url;
      if (navigator.share) {
        navigator.share({ title: 'AIRPET', text: text, url: url }).catch(function () {});
      } else {
        window.open('https://wa.me/?text=' + encodeURIComponent(text), '_blank');
      }
    }
  });

  /* ── Repost ── */
  var repostModal = document.getElementById('repostModal');
  var repostTexto = document.getElementById('repostTexto');
  var submitRepost = document.getElementById('submitRepost');

  document.addEventListener('click', function (e) {
    var btn = e.target.closest('.btn-repost');
    if (btn) {
      repostTargetId = btn.dataset.postId;
      repostModal.classList.remove('hidden');
      document.body.style.overflow = 'hidden';
      repostTexto.value = '';
      submitRepost.disabled = true;
      repostTexto.focus();
    }
  });

  repostTexto.addEventListener('input', function () {
    submitRepost.disabled = !repostTexto.value.trim();
  });

  document.getElementById('closeRepost').addEventListener('click', function () {
    repostModal.classList.add('hidden');
    document.body.style.overflow = '';
    repostTargetId = null;
  });
  document.getElementById('repostOverlay').addEventListener('click', function () {
    repostModal.classList.add('hidden');
    document.body.style.overflow = '';
    repostTargetId = null;
  });

  submitRepost.addEventListener('click', function () {
    if (!repostTargetId || !repostTexto.value.trim()) return;
    submitRepost.disabled = true;
    submitRepost.innerHTML = '<i class="fa-solid fa-spinner fa-spin mr-1.5"></i> Repostando...';

    fetch('/explorar/post/' + repostTargetId + '/repostar', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
      credentials: 'same-origin',
      body: JSON.stringify({ texto: repostTexto.value.trim() })
    })
    .then(function (r) { return r.json(); })
    .then(function (data) {
      if (data.sucesso) {
        repostModal.classList.add('hidden');
        document.body.style.overflow = '';
        var article = document.querySelector('article[data-post-id="' + repostTargetId + '"]');
        if (article) {
          var repostBtn = article.querySelector('.btn-repost');
          if (repostBtn) {
            repostBtn.classList.remove('text-gray-500', 'hover:text-green-500');
            repostBtn.classList.add('text-green-500');
            repostBtn.dataset.reposted = 'true';
            var cnt = repostBtn.querySelector('.repost-count');
            if (cnt && data.totalReposts !== undefined) cnt.textContent = data.totalReposts;
          }
        }
        repostTargetId = null;
      } else {
        alert(data.mensagem || 'Erro ao repostar.');
      }
      submitRepost.disabled = false;
      submitRepost.innerHTML = '<i class="fa-solid fa-retweet mr-1.5"></i> Repostar';
    })
    .catch(function () {
      alert('Erro de conexão.');
      submitRepost.disabled = false;
      submitRepost.innerHTML = '<i class="fa-solid fa-retweet mr-1.5"></i> Repostar';
    });
  });

  /* ── Comments Modal ── */
  var commentsModal = document.getElementById('commentsModal');
  var commentsBody = document.getElementById('commentsBody');
  var modalCommentForm = document.getElementById('modalCommentForm');
  var modalCommentInput = document.getElementById('modalCommentInput');
  var activeCommentPostId = null;

  function openComments(postId) {
    activeCommentPostId = postId;
    commentsModal.classList.remove('hidden');
    if (window.AIRPET_modalUi) window.AIRPET_modalUi.refreshBodyScroll();
    commentsBody.innerHTML = '<div class="flex flex-col items-center justify-center py-10 text-gray-300"><i class="fa-solid fa-spinner fa-spin text-xl"></i></div>';

    fetch('/explorar/post/' + postId + '/comentarios', { headers: { 'Accept': 'application/json' }, credentials: 'same-origin' })
      .then(function (r) { return r.json(); })
      .then(function (data) {
        if (!data.sucesso || !data.comentarios || !data.comentarios.length) {
          commentsBody.innerHTML = '<div class="text-center py-8 px-5"><p class="text-sm text-gray-400">Nenhum comentário ainda.</p><p class="text-xs text-gray-300 mt-1">Seja o primeiro a comentar!</p></div>';
          return;
        }
        if (window.AIRPET_commentRender && window.AIRPET_commentRender.renderList) {
          commentsBody.innerHTML = window.AIRPET_commentRender.renderList(data.comentarios, {
            meuId: myUserId,
            escapeHtml: escapeHtml,
            renderMencoes: renderMentions,
            tempoRelativo: tempoRelativo,
            useDataTimeAttr: false,
            forceDeleteButton: true,
            deleteDataAttr: 'data-id'
          });
        } else {
          var htmlfb = '';
          data.comentarios.forEach(function (c) {
            var isMe = myUserId && c.usuario_id === myUserId;
            htmlfb += '<div class="flex gap-2.5 group px-5" data-comment-id="' + c.id + '">';
            var cCor = c.cor_perfil || '#ec5a1c';
            if (c.foto_perfil) {
              htmlfb += '<a href="/explorar/perfil/' + c.usuario_id + '"><img src="' + c.foto_perfil + '" class="w-8 h-8 rounded-full object-cover flex-shrink-0" style="box-shadow:0 0 0 2px ' + cCor + '"></a>';
            } else {
              htmlfb += '<a href="/explorar/perfil/' + c.usuario_id + '"><span class="w-8 h-8 rounded-full flex items-center justify-center text-xs font-bold text-white flex-shrink-0 bg-gray-400" style="box-shadow:0 0 0 2px ' + cCor + '">' + (c.nome ? c.nome.charAt(0).toUpperCase() : 'U') + '</span></a>';
            }
            htmlfb += '<div class="flex-1 min-w-0"><p class="text-sm"><a href="/explorar/perfil/' + c.usuario_id + '" class="font-bold text-gray-900 hover:text-primary-600 transition-colors mr-1">' + escapeHtml(c.nome) + '</a><span class="text-gray-700">' + renderMentions(c.texto) + '</span></p>';
            htmlfb += '<div class="flex items-center gap-3 mt-1"><span class="text-[11px] text-gray-400">' + tempoRelativo(c.criado_em) + '</span>';
            if (isMe) htmlfb += '<button type="button" class="btn-del-comment text-[11px] text-gray-300 hover:text-red-500 opacity-0 group-hover:opacity-100 transition-all" data-id="' + c.id + '"><i class="fa-solid fa-trash-can"></i></button>';
            htmlfb += '</div></div></div>';
          });
          commentsBody.innerHTML = htmlfb;
        }
        commentsBody.scrollTop = commentsBody.scrollHeight;
      });
  }

  function closeComments() {
    commentsModal.classList.add('hidden');
    activeCommentPostId = null;
    if (window.AIRPET_modalUi) window.AIRPET_modalUi.refreshBodyScroll();
  }

  window.AIRPET_fecharCommentsModalPerfil = closeComments;

  document.addEventListener('click', function (e) {
    var btn = e.target.closest('.btn-open-comments');
    if (btn) openComments(btn.dataset.postId);
  });

  document.getElementById('closeComments').addEventListener('click', closeComments);
  document.getElementById('commentsOverlay').addEventListener('click', closeComments);

  modalCommentForm.addEventListener('submit', function (e) {
    e.preventDefault();
    var texto = modalCommentInput.value.trim();
    if (!texto || !activeCommentPostId) return;
    modalCommentInput.value = '';

    fetch('/explorar/post/' + activeCommentPostId + '/comentar', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
      credentials: 'same-origin',
      body: JSON.stringify({ texto: texto })
    })
    .then(function (r) { return r.json(); })
    .then(function (data) {
      if (data.sucesso) {
        openComments(activeCommentPostId);
        var article = document.querySelector('article[data-post-id="' + activeCommentPostId + '"]');
        if (article && data.total !== undefined) {
          var countEl = article.querySelector('.btn-open-comments .text-xs, .btn-open-comments span');
          if (countEl) countEl.textContent = data.total;
        }
      }
    });
  });

  document.addEventListener('click', function (e) {
    var btn = e.target.closest('.btn-del-comment');
    if (btn) {
      fetch('/explorar/comentario/' + btn.dataset.id, { method: 'DELETE', headers: { 'Accept': 'application/json' }, credentials: 'same-origin' })
        .then(function (r) { return r.json(); })
        .then(function (d) { if (d.sucesso && activeCommentPostId) openComments(activeCommentPostId); });
    }
  });

  /* ── Keyboard shortcuts (Escape global em airpet-modal-lock.js) ── */
  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape') {
      repostModal.classList.add('hidden');
      if (window.AIRPET_modalUi) window.AIRPET_modalUi.refreshBodyScroll();
    }
  });

})();
</script>
