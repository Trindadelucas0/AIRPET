<% locals.titulo = titulo || 'Grupos' %>
<%- include('../partials/header') %>
<%- include('../partials/flash') %>

<main class="flex-1 max-w-lg mx-auto px-4 py-6 pb-24">
  <h1 class="text-2xl font-black text-gray-900 tracking-tight">Grupos</h1>
  <p class="text-sm text-gray-500 mt-1">Comunidades abertas</p>

  <ul class="mt-6 space-y-3">
    <% (grupos || []).forEach(function(g) { %>
      <li class="rounded-2xl border border-gray-200 bg-white p-4 shadow-sm flex flex-col gap-2">
        <div class="font-bold text-gray-900"><%= g.nome %></div>
        <% if (g.descricao) { %><p class="text-sm text-gray-600"><%= g.descricao %></p><% } %>
        <div class="text-xs text-gray-500"><%= g.membros_count %> membros</div>
        <% if (g.sou_membro) { %>
          <span class="text-xs font-semibold text-green-600">Você já participa</span>
        <% } else { %>
          <button type="button" class="entrar-grupo rounded-xl bg-orange-500 text-white text-sm font-semibold py-2 px-4 w-fit" data-slug="<%= g.slug %>">Entrar</button>
        <% } %>
      </li>
    <% }); %>
    <% if (!(grupos || []).length) { %>
      <li class="text-sm text-gray-500">Nenhum grupo disponível ainda.</li>
    <% } %>
  </ul>

  <p class="mt-8 text-center text-sm">
    <a href="/explorar" class="text-orange-600 font-semibold">Voltar ao explorar</a>
  </p>
</main>

<script>
(function(){
  document.querySelectorAll('.entrar-grupo').forEach(function(btn){
    btn.addEventListener('click', function(){
      var slug = btn.getAttribute('data-slug');
      fetch('/explorar/grupos/' + encodeURIComponent(slug) + '/entrar', {
        method: 'POST',
        credentials: 'same-origin',
        headers: {
          'Accept': 'application/json',
          'Content-Type': 'application/json',
          'X-Requested-With': 'XMLHttpRequest',
        },
        body: '{}'
      }).then(function (r) {
        if (r.status === 401) {
          window.location.href = '/auth/login?return_to=/explorar/grupos';
          return null;
        }
        return r.json().catch(function () { return { sucesso: false }; });
      }).then(function (j) {
        if (!j) return;
        if (j.sucesso) location.reload();
        else alert(j.mensagem || 'Não foi possível entrar.');
      });
    });
  });
})();
</script>
<%- include('../partials/footer') %>
