<% locals.titulo = typeof titulo !== 'undefined' ? titulo : (pet && pet.nome) || 'Perfil do pet' %>
<% locals.extraHead = `
<style>
  .profile-reveal { animation: profileReveal .5s ease-out both; }
  @keyframes profileReveal { from { opacity: 0; transform: translateY(16px); } to { opacity: 1; transform: translateY(0); } }
  @keyframes postEnter { from { opacity: 0; transform: translateY(12px); } to { opacity: 1; transform: translateY(0); } }
  .post-enter { animation: postEnter .4s ease-out both; }
  .follow-btn { transition: all .3s cubic-bezier(.4,0,.2,1); }
  .menu-dropdown { transform-origin: top right; transition: opacity .15s, transform .15s; }
  .menu-dropdown.hidden { opacity: 0; transform: scale(.95); pointer-events: none; }
  .action-btn { transition: all .15s ease; }
  .heart-pop { animation: heartPop .45s cubic-bezier(.17,.67,.35,1.5); }
  @keyframes heartPop { 0% { transform: scale(1); } 30% { transform: scale(1.35); } 60% { transform: scale(0.9); } 100% { transform: scale(1); } }
  .float-heart { animation: floatHeart .8s ease-out forwards; pointer-events: none; }
  @keyframes floatHeart { 0% { opacity: 1; transform: translateY(0) scale(1); } 100% { opacity: 0; transform: translateY(-80px) scale(1.6); } }
  .repost-quote { border-left: 3px solid #e5e7eb; }
  .caption-expanded .line-clamp-3 { -webkit-line-clamp: unset !important; }
  .pet-hero {
    position: relative;
    overflow: hidden;
    border-radius: 0 0 28px 28px;
    background:
      radial-gradient(120% 120% at 88% -20%, rgba(255, 255, 255, .26) 0%, rgba(255, 255, 255, 0) 52%),
      radial-gradient(120% 150% at -12% -40%, rgba(253, 177, 118, .48) 0%, rgba(236, 90, 28, 0) 58%),
      linear-gradient(130deg, #ff8d5a 0%, #ec5a1c 44%, #b53e10 100%);
  }
  .pet-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: linear-gradient(135deg, rgba(255, 255, 255, .06) 25%, transparent 25%, transparent 50%, rgba(255, 255, 255, .06) 50%, rgba(255, 255, 255, .06) 75%, transparent 75%, transparent);
    background-size: 28px 28px;
    opacity: .25;
    pointer-events: none;
  }
  .pet-hero.has-cover {
    background: #111827;
  }
  .pet-hero.has-cover::before {
    background-image: linear-gradient(180deg, rgba(0,0,0,.12) 0%, rgba(0,0,0,.52) 100%);
    opacity: 1;
  }
  .pet-hero-cover {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
  }
  .glass-chip {
    background: rgba(255, 255, 255, .16);
    border: 1px solid rgba(255, 255, 255, .26);
    backdrop-filter: blur(8px);
  }
  .petshop-card {
    border: 1px solid #f2e4dc;
    background: linear-gradient(180deg, #fffdfc 0%, #fff8f4 100%);
    transition: all .25s ease;
  }
  .petshop-card:hover {
    border-color: #f8c5ae;
    transform: translateY(-1px);
    box-shadow: 0 10px 22px rgba(236, 90, 28, .08);
  }
  .btn-soft {
    transition: all .2s ease;
  }
  .btn-soft:hover { transform: translateY(-1px); }
  .btn-soft:active { transform: translateY(0); }
  .airpet-toast-wrap {
    position: fixed;
    right: 14px;
    bottom: 82px;
    z-index: 90;
    display: flex;
    flex-direction: column;
    gap: 8px;
    pointer-events: none;
  }
  .airpet-toast {
    min-width: 220px;
    max-width: min(88vw, 320px);
    border-radius: 12px;
    padding: 10px 12px;
    color: #111827;
    font-size: 13px;
    font-weight: 600;
    background: #fff;
    border: 1px solid #f3f4f6;
    box-shadow: 0 10px 26px rgba(15, 23, 42, .16);
    animation: toastIn .2s ease-out both;
  }
  .airpet-toast--success { border-color: #c8f1d8; background: #f4fff8; color: #13653a; }
  .airpet-toast--error { border-color: #ffd8d8; background: #fff6f6; color: #a02121; }
  @keyframes toastIn { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: translateY(0); } }
  .mini-link-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    max-width: 190px;
    padding: 5px 8px;
    border-radius: 999px;
    border: 1px solid #f5d5c4;
    background: #fff;
    font-size: 11px;
    font-weight: 700;
    color: #4b5563;
  }
</style>
` %>
<%- include('../partials/header') %>
<%- include('../partials/flash') %>

<main class="flex-1 pb-24 md:pb-6">
  <div class="max-w-2xl mx-auto">
    <!-- Bloco hero -->
    <section class="pet-hero <%= pet.foto_capa ? 'has-cover' : '' %> h-[170px] sm:h-[220px] px-4 pt-4 sm:pt-6 profile-reveal">
      <% if (pet.foto_capa) { %>
        <img src="<%= pet.foto_capa %>" alt="" class="pet-hero-cover">
      <% } %>
      <% if (eMeuPet) { %>
        <div class="relative z-10 flex justify-end">
          <input type="file" id="inputCapaPet" accept="image/*" class="hidden">
          <button type="button" id="btnEditarCapaPet" class="glass-chip rounded-full px-3 py-1.5 text-[11px] text-white/90 font-semibold">
            <i class="fa-solid fa-camera mr-1"></i>Editar capa
          </button>
        </div>
      <% } %>
    </section>

    <div class="px-4">
      <!-- Bloco identidade -->
      <div class="flex items-end justify-between -mt-12 sm:-mt-14 mb-3 profile-reveal">
        <div class="flex-shrink-0">
          <% if (pet.foto) { %>
            <img src="<%= pet.foto %>" alt="<%= pet.nome %>" class="w-24 h-24 sm:w-28 sm:h-28 rounded-full object-cover ring-4 ring-white shadow-xl shadow-primary-900/20">
          <% } else { %>
            <span class="w-24 h-24 sm:w-28 sm:h-28 rounded-full flex items-center justify-center text-3xl font-black text-white shadow-xl ring-4 ring-white bg-primary-500">
              <i class="fa-solid fa-paw"></i>
            </span>
          <% } %>
        </div>
        <% if (!eMeuPet) { %>
        <div class="pb-1">
          <button type="button" id="btnFollowPet" data-pet-id="<%= pet.id %>" data-following="<%= estaSeguindo ? 'true' : 'false' %>"
                  class="follow-btn flex items-center gap-2 px-5 py-2 rounded-full text-sm font-bold
                    <%= estaSeguindo ? 'bg-white border border-gray-300 text-gray-800 hover:border-red-300 hover:bg-red-50 hover:text-red-600' : 'bg-gradient-to-r from-primary-500 to-primary-600 text-white shadow-lg shadow-primary-500/20 hover:shadow-xl hover:-translate-y-0.5' %>">
            <i class="fa-solid <%= estaSeguindo ? 'fa-paw' : 'fa-paw' %> text-xs"></i>
            <span><%= estaSeguindo ? 'Seguindo' : 'Seguir' %></span>
          </button>
        </div>
        <% } %>
      </div>

      <section class="profile-reveal" style="animation-delay: .05s">
        <div class="flex flex-wrap items-center gap-2">
          <h1 class="text-2xl font-black text-gray-900 leading-tight"><%= pet.nome %></h1>
          <% if (pet.raca) { %>
            <span class="inline-flex items-center gap-1 rounded-full bg-orange-50 text-orange-700 px-2.5 py-1 text-[11px] font-bold">
              <i class="fa-solid fa-paw text-[10px]"></i> <%= pet.raca %>
            </span>
          <% } %>
        </div>
        <% if (dono) { %>
          <p class="text-sm text-gray-500 mt-1">
            Tutor: <a href="/explorar/perfil/<%= dono.id %>" class="text-primary-500 hover:underline font-semibold"><%= dono.nome %></a>
          </p>
        <% } %>

        <!-- Stats sociais: só mostra seguidores se for relevante -->
        <div class="flex items-center gap-3 mt-4">
          <% if (totalSeguidores > 0 || !eMeuPet) { %>
            <button type="button" id="btnVerSeguidores"
              class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full border border-gray-200 bg-white text-sm font-semibold text-gray-700 hover:border-primary-200 hover:bg-orange-50/50 transition-colors">
              <i class="fa-solid fa-paw text-primary-400 text-[11px]"></i>
              <span id="seguidoresCount"><%= totalSeguidores %></span>
              <span class="text-gray-400 font-normal"><%= totalSeguidores === 1 ? 'seguidor' : 'seguidores' %></span>
            </button>
          <% } %>
          <% if (eMeuPet) { %>
            <a href="/pets/<%= pet.id %>" class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full border border-primary-200 bg-primary-50 text-sm font-semibold text-primary-600 hover:bg-primary-100 transition-colors">
              <i class="fa-solid fa-shield-halved text-[11px]"></i> Gerenciar pet
            </a>
          <% } %>
        </div>
      </section>

      <% if (typeof petsMaisFofinhos !== 'undefined' && petsMaisFofinhos) { %>
      <section class="profile-reveal mt-5 rounded-2xl border border-amber-200/80 bg-gradient-to-br from-amber-50 via-white to-orange-50/40 p-4 sm:p-5 shadow-sm" style="animation-delay: .06s">
        <div class="flex items-start justify-between gap-3">
          <div>
            <h2 class="font-black text-gray-900 text-base sm:text-lg flex items-center gap-2">
              <span class="text-xl" aria-hidden="true">🐾</span> Pets mais fofinhos
            </h2>
            <p class="text-xs text-gray-600 mt-1">Concurso da comunidade AIRPET — o pet entra automaticamente quando cumpre os requisitos.</p>
          </div>
          <a href="/explorar/pet-do-mes" class="shrink-0 text-xs font-bold text-white bg-gradient-to-r from-orange-500 to-amber-500 rounded-full px-3 py-1.5 shadow-sm hover:opacity-95">Ver ranking</a>
        </div>
        <% if (petsMaisFofinhos.diasRestantes != null) { %>
          <p class="text-sm font-semibold text-amber-900 mt-3">Faltam <span class="tabular-nums"><%= petsMaisFofinhos.diasRestantes %></span> dia<%= petsMaisFofinhos.diasRestantes === 1 ? '' : 's' %> para acabar esta edição.</p>
        <% } %>
        <% if (petsMaisFofinhos.elegivel) { %>
          <p class="text-sm text-gray-800 mt-2">
            <strong><%= pet.nome %></strong> está a concorrer.
            <% if (petsMaisFofinhos.posicaoNacional != null) { %>
              Posição no ranking geral: <strong>#<%= petsMaisFofinhos.posicaoNacional %></strong>.
            <% } %>
          </p>
        <% } else { %>
          <ul class="mt-3 text-sm text-gray-700 list-disc pl-5 space-y-1">
            <% if ((petsMaisFofinhos.fotosComMidia || 0) < (petsMaisFofinhos.minFotos || 4)) { %>
              <li>Faltam posts com foto: tem <strong><%= petsMaisFofinhos.fotosComMidia || 0 %></strong> e precisa de pelo menos <strong><%= petsMaisFofinhos.minFotos || 4 %></strong>.</li>
            <% } %>
            <% if (!petsMaisFofinhos.temPetshop) { %>
              <li>Vincule um <strong>petshop</strong> ou parceiro ao pet para poder receber votos.</li>
            <% } %>
          </ul>
        <% } %>
      </section>
      <% } %>

      <!-- Bloco petshops — só exibe se tiver vínculos ou se for visitante -->
      <% var _petshops = petshopsVinculados || []; %>
      <% if (_petshops.length > 0 || !eMeuPet) { %>
      <section class="profile-reveal mt-5 rounded-2xl border border-[#f4dbce] bg-gradient-to-b from-[#fff5ee] via-[#fffaf7] to-white p-4 sm:p-5 shadow-[0_8px_24px_rgba(236,90,28,.08)]" style="animation-delay: .08s">
        <div class="flex items-start justify-between gap-3 mb-3">
          <div>
            <h2 class="font-black text-gray-900 text-base sm:text-lg">Parceiros do pet</h2>
            <p class="text-xs text-gray-500 mt-0.5">Clínicas e petshops vinculados.</p>
          </div>
          <a href="/petshops" class="text-[11px] font-semibold text-orange-700 bg-orange-100/70 rounded-full px-2.5 py-1 hover:bg-orange-200/70">Buscar PetParceiro</a>
        </div>

        <div id="petshopLinksWrap" class="space-y-2.5">
          <% if (_petshops.length === 0) { %>
            <p class="text-sm text-gray-400 text-center py-4">Nenhum parceiro vinculado ainda.</p>
          <% } %>
          <% _petshops.forEach(function(link) { %>
            <div class="petshop-card rounded-2xl p-3 sm:p-3.5 flex items-center justify-between gap-3" data-linked-petshop-id="<%= link.petshop_id %>">
              <div class="min-w-0">
                <a href="/petshops/<%= link.petshop_slug || link.petshop_id %>" class="text-sm sm:text-[15px] font-bold text-gray-800 hover:text-primary-500 block truncate"><%= link.petshop_nome %></a>
                <div class="mt-1">
                  <span class="mini-link-badge" title="Vinculado">
                    <% if (link.logo_url) { %>
                      <img src="<%= link.logo_url %>" alt="" class="w-4 h-4 rounded-full object-cover">
                    <% } else { %>
                      <span class="w-4 h-4 rounded-full bg-orange-200 text-orange-700 inline-flex items-center justify-center"><i class="fa-solid fa-store text-[8px]"></i></span>
                    <% } %>
                    Vinculado
                  </span>
                </div>
              </div>
              <div class="flex items-center gap-2 shrink-0">
                <button type="button"
                        class="btn-toggle-follow-petshop btn-soft text-xs px-3 py-1.5 rounded-xl border font-semibold <%= link.usuario_segue ? 'border-gray-300 bg-white text-gray-600' : 'border-primary-500 bg-white text-primary-600' %>"
                        data-petshop-id="<%= link.petshop_id %>">
                  <%= link.usuario_segue ? 'Seguindo' : 'Seguir' %>
                </button>
                <% if (eMeuPet) { %>
                  <button type="button" class="btn-unlink-petshop btn-soft text-xs px-3 py-1.5 rounded-xl border border-red-200 bg-red-50 text-red-600 font-semibold" data-petshop-id="<%= link.petshop_id %>">Desvincular</button>
                <% } %>
              </div>
            </div>
          <% }) %>
        </div>
      </section>
      <% } %> <!-- /if petshops -->
    </div>

    <div class="px-4 pt-4" id="postsContainer">
      <% if (posts.length === 0) { %>
        <div class="text-center py-16 profile-reveal">
          <div class="w-20 h-20 mx-auto mb-4 rounded-full bg-gray-50 flex items-center justify-center">
            <i class="fa-solid fa-feather-pointed text-3xl text-gray-300"></i>
          </div>
          <h3 class="text-lg font-bold text-gray-800 mb-1">Nenhuma publicação ainda</h3>
          <p class="text-sm text-gray-400"><%= pet.nome %> ainda não tem publicações.</p>
        </div>
      <% } %>

      <% posts.forEach(function(post, idx) { %>
        <% var exibirFotoMetaPet = (post.foto && String(post.foto).trim()) ? post.foto : (post.orig_foto ? post.orig_foto : ''); %>
        <% var textoMetaPet = post.texto || post.legenda || ''; %>
        <% var metaExplorarPet = {
          kind: 'organic',
          postId: post.id,
          foto: exibirFotoMetaPet || '',
          texto: textoMetaPet,
          criado_em: post.criado_em || '',
          autor_nome: post.autor_nome || '',
          usuario_id: post.usuario_id,
          foto_perfil: post.foto_perfil || '',
          cor_perfil: post.cor_perfil || '#ec5a1c',
          pet_id: pet.id,
          pet_nome: pet.nome,
          pet_foto: pet.foto || '',
          fixada: !!post.fixada,
          comments: true
        }; %>
        <article class="bg-white rounded-2xl shadow-[0_8px_22px_rgba(17,24,39,.06)] border border-orange-100/70 mb-4 overflow-hidden post-enter"
                 id="post-<%= post.id %>"
                 data-post-id="<%= post.id %>" data-author-id="<%= post.usuario_id %>"
                 data-explorar-meta="<%= encodeURIComponent(JSON.stringify(metaExplorarPet)) %>"
                 style="animation-delay: <%= (idx * 50) + 200 %>ms">
          <% if (post.fixada) { %>
            <div class="flex items-center gap-2 px-4 pt-3 pb-0 text-xs text-amber-500 font-semibold">
              <i class="fa-solid fa-thumbtack text-[10px]"></i><span>Fixado</span>
            </div>
          <% } %>
          <div class="flex items-center gap-3 px-4 pt-3 pb-2 bg-gradient-to-r from-orange-50/40 to-transparent">
            <a href="/explorar/pet/<%= pet.id %>" class="flex-shrink-0 rounded-full transition-transform active:scale-95">
              <% if (pet.foto) { %>
                <img src="<%= pet.foto %>" alt="" class="w-11 h-11 rounded-full object-cover ring-2 ring-primary-200 shadow-sm">
              <% } else { %>
                <span class="w-11 h-11 rounded-full flex items-center justify-center text-lg bg-primary-50 text-primary-500 ring-2 ring-primary-200/70">🐾</span>
              <% } %>
            </a>
            <div class="flex-1 min-w-0">
              <div class="font-display font-extrabold text-[15px] text-gray-900 tracking-tight leading-tight">
                <span class="mr-1" aria-hidden="true">🐾</span><%= pet.nome %>
              </div>
              <p class="text-xs text-gray-500 mt-0.5 truncate">por <a href="/explorar/perfil/<%= post.usuario_id %>" class="font-semibold text-gray-600 hover:text-primary-600"><%= post.autor_nome %></a></p>
              <span class="post-time text-[10px] text-gray-400" data-time="<%= post.criado_em %>"></span>
            </div>
          </div>
          <% if (post.texto || post.legenda) { %>
            <div class="px-4 pb-2 caption-area" data-post-id="<%= post.id %>">
              <p class="text-[15px] text-gray-800 leading-relaxed"><span class="caption-text line-clamp-3"><%= post.texto || post.legenda %></span></p>
              <button type="button" class="btn-ver-mais text-xs text-primary-500 font-semibold mt-1 hidden">ver mais</button>
            </div>
          <% } %>
          <% if (post.foto) { %>
            <div class="relative mx-4 mb-3 rounded-2xl overflow-hidden">
              <img src="<%= post.foto %>" alt="" class="post-photo w-full rounded-2xl object-cover max-h-[500px] cursor-zoom-in" loading="lazy" ondblclick="toggleLike(this, '<%= post.id %>')">
              <div class="dbl-heart-overlay absolute inset-0 flex items-center justify-center pointer-events-none"></div>
            </div>
          <% } %>
          <% if (post.orig_id) { %>
            <div class="mx-4 mb-3 repost-quote rounded-xl border border-gray-100 overflow-hidden bg-gray-50/50 p-3">
              <div class="flex items-start gap-2 mb-2">
                <% var oPet = post.orig_pet_id && post.orig_pet_nome; %>
                <% if (oPet) { %>
                  <a href="/explorar/pet/<%= post.orig_pet_id %>" class="shrink-0">
                    <% if (post.orig_pet_foto) { %>
                      <img src="<%= post.orig_pet_foto %>" alt="" class="w-7 h-7 rounded-full object-cover ring-1 ring-primary-200">
                    <% } else { %>
                      <span class="w-7 h-7 rounded-full bg-primary-50 text-primary-500 flex items-center justify-center text-xs">🐾</span>
                    <% } %>
                  </a>
                  <div class="min-w-0">
                    <a href="/explorar/pet/<%= post.orig_pet_id %>" class="font-display font-extrabold text-xs text-gray-900 block truncate"><%= post.orig_pet_nome %></a>
                    <span class="text-[10px] text-gray-500">por <%= post.orig_autor_nome %></span>
                  </div>
                <% } else { %>
                  <span class="text-xs font-bold text-gray-700"><%= post.orig_autor_nome %></span>
                <% } %>
              </div>
              <% if (post.orig_texto || post.orig_legenda) { %><p class="text-sm text-gray-700 line-clamp-3 mb-2"><%= post.orig_texto || post.orig_legenda %></p><% } %>
              <% if (post.orig_foto) { %><img src="<%= post.orig_foto %>" alt="" class="post-embed-img w-full rounded-lg object-cover max-h-[200px] cursor-zoom-in" loading="lazy"><% } %>
            </div>
          <% } %>
          <div class="px-4 pb-3 pt-1">
            <div class="flex items-center justify-between max-w-md">
              <button type="button" class="btn-open-comments action-btn group flex items-center gap-1.5 text-gray-500 hover:text-accent-500" data-post-id="<%= post.id %>">
                <div class="p-1.5 rounded-full group-hover:bg-blue-50"><i class="fa-regular fa-comment text-[15px]"></i></div>
                <span class="text-xs"><%= post.total_comentarios || '' %></span>
              </button>
              <button type="button" class="btn-repost action-btn group flex items-center gap-1.5 <%= post.repostou ? 'text-green-500' : 'text-gray-500 hover:text-green-500' %>" data-post-id="<%= post.id %>" data-reposted="<%= post.repostou ? 'true' : 'false' %>">
                <div class="p-1.5 rounded-full group-hover:bg-green-50"><i class="fa-solid fa-retweet text-[15px]"></i></div>
                <span class="text-xs repost-count"><%= post.total_reposts || '' %></span>
              </button>
              <button type="button" class="btn-like action-btn group flex items-center gap-1.5 <%= post.curtiu ? 'text-red-500' : 'text-gray-500 hover:text-red-500' %>" data-post-id="<%= post.id %>" data-liked="<%= post.curtiu ? 'true' : 'false' %>">
                <div class="p-1.5 rounded-full group-hover:bg-red-50"><i class="<%= post.curtiu ? 'fa-solid' : 'fa-regular' %> fa-heart text-[15px]"></i></div>
                <span class="text-xs likes-count"><%= post.total_curtidas || '' %></span>
              </button>
            </div>
          </div>
        </article>
      <% }); %>
    </div>
  </div>

  <!-- Modal lista seguidores/seguindo -->
  <div id="listaSegModal" class="fixed inset-0 z-[60] hidden">
    <div class="absolute inset-0 bg-black/40 backdrop-blur-sm" id="listaSegOverlay"></div>
    <div class="absolute bottom-0 left-0 right-0 bg-white rounded-t-3xl max-h-[70vh] flex flex-col safe-bottom md:relative md:top-1/2 md:-translate-y-1/2 md:max-w-md md:mx-auto md:rounded-2xl md:max-h-[60vh] shadow-[0_20px_50px_rgba(17,24,39,.2)] border border-orange-100">
      <div class="flex items-center justify-between px-5 py-4 border-b border-gray-100">
        <h3 class="font-bold text-gray-900" id="listaSegTitulo">Seguidores</h3>
        <button type="button" id="closeListaSeg" class="p-1 text-gray-400 hover:text-gray-600"><i class="fa-solid fa-xmark text-lg"></i></button>
      </div>
      <div id="listaSegBody" class="flex-1 overflow-y-auto px-5 py-3 space-y-2"></div>
    </div>
  </div>

  <!-- Modal comentários -->
  <div id="commentsModal" class="airpet-modal airpet-modal--comments hidden">
    <div class="airpet-modal__backdrop" id="commentsOverlay"></div>
    <div class="airpet-modal__sheet bg-white animate-slideUp" role="dialog" aria-modal="true" aria-labelledby="commentsModalPetTitle">
      <div class="airpet-modal__header border-b border-gray-100">
        <h3 id="commentsModalPetTitle" class="airpet-modal__title">Comentários</h3>
        <button type="button" id="closeComments" class="airpet-modal__header-btn" aria-label="Fechar">
          <i class="fa-solid fa-xmark text-lg"></i>
        </button>
      </div>
      <div id="commentsBody" class="airpet-modal__body px-0 min-h-[120px]"></div>
      <div id="perfilPetCommentsReplyBar" class="hidden px-5 pt-2 pb-1 flex items-center justify-between gap-2 text-xs bg-primary-50/90 border-t border-primary-100/80">
        <span class="text-gray-600 truncate">Respondendo a <strong id="perfilPetCommentsReplyToName" class="text-gray-900"></strong></span>
        <button type="button" id="perfilPetCommentsReplyCancel" class="shrink-0 font-semibold text-primary-600 py-1">Cancelar</button>
      </div>
      <form id="modalCommentForm" class="airpet-modal__footer border-t border-gray-100 flex items-center gap-2 px-5 pt-3">
        <input type="text" id="modalCommentInput" placeholder="Escreva um comentário..." maxlength="300"
               class="flex-1 text-sm bg-gray-50 rounded-full px-4 py-2.5 border-0 outline-none focus:ring-2 focus:ring-primary-500/20">
        <button type="submit" class="w-9 h-9 rounded-full bg-gradient-to-r from-primary-500 to-primary-600 text-white flex items-center justify-center shrink-0">
          <i class="fa-solid fa-paper-plane text-xs"></i>
        </button>
      </form>
    </div>
  </div>

<%- include('../partials/post-detail-modal') %>
</main>

<script>
(function () {
  var petId = '<%= pet.id %>';
  var eMeuPet = <%= typeof eMeuPet !== 'undefined' && eMeuPet ? 'true' : 'false' %>;
  var myUserId = <%= typeof usuario !== 'undefined' && usuario ? usuario.id : 'null' %>;
  var toastWrap = null;

  function petProfileDeferred(workFn, message) {
    var L = window.AIRPET_LOADING;
    if (L && typeof L.withDeferredOverlay === 'function') {
      return L.withDeferredOverlay(workFn, { message: message || 'Ainda a processar…' });
    }
    return Promise.resolve().then(workFn);
  }
  function petProfileCoordinator() {
    return window.AIRPET_REQ_COORDINATOR || null;
  }

  function escapeHtmlPet(str) {
    if (!str) return '';
    var div = document.createElement('div');
    div.textContent = str;
    return div.innerHTML;
  }
  function renderMencoesPet(texto) {
    var esc = escapeHtmlPet(texto);
    if (typeof window !== 'undefined' && window.AIRPET_socialTextoLinkify && typeof window.AIRPET_socialTextoLinkify.linkifyHashtagsInEscaped === 'function') {
      esc = window.AIRPET_socialTextoLinkify.linkifyHashtagsInEscaped(esc);
    }
    return esc.replace(/@(\S+)/g, '<span class="mention" data-user="$1">@$1</span>');
  }

  function tempoRelativo(dateStr) {
    var d = new Date(dateStr);
    var diff = Date.now() - d.getTime();
    var seg = Math.floor(diff / 1000);
    if (seg < 60) return 'agora';
    var min = Math.floor(seg / 60);
    if (min < 60) return min + 'min';
    var hrs = Math.floor(min / 60);
    if (hrs < 24) return hrs + 'h';
    var dias = Math.floor(hrs / 24);
    return dias + 'd';
  }
  document.querySelectorAll('.post-time[data-time]').forEach(function (el) { el.textContent = tempoRelativo(el.dataset.time); });
  setInterval(function () {
    document.querySelectorAll('.post-time[data-time]').forEach(function (el) { el.textContent = tempoRelativo(el.dataset.time); });
  }, 30000);

  document.querySelectorAll('.caption-area').forEach(function (area) {
    var text = area.querySelector('.caption-text');
    var btn = area.querySelector('.btn-ver-mais');
    if (text && btn && text.scrollHeight > text.clientHeight + 2) {
      btn.classList.remove('hidden');
      btn.addEventListener('click', function () { text.classList.remove('line-clamp-3'); btn.classList.add('hidden'); });
    }
  });

  var btnFollowPet = document.getElementById('btnFollowPet');
  if (btnFollowPet) {
    btnFollowPet.addEventListener('click', function () {
      var following = btnFollowPet.dataset.following === 'true';
      var method = following ? 'DELETE' : 'POST';
      btnFollowPet.disabled = true;
      petProfileDeferred(function () {
        return fetch('/explorar/pet/' + petId + '/seguir', { method: method, headers: { 'Accept': 'application/json' }, credentials: 'same-origin' })
          .then(function (r) { return r.json(); })
          .then(function (data) {
            if (data.sucesso) {
              btnFollowPet.dataset.following = data.seguindo ? 'true' : 'false';
              btnFollowPet.querySelector('span').textContent = data.seguindo ? 'Seguindo' : 'Seguir';
              btnFollowPet.className = 'follow-btn flex items-center gap-2 px-5 py-2 rounded-full text-sm font-bold ' +
                (data.seguindo ? 'bg-white border border-gray-300 text-gray-800 hover:border-red-300 hover:bg-red-50 hover:text-red-600' : 'bg-gradient-to-r from-primary-500 to-primary-600 text-white shadow-lg shadow-primary-500/20');
              if (data.totalSeguidores !== undefined) document.getElementById('seguidoresCount').textContent = data.totalSeguidores;
            }
          });
      }, following ? 'A deixar de seguir…' : 'A seguir pet…')
        .finally(function () { btnFollowPet.disabled = false; });
    });
  }

  function ensureToastWrap() {
    if (toastWrap) return toastWrap;
    toastWrap = document.createElement('div');
    toastWrap.className = 'airpet-toast-wrap';
    document.body.appendChild(toastWrap);
    return toastWrap;
  }

  function toastPetshop(msg, type) {
    if (!msg) return;
    var wrap = ensureToastWrap();
    var el = document.createElement('div');
    el.className = 'airpet-toast ' + (type === 'error' ? 'airpet-toast--error' : 'airpet-toast--success');
    el.textContent = msg;
    wrap.appendChild(el);
    setTimeout(function () {
      el.style.opacity = '0';
      el.style.transform = 'translateY(6px)';
      el.style.transition = 'opacity .15s ease, transform .15s ease';
      setTimeout(function () { el.remove(); }, 180);
    }, 2400);
  }

  var btnEditarCapaPet = document.getElementById('btnEditarCapaPet');
  var inputCapaPet = document.getElementById('inputCapaPet');
  if (btnEditarCapaPet && inputCapaPet) {
    btnEditarCapaPet.addEventListener('click', function () {
      inputCapaPet.click();
    });
    inputCapaPet.addEventListener('change', function () {
      var file = inputCapaPet.files && inputCapaPet.files[0] ? inputCapaPet.files[0] : null;
      if (!file) return;
      var fd = new FormData();
      fd.append('foto_capa', file);
      btnEditarCapaPet.disabled = true;
      btnEditarCapaPet.innerHTML = '<i class="fa-solid fa-spinner fa-spin mr-1"></i>Enviando';
      petProfileDeferred(function () {
        return fetch('/explorar/pet/' + petId + '/capa', {
          method: 'POST',
          credentials: 'same-origin',
          body: fd
        })
          .then(function (r) { return r.json().then(function (d) { return { ok: r.ok, data: d }; }); })
          .then(function (result) {
            if (!result.ok || !result.data.sucesso) {
              toastPetshop((result.data && result.data.mensagem) || 'Nao foi possivel atualizar capa.', 'error');
              return result;
            }
            toastPetshop('Capa atualizada com sucesso.', 'success');
            window.location.reload();
            return result;
          })
          .catch(function () {
            toastPetshop('Erro de conexao ao atualizar capa.', 'error');
            throw new Error('network');
          });
      }, 'A enviar capa…')
        .finally(function () {
          btnEditarCapaPet.disabled = false;
          btnEditarCapaPet.innerHTML = '<i class="fa-solid fa-camera mr-1"></i>Editar capa';
        });
    });
  }

  document.querySelectorAll('.btn-unlink-petshop').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var petshopId = btn.getAttribute('data-petshop-id');
      if (!petshopId) return;
      btn.disabled = true;
      petProfileDeferred(function () {
        return fetch('/explorar/pet/' + petId + '/petshops/' + petshopId, {
          method: 'DELETE',
          headers: { 'Accept': 'application/json' },
          credentials: 'same-origin'
        })
          .then(function (r) { return r.json().then(function (d) { return { ok: r.ok, data: d }; }); })
          .then(function (result) {
            if (!result.ok || !result.data.sucesso) {
              toastPetshop(result.data && result.data.mensagem ? result.data.mensagem : 'Nao foi possivel desvincular.', 'error');
              return result;
            }
            var row = btn.closest('[data-linked-petshop-id]');
            if (row) row.remove();
            toastPetshop('Petshop desvinculado.', 'success');
            return result;
          })
          .catch(function () {
            toastPetshop('Erro de conexao ao desvincular.', 'error');
            throw new Error('network');
          });
      }, 'A desvincular petshop…').finally(function () { btn.disabled = false; });
    });
  });

  document.querySelectorAll('.btn-toggle-follow-petshop').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var petshopId = btn.getAttribute('data-petshop-id');
      if (!petshopId) return;
      btn.disabled = true;
      petProfileDeferred(function () {
        return fetch('/petshops/' + petshopId + '/seguir-json', {
          method: 'POST',
          headers: { 'Accept': 'application/json' },
          credentials: 'same-origin'
        })
          .then(function (r) { return r.json().then(function (d) { return { ok: r.ok, data: d }; }); })
          .then(function (result) {
            if (!result.ok || !result.data.sucesso) {
              toastPetshop(result.data && result.data.mensagem ? result.data.mensagem : 'Nao foi possivel atualizar.', 'error');
              return result;
            }
            var seguindo = !!result.data.seguindo;
            btn.textContent = seguindo ? 'Seguindo' : 'Seguir';
            btn.className = 'btn-toggle-follow-petshop btn-soft text-xs px-3 py-1.5 rounded-xl border font-semibold ' +
              (seguindo ? 'border-gray-300 bg-white text-gray-600' : 'border-primary-500 bg-white text-primary-600');
            toastPetshop(seguindo ? 'Agora voce segue este petshop.' : 'Voce deixou de seguir este petshop.', 'success');
            return result;
          })
          .catch(function () {
            toastPetshop('Erro de conexao ao atualizar seguimento.', 'error');
            throw new Error('network');
          });
      }, 'A atualizar seguimento ao petshop…').finally(function () { btn.disabled = false; });
    });
  });

  function doLike(postId, btn) {
    var liked = btn.dataset.liked === 'true';
    var method = liked ? 'DELETE' : 'POST';
    var icon = btn.querySelector('i');
    var countEl = btn.querySelector('.likes-count');
    btn.dataset.liked = liked ? 'false' : 'true';
    icon.className = (liked ? 'fa-regular' : 'fa-solid') + ' fa-heart text-[15px]';
    btn.classList.toggle('text-red-500', !liked);
    btn.classList.toggle('text-gray-500', liked);
    if (!liked) btn.classList.add('heart-pop');
    setTimeout(function () { btn.classList.remove('heart-pop'); }, 500);
    petProfileDeferred(function () {
      return fetch('/explorar/post/' + postId + '/curtir', { method: method, headers: { 'Accept': 'application/json' }, credentials: 'same-origin' })
        .then(function (r) { return r.json(); })
        .then(function (data) { if (data.sucesso && countEl) countEl.textContent = data.total || ''; });
    }, liked ? 'A remover gosto…' : 'A registar gosto…');
  }
  document.addEventListener('click', function (e) {
    var btn = e.target.closest('.btn-like');
    if (btn) { e.preventDefault(); doLike(btn.dataset.postId, btn); }
  });
  window.toggleLike = function (img, postId) {
    var article = img.closest('article');
    if (!article) return;
    var btn = article.querySelector('.btn-like[data-post-id="' + postId + '"]');
    if (btn) doLike(postId, btn);
    var overlay = article.querySelector('.dbl-heart-overlay');
    if (overlay) {
      var heart = document.createElement('i');
      heart.className = 'fa-solid fa-heart text-white text-6xl float-heart drop-shadow-lg';
      overlay.appendChild(heart);
      setTimeout(function () { heart.remove(); }, 900);
    }
  };

  var commentsModal = document.getElementById('commentsModal');
  var commentsBody = document.getElementById('commentsBody');
  var modalCommentInput = document.getElementById('modalCommentInput');
  var currentPostId = null;
  var perfilPetReplyParentId = null;
  function clearPerfilPetReplyTarget() {
    perfilPetReplyParentId = null;
    var bar = document.getElementById('perfilPetCommentsReplyBar');
    if (bar) bar.classList.add('hidden');
  }
  function setPerfilPetReplyTarget(parentId, name) {
    perfilPetReplyParentId = parentId;
    var bar = document.getElementById('perfilPetCommentsReplyBar');
    var nm = document.getElementById('perfilPetCommentsReplyToName');
    if (nm) nm.textContent = name || '';
    if (bar) bar.classList.remove('hidden');
  }
  function openComments(postId) {
    clearPerfilPetReplyTarget();
    currentPostId = postId;
    commentsModal.classList.remove('hidden');
    if (window.AIRPET_modalUi) window.AIRPET_modalUi.refreshBodyScroll();
    commentsBody.innerHTML = '<div class="flex flex-col items-center justify-center py-10 text-gray-300"><i class="fa-solid fa-spinner fa-spin text-xl"></i></div>';
    petProfileDeferred(function () {
      return fetch('/explorar/post/' + postId + '/comentarios', { headers: { 'Accept': 'application/json' }, credentials: 'same-origin' })
        .then(function (r) { return r.json(); })
        .then(function (data) {
          var list = (data && data.comentarios) ? data.comentarios : [];
          if (!list.length) {
            commentsBody.innerHTML = '<div class="text-center py-8 px-5"><p class="text-sm text-gray-400">Nenhum comentário ainda.</p></div>';
            return;
          }
          if (window.AIRPET_commentRender && window.AIRPET_commentRender.renderList) {
            commentsBody.innerHTML = window.AIRPET_commentRender.renderList(list, {
              meuId: myUserId,
              escapeHtml: escapeHtmlPet,
              renderMencoes: renderMencoesPet,
              tempoRelativo: tempoRelativo,
              useDataTimeAttr: false,
              forceDeleteButton: true,
              deleteDataAttr: 'data-id',
              allowReply: !!myUserId
            });
          }
        });
    }, 'A carregar comentários…');
  }
  function closeComments() {
    commentsModal.classList.add('hidden');
    currentPostId = null;
    if (window.AIRPET_modalUi) window.AIRPET_modalUi.refreshBodyScroll();
  }
  window.AIRPET_fecharCommentsModalPerfil = closeComments;
  document.querySelectorAll('.btn-open-comments').forEach(function (btn) {
    btn.addEventListener('click', function () { openComments(btn.dataset.postId); });
  });
  document.getElementById('closeComments').addEventListener('click', closeComments);
  document.getElementById('commentsOverlay').addEventListener('click', closeComments);
  var perfilPetCommentsReplyCancel = document.getElementById('perfilPetCommentsReplyCancel');
  if (perfilPetCommentsReplyCancel) perfilPetCommentsReplyCancel.addEventListener('click', clearPerfilPetReplyTarget);
  document.getElementById('modalCommentForm').addEventListener('submit', function (e) {
    e.preventDefault();
    if (!currentPostId || !modalCommentInput.value.trim()) return;
    var texto = modalCommentInput.value.trim();
    modalCommentInput.value = '';
    var payload = { texto: texto };
    if (perfilPetReplyParentId) payload.parent_id = parseInt(perfilPetReplyParentId, 10);
    var body = JSON.stringify(payload);
    var url = '/explorar/post/' + currentPostId + '/comentar';
    var submitBtn = this.querySelector('button[type="submit"]');
    var runInner = function () {
      var c = petProfileCoordinator();
      if (c && typeof c.enqueue === 'function') {
        return c.enqueue({
          key: 'perfilPetComentar:' + currentPostId,
          group: 'perfilPetComentar',
          priority: c.PRIORITY ? c.PRIORITY.HIGH : 'HIGH',
          fetchFn: function (signal) {
            return fetch(url, {
              method: 'POST',
              headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
              credentials: 'same-origin',
              body: body,
              signal: signal
            }).then(function (r) { return r.json(); });
          }
        });
      }
      return fetch(url, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
        credentials: 'same-origin',
        body: body
      }).then(function (r) { return r.json(); });
    };
    var run = function () {
      return petProfileDeferred(runInner, 'A enviar comentário…');
    };
    var p = window.AIRPET_LOADING && submitBtn
      ? window.AIRPET_LOADING.runLocked({ button: submitBtn, busyText: '<span class="airpet-inline-dots">Enviando</span>' }, run)
      : run();
    p.then(function (data) {
      if (data && data.sucesso) {
        clearPerfilPetReplyTarget();
        openComments(currentPostId);
      }
    });
  });

  document.addEventListener('click', function (e) {
    var br = e.target.closest('.btn-reply-comment');
    if (br && commentsBody.contains(br)) {
      e.preventDefault();
      var cid = br.getAttribute('data-comment-id');
      var nm = br.getAttribute('data-author-name') || '';
      if (cid) setPerfilPetReplyTarget(cid, nm);
      if (modalCommentInput) modalCommentInput.focus();
      return;
    }
    var btn = e.target.closest('.btn-del-comment');
    if (!btn || !commentsBody.contains(btn)) return;
    var cid = btn.getAttribute('data-id');
    if (!cid || !currentPostId) return;
    if (!confirm('Excluir comentário?')) return;
    petProfileDeferred(function () {
      var c = petProfileCoordinator();
      if (c && typeof c.enqueue === 'function') {
        return c.enqueue({
          key: 'perfilPetDelComment:' + cid,
          group: 'perfilPetComentar',
          priority: c.PRIORITY ? c.PRIORITY.HIGH : 'HIGH',
          fetchFn: function (signal) {
            return fetch('/explorar/comentario/' + cid, { method: 'DELETE', headers: { 'Accept': 'application/json' }, credentials: 'same-origin', signal: signal })
              .then(function (r) { return r.json(); });
          }
        });
      }
      return fetch('/explorar/comentario/' + cid, { method: 'DELETE', headers: { 'Accept': 'application/json' }, credentials: 'same-origin' })
        .then(function (r) { return r.json(); });
    }, 'A apagar comentário…')
      .then(function (d) { if (d && d.sucesso) openComments(currentPostId); });
  });

  document.querySelectorAll('.btn-repost').forEach(function (btn) {
    btn.addEventListener('click', function () {
      if (btn.dataset.reposted === 'true') return;
      if (!confirm('Repostar esta publicação?')) return;
      var pid = btn.dataset.postId;
      var repBody = JSON.stringify({ texto: 'Repostado' });
      petProfileDeferred(function () {
        var c = petProfileCoordinator();
        if (c && typeof c.enqueue === 'function') {
          return c.enqueue({
            key: 'perfilPetRepost:' + pid,
            group: 'perfilPetRepost',
            priority: c.PRIORITY ? c.PRIORITY.MEDIUM : 'MEDIUM',
            fetchFn: function (signal) {
              return fetch('/explorar/post/' + pid + '/repost', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
                credentials: 'same-origin',
                body: repBody,
                signal: signal
              }).then(function (r) { return r.json(); });
            }
          });
        }
        return fetch('/explorar/post/' + pid + '/repost', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
          credentials: 'same-origin',
          body: repBody
        }).then(function (r) { return r.json(); });
      }, 'A republicar…')
        .then(function (data) { if (data && data.sucesso) location.reload(); });
    });
  });

  var listaSegModal = document.getElementById('listaSegModal');
  var listaSegBody = document.getElementById('listaSegBody');
  var listaSegTitulo = document.getElementById('listaSegTitulo');
  function escapeHtml(str) { if (!str) return ''; var div = document.createElement('div'); div.textContent = str; return div.innerHTML; }
  function openListaPet(tipo) {
    var url = tipo === 'seguidores' ? '/explorar/pet/' + petId + '/seguidores' : '/explorar/pet/' + petId + '/seguindo';
    listaSegTitulo.textContent = tipo === 'seguidores' ? 'Seguidores' : 'Seguindo';
    listaSegBody.innerHTML = '<div class="text-center py-8 text-gray-400"><i class="fa-solid fa-spinner fa-spin text-xl"></i></div>';
    listaSegModal.classList.remove('hidden');
    petProfileDeferred(function () {
      return fetch(url, { headers: { 'Accept': 'application/json' }, credentials: 'same-origin' })
        .then(function (r) { return r.json(); });
    }, 'A carregar lista…')
      .then(function (data) {
        var lista = data.lista || [];
        if (lista.length === 0) {
          listaSegBody.innerHTML = '<p class="text-sm text-gray-500 text-center py-6">Nenhum resultado.</p>';
          return;
        }
        if (tipo === 'seguidores') {
          listaSegBody.innerHTML = lista.map(function (u) {
            var avatar = u.foto_perfil ? '<img src="' + escapeHtml(u.foto_perfil) + '" alt="" class="w-10 h-10 rounded-full object-cover">' : '<span class="w-10 h-10 rounded-full flex items-center justify-center text-sm font-bold text-white" style="background:' + escapeHtml(u.cor_perfil || '#ec5a1c') + '">' + escapeHtml((u.nome || 'U').charAt(0).toUpperCase()) + '</span>';
            var row = '<div class="flex items-center justify-between gap-2 p-2 rounded-xl hover:bg-gray-50" data-seguidor-id="' + u.id + '"><a href="/explorar/perfil/' + u.id + '" class="flex items-center gap-3 flex-1 min-w-0">' + avatar + '<span class="font-semibold text-gray-900">' + escapeHtml(u.nome) + '</span></a>';
            if (eMeuPet) {
              row += '<button type="button" class="btn-remover-seguidor shrink-0 px-3 py-1.5 text-xs font-semibold text-red-500 hover:bg-red-50 rounded-lg transition-colors" data-usuario-id="' + u.id + '" title="Remover seguidor">Remover</button>';
            }
            row += '</div>';
            return row;
          }).join('');
          if (eMeuPet) {
            listaSegBody.querySelectorAll('.btn-remover-seguidor').forEach(function (btn) {
              btn.addEventListener('click', function (e) {
                e.preventDefault();
                var uid = btn.dataset.usuarioId;
                if (!uid || !confirm('Remover este seguidor? Ele deixará de seguir o perfil deste pet.')) return;
                btn.disabled = true;
                petProfileDeferred(function () {
                  return fetch('/explorar/pet/' + petId + '/seguidor/' + uid, { method: 'DELETE', headers: { 'Accept': 'application/json' }, credentials: 'same-origin' })
                    .then(function (r) { return r.json(); })
                    .then(function (data) {
                      if (data.sucesso) {
                        var row = btn.closest('[data-seguidor-id]');
                        if (row) row.remove();
                        if (data.totalSeguidores !== undefined) {
                          var el = document.getElementById('seguidoresCount');
                          if (el) el.textContent = data.totalSeguidores;
                        }
                      }
                      return data;
                    });
                }, 'A remover seguidor…')
                  .then(function (data) {
                    if (!data || !data.sucesso) btn.disabled = false;
                  })
                  .catch(function () { btn.disabled = false; });
              });
            });
          }
        } else {
          listaSegBody.innerHTML = lista.map(function (p) {
            var avatar = p.foto ? '<img src="' + escapeHtml(p.foto) + '" alt="" class="w-10 h-10 rounded-full object-cover">' : '<span class="w-10 h-10 rounded-full flex items-center justify-center text-primary-500"><i class="fa-solid fa-paw"></i></span>';
            return '<a href="/explorar/pet/' + p.id + '" class="flex items-center gap-3 p-2 rounded-xl hover:bg-gray-50">' + avatar + '<div><span class="font-semibold text-gray-900 block">' + escapeHtml(p.nome) + '</span><span class="text-xs text-gray-500">' + escapeHtml(p.dono_nome || '') + '</span></div></a>';
          }).join('');
        }
      })
      .catch(function () { listaSegBody.innerHTML = '<p class="text-sm text-red-500 text-center py-6">Erro ao carregar.</p>'; });
  }
  var _btnVerSeg = document.getElementById('btnVerSeguidores');
  if (_btnVerSeg) _btnVerSeg.addEventListener('click', function () { openListaPet('seguidores'); });
  document.getElementById('closeListaSeg').addEventListener('click', function () { listaSegModal.classList.add('hidden'); });
  document.getElementById('listaSegOverlay').addEventListener('click', function () { listaSegModal.classList.add('hidden'); });
})();
</script>
