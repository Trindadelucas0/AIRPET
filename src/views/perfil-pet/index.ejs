<%
/*
 * /p/:slug — Perfil unificado do pet.
 *
 * Renderiza header com capa + avatar (selo+cadeado overlay), nome+status,
 * tutor, acoes contextuais, abas (Posts | Sobre | Saude | Tags | Scans) e
 * o painel da aba ativa. As 3 ultimas abas so existem para o dono.
 *
 * Variaveis recebidas (do petPublicController):
 *   pet, dono, posts, ehDono, ehVisitanteAnonimo, estaSeguindo,
 *   totalSeguidores, totalSeguindo, petshopsVinculados, abaAtiva,
 *   calendarioSaude, tagsAtivas, tagsHistorico, scans, alertaAtivo,
 *   idadePet, totalCurtidasAgregado, canonicalUrl
 *
 * Reportar perdido / encontrado: aba Scans (?tab=scans) — CTA principal.
 * Painel do tutor: GET /pets/<id> — ver redirect em routes/index.js.
 */
var abas = [
  { id: 'posts', label: 'Posts',  icone: 'fa-th',           sempre: true  },
  { id: 'sobre', label: 'Sobre',  icone: 'fa-circle-info',  sempre: true  },
  { id: 'saude', label: 'Saude',  icone: 'fa-stethoscope',  sempre: false },
  { id: 'nfc',   label: 'Tags',   icone: 'fa-tag',          sempre: false },
  { id: 'scans', label: 'Scans',  icone: 'fa-location-dot', sempre: false }
];
var abaAtual = typeof abaAtiva !== 'undefined' && abaAtiva ? abaAtiva : 'posts';
locals.extraHead = '<link rel="stylesheet" href="/css/perfil-pet-unificado.css">';
%>
<%- include('../partials/header') %>
<%- include('../partials/flash') %>

<main class="flex-1 pb-24 md:pb-6">
  <div class="max-w-2xl mx-auto">

    <%# ====== HERO COM CAPA ====== %>
    <section class="pp-hero <%= pet.foto_capa ? 'pp-hero--has-cover' : '' %>">
      <% if (pet.foto_capa) { %>
        <img src="<%= pet.foto_capa %>" alt="" class="pp-hero__cover">
        <div class="pp-hero__overlay"></div>
      <% } %>
      <% if (ehDono) { %>
        <button type="button" class="pp-hero__edit-cover" id="btnEditarCapaPet">
          <i class="fa-solid fa-camera"></i> Editar capa
        </button>
        <input type="file" id="inputCapaPet" accept="image/*" class="hidden">
      <% } %>
    </section>

    <%# ====== IDENTIDADE (avatar + acoes + nome + tutor + stats) ====== %>
    <section class="pp-identity">
      <div class="pp-identity-row">
        <div class="pp-avatar-wrap pet-photo-wrap">
          <% if (pet.foto) { %>
            <img src="<%= pet.foto %>" alt="<%= pet.nome %>">
          <% } else { %>
            <span class="pp-avatar-fallback"><i class="fa-solid fa-paw"></i></span>
          <% } %>
          <%- include('../partials/pet-verified-badge', { pet: pet, size: 'lg' }) %>
        </div>

        <div class="pp-actions">
          <% if (ehVisitanteAnonimo) { %>
            <a href="/auth/login?return_to=/p/<%= pet.slug %>" class="pp-btn pp-btn--primary">
              <i class="fa-solid fa-right-to-bracket"></i> Entrar para seguir
            </a>
          <% } else if (!ehDono) { %>
            <button type="button" id="btnFollowPet" data-pet-id="<%= pet.id %>"
                    data-following="<%= estaSeguindo ? 'true' : 'false' %>"
                    class="pp-btn <%= estaSeguindo ? '' : 'pp-btn--primary' %>">
              <i class="fa-solid fa-paw"></i>
              <span><%= estaSeguindo ? 'Seguindo' : 'Seguir' %></span>
            </button>
          <% } else { %>
            <a href="/pets/<%= pet.id %>/editar" class="pp-btn pp-btn--secondary">
              <i class="fa-solid fa-pen"></i> Editar pet
            </a>
            <button type="button" id="btnNovoPost" class="pp-btn pp-btn--primary" data-pet-id="<%= pet.id %>">
              <i class="fa-solid fa-plus"></i> Novo post
            </button>
          <% } %>
          <button type="button" id="btnSharePet" class="pp-btn pp-btn--ghost pp-btn--icon" title="Compartilhar perfil"
                  data-url="<%= typeof canonicalUrl !== 'undefined' ? canonicalUrl : '' %>"
                  data-nome="<%= pet.nome %>">
            <i class="fa-solid fa-share-nodes"></i>
          </button>
          <% if (ehDono) { %>
          <a href="/pets/<%= pet.id %>/qr" class="pp-btn pp-btn--ghost pp-btn--icon" title="QR Code do pet">
            <i class="fa-solid fa-qrcode"></i>
          </a>
          <% } %>
        </div>
        <% if (ehDono) { %>
        <p class="text-center text-xs text-slate-500 mt-2 px-2">
          <a href="/pets/<%= pet.id %>" class="font-medium text-slate-600 hover:text-primary-600 hover:underline">Painel do tutor</a>
          <span class="text-slate-400"> — saúde, scans NFC e mapa</span>
        </p>
        <% } %>
      </div>

      <div class="pp-name-block">
        <h1 class="pp-name">
          <%= pet.nome %>
          <% if (pet.status === 'perdido') { %>
            <span class="pp-status-chip pp-status-chip--perdido">
              <i class="fa-solid fa-triangle-exclamation"></i> Perdido
            </span>
          <% } else { %>
            <span class="pp-status-chip pp-status-chip--seguro">
              <i class="fa-solid fa-shield-halved"></i> Seguro
            </span>
          <% } %>
        </h1>

        <div class="pp-meta">
          <% if (pet.raca) { %><span><%= pet.raca %></span><% } %>
          <% if (pet.raca && pet.tipo) { %><span class="pp-meta-dot">·</span><% } %>
          <% if (pet.tipo) { %><span><%= pet.tipo_custom || pet.tipo %></span><% } %>
          <% if ((pet.raca || pet.tipo) && pet.sexo) { %><span class="pp-meta-dot">·</span><% } %>
          <% if (pet.sexo) { %><span><%= pet.sexo %></span><% } %>
          <% if (typeof idadePet !== 'undefined' && idadePet) { %>
            <span class="pp-meta-dot">·</span>
            <span><%= idadePet.anos %> ano<%= idadePet.anos === 1 ? '' : 's' %></span>
          <% } %>
        </div>

        <% if (typeof perfilRestrito !== 'undefined' && perfilRestrito) { %>
          <div class="pp-private-banner" style="margin-top:12px;padding:12px 14px;border-radius:12px;background:rgba(15,23,42,0.06);border:1px solid rgba(15,23,42,0.08);font-size:13px;line-height:1.45;color:#334155;">
            <i class="fa-solid fa-lock" style="margin-right:8px;color:#64748b;"></i>
            Este perfil é <strong>privado</strong>. Siga o pet para ver posts e destaques.
          </div>
        <% } else if (pet.bio_pet && String(pet.bio_pet).trim()) { %>
          <p class="pp-bio-pet" style="margin-top:12px;font-size:15px;line-height:1.45;color:#1e293b;font-style:italic;">
            “<%= pet.bio_pet.trim() %>”
          </p>
        <% } %>

        <% if (dono) { %>
          <a href="/explorar/perfil/<%= dono.id %>" class="pp-tutor-line">
            <% if (dono.foto_perfil) { %>
              <img src="<%= dono.foto_perfil %>" alt="" class="pp-tutor-avatar">
            <% } else { %>
              <span class="pp-tutor-avatar" style="display:flex;align-items:center;justify-content:center;background:#f1f5f9;color:#64748b;font-size:11px;font-weight:800;">
                <%= (dono.nome || '?').charAt(0).toUpperCase() %>
              </span>
            <% } %>
            <span>Tutor: <strong><%= dono.nome %></strong></span>
          </a>
        <% } %>

        <div class="pp-stats">
          <span class="pp-stat"><strong><%= (typeof perfilRestrito !== 'undefined' && perfilRestrito) ? '—' : (posts ? posts.length : 0) %></strong> posts</span>
          <button type="button" id="btnVerSeguidores" class="pp-stat" style="background:transparent;border:0;cursor:pointer;padding:0;color:inherit;font:inherit;">
            <strong><%= totalSeguidores || 0 %></strong> seguidores
          </button>
          <% if (typeof totalCurtidasAgregado !== 'undefined' && totalCurtidasAgregado > 0) { %>
            <span class="pp-stat"><strong><%= totalCurtidasAgregado %></strong> curtidas</span>
          <% } %>
        </div>
      </div>
    </section>

    <% if (ehVisitanteAnonimo) { %>
    <div class="pp-anonymous-cta">
      <i class="fa-solid fa-paw" style="font-size:24px;color:#ec5a1c;"></i>
      <div class="pp-anonymous-cta__txt">
        <strong>Veja mais sobre <%= pet.nome %> no AIRPET</strong> — curta posts, siga e ative sua propria tag NFC.
      </div>
      <a href="/auth/login?return_to=/p/<%= pet.slug %>" class="pp-anonymous-cta__btn">Entrar</a>
    </div>
    <% } %>

    <%# ====== ABAS ====== %>
    <nav class="pp-tabs" role="tablist">
      <% abas.forEach(function(aba) {
        if (!aba.sempre && !ehDono) return;
        var url = '/p/' + pet.slug + (aba.id === 'posts' ? '' : '?tab=' + aba.id);
      %>
        <a href="<%= url %>" class="pp-tab <%= abaAtual === aba.id ? 'pp-tab--active' : '' %><%= (aba.id === 'scans' && ehDono && pet.status !== 'perdido') ? ' pp-tab--hint' : '' %>" data-tab="<%= aba.id %>">
          <i class="fa-solid <%= aba.icone %>"></i> <span><%= aba.label %></span>
        </a>
      <% }); %>
    </nav>

    <%# ====== DESTAQUES (Stories) ====== %>
    <%
      var _destaques = (typeof destaques !== 'undefined' && Array.isArray(destaques)) ? destaques : [];
    %>
    <% if (abaAtual === 'posts' && _destaques.length > 0) { %>
      <div class="pp-highlights" aria-label="Destaques">
        <% _destaques.forEach(function(d) { %>
          <a href="/p/<%= pet.slug %>/post/<%= d.id %>" class="pp-highlight" data-post-id="<%= d.id %>">
            <span class="pp-highlight__ring">
              <span class="pp-highlight__inner">
                <img class="pp-highlight__img" src="<%= d.media_url %>" alt="<%= d.legenda || 'Destaque' %>">
              </span>
            </span>
            <span class="pp-highlight__label">
              <%= d.legenda ? (d.legenda.length > 16 ? d.legenda.slice(0,16) + '…' : d.legenda) : 'Fixado' %>
            </span>
          </a>
        <% }); %>
      </div>
    <% } %>

    <%# ====== CONTEUDO DA ABA ATIVA ====== %>
    <% if (abaAtual === 'posts') { %>
      <%- include('./partials/aba-posts', { pet: pet, posts: posts, ehDono: ehDono }) %>
    <% } else if (abaAtual === 'sobre') { %>
      <%- include('./partials/aba-sobre', { pet: pet, dono: dono, ehDono: ehDono, idadePet: typeof idadePet !== 'undefined' ? idadePet : null, petshopsVinculados: petshopsVinculados, timeline: typeof timeline !== 'undefined' ? timeline : [] }) %>
    <% } else if (abaAtual === 'saude' && ehDono) { %>
      <%- include('./partials/aba-saude', { pet: pet, calendarioSaude: typeof calendarioSaude !== 'undefined' ? calendarioSaude : [] }) %>
    <% } else if (abaAtual === 'nfc' && ehDono) { %>
      <%- include('./partials/aba-nfc', { pet: pet, tagsAtivas: typeof tagsAtivas !== 'undefined' ? tagsAtivas : [], tagsHistorico: typeof tagsHistorico !== 'undefined' ? tagsHistorico : [] }) %>
    <% } else if (abaAtual === 'scans' && ehDono) { %>
      <%- include('./partials/aba-scans', { pet: pet, scans: typeof scans !== 'undefined' ? scans : [], alertaAtivo: typeof alertaAtivo !== 'undefined' ? alertaAtivo : null }) %>
    <% } else { %>
      <%- include('./partials/aba-posts', { pet: pet, posts: posts, ehDono: ehDono }) %>
    <% } %>

  </div>

  <%# Modais reutilizados (post detail, comentarios, seguidores) %>
  <%- include('../partials/post-detail-modal') %>

  <%# Modal: lista de seguidores do pet (acionado por #btnVerSeguidores) %>
  <div id="listaSegModal" class="hidden fixed inset-0 z-[110] flex items-center justify-center px-4" style="background:rgba(15,23,42,0.55);">
    <div class="bg-white rounded-2xl shadow-2xl w-full max-w-md max-h-[80vh] overflow-hidden flex flex-col">
      <div class="flex items-center justify-between px-5 py-3 border-b border-slate-100">
        <h3 class="text-base font-bold text-slate-900"><i class="fa-solid fa-paw mr-2 text-primary-500"></i>Seguidores</h3>
        <button type="button" id="closeListaSegModal" class="text-slate-400 hover:text-slate-700 text-xl leading-none" aria-label="Fechar">&times;</button>
      </div>
      <div id="listaSegBody" class="flex-1 overflow-y-auto px-5 py-4 space-y-2"></div>
    </div>
  </div>
</main>

<script src="/js/airpet-post-detail-organic.js"></script>
<script src="/js/post-modal.js"></script>
<script>
  /*
   * Boot da pagina:
   *   - Seguir/deixar de seguir o pet (toggle via /pets/:id/seguir).
   *   - Listagem de seguidores (modal alimentado por /explorar/pet/:id/seguidores).
   *   - Web Share API + fallback de clipboard para o botao "Compartilhar".
   *   - Hook do "Novo post" abre o composer dentro do contexto deste pet.
   */
  (function () {
    var PET_ID = <%= pet.id %>;

    function escHtml(s) {
      var d = document.createElement('div');
      d.textContent = String(s == null ? '' : s);
      return d.innerHTML;
    }

    /* ── Seguir / Deixar de seguir o pet ── */
    var btnFollow = document.getElementById('btnFollowPet');
    if (btnFollow) {
      btnFollow.addEventListener('click', function () {
        if (btnFollow.disabled) return;
        btnFollow.disabled = true;
        var label = btnFollow.querySelector('span');
        fetch('/pets/' + PET_ID + '/seguir', {
          method: 'POST',
          headers: { 'Accept': 'application/json' },
          credentials: 'same-origin',
        })
          .then(function (r) {
            if (r.status === 401 || r.redirected) {
              window.location.href = '/auth/login?return_to=' + encodeURIComponent(window.location.pathname);
              return null;
            }
            return r.json();
          })
          .then(function (data) {
            if (!data || !data.sucesso) return;
            var seguindo = !!data.seguindo;
            btnFollow.setAttribute('data-following', seguindo ? 'true' : 'false');
            if (label) label.textContent = seguindo ? 'Seguindo' : 'Seguir';
            if (seguindo) btnFollow.classList.remove('pp-btn--primary');
            else btnFollow.classList.add('pp-btn--primary');
            if (typeof data.totalSeguidores !== 'undefined' && btnVerSeg) {
              var strong = btnVerSeg.querySelector('strong');
              if (strong) strong.textContent = String(data.totalSeguidores);
            }
          })
          .catch(function () { /* silencioso */ })
          .finally(function () { btnFollow.disabled = false; });
      });
    }

    /* ── Modal de seguidores ── */
    var btnVerSeg = document.getElementById('btnVerSeguidores');
    var modalSeg = document.getElementById('listaSegModal');
    var modalSegBody = document.getElementById('listaSegBody');
    var closeSegBtn = document.getElementById('closeListaSegModal');

    function fecharSegModal() {
      if (modalSeg) modalSeg.classList.add('hidden');
    }
    if (closeSegBtn) closeSegBtn.addEventListener('click', fecharSegModal);
    if (modalSeg) {
      modalSeg.addEventListener('click', function (e) {
        if (e.target === modalSeg) fecharSegModal();
      });
    }
    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && modalSeg && !modalSeg.classList.contains('hidden')) fecharSegModal();
    });

    if (btnVerSeg && modalSeg && modalSegBody) {
      btnVerSeg.addEventListener('click', function () {
        modalSegBody.innerHTML = '<div class="text-center py-8 text-slate-400"><i class="fa-solid fa-spinner fa-spin text-xl"></i></div>';
        modalSeg.classList.remove('hidden');
        fetch('/explorar/pet/' + PET_ID + '/seguidores', {
          headers: { 'Accept': 'application/json' },
          credentials: 'same-origin',
        })
          .then(function (r) {
            if (r.status === 401) {
              window.location.href = '/auth/login?return_to=' + encodeURIComponent(window.location.pathname);
              return null;
            }
            return r.json();
          })
          .then(function (data) {
            if (!data) return;
            var lista = data.lista || data.seguidores || [];
            if (!lista.length) {
              modalSegBody.innerHTML = '<p class="text-sm text-slate-500 text-center py-6">Nenhum seguidor ainda.</p>';
              return;
            }
            modalSegBody.innerHTML = lista.map(function (u) {
              var avatar = u.foto_perfil
                ? '<img src="' + escHtml(u.foto_perfil) + '" class="w-10 h-10 rounded-full object-cover" alt="">'
                : '<span class="w-10 h-10 rounded-full flex items-center justify-center text-white text-sm font-bold" style="background:' + escHtml(u.cor_perfil || '#ec5a1c') + '">' + escHtml(String(u.nome || 'U').charAt(0).toUpperCase()) + '</span>';
              var href = u.id ? '/explorar/perfil/' + encodeURIComponent(u.id) : '#';
              return '<a href="' + href + '" class="flex items-center gap-3 py-2 px-2 rounded-lg hover:bg-slate-50 transition">'
                + avatar
                + '<div class="flex-1 min-w-0">'
                + '<p class="text-sm font-semibold text-slate-900 truncate">' + escHtml(u.nome || 'Usuário') + '</p>'
                + (u.apelido ? '<p class="text-xs text-slate-500 truncate">@' + escHtml(u.apelido) + '</p>' : '')
                + '</div></a>';
            }).join('');
          })
          .catch(function () {
            modalSegBody.innerHTML = '<p class="text-sm text-rose-600 text-center py-6">Não foi possível carregar a lista agora.</p>';
          });
      });
    }

    /* ── Compartilhar ── */
    var btnShare = document.getElementById('btnSharePet');
    if (btnShare) {
      btnShare.addEventListener('click', async function () {
        var url = btnShare.getAttribute('data-url') || window.location.href;
        var nome = btnShare.getAttribute('data-nome') || 'meu pet';
        var dados = { title: nome + ' | AIRPET', text: 'Conheca ' + nome + ' no AIRPET', url: url };
        try {
          if (navigator.share) {
            await navigator.share(dados);
            return;
          }
        } catch (_) {}
        try {
          await navigator.clipboard.writeText(url);
          alert('Link copiado: ' + url);
        } catch (_) {
          window.prompt('Copie o link:', url);
        }
      });
    }

    /* ── Novo post (composer no feed) ── */
    var btnNovoPost = document.getElementById('btnNovoPost');
    if (btnNovoPost) {
      btnNovoPost.addEventListener('click', function () {
        var petId = btnNovoPost.getAttribute('data-pet-id');
        window.location.href = '/feed?compose=1&pet_id=' + encodeURIComponent(petId);
      });
    }
  })();
</script>

<%- include('../partials/footer') %>
