<%
var lista = (typeof scans !== 'undefined' && Array.isArray(scans)) ? scans : [];
var alerta = (typeof alertaAtivo !== 'undefined') ? alertaAtivo : null;
var returnScans = '/p/' + pet.slug + '?tab=scans';
var urlFormPerdido = '/perdidos/' + pet.id + '/formulario?return_to=' + encodeURIComponent(returnScans);
var urlEncontrado = '/perdidos/' + pet.id + '/encontrado?return_to=' + encodeURIComponent(returnScans);
var ultimo = lista.length > 0 ? lista[0] : null;
function _fmtData(d) {
  if (!d) return '';
  try { return new Date(d).toLocaleString('pt-BR'); } catch (_) { return ''; }
}
%>

<div class="pp-panel">
  <% if (!alerta && pet.status !== 'perdido') { %>
    <div class="pp-card" style="border-color:#fecaca;background:linear-gradient(135deg,#fff1f2 0%,#fff 55%);margin-bottom:12px;">
      <div class="pp-card-title" style="color:#b91c1c;">
        <i class="fa-solid fa-shield-halved" style="color:#dc2626;"></i> Protecao e localizacao
      </div>
      <p style="font-size:13px;color:#7f1d1d;margin:0 0 12px;line-height:1.5;">
        Quando alguem escanear a tag NFC de <%= pet.nome %>, a leitura aparece aqui.
        Se ele sumiu, ative o alerta para a comunidade AIRPET ajudar.
      </p>
      <% if (ultimo) { %>
        <p style="font-size:12px;color:#64748b;margin:0 0 12px;padding:10px 12px;background:#f8fafc;border-radius:10px;border:1px solid #e2e8f0;">
          <i class="fa-solid fa-satellite-dish" style="color:#2563eb;margin-right:6px;"></i>
          <strong>Ultima leitura:</strong>
          <% if (ultimo.hasMaps && ultimo.mapsUrl) { %>
            <a href="<%= ultimo.mapsUrl %>" target="_blank" rel="noopener" style="color:#2563eb;font-weight:700;text-decoration:none;"><%= ultimo.locLabel %></a>
          <% } else { %>
            <%= ultimo.locLabel %>
          <% } %>
           — <%= _fmtData(ultimo.data) %>.
          Voce podera usar isso no formulario de alerta.
        </p>
      <% } %>
      <a href="<%= urlFormPerdido %>" class="pp-btn pp-btn--danger-outline pp-btn--block" style="justify-content:center;">
        <i class="fa-solid fa-triangle-exclamation"></i> Perdi meu pet
      </a>
    </div>
  <% } else if (pet.status === 'perdido' || alerta) { %>
    <div class="pp-card" style="border-color:#fecaca;background:linear-gradient(135deg,#fee2e2 0%,#fff 60%);margin-bottom:12px;">
      <div class="pp-card-title" style="color:#b91c1c;">
        <i class="fa-solid fa-triangle-exclamation" style="color:#dc2626;"></i>
        <%= alerta ? 'Alerta de pet perdido ativo' : pet.nome + ' esta perdido' %>
      </div>
      <p style="font-size:13px;color:#7f1d1d;margin:0 0 12px;">
        Toda leitura da tag e priorizada. Quando <%= pet.nome %> for encontrado, marque aqui.
      </p>
      <div style="display:flex;flex-wrap:wrap;gap:8px;align-items:center;">
        <% if (alerta && alerta.status === 'aprovado') { %>
        <a href="/alerta/<%= alerta.id %>" class="pp-btn pp-btn--secondary">
          <i class="fa-solid fa-eye"></i> Ver alerta publico
        </a>
        <% } else if (alerta && alerta.status === 'pendente') { %>
        <span style="font-size:12px;color:#7f1d1d;padding:8px 12px;background:rgba(255,255,255,0.7);border-radius:10px;border:1px solid #fecaca;">
          <i class="fa-solid fa-clock"></i> Aguardando aprovacao da equipe AIRPET
        </span>
        <% } %>
        <a href="<%= urlEncontrado %>" class="pp-btn pp-btn--success-outline">
          <i class="fa-solid fa-check-circle"></i> Marcar como encontrado
        </a>
      </div>
    </div>
  <% } %>

  <div class="pp-card">
    <div class="pp-card-title"><i class="fa-solid fa-location-dot"></i> Ultimas leituras da tag</div>
    <% if (lista.length === 0) { %>
      <p style="font-size:13px;color:#94a3b8;margin:0;">
        Nenhuma leitura registrada ainda. Quando alguem escanear a tag, voce vera aqui.
      </p>
    <% } else { %>
      <div style="display:flex;flex-direction:column;gap:8px;">
        <% lista.forEach(function(s) { %>
          <div style="display:flex;align-items:flex-start;gap:10px;padding:10px 0;border-bottom:1px solid #f1f5f9;">
            <span style="width:28px;height:28px;border-radius:999px;background:#fff7ed;color:#ea580c;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
              <i class="fa-solid fa-location-dot" style="font-size:12px;"></i>
            </span>
            <div style="flex:1;min-width:0;">
              <div style="font-size:13px;color:#0f172a;font-weight:700;">
                <% if (s.hasMaps && s.mapsUrl) { %>
                  <a href="<%= s.mapsUrl %>" target="_blank" rel="noopener" style="color:#0f172a;text-decoration:none;border-bottom:1px dashed #ea580c;"><%= s.locLabel %></a>
                <% } else { %>
                  <%= s.locLabel %>
                <% } %>
              </div>
              <div style="font-size:11px;color:#64748b;"><%= _fmtData(s.data) %></div>
              <% if (s.hasMaps && s.mapsUrl) { %>
                <a href="<%= s.mapsUrl %>" target="_blank" rel="noopener" style="display:inline-flex;align-items:center;gap:5px;margin-top:6px;font-size:11px;font-weight:700;color:#2563eb;text-decoration:none;">
                  <i class="fa-solid fa-map-location-dot"></i> Ver no Google Maps
                </a>
              <% } %>
            </div>
          </div>
        <% }); %>
      </div>
    <% } %>
  </div>
</div>
