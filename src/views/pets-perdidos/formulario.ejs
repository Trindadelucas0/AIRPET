<% locals.titulo = 'Reportar ' + pet.nome + ' como Perdido' %>
<% locals.extraHead = `
<link href="https://fonts.googleapis.com/css2?family=Rubik+Doodle+Shadow&family=Syne:wght@700;800&family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css">
<style>
  :root{--ink:#0d0d0f;--ink-2:#13131a;--ink-3:#1c1c26;--border:rgba(255,255,255,0.07);--border-hover:rgba(255,255,255,0.13);--text:#e4e4f0;--text-dim:#7a7a96;--text-muted:#3d3d52;--accent:#f26020;--red:#ef4444;--green:#22c55e;--blue:#60a5fa;}
  body{background:var(--ink)!important;color:var(--text)!important;font-family:'DM Sans',sans-serif;}
  .form-wrap{max-width:560px;margin:0 auto;padding:24px 20px 80px;}
  .page-topbar{position:sticky;top:56px;z-index:40;background:rgba(13,13,15,0.88);backdrop-filter:blur(20px);border-bottom:1px solid var(--border);padding:12px 0;}
  .topbar-inner{max-width:560px;margin:0 auto;padding:0 20px;display:flex;align-items:center;gap:12px;}
  .back-link{color:var(--text-dim);font-size:13px;text-decoration:none;display:flex;align-items:center;gap:6px;transition:color 0.15s;}
  .back-link:hover{color:var(--accent);text-decoration:none;}
  .page-title{font-family:var(--font-display);font-size:18px;font-weight:800;color:#fff;}
  /* Alert hero */
  .alert-hero{background:rgba(239,68,68,0.06);border:1px solid rgba(239,68,68,0.2);border-radius:18px;padding:20px;display:flex;align-items:center;gap:16px;margin-bottom:16px;}
  .alert-hero-avatar{width:56px;height:56px;border-radius:16px;object-fit:cover;border:2px solid rgba(239,68,68,0.4);flex-shrink:0;}
  .alert-hero-init{width:56px;height:56px;border-radius:16px;background:rgba(239,68,68,0.1);display:flex;align-items:center;justify-content:center;font-size:22px;flex-shrink:0;}
  .alert-hero-name{font-family:var(--font-display);font-size:18px;font-weight:800;color:#fff;}
  .alert-hero-sub{font-size:12px;color:var(--text-dim);}
  /* Section */
  .section-card{background:var(--ink-2);border:1px solid var(--border);border-radius:18px;padding:22px;margin-bottom:14px;}
  .section-title{font-family:var(--font-display);font-size:13px;font-weight:700;color:var(--text-dim);letter-spacing:0.08em;text-transform:uppercase;margin-bottom:16px;display:flex;align-items:center;gap:8px;}
  .section-icon{width:26px;height:26px;border-radius:7px;display:flex;align-items:center;justify-content:center;font-size:11px;}
  .si-red{background:rgba(239,68,68,0.1);color:var(--red);}
  .si-blue{background:rgba(96,165,250,0.1);color:var(--blue);}
  .si-accent{background:var(--accent-glow);color:var(--accent);}
  /* Loc option */
  .loc-option{display:flex;align-items:center;gap:12px;padding:14px 16px;border:2px solid var(--border);border-radius:12px;cursor:pointer;transition:all 0.15s;margin-bottom:8px;}
  .loc-option:hover{border-color:var(--border-hover);}
  .loc-option.active{border-color:var(--accent);background:var(--accent-glow);}
  .loc-option-icon{width:40px;height:40px;border-radius:11px;display:flex;align-items:center;justify-content:center;flex-shrink:0;}
  .loc-option-name{font-size:14px;font-weight:700;color:#fff;}
  .loc-option-sub{font-size:11px;color:var(--text-dim);}
  /* Input */
  .ds-input{width:100%;background:var(--ink-3);border:1px solid var(--border);border-radius:10px;padding:11px 14px;color:var(--text);font-family:'DM Sans',sans-serif;font-size:14px;outline:none;transition:border-color 0.2s,box-shadow 0.2s;}
  .ds-input::placeholder{color:var(--text-muted);}
  .ds-input:focus{border-color:rgba(242,96,32,0.5);box-shadow:0 0 0 3px rgba(242,96,32,0.06);}
  .ds-label{display:block;font-size:11px;font-weight:700;color:var(--text-dim);letter-spacing:0.07em;text-transform:uppercase;margin-bottom:6px;}
  .field-group{margin-bottom:14px;}
  #mapaPerdido{height:260px;border-radius:12px;overflow:hidden;filter:brightness(0.85) saturate(0.7);}
  .search-results{background:var(--ink-3);border:1px solid var(--border);border-radius:10px;max-height:200px;overflow-y:auto;}
  .search-result-item{padding:10px 14px;font-size:13px;cursor:pointer;color:var(--text);transition:background 0.1s;}
  .search-result-item:hover{background:var(--ink-4);}
  .btn-submit{width:100%;padding:14px;background:var(--red);color:#fff;border:none;border-radius:12px;font-family:'DM Sans',sans-serif;font-size:16px;font-weight:700;cursor:pointer;transition:all 0.2s;display:flex;align-items:center;justify-content:center;gap:8px;}
  .btn-submit:hover{background:#dc2626;transform:translateY(-1px);}
</style>
` %>
<%- include('../partials/header') %>
<%- include('../partials/flash') %>

<div class="page-topbar">
  <div class="topbar-inner">
    <a href="/pets/<%= pet.id %>" class="back-link"><i class="fa-solid fa-arrow-left"></i> <%= pet.nome %></a>
    <span class="page-title">Reportar como perdido</span>
  </div>
</div>

<main class="flex-1">
  <div class="form-wrap">

    <!-- Pet hero -->
    <div class="alert-hero">
      <% if (pet.foto) { %>
        <img src="<%= pet.foto %>" class="alert-hero-avatar" alt="<%= pet.nome %>">
      <% } else { %>
        <div class="alert-hero-init">🐾</div>
      <% } %>
      <div>
        <div class="alert-hero-name"><%= pet.nome %></div>
        <div class="alert-hero-sub"><%= pet.tipo ? pet.tipo.charAt(0).toUpperCase()+pet.tipo.slice(1) : 'Pet' %> · <%= pet.raca || 'Sem raça' %></div>
      </div>
    </div>

    <form action="/perdidos/<%= pet.id %>/reportar" method="POST" id="formPerdido">
      <input type="hidden" name="latitude" id="latInput">
      <input type="hidden" name="longitude" id="lngInput">
      <input type="hidden" name="local_descricao" id="localDescInput">

      <!-- Localização -->
      <div class="section-card">
        <div class="section-title"><div class="section-icon si-red"><i class="fa-solid fa-location-dot"></i></div>Última localização conhecida</div>

        <% if (typeof ultimoScan !== 'undefined' && ultimoScan && ultimoScan.latitude && ultimoScan.longitude) { %>
          <div class="loc-option" id="optScan" onclick="usarUltimoScan()">
            <div class="loc-option-icon" style="background:rgba(96,165,250,0.1);"><i class="fa-solid fa-satellite-dish" style="color:var(--blue);"></i></div>
            <div>
              <div class="loc-option-name">Último scan da tag NFC</div>
              <div class="loc-option-sub"><% var dtScan = new Date(ultimoScan.data); %><%= dtScan.toLocaleDateString('pt-BR') %> às <%= dtScan.toLocaleTimeString('pt-BR',{hour:'2-digit',minute:'2-digit'}) %></div>
            </div>
          </div>
        <% } %>

        <div class="loc-option" id="optMapa" onclick="usarMapa()">
          <div class="loc-option-icon" style="background:var(--accent-glow);"><i class="fa-solid fa-map-location-dot" style="color:var(--accent);"></i></div>
          <div>
            <div class="loc-option-name">Marcar no mapa</div>
            <div class="loc-option-sub">Toque no mapa para indicar o local</div>
          </div>
        </div>

        <div class="loc-option" id="optBusca" onclick="usarBusca()">
          <div class="loc-option-icon" style="background:rgba(34,197,94,0.1);"><i class="fa-solid fa-magnifying-glass-location" style="color:var(--green);"></i></div>
          <div>
            <div class="loc-option-name">Buscar endereço</div>
            <div class="loc-option-sub">Digite um endereço para localizar</div>
          </div>
        </div>

        <div id="mapaPerdidoWrap" class="hidden" style="margin-top:12px;">
          <div id="mapaPerdido"></div>
        </div>
        <div id="buscaWrap" class="hidden" style="margin-top:12px;">
          <input type="text" id="buscaEndereco" class="ds-input" placeholder="Digite o endereço ou bairro...">
          <div id="searchResults" class="search-results hidden" style="margin-top:4px;"></div>
        </div>
        <div id="localSelecionado" class="hidden" style="margin-top:10px;padding:10px 14px;background:rgba(34,197,94,0.08);border:1px solid rgba(34,197,94,0.2);border-radius:10px;font-size:13px;color:var(--green);display:flex;align-items:center;gap:8px;">
          <i class="fa-solid fa-check-circle"></i>
          <span id="localSelecionadoText"></span>
        </div>
      </div>

      <!-- Observações -->
      <div class="section-card">
        <div class="section-title"><div class="section-icon si-accent"><i class="fa-solid fa-file-lines"></i></div>Detalhes</div>
        <div class="field-group">
          <label class="ds-label">Descrição</label>
          <textarea name="descricao" class="ds-input" rows="3" style="resize:none;" placeholder="Como estava usando? Sinais particulares? Qualquer detalhe ajuda..." maxlength="500"></textarea>
        </div>
        <div class="field-group" style="margin-bottom:0">
          <label class="ds-label">Recompensa (opcional)</label>
          <input type="text" name="recompensa" class="ds-input" placeholder="Ex: R$200, Pix, etc. (opcional)" maxlength="60">
        </div>
      </div>

      <button type="submit" class="btn-submit">
        <i class="fa-solid fa-triangle-exclamation"></i> Reportar como perdido
      </button>
    </form>
  </div>
</main>

<% locals.extraScripts = `
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script>
var mapa = null, marker = null;
var optScan = document.getElementById('optScan');
var optMapa = document.getElementById('optMapa');
var optBusca = document.getElementById('optBusca');

function clearActive() {
  [optScan,optMapa,optBusca].filter(Boolean).forEach(function(el){ el.classList.remove('active'); });
}

function setLocal(lat, lng, desc) {
  document.getElementById('latInput').value = lat;
  document.getElementById('lngInput').value = lng;
  document.getElementById('localDescInput').value = desc || '';
  var el = document.getElementById('localSelecionado');
  el.classList.remove('hidden');
  document.getElementById('localSelecionadoText').textContent = desc || lat+', '+lng;
}

<% if (typeof ultimoScan !== 'undefined' && ultimoScan && ultimoScan.latitude && ultimoScan.longitude) { %>
function usarUltimoScan() {
  clearActive(); optScan.classList.add('active');
  document.getElementById('mapaPerdidoWrap').classList.add('hidden');
  document.getElementById('buscaWrap').classList.add('hidden');
  setLocal(${ultimoScan.latitude}, ${ultimoScan.longitude}, 'Último scan da tag NFC');
}
<% } %>

function usarMapa() {
  clearActive(); optMapa.classList.add('active');
  document.getElementById('buscaWrap').classList.add('hidden');
  var wrap = document.getElementById('mapaPerdidoWrap');
  wrap.classList.remove('hidden');
  if (!mapa) {
    mapa = L.map('mapaPerdido').setView([-15.78,-47.93],13);
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png',{attribution:'© OSM'}).addTo(mapa);
    mapa.on('click', function(e) {
      var ll = e.latlng;
      if (marker) marker.setLatLng(ll);
      else marker = L.marker(ll).addTo(mapa);
      setLocal(ll.lat.toFixed(6), ll.lng.toFixed(6), 'Marcado no mapa');
    });
  } else { mapa.invalidateSize(); }
}

function usarBusca() {
  clearActive(); optBusca.classList.add('active');
  document.getElementById('mapaPerdidoWrap').classList.add('hidden');
  document.getElementById('buscaWrap').classList.remove('hidden');
}

var buscaTimer;
document.getElementById('buscaEndereco').addEventListener('input', function() {
  clearTimeout(buscaTimer);
  var q = this.value.trim();
  if (q.length < 3) { document.getElementById('searchResults').classList.add('hidden'); return; }
  buscaTimer = setTimeout(function() {
    fetch('https://nominatim.openstreetmap.org/search?q='+encodeURIComponent(q)+'&format=json&limit=4&accept-language=pt-BR')
      .then(function(r){ return r.json(); })
      .then(function(data) {
        var el = document.getElementById('searchResults');
        if (!data.length) { el.classList.add('hidden'); return; }
        el.innerHTML = data.map(function(d){
          return '<div class="search-result-item" onclick="selecionarLocal('+d.lat+','+d.lon+',\\''+d.display_name.replace(/'/g,'')+'\\')">'+ d.display_name +'</div>';
        }).join('');
        el.classList.remove('hidden');
      });
  }, 400);
});

function selecionarLocal(lat, lng, desc) {
  document.getElementById('searchResults').classList.add('hidden');
  document.getElementById('buscaEndereco').value = desc.split(',')[0];
  setLocal(lat, lng, desc.split(',').slice(0,2).join(','));
}
</script>
` %>

<%- include('../partials/footer') %>
