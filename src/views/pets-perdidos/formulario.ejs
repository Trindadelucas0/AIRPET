<% locals.titulo = 'Reportar Pet Perdido' %>
<% locals.extraHead = `
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css">
<style>
  #mapaPerdido { height: 300px; border-radius: 12px; z-index: 1; }
  .loc-option { transition: all .2s ease; cursor: pointer; }
  .loc-option.active { border-color: var(--color-primary) !important; background: #fff7ed !important; }
  .loc-option:hover { border-color: var(--color-primary); }
  .search-results { max-height: 200px; overflow-y: auto; }
</style>
` %>
<%- include('../partials/header') %>
<%- include('../partials/flash') %>

<main class="flex-1 container mx-auto px-4 py-6 max-w-lg">
  <%- include('../partials/page-header', { backHref: '/pets/' + pet.id, backLabel: 'Voltar ao perfil', sticky: false }) %>

  <div class="mb-6 mt-6">
    <h1 class="text-2xl font-bold text-gray-900">Reportar <%= pet.nome %> como Perdido</h1>
  </div>

  <div class="card mb-6 bg-red-50 border border-red-200">
    <div class="flex items-center gap-3">
      <% if (pet.foto) { %>
        <img src="<%= pet.foto %>" class="w-16 h-16 rounded-full object-cover" alt="<%= pet.nome %>">
      <% } else { %>
        <div class="w-16 h-16 rounded-full bg-red-200 flex items-center justify-center">
          <i class="fa-solid fa-paw text-red-400 text-2xl"></i>
        </div>
      <% } %>
      <div>
        <p class="font-bold text-gray-800"><%= pet.nome %></p>
        <p class="text-sm text-gray-600 capitalize"><%= pet.tipo %> — <%= pet.raca || 'Sem raca' %></p>
      </div>
    </div>
  </div>

  <form action="/perdidos/<%= pet.id %>/reportar" method="POST" id="formPerdido">
    <div class="space-y-5">

      <!-- Escolha de localizacao -->
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-2">
          <i class="fa-solid fa-location-dot text-[#ec5a1c] mr-1"></i>
          Ultima localizacao conhecida
        </label>

        <div class="grid grid-cols-1 gap-2 mb-3">

          <% if (typeof ultimoScan !== 'undefined' && ultimoScan && ultimoScan.latitude && ultimoScan.longitude) { %>
            <div id="optScan" class="loc-option border-2 border-gray-200 rounded-xl p-3 flex items-center gap-3"
                 onclick="usarUltimoScan()">
              <div class="w-10 h-10 rounded-full bg-blue-100 flex items-center justify-center flex-shrink-0">
                <i class="fa-solid fa-satellite-dish text-blue-600"></i>
              </div>
              <div class="flex-1 min-w-0">
                <p class="text-sm font-semibold text-gray-800">Ultimo scan da tag NFC</p>
                <p class="text-xs text-gray-500 truncate">
                  <% var dtScan = new Date(ultimoScan.data); %>
                  <%= dtScan.toLocaleDateString('pt-BR') %> as <%= dtScan.toLocaleTimeString('pt-BR', {hour:'2-digit',minute:'2-digit'}) %>
                  <% if (ultimoScan.cidade) { %> — <%= ultimoScan.cidade %><% } %>
                </p>
              </div>
              <i class="fa-solid fa-check-circle text-[#ec5a1c] text-lg opacity-0" id="optScanCheck"></i>
            </div>
          <% } %>

          <div id="optManual" class="loc-option border-2 border-gray-200 rounded-xl p-3 flex items-center gap-3"
               onclick="usarManual()">
            <div class="w-10 h-10 rounded-full bg-orange-100 flex items-center justify-center flex-shrink-0">
              <i class="fa-solid fa-map-pin text-orange-600"></i>
            </div>
            <div class="flex-1 min-w-0">
              <p class="text-sm font-semibold text-gray-800">Marcar no mapa</p>
              <p class="text-xs text-gray-500">Clique no mapa ou busque um endereco</p>
            </div>
            <i class="fa-solid fa-check-circle text-[#ec5a1c] text-lg opacity-0" id="optManualCheck"></i>
          </div>

          <div id="optGeo" class="loc-option border-2 border-gray-200 rounded-xl p-3 flex items-center gap-3"
               onclick="usarMinhaLocalizacao()">
            <div class="w-10 h-10 rounded-full bg-green-100 flex items-center justify-center flex-shrink-0">
              <i class="fa-solid fa-location-crosshairs text-green-600"></i>
            </div>
            <div class="flex-1 min-w-0">
              <p class="text-sm font-semibold text-gray-800">Minha localizacao atual</p>
              <p class="text-xs text-gray-500">Usar GPS do celular agora</p>
            </div>
            <i class="fa-solid fa-check-circle text-[#ec5a1c] text-lg opacity-0" id="optGeoCheck"></i>
          </div>
        </div>

        <!-- Busca de endereco -->
        <div id="buscaEnderecoBox" class="mb-3 hidden">
          <div class="relative">
            <input type="text" id="buscaEndereco" placeholder="Buscar endereco..."
                   class="input-field !pr-10" autocomplete="off">
            <button type="button" onclick="buscarEndereco()"
                    class="absolute right-2 top-1/2 -translate-y-1/2 text-gray-400 hover:text-[#ec5a1c] transition-colors">
              <i class="fa-solid fa-magnifying-glass"></i>
            </button>
          </div>
          <div id="resultadosBusca" class="search-results hidden mt-1 bg-white border rounded-xl shadow-lg"></div>
        </div>

        <div id="mapaPerdido"></div>
        <p id="coordInfo" class="text-xs text-gray-400 mt-1 hidden">
          <i class="fa-solid fa-map-pin mr-1"></i>
          <span id="coordText"></span>
        </p>
        <input type="hidden" name="latitude" id="perdidoLat">
        <input type="hidden" name="longitude" id="perdidoLng">
      </div>

      <div>
        <label for="descricao" class="block text-sm font-medium text-gray-700 mb-1">O que aconteceu?</label>
        <textarea name="descricao" id="descricao" rows="4" required
                  placeholder="Descreva as circunstancias: quando sumiu, onde estava, o que vestia..."
                  class="input-field resize-none"></textarea>
      </div>

      <div>
        <label for="recompensa" class="block text-sm font-medium text-gray-700 mb-1">Recompensa (opcional)</label>
        <input type="text" name="recompensa" id="recompensa" placeholder="Ex: R$ 200,00" class="input-field">
      </div>

      <div class="bg-yellow-50 border border-yellow-200 rounded-xl p-4">
        <p class="text-sm text-yellow-800">
          <i class="fa-solid fa-info-circle mr-1"></i>
          Seu reporte sera enviado para analise da equipe. Apos aprovacao, o alerta sera publicado
          e usuarios proximos serao notificados.
        </p>
      </div>

      <button type="submit" class="btn-primary w-full bg-red-600 hover:bg-red-700">
        <i class="fa-solid fa-triangle-exclamation mr-2"></i>Enviar Reporte
      </button>
    </div>
  </form>
</main>

<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script>
(function () {
  /* Dados do ultimo scan vindos do server */
  var ultimoScan = <%- (typeof ultimoScan !== 'undefined' && ultimoScan) ? JSON.stringify({ lat: ultimoScan.latitude, lng: ultimoScan.longitude, data: ultimoScan.data, cidade: ultimoScan.cidade || '' }) : 'null' %>;

  var defaultCenter = [-15.78, -47.93];
  var defaultZoom = 5;

  var map = L.map('mapaPerdido').setView(defaultCenter, defaultZoom);
  L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
    attribution: '&copy; OSM', maxZoom: 19
  }).addTo(map);

  var marker = null;

  /* Se tem ultimo scan, ja pre-seleciona */
  if (ultimoScan) {
    usarUltimoScan();
  }

  function setMarker(lat, lng, popup) {
    if (marker) map.removeLayer(marker);
    marker = L.marker([lat, lng], {
      draggable: true,
      icon: L.divIcon({
        className: 'custom-pin',
        html: '<div style="background:#dc2626;width:34px;height:34px;border-radius:50%;border:3px solid #fff;box-shadow:0 2px 8px rgba(0,0,0,.3);display:flex;align-items:center;justify-content:center"><i class="fa-solid fa-exclamation" style="color:#fff;font-size:14px"></i></div>',
        iconSize: [34, 34], iconAnchor: [17, 17]
      })
    }).addTo(map);
    if (popup) marker.bindPopup(popup).openPopup();

    marker.on('dragend', function (e) {
      var p = e.target.getLatLng();
      updateCoords(p.lat, p.lng);
    });

    updateCoords(lat, lng);
  }

  function updateCoords(lat, lng) {
    document.getElementById('perdidoLat').value = parseFloat(lat).toFixed(7);
    document.getElementById('perdidoLng').value = parseFloat(lng).toFixed(7);
    document.getElementById('coordInfo').classList.remove('hidden');
    document.getElementById('coordText').textContent = parseFloat(lat).toFixed(5) + ', ' + parseFloat(lng).toFixed(5);
  }

  function clearSelection() {
    document.querySelectorAll('.loc-option').forEach(function (el) {
      el.classList.remove('active');
      var chk = el.querySelector('.fa-check-circle');
      if (chk) chk.style.opacity = '0';
    });
  }

  function selectOption(id) {
    clearSelection();
    var el = document.getElementById(id);
    if (el) {
      el.classList.add('active');
      var chk = el.querySelector('.fa-check-circle');
      if (chk) chk.style.opacity = '1';
    }
  }

  /* Usar ultimo scan da tag */
  window.usarUltimoScan = function () {
    if (!ultimoScan) return;
    selectOption('optScan');
    document.getElementById('buscaEnderecoBox').classList.add('hidden');
    map.setView([ultimoScan.lat, ultimoScan.lng], 15);
    var dt = new Date(ultimoScan.data);
    var popupText = '<b>Ultimo scan NFC</b><br>' + dt.toLocaleDateString('pt-BR') + ' ' + dt.toLocaleTimeString('pt-BR', {hour:'2-digit',minute:'2-digit'});
    if (ultimoScan.cidade) popupText += '<br>' + ultimoScan.cidade;
    setMarker(ultimoScan.lat, ultimoScan.lng, popupText);
  };

  /* Marcar manualmente no mapa */
  window.usarManual = function () {
    selectOption('optManual');
    document.getElementById('buscaEnderecoBox').classList.remove('hidden');
    map.on('click', onMapClick);
  };

  function onMapClick(e) {
    setMarker(e.latlng.lat, e.latlng.lng);
  }
  map.on('click', function (e) {
    var manual = document.getElementById('optManual');
    if (manual && manual.classList.contains('active')) {
      setMarker(e.latlng.lat, e.latlng.lng);
    }
  });

  /* Usar GPS */
  window.usarMinhaLocalizacao = function () {
    selectOption('optGeo');
    document.getElementById('buscaEnderecoBox').classList.add('hidden');
    if (!navigator.geolocation) {
      alert('Geolocalizacao nao suportada neste dispositivo');
      return;
    }
    navigator.geolocation.getCurrentPosition(function (pos) {
      map.setView([pos.coords.latitude, pos.coords.longitude], 16);
      setMarker(pos.coords.latitude, pos.coords.longitude, '<b>Sua localizacao atual</b>');
    }, function (err) {
      var msg = (window.airpetGeo && window.airpetGeo.getErrorMessage)
        ? window.airpetGeo.getErrorMessage(err)
        : 'Nao foi possivel obter sua localizacao. Verifique as permissoes.';
      alert(msg);
    }, { timeout: 12000, enableHighAccuracy: true });
  };

  /* Busca de endereco via Nominatim */
  window.buscarEndereco = function () {
    var q = document.getElementById('buscaEndereco').value.trim();
    if (!q || q.length < 3) return;
    var box = document.getElementById('resultadosBusca');
    box.innerHTML = '<p class="p-3 text-sm text-gray-400">Buscando...</p>';
    box.classList.remove('hidden');

    fetch('https://nominatim.openstreetmap.org/search?format=json&q=' + encodeURIComponent(q) + '&limit=5&countrycodes=br')
      .then(function (r) { return r.json(); })
      .then(function (data) {
        if (!data.length) {
          box.innerHTML = '<p class="p-3 text-sm text-gray-500">Nenhum resultado encontrado</p>';
          return;
        }
        box.innerHTML = data.map(function (r) {
          return '<div class="p-3 hover:bg-orange-50 cursor-pointer text-sm border-b last:border-0 transition-colors" onclick="selecionarEndereco(' + r.lat + ',' + r.lon + ',\'' + r.display_name.replace(/'/g, "\\'").substring(0, 80) + '\')">' +
            '<i class="fa-solid fa-location-dot text-[#ec5a1c] mr-1"></i>' + r.display_name.substring(0, 80) + '</div>';
        }).join('');
      })
      .catch(function () {
        box.innerHTML = '<p class="p-3 text-sm text-red-500">Erro na busca</p>';
      });
  };

  window.selecionarEndereco = function (lat, lng, nome) {
    document.getElementById('resultadosBusca').classList.add('hidden');
    document.getElementById('buscaEndereco').value = nome;
    map.setView([lat, lng], 16);
    setMarker(lat, lng, '<b>' + nome + '</b>');
  };

  document.getElementById('buscaEndereco').addEventListener('keydown', function (e) {
    if (e.key === 'Enter') { e.preventDefault(); buscarEndereco(); }
  });

  setTimeout(function () { map.invalidateSize(); }, 200);
})();
</script>

<%- include('../partials/footer') %>
