<% locals.titulo = dados.petNome + ' está seguro!' %>
<% locals.extraHead = `
<link href="https://fonts.googleapis.com/css2?family=Rubik+Doodle+Shadow&family=Syne:wght@700;800&family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
  :root{--ink:#0d0d0f;--ink-2:#13131a;--ink-3:#1c1c26;--border:rgba(255,255,255,0.07);--text:#e4e4f0;--text-dim:#7a7a96;--accent:#f26020;--green:#22c55e;}
  body{background:var(--ink)!important;color:var(--text)!important;font-family:'DM Sans',sans-serif;}
  .conf-wrap{max-width:480px;margin:0 auto;padding:40px 20px 80px;text-align:center;}
  /* Confetti */
  .confetti-container{position:fixed;inset:0;pointer-events:none;z-index:999;overflow:hidden;}
  .confetti{position:absolute;top:-20px;width:10px;height:10px;border-radius:2px;animation:confettiFall var(--duration) var(--delay) ease-in forwards;}
  @keyframes confettiFall{0%{transform:translateY(0) rotate(0deg) scale(1);opacity:1;}80%{opacity:1;}100%{transform:translateY(100vh) rotate(var(--rot)) scale(0.5);opacity:0;}}
  /* Avatar bounce */
  @keyframes celebBounce{0%{transform:scale(0.3);opacity:0;}50%{transform:scale(1.08);}70%{transform:scale(0.95);}100%{transform:scale(1);opacity:1;}}
  .celeb-avatar{animation:celebBounce 0.6s ease-out both;}
  @keyframes slideUp{from{opacity:0;transform:translateY(16px);}to{opacity:1;transform:none;}}
  .slide-1{animation:slideUp 0.5s 0.1s both;}
  .slide-2{animation:slideUp 0.5s 0.2s both;}
  .slide-3{animation:slideUp 0.5s 0.3s both;}
  .slide-4{animation:slideUp 0.5s 0.4s both;}
  /* Avatar ring pulse */
  @keyframes ring-pulse{0%,100%{box-shadow:0 0 0 0 rgba(34,197,94,0.4);}50%{box-shadow:0 0 0 12px rgba(34,197,94,0);}}
  .avatar-img{animation:ring-pulse 2s ease-in-out 0.8s infinite;}
  /* Stats grid */
  .stats-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin:24px 0;}
  .stat-card{background:var(--ink-2);border:1px solid var(--border);border-radius:14px;padding:16px;text-align:center;}
  .stat-val{font-family:var(--font-display);font-size:24px;font-weight:800;color:#fff;}
  .stat-label{font-size:11px;font-weight:700;color:var(--text-dim);text-transform:uppercase;letter-spacing:0.08em;margin-top:3px;}
  /* Buttons */
  .btn-primary{display:inline-flex;align-items:center;justify-content:center;gap:8px;padding:14px 28px;background:var(--accent);color:#fff;border:none;border-radius:12px;font-family:'DM Sans',sans-serif;font-size:15px;font-weight:700;cursor:pointer;transition:all 0.2s;text-decoration:none;width:100%;}
  .btn-primary:hover{background:var(--accent-light);transform:translateY(-1px);color:#fff;text-decoration:none;}
  .btn-ghost{display:inline-flex;align-items:center;justify-content:center;gap:8px;padding:13px 28px;background:transparent;color:var(--text-dim);border:1px solid var(--border);border-radius:12px;font-family:'DM Sans',sans-serif;font-size:14px;font-weight:600;cursor:pointer;transition:all 0.15s;text-decoration:none;width:100%;margin-top:8px;}
  .btn-ghost:hover{border-color:var(--border-hover);color:var(--text);text-decoration:none;}
  /* Share */
  .share-row{display:flex;gap:10px;margin-top:16px;}
  .share-btn{flex:1;display:flex;flex-direction:column;align-items:center;gap:6px;padding:14px 10px;background:var(--ink-2);border:1px solid var(--border);border-radius:12px;cursor:pointer;transition:all 0.15s;font-size:12px;font-weight:700;color:var(--text-dim);}
  .share-btn:hover{border-color:var(--border-hover);color:var(--text);}
  .share-btn i{font-size:20px;}
</style>
` %>
<%- include('../partials/header') %>

<!-- Confetti -->
<div class="confetti-container" id="confettiBox"></div>

<main class="flex-1">
  <div class="conf-wrap">

    <!-- Avatar -->
    <div class="celeb-avatar" style="position:relative;display:inline-block;margin-bottom:24px;">
      <% if (dados.petFoto) { %>
        <img src="<%= dados.petFoto %>" alt="<%= dados.petNome %>"
             class="avatar-img"
             style="width:120px;height:120px;border-radius:50%;object-fit:cover;border:4px solid rgba(34,197,94,0.5);">
      <% } else { %>
        <div class="avatar-img" style="width:120px;height:120px;border-radius:50%;background:rgba(34,197,94,0.1);display:flex;align-items:center;justify-content:center;border:4px solid rgba(34,197,94,0.4);font-size:48px;">🐾</div>
      <% } %>
      <span style="position:absolute;bottom:-4px;right:-4px;width:40px;height:40px;border-radius:50%;background:var(--green);display:flex;align-items:center;justify-content:center;border:3px solid var(--ink);box-shadow:0 4px 12px rgba(34,197,94,0.4);">
        <i class="fa-solid fa-shield-halved" style="color:#fff;font-size:16px;"></i>
      </span>
    </div>

    <h1 class="slide-1" style="font-family:var(--font-display);font-size:32px;font-weight:800;color:#fff;margin-bottom:8px;">
      Que alívio! 🎉
    </h1>
    <p class="slide-2" style="font-size:16px;color:var(--text-dim);line-height:1.6;margin-bottom:4px;">
      <strong style="color:var(--text)"><%= dados.petNome %></strong> está protegido pelo AIRPET.
    </p>
    <p class="slide-2" style="font-size:14px;color:var(--text-dim);">A tag NFC fará toda a diferença na próxima aventura.</p>

    <!-- Stats (somente chaves que vêm do petPerdidoController) -->
    <% if (dados.tempoPerdido || dados.comoEncontrado || dados.descricao) { %>
      <div class="stats-grid slide-3">
        <% if (dados.tempoPerdido) { %>
          <div class="stat-card">
            <div class="stat-val"><%= dados.tempoPerdido %></div>
            <div class="stat-label">Tempo perdido</div>
          </div>
        <% } %>
        <% if (dados.comoEncontrado) { %>
          <div class="stat-card">
            <div class="stat-val" style="font-size:16px;line-height:1.3;"><%= dados.comoEncontrado %></div>
            <div class="stat-label">Como foi encontrado</div>
          </div>
        <% } %>
        <% if (dados.descricao) { %>
          <div class="stat-card" style="grid-column:1/-1;">
            <div class="stat-label" style="margin-top:0;">Detalhes</div>
            <div style="font-size:13px;color:var(--text-dim);line-height:1.6;margin-top:6px;"><%= dados.descricao %></div>
          </div>
        <% } %>
      </div>
    <% } %>

    <!-- Actions -->
    <div class="slide-4">
      <a href="/pets/<%= dados.petId %>" class="btn-primary">
        <i class="fa-solid fa-paw"></i> Ver perfil de <%= dados.petNome %>
      </a>
      <a href="/feed" class="btn-ghost">
        <i class="fa-solid fa-house"></i> Ir para o Feed
      </a>

      <!-- Share -->
      <div class="share-row">
        <button class="share-btn" onclick="compartilhar('whatsapp')">
          <i class="fa-brands fa-whatsapp" style="color:#25d366;"></i>
          WhatsApp
        </button>
        <button class="share-btn" onclick="compartilhar('copy')">
          <i class="fa-solid fa-link" style="color:var(--accent);"></i>
          Copiar link
        </button>
        <button class="share-btn" onclick="compartilhar('share')">
          <i class="fa-solid fa-share-from-square" style="color:var(--blue);"></i>
          Compartilhar
        </button>
      </div>
    </div>

  </div>
</main>

<script>
// Confetti
(function(){
  var box = document.getElementById('confettiBox');
  var colors = ['#f26020','#ff7a3d','#22c55e','#a78bfa','#facc15','#60a5fa','#f472b6'];
  for (var i = 0; i < 70; i++) {
    var c = document.createElement('div');
    c.className = 'confetti';
    c.style.setProperty('--duration', (Math.random()*1.5+1.2)+'s');
    c.style.setProperty('--delay', (Math.random()*1.5)+'s');
    c.style.setProperty('--rot', (Math.random()*720-360)+'deg');
    c.style.left = Math.random()*100+'vw';
    c.style.background = colors[Math.floor(Math.random()*colors.length)];
    c.style.width = (Math.random()*8+5)+'px';
    c.style.height = (Math.random()*8+5)+'px';
    c.style.borderRadius = Math.random() > 0.5 ? '50%' : '2px';
    box.appendChild(c);
  }
})();

function compartilhar(tipo) {
  var url = window.location.origin + '/explorar/pet/<%= dados.petId %>';
  var text = 'Boa notícia! <%= dados.petNome %> está seguro e protegido pelo AIRPET 🐾';
  if (tipo === 'whatsapp') {
    window.open('https://wa.me/?text='+encodeURIComponent(text+' '+url),'_blank');
  } else if (tipo === 'copy') {
    navigator.clipboard.writeText(url).then(function(){ alert('Link copiado!'); });
  } else if (tipo === 'share' && navigator.share) {
    navigator.share({ title: text, url: url });
  }
}
</script>

<%- include('../partials/footer') %>
