<% locals.titulo = pet.nome + ' foi encontrado!' %>
<% locals.extraHead = `
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css">
<style>
  .enc-page .enc-step{display:none;}
  .enc-page .enc-step.active{display:block;}
  .enc-page .step-progress{display:flex;align-items:center;gap:0;margin-bottom:6px;}
  .enc-page .step-dot{width:10px;height:10px;border-radius:50%;transition:all 0.3s;}
  .enc-page .step-dot.active{background:var(--green);transform:scale(1.3);}
  .enc-page .step-dot.done{background:var(--green);}
  .enc-page .step-dot.pending{background:var(--text-muted);}
  .enc-page .step-bar{flex:1;height:2px;transition:background 0.3s;}
  .enc-page .step-bar.done{background:var(--green);}
  .enc-page .step-bar.pending{background:var(--text-muted);}
  .enc-page #mapaEncontrado{height:240px;border-radius:12px;overflow:hidden;}
  .enc-page .enc-search-results{background:var(--ink-2);border:1px solid var(--border);border-radius:10px;max-height:180px;overflow-y:auto;}
  .enc-page .enc-search-result-item{padding:10px 14px;font-size:13px;cursor:pointer;color:var(--text);transition:background 0.1s;}
  .enc-page .enc-search-result-item:hover{background:var(--ink-3);}
</style>
` %>
<%- include('../partials/header') %>
<%- include('../partials/flash') %>

<div class="air-sticky-topbar enc-page">
  <div class="max-w-lg mx-auto px-5 py-3 flex items-center gap-3">
    <a href="/pets/<%= pet.id %>" class="text-sm text-gray-500 hover:text-primary-600 flex items-center gap-2 no-underline">
      <i class="fa-solid fa-arrow-left"></i> <%= pet.nome %>
    </a>
  </div>
</div>

<main class="flex-1 enc-page">
  <div class="max-w-lg mx-auto px-5 pt-6 pb-24">

    <div class="rounded-2xl border border-emerald-200/80 bg-emerald-50/60 px-5 py-6 text-center mb-5">
      <% if (pet.foto) { %>
        <img src="<%= pet.foto %>" class="w-20 h-20 rounded-full object-cover border-[3px] border-emerald-400/60 mx-auto mb-3 shadow-sm" alt="<%= pet.nome %>">
      <% } else { %>
        <div class="w-20 h-20 rounded-full bg-emerald-100 border-[3px] border-emerald-300/50 mx-auto mb-3 flex items-center justify-center text-3xl">🐾</div>
      <% } %>
      <h1 class="font-display text-xl font-extrabold text-gray-900 mb-1">Boas notícias! 🎉</h1>
      <p class="text-sm text-gray-600">Você encontrou <strong class="text-gray-900"><%= pet.nome %></strong>? Conte-nos os detalhes.</p>
    </div>

    <div class="step-progress" id="progressBar">
      <div class="step-dot active" id="dot1"></div>
      <div class="step-bar pending" id="bar1"></div>
      <div class="step-dot pending" id="dot2"></div>
      <div class="step-bar pending" id="bar2"></div>
      <div class="step-dot pending" id="dot3"></div>
    </div>
    <div class="flex justify-between text-[11px] font-bold mb-5">
      <span id="label1" class="text-emerald-600 label-step">Detalhes</span>
      <span id="label2" class="text-gray-400 label-step">Localização</span>
      <span id="label3" class="text-gray-400 label-step">Confirmar</span>
    </div>

    <form action="/perdidos/<%= pet.id %>/encontrado" method="POST" id="formEncontrado">
      <input type="hidden" name="latitude" id="encLat">
      <input type="hidden" name="longitude" id="encLng">
      <input type="hidden" name="local_descricao" id="encLocalDesc">
      <input type="hidden" name="como_encontrado" id="encComo">

      <div class="enc-step active" id="stepComo">
        <div class="air-section-card mb-4">
          <div class="font-display text-xs font-bold text-gray-500 uppercase tracking-wide mb-4">Como foi encontrado?</div>
          <div class="como-option flex items-center gap-3 p-3.5 mb-2 rounded-xl border-2 border-gray-200 cursor-pointer transition-all hover:border-gray-300" data-val="resgatado" role="button" tabindex="0">
            <div class="w-10 h-10 rounded-xl bg-emerald-100 text-emerald-600 flex items-center justify-center shrink-0 text-base"><i class="fa-solid fa-hands-holding-heart"></i></div>
            <div><div class="text-sm font-bold text-gray-900">Resgatei pessoalmente</div><div class="text-[11px] text-gray-500">Eu fui buscar</div></div>
          </div>
          <div class="como-option flex items-center gap-3 p-3.5 mb-2 rounded-xl border-2 border-gray-200 cursor-pointer transition-all hover:border-gray-300" data-val="terceiro" role="button" tabindex="0">
            <div class="w-10 h-10 rounded-xl bg-emerald-100 text-emerald-600 flex items-center justify-center shrink-0 text-base"><i class="fa-solid fa-person-walking"></i></div>
            <div><div class="text-sm font-bold text-gray-900">Terceiro encontrou</div><div class="text-[11px] text-gray-500">Alguém me devolveu</div></div>
          </div>
          <div class="como-option flex items-center gap-3 p-3.5 mb-2 rounded-xl border-2 border-gray-200 cursor-pointer transition-all hover:border-gray-300" data-val="voltou" role="button" tabindex="0">
            <div class="w-10 h-10 rounded-xl bg-emerald-100 text-emerald-600 flex items-center justify-center shrink-0 text-base"><i class="fa-solid fa-house"></i></div>
            <div><div class="text-sm font-bold text-gray-900">Voltou por conta própria</div><div class="text-[11px] text-gray-500">Apareceu sozinho</div></div>
          </div>
        </div>
        <div class="air-section-card mb-4">
          <div class="font-display text-xs font-bold text-gray-500 uppercase tracking-wide mb-3">Observações</div>
          <textarea name="descricao_encontrado" class="w-full rounded-xl border border-gray-200 bg-white px-3.5 py-3 text-sm text-gray-900 placeholder:text-gray-400 focus:ring-2 focus:ring-primary-500/20 focus:border-primary-400 outline-none" rows="3" style="resize:none;" placeholder="Como estava? Algum detalhe importante?"></textarea>
        </div>
        <button type="button" class="w-full py-3.5 rounded-xl bg-emerald-600 hover:bg-emerald-700 text-white font-bold text-sm flex items-center justify-center gap-2 shadow-sm" onclick="irParaStep2()"><i class="fa-solid fa-arrow-right"></i> Próximo</button>
      </div>

      <div class="enc-step" id="stepLocal">
        <div class="air-section-card mb-4">
          <div class="font-display text-xs font-bold text-gray-500 uppercase tracking-wide mb-4">Onde foi encontrado?</div>
          <div class="mb-3">
            <label class="block text-[11px] font-bold text-gray-500 uppercase tracking-wide mb-1.5">Buscar endereço</label>
            <input type="text" id="encBuscaEndereco" class="w-full rounded-xl border border-gray-200 bg-white px-3.5 py-2.5 text-sm" placeholder="Bairro, rua...">
            <div id="encSearchResults" class="enc-search-results hidden mt-1"></div>
          </div>
          <div id="encMapaWrap" class="mt-2">
            <div id="mapaEncontrado"></div>
            <p class="text-[11px] text-gray-500 mt-1.5"><i class="fa-solid fa-hand-pointer mr-1"></i>Toque no mapa para marcar o local</p>
          </div>
          <div id="encLocalSel" class="hidden mt-2.5 px-3.5 py-2.5 rounded-xl text-sm text-emerald-700 bg-emerald-50 border border-emerald-200">
            <i class="fa-solid fa-check-circle mr-1"></i><span id="encLocalSelText"></span>
          </div>
        </div>
        <button type="button" class="w-full py-3.5 rounded-xl bg-emerald-600 hover:bg-emerald-700 text-white font-bold text-sm flex items-center justify-center gap-2" onclick="irParaStep3()"><i class="fa-solid fa-arrow-right"></i> Próximo</button>
        <button type="button" class="btn-ghost w-full mt-2 py-2.5 text-sm font-semibold" onclick="irParaStep1()"><i class="fa-solid fa-arrow-left mr-1"></i> Voltar</button>
      </div>

      <div class="enc-step" id="stepConfirmar">
        <div class="air-section-card text-center py-8 px-5">
          <div class="text-5xl mb-4">🎊</div>
          <div class="font-display text-xl font-extrabold text-gray-900 mb-2">Tudo pronto!</div>
          <p class="text-sm text-gray-600 leading-relaxed mb-6">Confirme para registrar que <strong class="text-gray-900"><%= pet.nome %></strong> foi encontrado e remover o alerta.</p>
          <button type="submit" class="w-full py-3.5 rounded-xl bg-emerald-600 hover:bg-emerald-700 text-white font-bold text-sm flex items-center justify-center gap-2">
            <i class="fa-solid fa-check"></i> Confirmar — <%= pet.nome %> está seguro!
          </button>
          <button type="button" class="btn-ghost w-full mt-2 py-2.5 text-sm font-semibold" onclick="irParaStep2()"><i class="fa-solid fa-arrow-left mr-1"></i> Voltar</button>
        </div>
      </div>
    </form>
  </div>
</main>

<% locals.extraScripts = `
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script>
(function(){
  var encMapa=null, encMarker=null;
  function selecionarComo(el,val){
    document.querySelectorAll('.como-option').forEach(function(e){e.classList.remove('border-emerald-500','bg-emerald-50');});
    el.classList.add('border-emerald-500','bg-emerald-50');
    document.getElementById('encComo').value=val;
  }
  document.querySelectorAll('.como-option').forEach(function(opt){
    opt.addEventListener('click',function(){selecionarComo(opt,opt.getAttribute('data-val'));});
    opt.addEventListener('keydown',function(ev){if(ev.key==='Enter'||ev.key===' '){ev.preventDefault();selecionarComo(opt,opt.getAttribute('data-val'));}});
  });
  function atualizarProgress(step){
    ['dot1','dot2','dot3'].forEach(function(id,i){var el=document.getElementById(id);el.className='step-dot '+(i+1<step?'done':i+1===step?'active':'pending');});
    ['bar1','bar2'].forEach(function(id,i){document.getElementById(id).className='step-bar '+(i+1<step?'done':'pending');});
    ['label1','label2','label3'].forEach(function(id,i){var e=document.getElementById(id);if(!e)return;e.classList.toggle('text-emerald-600',i+1===step);e.classList.toggle('text-gray-400',i+1!==step);});
  }
  window.irParaStep1=function(){document.getElementById('stepComo').classList.add('active');document.getElementById('stepLocal').classList.remove('active');document.getElementById('stepConfirmar').classList.remove('active');atualizarProgress(1);};
  window.irParaStep2=function(){document.getElementById('stepComo').classList.remove('active');document.getElementById('stepLocal').classList.add('active');document.getElementById('stepConfirmar').classList.remove('active');atualizarProgress(2);iniciarMapa();};
  window.irParaStep3=function(){document.getElementById('stepLocal').classList.remove('active');document.getElementById('stepConfirmar').classList.add('active');atualizarProgress(3);};
  function iniciarMapa(){
    if(encMapa){encMapa.invalidateSize();return;}
    encMapa=L.map('mapaEncontrado').setView([-15.78,-47.93],13);
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png',{attribution:'© OSM'}).addTo(encMapa);
    encMapa.on('click',function(e){var ll=e.latlng;if(encMarker)encMarker.setLatLng(ll);else encMarker=L.marker(ll).addTo(encMapa);setEncLocal(ll.lat.toFixed(6),ll.lng.toFixed(6),'Marcado no mapa');});
  }
  function setEncLocal(lat,lng,desc){
    document.getElementById('encLat').value=lat;document.getElementById('encLng').value=lng;document.getElementById('encLocalDesc').value=desc;
    var el=document.getElementById('encLocalSel');el.classList.remove('hidden');document.getElementById('encLocalSelText').textContent=desc;
  }
  window.selecionarEncLocal=function(lat,lng,desc){
    document.getElementById('encSearchResults').classList.add('hidden');
    document.getElementById('encBuscaEndereco').value=String(desc).split(',')[0];
    setEncLocal(lat,lng,String(desc).split(',').slice(0,2).join(','));
    if(encMapa){encMapa.setView([lat,lng],15);if(encMarker)encMarker.setLatLng([lat,lng]);else encMarker=L.marker([lat,lng]).addTo(encMapa);}
  };
  var buscaTimer;
  document.getElementById('encBuscaEndereco').addEventListener('input',function(){
    clearTimeout(buscaTimer);var q=this.value.trim();var elR=document.getElementById('encSearchResults');
    if(q.length<3){elR.classList.add('hidden');elR.innerHTML='';return;}
    buscaTimer=setTimeout(function(){
      fetch('https://nominatim.openstreetmap.org/search?q='+encodeURIComponent(q)+'&format=json&limit=4&accept-language=pt-BR')
        .then(function(r){return r.json();}).then(function(data){
          if(!data.length){elR.classList.add('hidden');elR.innerHTML='';return;}
          elR.innerHTML='';
          data.forEach(function(d){
            var div=document.createElement('div');
            div.className='enc-search-result-item';
            div.textContent=d.display_name||'';
            div.addEventListener('click',function(){selecionarEncLocal(parseFloat(d.lat),parseFloat(d.lon),d.display_name);});
            elR.appendChild(div);
          });
          elR.classList.remove('hidden');
        });
    },400);
  });
})();
</script>
` %>

<%- include('../partials/footer') %>
