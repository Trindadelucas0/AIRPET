<% locals.titulo = pet.nome + ' foi encontrado!' %>
<% locals.extraHead = `
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css">
<style>
  #mapaEncontrado { height: 280px; border-radius: 12px; z-index: 1; }
  .como-option { transition: all .2s ease; cursor: pointer; }
  .como-option.active { border-color: #10b981 !important; background: #ecfdf5 !important; }
  .como-option:hover { border-color: #34d399; }
  .loc-option { transition: all .2s ease; cursor: pointer; }
  .loc-option.active { border-color: #10b981 !important; background: #ecfdf5 !important; }
  .loc-option:hover { border-color: #34d399; }
  .search-results { max-height: 200px; overflow-y: auto; }
  .step-dot { width: 10px; height: 10px; border-radius: 50%; transition: all .3s; }
  .step-dot.active { background: #10b981; transform: scale(1.3); }
  .step-dot.done { background: #10b981; }
  .step-dot.pending { background: #d1d5db; }
  .step-bar { height: 2px; flex: 1; transition: background .3s; }
  .step-bar.done { background: #10b981; }
  .step-bar.pending { background: #e5e7eb; }
</style>
` %>
<%- include('../partials/header') %>
<%- include('../partials/flash') %>

<main class="flex-1 container mx-auto px-4 py-6 max-w-lg">
  <%- include('../partials/page-header', { backHref: '/pets/' + pet.id, backLabel: 'Voltar ao perfil', sticky: false }) %>

  <!-- Header emotivo -->
  <div class="card mb-6 mt-6 bg-emerald-50 border border-emerald-200 text-center">
    <div class="relative inline-block mb-4">
      <% if (pet.foto) { %>
        <img src="<%= pet.foto %>" class="w-24 h-24 rounded-full object-cover ring-4 ring-emerald-400 mx-auto" alt="<%= pet.nome %>">
      <% } else { %>
        <div class="w-24 h-24 rounded-full bg-emerald-200 flex items-center justify-center ring-4 ring-emerald-400 mx-auto">
          <i class="fa-solid fa-paw text-emerald-500 text-3xl"></i>
        </div>
      <% } %>
      <span class="absolute -bottom-1 -right-1 w-8 h-8 bg-emerald-500 rounded-full flex items-center justify-center ring-2 ring-white">
        <i class="fa-solid fa-heart text-white text-sm"></i>
      </span>
    </div>
    <h1 class="text-2xl font-bold text-gray-900 mb-1">Boas noticias!</h1>
    <p class="text-gray-600">Voce encontrou <strong class="text-emerald-700"><%= pet.nome %></strong>? Conte-nos os detalhes.</p>
  </div>

  <!-- Barra de progresso -->
  <div class="flex items-center gap-0 mb-6 px-4" id="progressBar">
    <div class="step-dot active" id="dot1"></div>
    <div class="step-bar pending" id="bar1"></div>
    <div class="step-dot pending" id="dot2"></div>
    <div class="step-bar pending" id="bar2"></div>
    <div class="step-dot pending" id="dot3"></div>
  </div>
  <div class="flex justify-between text-xs text-gray-400 mb-6 px-2">
    <span id="label1" class="font-semibold text-emerald-600">Detalhes</span>
    <span id="label2">Localização</span>
    <span id="label3">Confirmar</span>
  </div>

  <form action="/perdidos/<%= pet.id %>/encontrado" method="POST" id="formEncontrado">

    <!-- PASSO 1: Como foi encontrado -->
    <div id="step1" class="space-y-5">
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-3">
          <i class="fa-solid fa-magnifying-glass text-emerald-500 mr-1"></i>
          Como <%= pet.nome %> foi encontrado?
        </label>
        <div class="grid grid-cols-2 gap-3">
          <div class="como-option border-2 border-gray-200 rounded-xl p-4 text-center" onclick="selecionarComo(this, 'voltou_sozinho')">
            <i class="fa-solid fa-house-chimney text-2xl text-emerald-400 mb-2"></i>
            <p class="text-sm font-semibold text-gray-800">Voltou sozinho</p>
            <p class="text-xs text-gray-400 mt-1">Apareceu em casa</p>
          </div>
          <div class="como-option border-2 border-gray-200 rounded-xl p-4 text-center" onclick="selecionarComo(this, 'alguem_encontrou')">
            <i class="fa-solid fa-people-arrows text-2xl text-blue-400 mb-2"></i>
            <p class="text-sm font-semibold text-gray-800">Alguem encontrou</p>
            <p class="text-xs text-gray-400 mt-1">Uma pessoa ajudou</p>
          </div>
          <div class="como-option border-2 border-gray-200 rounded-xl p-4 text-center" onclick="selecionarComo(this, 'tag_nfc')">
            <i class="fa-solid fa-wifi text-2xl text-purple-400 mb-2"></i>
            <p class="text-sm font-semibold text-gray-800">Via tag NFC</p>
            <p class="text-xs text-gray-400 mt-1">Scan da coleira</p>
          </div>
          <div class="como-option border-2 border-gray-200 rounded-xl p-4 text-center" onclick="selecionarComo(this, 'outra_forma')">
            <i class="fa-solid fa-ellipsis text-2xl text-gray-400 mb-2"></i>
            <p class="text-sm font-semibold text-gray-800">Outra forma</p>
            <p class="text-xs text-gray-400 mt-1">Quero descrever</p>
          </div>
        </div>
        <input type="hidden" name="como_encontrado" id="comoEncontrado" value="">
      </div>

      <div>
        <label for="descricao_encontrado" class="block text-sm font-medium text-gray-700 mb-1">
          Quer contar mais? <span class="text-gray-400 font-normal">(opcional)</span>
        </label>
        <textarea name="descricao_encontrado" id="descricao_encontrado" rows="3"
                  placeholder="Ex: Encontrei ele no parque perto de casa, um vizinho me avisou..."
                  class="input-field resize-none"></textarea>
      </div>

      <button type="button" onclick="irParaPasso(2)" id="btnStep1"
              class="w-full py-3.5 rounded-xl font-semibold text-white bg-emerald-500 hover:bg-emerald-600 transition-colors disabled:opacity-40 disabled:cursor-not-allowed"
              disabled>
        Continuar <i class="fa-solid fa-arrow-right ml-2"></i>
      </button>
    </div>

    <!-- PASSO 2: Onde foi encontrado -->
    <div id="step2" class="space-y-5 hidden">
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-3">
          <i class="fa-solid fa-location-dot text-emerald-500 mr-1"></i>
          Onde <%= pet.nome %> foi encontrado?
        </label>

        <div class="grid grid-cols-1 gap-2 mb-3">
          <div id="optGeo" class="loc-option border-2 border-gray-200 rounded-xl p-3 flex items-center gap-3"
               onclick="usarMinhaLocalizacao()">
            <div class="w-10 h-10 rounded-full bg-emerald-100 flex items-center justify-center flex-shrink-0">
              <i class="fa-solid fa-location-crosshairs text-emerald-600"></i>
            </div>
            <div class="flex-1 min-w-0">
              <p class="text-sm font-semibold text-gray-800">Minha localizacao atual</p>
              <p class="text-xs text-gray-500">Usar GPS do celular</p>
            </div>
            <i class="fa-solid fa-check-circle text-emerald-500 text-lg opacity-0" id="optGeoCheck"></i>
          </div>

          <div id="optManual" class="loc-option border-2 border-gray-200 rounded-xl p-3 flex items-center gap-3"
               onclick="usarManual()">
            <div class="w-10 h-10 rounded-full bg-blue-100 flex items-center justify-center flex-shrink-0">
              <i class="fa-solid fa-map-pin text-blue-600"></i>
            </div>
            <div class="flex-1 min-w-0">
              <p class="text-sm font-semibold text-gray-800">Marcar no mapa</p>
              <p class="text-xs text-gray-500">Clique no mapa ou busque um endereco</p>
            </div>
            <i class="fa-solid fa-check-circle text-emerald-500 text-lg opacity-0" id="optManualCheck"></i>
          </div>

          <div id="optPular" class="loc-option border-2 border-gray-200 rounded-xl p-3 flex items-center gap-3"
               onclick="pularLocalizacao()">
            <div class="w-10 h-10 rounded-full bg-gray-100 flex items-center justify-center flex-shrink-0">
              <i class="fa-solid fa-forward text-gray-500"></i>
            </div>
            <div class="flex-1 min-w-0">
              <p class="text-sm font-semibold text-gray-800">Nao sei / Pular</p>
              <p class="text-xs text-gray-500">Nao quero informar a localizacao</p>
            </div>
            <i class="fa-solid fa-check-circle text-emerald-500 text-lg opacity-0" id="optPularCheck"></i>
          </div>
        </div>

        <!-- Busca de endereco -->
        <div id="buscaEnderecoBox" class="mb-3 hidden">
          <div class="relative">
            <input type="text" id="buscaEndereco" placeholder="Buscar endereco..."
                   class="input-field !pr-10" autocomplete="off">
            <button type="button" onclick="buscarEndereco()"
                    class="absolute right-2 top-1/2 -translate-y-1/2 text-gray-400 hover:text-emerald-600 transition-colors">
              <i class="fa-solid fa-magnifying-glass"></i>
            </button>
          </div>
          <div id="resultadosBusca" class="search-results hidden mt-1 bg-white border rounded-xl shadow-lg"></div>
        </div>

        <div id="mapaEncontrado" class="hidden"></div>
        <p id="coordInfo" class="text-xs text-gray-400 mt-1 hidden">
          <i class="fa-solid fa-map-pin mr-1"></i>
          <span id="coordText"></span>
        </p>
        <input type="hidden" name="latitude" id="encontradoLat">
        <input type="hidden" name="longitude" id="encontradoLng">
      </div>

      <div class="flex gap-3">
        <button type="button" onclick="irParaPasso(1)"
                class="flex-1 py-3 rounded-xl font-semibold text-gray-600 bg-gray-100 hover:bg-gray-200 transition-colors">
          <i class="fa-solid fa-arrow-left mr-2"></i> Voltar
        </button>
        <button type="button" onclick="irParaPasso(3)" id="btnStep2"
                class="flex-1 py-3 rounded-xl font-semibold text-white bg-emerald-500 hover:bg-emerald-600 transition-colors disabled:opacity-40 disabled:cursor-not-allowed"
                disabled>
          Continuar <i class="fa-solid fa-arrow-right ml-2"></i>
        </button>
      </div>
    </div>

    <!-- PASSO 3: Confirmacao e agradecimento -->
    <div id="step3" class="space-y-5 hidden">

      <!-- Resumo -->
      <div class="card bg-emerald-50 border border-emerald-200">
        <h3 class="text-sm font-bold text-gray-800 mb-3">
          <i class="fa-solid fa-clipboard-check text-emerald-500 mr-1"></i> Resumo
        </h3>
        <div class="space-y-2 text-sm">
          <div class="flex items-center gap-2">
            <i class="fa-solid fa-paw text-emerald-400 w-5 text-center"></i>
            <span class="text-gray-600">Pet: <strong><%= pet.nome %></strong></span>
          </div>
          <div class="flex items-center gap-2" id="resumoComo">
            <i class="fa-solid fa-magnifying-glass text-emerald-400 w-5 text-center"></i>
            <span class="text-gray-600">Como: <strong id="resumoComoTexto">—</strong></span>
          </div>
          <div class="flex items-center gap-2" id="resumoOnde">
            <i class="fa-solid fa-location-dot text-emerald-400 w-5 text-center"></i>
            <span class="text-gray-600">Local: <strong id="resumoOndeTexto">—</strong></span>
          </div>
        </div>
      </div>

      <!-- Agradecimento publico -->
      <div>
        <label class="flex items-center gap-3 cursor-pointer mb-3">
          <input type="checkbox" id="toggleAgradecimento" class="w-5 h-5 rounded border-gray-300 text-emerald-500 focus:ring-emerald-500"
                 onchange="toggleAgradecimento()">
          <div>
            <span class="text-sm font-medium text-gray-700">Agradecer a comunidade</span>
            <p class="text-xs text-gray-400">Enviar uma mensagem para quem ajudou na busca</p>
          </div>
        </label>
        <div id="agradecimentoBox" class="hidden">
          <textarea name="mensagem_agradecimento" id="mensagemAgradecimento" rows="3"
                    placeholder="Obrigado a todos que ajudaram! Meu pet esta em casa e seguro..."
                    class="input-field resize-none"></textarea>
        </div>
      </div>

      <!-- Aviso -->
      <div class="bg-amber-50 border border-amber-200 rounded-xl p-4">
        <p class="text-sm text-amber-800">
          <i class="fa-solid fa-info-circle mr-1"></i>
          Ao confirmar, o alerta de <strong><%= pet.nome %></strong> sera encerrado e removido do mapa publico.
          As conversas relacionadas serao apagadas por questoes de privacidade.
        </p>
      </div>

      <div class="flex gap-3">
        <button type="button" onclick="irParaPasso(2)"
                class="flex-1 py-3 rounded-xl font-semibold text-gray-600 bg-gray-100 hover:bg-gray-200 transition-colors">
          <i class="fa-solid fa-arrow-left mr-2"></i> Voltar
        </button>
        <button type="submit" id="btnConfirmar"
                class="flex-1 py-3.5 rounded-xl font-bold text-white bg-emerald-500 hover:bg-emerald-600 transition-colors active:scale-[0.98]">
          <i class="fa-solid fa-check-circle mr-2"></i> Confirmar
        </button>
      </div>
    </div>

  </form>
</main>

<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script>
(function () {
  var passoAtual = 1;
  var locSelecionada = false;
  var map = null;
  var marker = null;

  var comoTextos = {
    'voltou_sozinho': 'Voltou sozinho',
    'alguem_encontrou': 'Alguem encontrou',
    'tag_nfc': 'Via tag NFC',
    'outra_forma': 'Outra forma'
  };

  /* ========== Passo 1: Como ========== */

  window.selecionarComo = function (el, valor) {
    document.querySelectorAll('.como-option').forEach(function (o) { o.classList.remove('active'); });
    el.classList.add('active');
    document.getElementById('comoEncontrado').value = valor;
    document.getElementById('btnStep1').disabled = false;
  };

  /* ========== Passo 2: Onde ========== */

  function initMap() {
    if (map) return;
    var container = document.getElementById('mapaEncontrado');
    container.classList.remove('hidden');
    map = L.map('mapaEncontrado').setView([-15.78, -47.93], 5);
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
      attribution: '&copy; OSM', maxZoom: 19
    }).addTo(map);
    setTimeout(function () { map.invalidateSize(); }, 200);
  }

  function setMarker(lat, lng, popup) {
    if (!map) initMap();
    if (marker) map.removeLayer(marker);
    marker = L.marker([lat, lng], {
      draggable: true,
      icon: L.divIcon({
        className: 'custom-pin',
        html: '<div style="background:#10b981;width:34px;height:34px;border-radius:50%;border:3px solid #fff;box-shadow:0 2px 8px rgba(0,0,0,.3);display:flex;align-items:center;justify-content:center"><i class="fa-solid fa-check" style="color:#fff;font-size:14px"></i></div>',
        iconSize: [34, 34], iconAnchor: [17, 17]
      })
    }).addTo(map);
    if (popup) marker.bindPopup(popup).openPopup();

    marker.on('dragend', function (e) {
      var p = e.target.getLatLng();
      updateCoords(p.lat, p.lng);
    });

    updateCoords(lat, lng);
  }

  function updateCoords(lat, lng) {
    document.getElementById('encontradoLat').value = parseFloat(lat).toFixed(7);
    document.getElementById('encontradoLng').value = parseFloat(lng).toFixed(7);
    document.getElementById('coordInfo').classList.remove('hidden');
    document.getElementById('coordText').textContent = parseFloat(lat).toFixed(5) + ', ' + parseFloat(lng).toFixed(5);
    locSelecionada = true;
    document.getElementById('btnStep2').disabled = false;
  }

  function clearLocSelection() {
    document.querySelectorAll('.loc-option').forEach(function (el) {
      el.classList.remove('active');
      var chk = el.querySelector('.fa-check-circle');
      if (chk) chk.style.opacity = '0';
    });
  }

  function selectLocOption(id) {
    clearLocSelection();
    var el = document.getElementById(id);
    if (el) {
      el.classList.add('active');
      var chk = el.querySelector('.fa-check-circle');
      if (chk) chk.style.opacity = '1';
    }
  }

  window.usarMinhaLocalizacao = function () {
    selectLocOption('optGeo');
    document.getElementById('buscaEnderecoBox').classList.add('hidden');
    initMap();
    if (!navigator.geolocation) {
      alert('Geolocalizacao nao suportada neste dispositivo');
      return;
    }
    navigator.geolocation.getCurrentPosition(function (pos) {
      map.setView([pos.coords.latitude, pos.coords.longitude], 16);
      setMarker(pos.coords.latitude, pos.coords.longitude, '<b>Localizacao atual</b>');
    }, function () {
      alert('Nao foi possivel obter sua localizacao.');
    }, { timeout: 10000, enableHighAccuracy: true });
  };

  window.usarManual = function () {
    selectLocOption('optManual');
    document.getElementById('buscaEnderecoBox').classList.remove('hidden');
    initMap();
    map.on('click', function (e) {
      var manual = document.getElementById('optManual');
      if (manual && manual.classList.contains('active')) {
        setMarker(e.latlng.lat, e.latlng.lng);
      }
    });
  };

  window.pularLocalizacao = function () {
    selectLocOption('optPular');
    document.getElementById('buscaEnderecoBox').classList.add('hidden');
    document.getElementById('encontradoLat').value = '';
    document.getElementById('encontradoLng').value = '';
    document.getElementById('coordInfo').classList.add('hidden');
    locSelecionada = true;
    document.getElementById('btnStep2').disabled = false;
  };

  window.buscarEndereco = function () {
    var q = document.getElementById('buscaEndereco').value.trim();
    if (!q || q.length < 3) return;
    var box = document.getElementById('resultadosBusca');
    box.innerHTML = '<p class="p-3 text-sm text-gray-400">Buscando...</p>';
    box.classList.remove('hidden');

    fetch('https://nominatim.openstreetmap.org/search?format=json&q=' + encodeURIComponent(q) + '&limit=5&countrycodes=br')
      .then(function (r) { return r.json(); })
      .then(function (data) {
        if (!data.length) {
          box.innerHTML = '<p class="p-3 text-sm text-gray-500">Nenhum resultado</p>';
          return;
        }
        box.innerHTML = data.map(function (r) {
          return '<div class="p-3 hover:bg-emerald-50 cursor-pointer text-sm border-b last:border-0 transition-colors" onclick="selecionarEndereco(' + r.lat + ',' + r.lon + ',\'' + r.display_name.replace(/'/g, "\\'").substring(0, 80) + '\')">' +
            '<i class="fa-solid fa-location-dot text-emerald-500 mr-1"></i>' + r.display_name.substring(0, 80) + '</div>';
        }).join('');
      })
      .catch(function () {
        box.innerHTML = '<p class="p-3 text-sm text-red-500">Erro na busca</p>';
      });
  };

  window.selecionarEndereco = function (lat, lng, nome) {
    document.getElementById('resultadosBusca').classList.add('hidden');
    document.getElementById('buscaEndereco').value = nome;
    map.setView([lat, lng], 16);
    setMarker(lat, lng, '<b>' + nome + '</b>');
  };

  var buscaInput = document.getElementById('buscaEndereco');
  if (buscaInput) {
    buscaInput.addEventListener('keydown', function (e) {
      if (e.key === 'Enter') { e.preventDefault(); buscarEndereco(); }
    });
  }

  /* ========== Passo 3: Agradecimento ========== */

  window.toggleAgradecimento = function () {
    var box = document.getElementById('agradecimentoBox');
    box.classList.toggle('hidden');
  };

  /* ========== Navegacao entre passos ========== */

  function atualizarResumo() {
    var como = document.getElementById('comoEncontrado').value;
    document.getElementById('resumoComoTexto').textContent = comoTextos[como] || '—';

    var lat = document.getElementById('encontradoLat').value;
    if (lat) {
      document.getElementById('resumoOndeTexto').textContent = 'Localização informada';
    } else {
      document.getElementById('resumoOndeTexto').textContent = 'Não informado';
    }
  }

  function atualizarProgresso(passo) {
    for (var i = 1; i <= 3; i++) {
      var dot = document.getElementById('dot' + i);
      var label = document.getElementById('label' + i);
      if (i < passo) {
        dot.className = 'step-dot done';
        label.className = 'text-xs text-emerald-600 font-semibold';
      } else if (i === passo) {
        dot.className = 'step-dot active';
        label.className = 'text-xs text-emerald-600 font-semibold';
      } else {
        dot.className = 'step-dot pending';
        label.className = 'text-xs text-gray-400';
      }
    }
    for (var j = 1; j <= 2; j++) {
      var bar = document.getElementById('bar' + j);
      bar.className = j < passo ? 'step-bar done' : 'step-bar pending';
    }
  }

  window.irParaPasso = function (passo) {
    document.getElementById('step1').classList.add('hidden');
    document.getElementById('step2').classList.add('hidden');
    document.getElementById('step3').classList.add('hidden');
    document.getElementById('step' + passo).classList.remove('hidden');
    passoAtual = passo;
    atualizarProgresso(passo);

    if (passo === 2 && map) {
      setTimeout(function () { map.invalidateSize(); }, 200);
    }
    if (passo === 3) {
      atualizarResumo();
    }

    window.scrollTo({ top: 0, behavior: 'smooth' });
  };

  /* Confirmacao antes de enviar */
  document.getElementById('formEncontrado').addEventListener('submit', function (e) {
    var como = document.getElementById('comoEncontrado').value;
    if (!como) {
      e.preventDefault();
      alert('Por favor, selecione como o pet foi encontrado.');
      irParaPasso(1);
      return;
    }

    var btn = document.getElementById('btnConfirmar');
    btn.disabled = true;
    btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin mr-2"></i> Processando...';
  });
})();
</script>

<%- include('../partials/footer') %>
