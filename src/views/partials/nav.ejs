<% var isLogado = typeof usuario !== 'undefined' && usuario; %>
<% var notifCount = typeof notificacoesNaoLidas !== 'undefined' ? notificacoesNaoLidas : 0; %>
<% var currentPath = typeof req !== 'undefined' ? req.path : ''; %>
<% var currentOriginalUrl = typeof req !== 'undefined' ? (req.originalUrl || '') : ''; %>
<% var pageTitle = typeof titulo !== 'undefined' ? String(titulo).toLowerCase() : ''; %>
<% var isHomePage = currentPath === '/' || currentOriginalUrl === '/' || pageTitle === 'inicio'; %>
<% var isMeuPerfilPublico = isLogado && usuario && currentPath === '/explorar/perfil/' + usuario.id; %>
<% var isPerfilSettings = currentPath === '/perfil' || (currentPath && String(currentPath).indexOf('/perfil/') === 0); %>
<% var isMaisDestaque = isLogado && currentPath && (
  currentPath.startsWith('/pets') ||
  currentPath.startsWith('/explorar/busca') ||
  currentPath.startsWith('/tags') ||
  currentPath.startsWith('/perfil')
); %>

<!-- Top Nav — estilo Instagram: nome no topo centralizado no mobile -->
<nav class="sticky top-0 z-50 shadow-sm" id="navbar">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="flex items-center justify-between h-13 md:h-14">
      <!-- Mobile: layout 3 colunas para centralizar AIRPET no topo (estilo Instagram) -->
      <div class="flex-1 md:flex-none min-w-0"></div>
      <a href="<%= isLogado ? '/feed' : '/' %>" class="flex items-center gap-2 group shrink-0">
        <span class="bg-gradient-to-br from-primary-500 to-primary-600 text-white w-7 h-7 md:w-8 md:h-8 rounded-xl flex items-center justify-center shadow-md md:shadow-lg shadow-primary-500/20 group-hover:scale-105 md:group-hover:scale-110 transition-transform">
          <i class="fa-solid fa-paw text-xs md:text-sm"></i>
        </span>
        <span class="font-brand text-[16px] md:text-[18px] leading-none text-gray-800">AIRPET</span>
      </a>
      <div class="flex-1 md:hidden min-w-0"></div>

      <!-- Desktop: menu à direita -->
      <div class="hidden md:flex items-center gap-1">
        <% if (isLogado) { %>
          <a href="/feed" class="relative px-3 py-1.5 rounded-full text-[13px] font-semibold transition-all duration-200 <%= currentPath === '/feed' ? 'bg-primary-100 text-primary-700 shadow-sm' : 'text-gray-500 hover:bg-primary-50 hover:text-primary-600' %>">
            <i class="fa-solid fa-house mr-1.5"></i>Feed
          </a>
          <a href="/explorar" class="relative px-3 py-1.5 rounded-full text-[13px] font-semibold transition-all duration-200 <%= currentPath === '/explorar' ? 'bg-primary-100 text-primary-700 shadow-sm' : 'text-gray-500 hover:bg-primary-50 hover:text-primary-600' %>">
            <i class="fa-solid fa-compass mr-1.5"></i>Explorar
          </a>
          <a href="/explorar/busca" class="px-3 py-1.5 rounded-full text-[13px] font-semibold transition-all duration-200 <%= currentPath.startsWith('/explorar/busca') ? 'bg-primary-100 text-primary-700 shadow-sm' : 'text-gray-500 hover:bg-primary-50 hover:text-primary-600' %>">
            <i class="fa-solid fa-magnifying-glass mr-1.5"></i>Buscar
          </a>
          <a href="/pets" class="px-3 py-1.5 rounded-full text-[13px] font-semibold transition-all duration-200 <%= currentPath.startsWith('/pets') ? 'bg-primary-100 text-primary-700 shadow-sm' : 'text-gray-500 hover:bg-primary-50 hover:text-primary-600' %>">
            <i class="fa-solid fa-paw mr-1.5"></i>Meus Pets
          </a>
          <a href="/tags/pedidos" class="px-3 py-1.5 rounded-full text-[13px] font-semibold transition-all duration-200 <%= currentPath.startsWith('/tags') ? 'bg-primary-100 text-primary-700 shadow-sm' : 'text-gray-500 hover:bg-primary-50 hover:text-primary-600' %>">
            <i class="fa-solid fa-tag mr-1.5"></i>Minhas TAGs
          </a>
          <a href="/mapa" class="px-3 py-1.5 rounded-full text-[13px] font-semibold transition-all duration-200 <%= currentPath.startsWith('/mapa') ? 'bg-primary-100 text-primary-700 shadow-sm' : 'text-gray-500 hover:bg-primary-50 hover:text-primary-600' %>">
            <i class="fa-solid fa-map-location-dot mr-1.5"></i>Mapa
          </a>
          <a href="/petshops" class="px-3 py-1.5 rounded-full text-[13px] font-semibold transition-all duration-200 <%= currentPath.startsWith('/petshops') ? 'bg-primary-100 text-primary-700 shadow-sm' : 'text-gray-500 hover:bg-primary-50 hover:text-primary-600' %>">
            <i class="fa-solid fa-store mr-1.5"></i>Petshops
          </a>
          <a href="/notificacoes" class="relative px-3 py-1.5 rounded-full text-[13px] font-semibold transition-all duration-200 <%= currentPath.startsWith('/notificacoes') ? 'bg-primary-100 text-primary-700 shadow-sm' : 'text-gray-500 hover:bg-primary-50 hover:text-primary-600' %>">
            <i class="fa-solid fa-bell mr-1.5"></i>
            <span data-notif-badge class="absolute -top-0.5 left-[22px] min-w-[18px] h-[18px] px-1 bg-red-500 text-white text-[10px] font-bold rounded-full flex items-center justify-center animate-pulse <%= notifCount > 0 ? '' : 'hidden' %>">
              <%= notifCount > 9 ? '9+' : notifCount %>
            </span>
          </a>

          <div class="relative ml-1" id="profileDropdown">
            <button type="button" id="profileBtn"
                    class="flex items-center gap-2 p-1.5 rounded-xl hover:bg-gray-100 transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-primary-500/20">
              <% var navCor = usuario.cor_perfil || '#ec5a1c'; %>
              <% if (usuario.foto_perfil) { %>
                <img src="<%= usuario.foto_perfil %>" alt="" class="w-8 h-8 rounded-full object-cover" style="box-shadow: 0 0 0 2px <%= navCor %>">
              <% } else { %>
                <span class="w-8 h-8 rounded-full flex items-center justify-center text-xs font-bold text-white bg-gray-400"
                      style="box-shadow: 0 0 0 2px <%= navCor %>">
                  <%= usuario.nome ? usuario.nome.charAt(0).toUpperCase() : 'U' %>
                </span>
              <% } %>
              <i class="fa-solid fa-chevron-down text-[10px] text-gray-400"></i>
            </button>

            <div id="profileMenu"
                 class="hidden absolute right-0 mt-2 w-56 rounded-2xl py-2 z-50 opacity-0 translate-y-1 transition-all duration-200"
                 style="opacity:0; transform:translateY(4px)">
              <div class="px-4 py-3 border-b border-gray-100">
                <p class="text-sm font-bold text-gray-900 truncate"><%= usuario.nome %></p>
                <p class="text-xs text-gray-400 truncate"><%= usuario.email %></p>
              </div>
              <a href="/explorar/perfil/<%= usuario.id %>" class="flex items-center gap-3 px-4 py-2.5 text-sm text-gray-700 hover:bg-gray-50 transition-colors">
                <i class="fa-solid fa-user w-4 text-center text-gray-400"></i> Meu Perfil
              </a>
              <a href="/perfil" class="flex items-center gap-3 px-4 py-2.5 text-sm text-gray-700 hover:bg-gray-50 transition-colors">
                <i class="fa-solid fa-gear w-4 text-center text-gray-400"></i> Configurações
              </a>
              <a href="/tags/pedidos" class="flex items-center gap-3 px-4 py-2.5 text-sm text-gray-700 hover:bg-gray-50 transition-colors">
                <i class="fa-solid fa-tag w-4 text-center text-gray-400"></i> Minhas TAGs
              </a>
              <% if (typeof petshopAccount !== 'undefined' && petshopAccount) { %>
              <a href="/petshop-panel/dashboard" class="flex items-center gap-3 px-4 py-2.5 text-sm text-emerald-600 hover:bg-emerald-50 transition-colors">
                <i class="fa-solid fa-store w-4 text-center"></i> Painel parceiro
              </a>
              <% } %>
              <div class="border-t border-gray-100 my-1"></div>
              <a href="/auth/logout" class="flex items-center gap-3 px-4 py-2.5 text-sm text-red-500 hover:bg-red-50 transition-colors">
                <i class="fa-solid fa-right-from-bracket w-4 text-center"></i> Sair
              </a>
            </div>
          </div>

        <% } else { %>
          <a href="/auth/login" class="px-4 py-2 rounded-xl text-sm font-medium text-gray-500 hover:text-primary-600 hover:bg-primary-50 transition-all duration-200">
            Entrar
          </a>
          <a href="/auth/registro" class="px-5 py-2 rounded-xl text-sm font-semibold text-white bg-gradient-to-r from-primary-500 to-primary-600 hover:shadow-lg hover:shadow-primary-500/25 hover:-translate-y-0.5 transition-all duration-300">
            Criar Conta
          </a>
        <% } %>
      </div>

      <!-- Mobile hamburger (for non-logged in) -->
      <% if (!isLogado && !isHomePage) { %>
      <button type="button" id="mobileMenuBtn"
              class="md:hidden p-2 rounded-xl text-gray-500 hover:bg-gray-100 transition-colors">
        <i class="fa-solid fa-bars text-lg" id="menuIcon"></i>
      </button>
      <% } %>
    </div>
  </div>

  <!-- Mobile Menu (non-logged) -->
  <% if (!isLogado && !isHomePage) { %>
  <div id="mobileMenu" class="hidden md:hidden border-t border-gray-100 bg-white/95 backdrop-blur-lg">
    <div class="px-4 py-4 space-y-2">
      <a href="/auth/login" class="flex items-center justify-center gap-2 px-4 py-3 rounded-xl text-sm font-medium text-gray-700 bg-gray-50 hover:bg-gray-100 transition-colors">
        <i class="fa-solid fa-right-to-bracket"></i> Entrar
      </a>
      <a href="/auth/registro" class="flex items-center justify-center gap-2 px-4 py-3 rounded-xl text-sm font-semibold text-white bg-gradient-to-r from-primary-500 to-primary-600 transition-colors">
        <i class="fa-solid fa-user-plus"></i> Criar Conta
      </a>
    </div>
  </div>
  <% } %>
</nav>

<!-- Mobile Bottom Navigation (logged in only) -->
<% if (isLogado) { %>
<nav id="bottomNav" class="md:hidden fixed bottom-0 left-0 right-0 z-50 safe-bottom">
  <!-- Mantido no DOM para explorar.ejs / tour / CTAs que chamam .click() — sem botão visual no centro -->
  <button type="button" id="fabNewPost" class="fab-new-post-hidden" tabindex="-1" aria-hidden="true"></button>
  <div class="bottom-nav-grid h-[60px] px-2 max-w-lg mx-auto w-full">
    <a href="/feed" id="bottomNavFeedTab" class="bottom-tab bottom-tab-cell <%= currentPath === '/feed' ? 'bottom-tab--active' : '' %>">
      <span class="bottom-tab-iconwrap"><i class="fa-solid fa-house text-[1.125rem] leading-none"></i></span>
      <span class="bottom-tab-label">Feed</span>
    </a>
    <a href="/explorar" class="bottom-tab bottom-tab-cell <%= currentPath === '/explorar' ? 'bottom-tab--active' : '' %>">
      <span class="bottom-tab-iconwrap"><i class="fa-solid fa-compass text-[1.125rem] leading-none"></i></span>
      <span class="bottom-tab-label">Explorar</span>
    </a>
    <a href="/pets" class="bottom-tab bottom-tab-cell <%= currentPath && currentPath.startsWith('/pets') ? 'bottom-tab--active' : '' %>">
      <span class="bottom-tab-iconwrap"><i class="fa-solid fa-paw text-[1.125rem] leading-none"></i></span>
      <span class="bottom-tab-label">Pets</span>
    </a>
    <a href="/mapa" class="bottom-tab bottom-tab-cell <%= currentPath.startsWith('/mapa') || currentPath.startsWith('/petshops') ? 'bottom-tab--active' : '' %>">
      <span class="bottom-tab-iconwrap"><i class="fa-solid fa-map-location-dot text-[1.125rem] leading-none"></i></span>
      <span class="bottom-tab-label">Mapa</span>
    </a>
    <a href="/chat" class="bottom-tab bottom-tab-cell <%= currentPath.startsWith('/chat') ? 'bottom-tab--active' : '' %>">
      <span class="bottom-tab-iconwrap relative">
        <i class="fa-solid fa-comments text-[1.125rem] leading-none"></i>
      </span>
      <span class="bottom-tab-label">Chat</span>
    </a>
    <button type="button" id="bottomNavMaisBtn" class="bottom-tab bottom-tab-cell bottom-nav-mais-btn <%= isMaisDestaque ? 'bottom-tab--active' : '' %>"
            aria-expanded="false" aria-controls="bottomNavMaisPanel" aria-label="Mais opções">
      <span class="bottom-tab-iconwrap"><i class="fa-solid fa-ellipsis text-[1.125rem] leading-none"></i></span>
      <span class="bottom-tab-label">Mais</span>
    </button>
  </div>

  <div id="bottomNavMaisPanel" class="bottom-nav-mais-panel hidden md:hidden" role="menu" aria-hidden="true">
    <div class="bottom-nav-mais-panel-inner">
      <a href="/pets" role="menuitem" class="bottom-nav-mais-link <%= currentPath && currentPath.startsWith('/pets') ? 'bottom-nav-mais-link--active' : '' %>">
        <span class="bottom-nav-mais-ic"><i class="fa-solid fa-paw"></i></span>
        <span>Meus Pets</span>
      </a>
      <a href="/notificacoes" role="menuitem" class="bottom-nav-mais-link <%= currentPath && currentPath.startsWith('/notificacoes') ? 'bottom-nav-mais-link--active' : '' %>">
        <span class="bottom-nav-mais-ic"><i class="fa-solid fa-bell"></i></span>
        <span>Notificações</span>
      </a>
      <a href="/explorar/busca" role="menuitem" class="bottom-nav-mais-link <%= currentPath && currentPath.startsWith('/explorar/busca') ? 'bottom-nav-mais-link--active' : '' %>">
        <span class="bottom-nav-mais-ic"><i class="fa-solid fa-magnifying-glass"></i></span>
        <span>Buscar</span>
      </a>
      <a href="/tags/pedidos" role="menuitem" class="bottom-nav-mais-link <%= currentPath && currentPath.startsWith('/tags') ? 'bottom-nav-mais-link--active' : '' %>">
        <span class="bottom-nav-mais-ic"><i class="fa-solid fa-tag"></i></span>
        <span>Minhas TAGs</span>
      </a>
      <a href="/perfil" role="menuitem" class="bottom-nav-mais-link <%= isPerfilSettings ? 'bottom-nav-mais-link--active' : '' %>">
        <span class="bottom-nav-mais-ic"><i class="fa-solid fa-gear"></i></span>
        <span>Configurações</span>
      </a>
      <a href="/explorar/perfil/<%= usuario.id %>" role="menuitem" class="bottom-nav-mais-link <%= isMeuPerfilPublico ? 'bottom-nav-mais-link--active' : '' %>">
        <span class="bottom-nav-mais-ic"><i class="fa-solid fa-user"></i></span>
        <span>Meu perfil</span>
      </a>
    </div>
  </div>
</nav>
<% } %>

<style>
  #navbar {
    background: color-mix(in srgb, var(--ink-2) 88%, transparent) !important;
    border-bottom: 1px solid var(--border) !important;
    backdrop-filter: blur(18px);
    -webkit-backdrop-filter: blur(18px);
  }
  #navbar a,
  #navbar button {
    color: var(--text-dim);
  }
  #navbar a:hover,
  #navbar button:hover {
    color: var(--accent) !important;
  }
  #navbar #profileBtn:hover {
    background: var(--ink-3) !important;
  }
  #profileMenu {
    background: var(--ink-2) !important;
    border: 1px solid var(--border) !important;
    box-shadow: 0 18px 48px rgba(15, 23, 42, 0.12) !important;
  }
  #profileMenu .border-b,
  #profileMenu .border-t {
    border-color: var(--border) !important;
  }
  #profileMenu p:first-child {
    color: var(--text) !important;
  }
  #profileMenu p:last-child {
    color: var(--text-dim) !important;
  }
  #profileMenu a {
    color: var(--text) !important;
  }
  #profileMenu a:hover {
    background: var(--ink-4) !important;
  }
  #mobileMenu {
    background: var(--ink-2) !important;
    border-top: 1px solid var(--border) !important;
  }
  #bottomNav {
    background: var(--ink-2) !important;
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-top: 1px solid var(--border) !important;
  }
  .fab-new-post-hidden {
    position: absolute;
    width: 0;
    height: 0;
    opacity: 0;
    pointer-events: none;
    border: 0;
    padding: 0;
    margin: 0;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
  }
  #bottomNav .bottom-nav-grid {
    display: flex;
    flex-direction: row;
    flex-wrap: nowrap;
    align-items: center;
    justify-content: space-evenly;
    width: 100%;
    box-sizing: border-box;
  }
  #bottomNav .bottom-nav-mais-btn {
    border: none;
    font: inherit;
    cursor: pointer;
    width: auto;
    -webkit-appearance: none;
    appearance: none;
  }
  #bottomNav .bottom-nav-mais-panel {
    position: fixed;
    left: 12px;
    right: 12px;
    z-index: 55;
    bottom: calc(56px + env(safe-area-inset-bottom, 0px) + 6px);
    pointer-events: none;
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 0.2s ease, transform 0.2s ease;
  }
  #bottomNav .bottom-nav-mais-panel:not(.hidden) {
    pointer-events: auto;
    opacity: 1;
    transform: translateY(0);
  }
  #bottomNav .bottom-nav-mais-panel-inner {
    background: var(--ink-2) !important;
    border: 1px solid var(--border) !important;
    border-radius: 16px;
    box-shadow: 0 -8px 40px rgba(15, 23, 42, 0.12);
    padding: 8px;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  #bottomNav .bottom-nav-mais-link {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 14px;
    border-radius: 12px;
    text-decoration: none !important;
    font-size: 14px;
    font-weight: 600;
    color: var(--text) !important;
    transition: background 0.15s ease;
  }
  #bottomNav .bottom-nav-mais-link:hover,
  #bottomNav .bottom-nav-mais-link:focus-visible {
    background: var(--ink-3) !important;
    outline: none;
  }
  #bottomNav .bottom-nav-mais-link--active {
    color: var(--accent) !important;
    background: color-mix(in srgb, var(--accent) 10%, transparent) !important;
  }
  #bottomNav .bottom-nav-mais-ic {
    width: 36px;
    height: 36px;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--ink-3);
    color: var(--accent);
    flex-shrink: 0;
  }
  #bottomNav .bottom-tab.bottom-tab-cell {
    position: relative;
    display: flex;
    flex-direction: column;
    flex: 1 1 0;
    align-items: center;
    justify-content: center;
    gap: 2px;
    min-width: 0;
    min-height: 0;
    padding: 4px 1px 6px;
    border-radius: 0;
    text-decoration: none;
    color: var(--text-dim) !important;
    background: transparent;
    transition: color 0.18s ease, opacity 0.18s ease, transform 0.12s ease;
    -webkit-tap-highlight-color: transparent;
  }
  #bottomNav .bottom-tab.bottom-tab-cell:active {
    transform: scale(0.96);
  }
  #bottomNav .bottom-tab-iconwrap {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 22px;
    width: 100%;
    position: relative;
  }
  #bottomNav .bottom-tab-iconwrap--avatar {
    height: 22px;
  }
  #bottomNav .bottom-tab-label {
    font-size: 10px;
    font-weight: 600;
    line-height: 1.1;
    text-align: center;
    max-width: 100%;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    padding: 0 1px;
  }
  @media (max-width: 380px) {
    #bottomNav .bottom-tab-label {
      font-size: 9px;
    }
  }
  #bottomNav .bottom-tab--active {
    color: var(--accent) !important;
    background: transparent;
  }
  #bottomNav .bottom-tab-cell:hover:not(.bottom-tab--active) {
    color: var(--accent) !important;
    background: transparent;
    opacity: 0.92;
  }
  #mobileMenu a {
    color: var(--text) !important;
  }
  #mobileMenu a:first-child {
    background: var(--ink-3) !important;
    border: 1px solid var(--border) !important;
  }
  #mobileMenu a:last-child {
    background: var(--accent) !important;
  }
</style>

<script>
(function () {
  var profileBtn = document.getElementById('profileBtn');
  var profileMenu = document.getElementById('profileMenu');
  if (profileBtn && profileMenu) {
    profileBtn.addEventListener('click', function (e) {
      e.stopPropagation();
      var open = profileMenu.classList.contains('hidden');
      profileMenu.classList.toggle('hidden');
      if (open) {
        requestAnimationFrame(function () { profileMenu.style.opacity = '1'; profileMenu.style.transform = 'translateY(0)'; });
      } else {
        profileMenu.style.opacity = '0'; profileMenu.style.transform = 'translateY(4px)';
      }
    });
    document.addEventListener('click', function () {
      profileMenu.classList.add('hidden');
      profileMenu.style.opacity = '0'; profileMenu.style.transform = 'translateY(4px)';
    });
  }
  var mobileMenuBtn = document.getElementById('mobileMenuBtn');
  var mobileMenu = document.getElementById('mobileMenu');
  var menuIcon = document.getElementById('menuIcon');
  if (mobileMenuBtn && mobileMenu) {
    mobileMenuBtn.addEventListener('click', function () {
      var open = !mobileMenu.classList.contains('hidden');
      mobileMenu.classList.toggle('hidden');
      if (menuIcon) menuIcon.className = open ? 'fa-solid fa-bars text-lg' : 'fa-solid fa-xmark text-lg';
    });
  }

  var maisBtn = document.getElementById('bottomNavMaisBtn');
  var maisPanel = document.getElementById('bottomNavMaisPanel');
  function closeMaisPanel() {
    if (!maisPanel || !maisBtn) return;
    maisPanel.classList.add('hidden');
    maisPanel.setAttribute('aria-hidden', 'true');
    maisBtn.setAttribute('aria-expanded', 'false');
  }
  function toggleMaisPanel() {
    if (!maisPanel || !maisBtn) return;
    var open = maisPanel.classList.contains('hidden');
    if (open) {
      maisPanel.classList.remove('hidden');
      maisPanel.setAttribute('aria-hidden', 'false');
      maisBtn.setAttribute('aria-expanded', 'true');
    } else {
      closeMaisPanel();
    }
  }
  if (maisBtn && maisPanel) {
    maisBtn.addEventListener('click', function (e) {
      e.stopPropagation();
      toggleMaisPanel();
    });
    maisPanel.addEventListener('click', function (e) {
      e.stopPropagation();
    });
    maisPanel.querySelectorAll('a[href]').forEach(function (link) {
      link.addEventListener('click', function () {
        closeMaisPanel();
      });
    });
    document.addEventListener('click', function () {
      closeMaisPanel();
    });
  }
})();
</script>
