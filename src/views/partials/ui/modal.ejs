<%
  var id = typeof id === 'string' ? id : 'ui-modal';
  var title = typeof title === 'string' ? title : '';
  var size = typeof size === 'string' ? size : 'max-w-lg';
%>
<div id="<%= id %>" class="hidden fixed inset-0 z-[70] p-4 md:p-6" role="dialog" aria-modal="true" aria-labelledby="<%= id %>-title">
  <div class="absolute inset-0 bg-slate-900/50 backdrop-blur-sm" data-modal-close></div>
  <div class="relative mx-auto <%= size %> surface-card p-5 md:p-6 shadow-panel">
    <header class="mb-4 flex items-center justify-between gap-3">
      <h3 id="<%= id %>-title" class="text-lg font-bold text-[color:var(--text)]"><%= title %></h3>
      <button type="button" class="btn-ghost !px-2 !py-1" data-modal-close aria-label="Fechar">
        <i class="fa-solid fa-xmark"></i>
      </button>
    </header>
    <div>
      <%- body || '' %>
    </div>
  </div>
</div>
