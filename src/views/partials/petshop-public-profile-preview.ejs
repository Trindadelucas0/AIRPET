<section class="partner-card">
  <div class="flex items-center justify-between mb-3">
    <h2 class="font-bold">Preview do perfil público</h2>
    <a href="/petshops/<%= petshop.slug || petshop.id %>" target="_blank" rel="noopener" class="text-xs text-[color:var(--accent)]">Abrir perfil público</a>
  </div>

  <div class="rounded-2xl border border-[color:var(--border)] bg-[color:var(--ink-3)] p-4">
    <p class="text-xs uppercase tracking-wide text-[color:var(--text-dim)]">Petshop parceiro</p>
    <h3 class="text-lg font-black text-[color:var(--text)] mt-1"><%= petshop.nome %></h3>
    <% if (profile && profile.slogan) { %>
      <p class="text-sm font-semibold mt-2"><%= profile.slogan %></p>
    <% } %>
    <% if (profile && profile.descricao_curta) { %>
      <p class="text-sm text-[color:var(--text-dim)] mt-1"><%= profile.descricao_curta %></p>
    <% } %>
    <div class="grid grid-cols-3 gap-2 mt-3 text-xs">
      <div class="rounded-xl bg-[color:var(--ink-2)] p-2"><strong><%= (postsComFoto || []).length %></strong><br>Fotos</div>
      <div class="rounded-xl bg-[color:var(--ink-2)] p-2"><strong><%= (promocoes || []).length %></strong><br>Promoções</div>
      <div class="rounded-xl bg-[color:var(--ink-2)] p-2"><strong><%= followerCount || 0 %></strong><br>Seguidores</div>
    </div>
    <div class="mt-3 text-xs text-[color:var(--text-dim)] space-y-1">
      <p><strong>Telefone:</strong> <%= petshop.telefone || '-' %></p>
      <p><strong>WhatsApp público:</strong> <%= profile && profile.whatsapp_publico ? profile.whatsapp_publico : '-' %></p>
      <p><strong>Instagram:</strong> <%= profile && profile.instagram_url ? profile.instagram_url : '-' %></p>
      <p><strong>Endereço:</strong> <%= petshop.endereco || '-' %></p>
    </div>
  </div>
</section>
