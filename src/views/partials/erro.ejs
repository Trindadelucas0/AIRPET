<%- include('header') %>

<main class="flex-1 flex items-center justify-center px-4 py-16">
  <div class="text-center max-w-md">
    <div class="mb-6">
      <span class="text-8xl sm:text-9xl font-black text-primary-500/15 select-none leading-none">
        <%= typeof codigo !== 'undefined' ? codigo : 500 %>
      </span>
    </div>

    <div class="relative -mt-10">
      <div class="w-20 h-20 mx-auto mb-6 rounded-2xl bg-primary-500/10 flex items-center justify-center">
        <% var iconMap = { 404: 'fa-magnifying-glass', 403: 'fa-lock', 401: 'fa-user-lock', 500: 'fa-triangle-exclamation' }; %>
        <% var icon = (typeof codigo !== 'undefined' && iconMap[codigo]) ? iconMap[codigo] : 'fa-triangle-exclamation'; %>
        <i class="fa-solid <%= icon %> text-3xl text-primary-500"></i>
      </div>

      <h1 class="text-2xl sm:text-3xl font-bold text-gray-800 mb-3">
        <%= typeof titulo !== 'undefined' ? titulo : 'Algo deu errado' %>
      </h1>

      <p class="text-gray-500 mb-8 leading-relaxed">
        <%= typeof mensagem !== 'undefined' ? mensagem : 'Não conseguimos processar sua solicitação. Tente novamente mais tarde.' %>
      </p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
        <a href="javascript:history.back()" class="btn-ghost">
          <i class="fa-solid fa-arrow-left"></i> Voltar
        </a>
        <a href="/" class="btn-primary-inline">
          <i class="fa-solid fa-house"></i> Página Inicial
        </a>
      </div>
    </div>
  </div>
</main>

<%- include('footer') %>
