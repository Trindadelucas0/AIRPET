<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <title><%= typeof titulo !== 'undefined' ? titulo + ' | ' + (typeof appName !== 'undefined' ? appName : 'AIRPET') : (typeof appName !== 'undefined' ? appName : 'AIRPET') + ' — Proteja seu Pet' %></title>

  <meta name="theme-color" content="<%= typeof themeColor !== 'undefined' ? themeColor : '#ec5a1c' %>">
  <meta name="description" content="AIRPET — Rede social e protecao inteligente para seu pet via NFC">
  <meta name="mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="default">
  <meta name="apple-mobile-web-app-title" content="<%= typeof appName !== 'undefined' ? appName : 'AIRPET' %>">
  <meta name="application-name" content="<%= typeof appName !== 'undefined' ? appName : 'AIRPET' %>">
  <meta name="msapplication-TileColor" content="<%= typeof themeColor !== 'undefined' ? themeColor : '#ec5a1c' %>">
  <meta name="format-detection" content="telephone=no">
  <meta name="referrer" content="origin">

  <link rel="icon" type="image/png" href="<%= typeof pwaIcon192 !== 'undefined' ? pwaIcon192 : '/images/icons/icon-192.png' %>">
  <link rel="apple-touch-icon" href="<%= typeof pwaIcon192 !== 'undefined' ? pwaIcon192 : '/images/icons/icon-192.png' %>">
  <link rel="manifest" href="/manifest.json">

  <style>
    :root {
      --color-primary: <%= typeof primaryColor !== 'undefined' ? primaryColor : '#f26020' %>;
      --color-primary-hover: <%= typeof primaryHoverColor !== 'undefined' ? primaryHoverColor : '#ff7a3d' %>;
      --color-accent-glow: <%= typeof accentGlowColor !== 'undefined' ? accentGlowColor : 'rgba(242,96,32,0.12)' %>;
      --color-green: <%= typeof greenColor !== 'undefined' ? greenColor : '#22c55e' %>;
      --color-red: <%= typeof redColor !== 'undefined' ? redColor : '#ef4444' %>;
      --color-purple: <%= typeof purpleColor !== 'undefined' ? purpleColor : '#a78bfa' %>;
      --color-blue: <%= typeof blueColor !== 'undefined' ? blueColor : '#60a5fa' %>;
      --color-yellow: <%= typeof yellowColor !== 'undefined' ? yellowColor : '#facc15' %>;
    }
  </style>
  <link rel="stylesheet" href="/css/output.css">
  <link rel="stylesheet" href="/css/design-system.css">
  <link rel="stylesheet" href="/css/theme-override.css">
  <link rel="stylesheet" href="/css/airpet-modals.css">
  <!-- RequestCoordinator + SWR-like cache (client-side performance) -->
  <script src="/js/airpet/requestCoordinator.js"></script>
  <script src="/js/airpet/swrCache.js"></script>
  <script src="/js/airpet-comment-render.js"></script>
  <script src="/js/airpet-modal-lock.js"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;700;800&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
        integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA=="
        crossorigin="anonymous" referrerpolicy="no-referrer">

  <% if (typeof extraHead !== 'undefined') { %>
    <%- extraHead %>
  <% } %>

  <style>
    .font-display { font-family: 'Syne', sans-serif; letter-spacing: -0.01em; }
    .fade-out { animation: fadeOut 0.4s ease-out forwards; }
    @keyframes fadeOut { to { opacity: 0; transform: translateY(-8px); height: 0; margin: 0; padding: 0; overflow: hidden; } }
    @keyframes slideUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
    @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
    @keyframes scaleIn { from { opacity: 0; transform: scale(0.9); } to { opacity: 1; transform: scale(1); } }
    @keyframes heartBeat { 0% { transform: scale(1); } 25% { transform: scale(1.3); } 50% { transform: scale(0.95); } 100% { transform: scale(1); } }
    .animate-slideUp { animation: slideUp 0.5s ease-out both; }
    .animate-fadeIn { animation: fadeIn 0.4s ease-out both; }
    .animate-scaleIn { animation: scaleIn 0.3s ease-out both; }
    .animate-heart { animation: heartBeat 0.4s ease-out; }
    .safe-top { padding-top: env(safe-area-inset-top); }
    .safe-bottom { padding-bottom: env(safe-area-inset-bottom); }
    .glass { background: rgba(255,255,255,0.8); backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px); }
    .line-clamp-2 { display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
    .line-clamp-3 { display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }
    .scrollbar-hide::-webkit-scrollbar { display: none; }
    .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }
  </style>
</head>
<body class="min-h-screen flex flex-col antialiased airpet-app"
      data-logado="<%= (typeof usuario !== 'undefined' && usuario) ? 'true' : 'false' %>"
      data-verificar-permissoes="<%= (typeof verificarPermissoes !== 'undefined' && verificarPermissoes) ? 'true' : 'false' %>"
      data-vapid-key="<%= typeof vapidPublicKey !== 'undefined' ? vapidPublicKey : '' %>"
      data-usuario-id="<%= (typeof usuario !== 'undefined' && usuario) ? usuario.id : '' %>">

<%- include('nav') %>
