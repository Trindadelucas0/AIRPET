<section class="partner-card">
  <div class="flex items-center justify-between mb-3">
    <h2 class="font-bold">Pets vinculados</h2>
    <span class="text-xs text-[color:var(--text-dim)]"><%= (petsVinculadosDetalhados || []).length %> pet(s)</span>
  </div>

  <% if (!(petsVinculadosDetalhados || []).length) { %>
    <p class="text-sm text-[color:var(--text-dim)]">Nenhum pet vinculado no momento.</p>
  <% } else { %>
    <div class="space-y-3">
      <% (petsVinculadosDetalhados || []).forEach(function(pet) { %>
        <article class="partner-list-item">
          <div class="flex flex-col md:flex-row md:items-start gap-3">
            <img src="<%= pet.pet_foto || '/img/avatar-placeholder.svg' %>" alt="<%= pet.pet_nome %>" class="w-14 h-14 rounded-xl object-cover border border-[color:var(--border)]">
            <div class="flex-1">
              <div class="flex flex-wrap items-center gap-2">
                <h3 class="font-semibold"><%= pet.pet_nome %></h3>
                <span class="text-[10px] px-2 py-1 rounded-full bg-[color:var(--secondary)] text-[color:var(--text-dim)] uppercase tracking-wide">
                  <%= pet.tipo_vinculo || 'cliente' %>
                </span>
                <% if (pet.is_principal) { %>
                  <span class="text-[10px] px-2 py-1 rounded-full bg-[color:var(--accent)]/25 text-[color:var(--accent)] uppercase tracking-wide">Principal</span>
                <% } %>
              </div>
              <p class="text-xs text-[color:var(--text-dim)] mt-1">
                <%= pet.pet_tipo || '-' %> • <%= pet.pet_raca || '-' %> • <%= pet.pet_porte || '-' %> • Tutor: <strong><%= pet.tutor_nome || '-' %></strong>
              </p>
              <p class="text-xs text-[color:var(--text-dim)] mt-1">
                Contato: <%= pet.tutor_telefone || '-' %> • <%= pet.tutor_whatsapp || '-' %> • <%= pet.tutor_email || '-' %>
              </p>
            </div>
          </div>

          <details class="mt-3">
            <summary class="cursor-pointer text-xs font-semibold text-[color:var(--accent)]">Ver ficha completa do pet</summary>
            <div class="mt-2 grid lg:grid-cols-2 gap-3 text-xs">
              <div class="rounded-xl border border-[color:var(--border)] p-2">
                <p class="font-semibold mb-1">Resumo</p>
                <p>Sexo: <strong><%= pet.pet_sexo || '-' %></strong></p>
                <p>Peso: <strong><%= pet.pet_peso || '-' %></strong></p>
                <p>Comportamento: <strong><%= pet.descricao_emocional || '-' %></strong></p>
                <p>Alergias/medicações: <strong><%= pet.alergias_medicacoes || '-' %></strong></p>
                <p>Veterinário: <strong><%= pet.veterinario_nome || '-' %></strong> (<%= pet.veterinario_telefone || '-' %>)</p>
                <p>Observações: <strong><%= pet.observacoes || '-' %></strong></p>
              </div>
              <div class="rounded-xl border border-[color:var(--border)] p-2">
                <p class="font-semibold mb-1">Saúde</p>
                <p>Vacinas: <strong><%= (pet.vacinas || []).length %></strong></p>
                <p>Registros de saúde: <strong><%= (pet.registros_saude || []).length %></strong></p>
                <% if ((pet.vacinas || []).length) { %>
                  <p class="mt-1 text-[color:var(--text-dim)]">Última vacina: <%= pet.vacinas[0].nome_vacina %> em <%= new Date(pet.vacinas[0].data_aplicacao).toLocaleDateString('pt-BR') %></p>
                <% } %>
              </div>
              <div class="rounded-xl border border-[color:var(--border)] p-2 lg:col-span-2">
                <p class="font-semibold mb-1">Histórico de agendamentos</p>
                <% if (!(pet.historico_agendamentos || []).length) { %>
                  <p class="text-[color:var(--text-dim)]">Sem histórico ainda.</p>
                <% } else { %>
                  <div class="space-y-1">
                    <% (pet.historico_agendamentos || []).slice(0, 5).forEach(function(h) { %>
                      <p><%= new Date(h.data_agendada).toLocaleString('pt-BR') %> • <%= h.servico_nome || 'Serviço' %> • <strong><%= h.status %></strong></p>
                    <% }) %>
                  </div>
                <% } %>
              </div>
              <div class="rounded-xl border border-[color:var(--border)] p-2 lg:col-span-2">
                <p class="font-semibold mb-2">Documentos e anexos</p>
                <%- include('./pet-linked-documents', { documentos: pet.documentos || [] }) %>
              </div>
            </div>
          </details>
        </article>
      <% }) %>
    </div>
  <% } %>
</section>
