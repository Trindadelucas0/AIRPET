<% if (typeof flash !== 'undefined' && flash) { %>
  <%
    var tipos = {
      sucesso: {
        icon: 'fa-circle-check',
        titulo: 'Sucesso',
        toneClass: 'border-emerald-200 bg-white/95 text-slate-800',
        iconClass: 'text-emerald-500',
        role: 'status',
        live: 'polite'
      },
      success: {
        icon: 'fa-circle-check',
        titulo: 'Sucesso',
        toneClass: 'border-emerald-200 bg-white/95 text-slate-800',
        iconClass: 'text-emerald-500',
        role: 'status',
        live: 'polite'
      },
      erro: {
        icon: 'fa-circle-exclamation',
        titulo: 'Erro',
        toneClass: 'border-rose-200 bg-white/95 text-slate-800',
        iconClass: 'text-rose-500',
        role: 'alert',
        live: 'assertive'
      },
      error: {
        icon: 'fa-circle-exclamation',
        titulo: 'Erro',
        toneClass: 'border-rose-200 bg-white/95 text-slate-800',
        iconClass: 'text-rose-500',
        role: 'alert',
        live: 'assertive'
      },
      info: {
        icon: 'fa-circle-info',
        titulo: 'Informacao',
        toneClass: 'border-sky-200 bg-white/95 text-slate-800',
        iconClass: 'text-sky-500',
        role: 'status',
        live: 'polite'
      },
      aviso: {
        icon: 'fa-triangle-exclamation',
        titulo: 'Aviso',
        toneClass: 'border-amber-200 bg-white/95 text-slate-800',
        iconClass: 'text-amber-500',
        role: 'alert',
        live: 'assertive'
      },
    };

    var msgs = [];
    if (flash.success)  msgs.push({ tipo: 'success',  mensagem: flash.success });
    if (flash.sucesso)  msgs.push({ tipo: 'sucesso',  mensagem: flash.sucesso });
    if (flash.error)    msgs.push({ tipo: 'error',    mensagem: flash.error });
    if (flash.erro)     msgs.push({ tipo: 'erro',     mensagem: flash.erro });
    if (flash.info)     msgs.push({ tipo: 'info',     mensagem: flash.info });
    if (flash.tipo && flash.mensagem) msgs.push({ tipo: flash.tipo, mensagem: flash.mensagem });
  %>

  <% if (msgs.length > 0) { %>
    <div id="flashContainer"
         data-flash-autoclose-ms="8000"
         class="fixed z-[90] top-3 left-3 right-3 sm:left-auto sm:right-4 sm:w-[26rem] space-y-2 pointer-events-none"
         style="top: calc(env(safe-area-inset-top, 0px) + 0.75rem);">
      <% msgs.forEach(function(msg) { %>
        <% var s = tipos[msg.tipo] || tipos.info; %>
        <div class="flash-msg pointer-events-auto flex items-start gap-3 rounded-2xl border shadow-lg ring-1 ring-black/5 px-4 py-3 backdrop-blur-sm animate-slideUp <%= s.toneClass %>"
             role="<%= s.role %>"
             aria-live="<%= s.live %>"
             aria-atomic="true">
          <i class="fa-solid <%= s.icon %> mt-0.5 text-base flex-shrink-0 <%= s.iconClass %>"></i>
          <div class="min-w-0 flex-1">
            <p class="text-[11px] uppercase tracking-wide font-semibold text-slate-500"><%= s.titulo %></p>
            <p class="text-sm leading-relaxed font-medium break-words"><%= msg.mensagem %></p>
          </div>
          <button type="button"
                  data-flash-close
                  aria-label="Fechar mensagem"
                  class="ml-2 mt-0.5 text-slate-400 hover:text-slate-700 transition-colors">
            <i class="fa-solid fa-xmark"></i>
          </button>
        </div>
      <% }); %>
    </div>

    <script>
      <% var perfilOk = msgs.some(function (m) { return m.tipo === 'sucesso' && String(m.mensagem || '').indexOf('Perfil atualizado') !== -1; }); %>
      <% if (perfilOk) { %>
      (function () {
        var c = window.AIRPET_SWR_CACHE;
        if (c && typeof c.invalidateSyncV1 === 'function') c.invalidateSyncV1();
      })();
      <% } %>
    </script>
  <% } %>
<% } %>
