<% if (typeof flash !== 'undefined' && flash) { %>
  <%
    var tipos = {
      sucesso:  { icon: 'fa-circle-check', color: 'var(--green)' },
      success:  { icon: 'fa-circle-check', color: 'var(--green)' },
      erro:     { icon: 'fa-circle-xmark', color: 'var(--red)' },
      error:    { icon: 'fa-circle-xmark', color: 'var(--red)' },
      info:     { icon: 'fa-circle-info', color: 'var(--blue)' },
      aviso:    { icon: 'fa-triangle-exclamation', color: 'var(--yellow)' },
    };

    var msgs = [];
    if (flash.success)  msgs.push({ tipo: 'success',  mensagem: flash.success });
    if (flash.sucesso)  msgs.push({ tipo: 'sucesso',  mensagem: flash.sucesso });
    if (flash.error)    msgs.push({ tipo: 'error',    mensagem: flash.error });
    if (flash.erro)     msgs.push({ tipo: 'erro',     mensagem: flash.erro });
    if (flash.info)     msgs.push({ tipo: 'info',     mensagem: flash.info });
    if (flash.tipo && flash.mensagem) msgs.push({ tipo: flash.tipo, mensagem: flash.mensagem });
  %>

  <% if (msgs.length > 0) { %>
    <div class="max-w-5xl mx-auto px-4 sm:px-6 pt-3 space-y-2" id="flashContainer">
      <% msgs.forEach(function(msg) { %>
        <% var s = tipos[msg.tipo] || tipos.info; %>
        <div class="flash-msg flex items-center gap-3 px-4 py-3 rounded-2xl border-l-4 shadow-sm animate-slideUp"
             style="background: var(--ink-2); border-color: <%= s.color %>; color: var(--text);"
             role="alert">
          <i class="fa-solid <%= s.icon %> text-lg flex-shrink-0" style="color: <%= s.color %>;"></i>
          <span class="text-sm font-medium flex-1"><%= msg.mensagem %></span>
          <button type="button" onclick="this.parentElement.classList.add('fade-out'); setTimeout(function(){ this.parentElement.remove(); }.bind(this), 400);"
                  class="ml-auto transition-colors" style="color: var(--text-dim);">
            <i class="fa-solid fa-xmark"></i>
          </button>
        </div>
      <% }); %>
    </div>

    <script>
      setTimeout(function () {
        var msgs = document.querySelectorAll('.flash-msg');
        msgs.forEach(function (el) {
          el.classList.add('fade-out');
          setTimeout(function () { el.remove(); }, 400);
        });
      }, 5000);
      <% var perfilOk = msgs.some(function (m) { return m.tipo === 'sucesso' && String(m.mensagem || '').indexOf('Perfil atualizado') !== -1; }); %>
      <% if (perfilOk) { %>
      (function () {
        var c = window.AIRPET_SWR_CACHE;
        if (c && typeof c.invalidateSyncV1 === 'function') c.invalidateSyncV1();
      })();
      <% } %>
    </script>
  <% } %>
<% } %>
