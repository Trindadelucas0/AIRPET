<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof titulo !== 'undefined' ? titulo + ' | AIRPET Admin' : 'Painel de Controle | AIRPET Admin' %></title>
  <link rel="stylesheet" href="/css/output.css">
  <link rel="stylesheet" href="/css/design-system.css">
  <link rel="stylesheet" href="/css/theme-override.css">
  <link rel="stylesheet" href="/css/admin-modern.css">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Rubik+Doodle+Shadow&family=Syne:wght@700;800&family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" crossorigin="anonymous" referrerpolicy="no-referrer">
</head>
<body class="admin-modern-shell admin-shell app-shell min-h-screen antialiased text-gray-800">
<% const p = typeof currentPath !== 'undefined' ? currentPath : ''; %>
<div class="admin-modern-layout">
  <aside class="admin-modern-sidebar" id="adminSidebar">
    <div class="admin-modern-brand">
      <a href="<%= adminPath %>" class="admin-brand-link">
        <span class="admin-brand-icon"><i class="fa-solid fa-shield-dog"></i></span>
        <span>
          <span class="admin-brand-name">AIRPET</span>
          <span class="admin-brand-tag">Admin Console</span>
        </span>
      </a>
    </div>

    <nav class="admin-modern-nav">
      <div class="admin-nav-section">Principal</div>
      <a href="<%= adminPath %>" class="admin-nav-item <%= (p === '' || p === '/') ? 'active' : '' %>">
        <i class="fa-solid fa-chart-line"></i> Dashboard
      </a>
      <a href="<%= adminPath %>/analytics" class="admin-nav-item <%= p === '/analytics' ? 'active' : '' %>">
        <i class="fa-solid fa-chart-pie"></i> Analytics
      </a>
      <a href="<%= adminPath %>/pets-perdidos" class="admin-nav-item <%= p === '/pets-perdidos' ? 'active' : '' %>">
        <i class="fa-solid fa-paw"></i> Pets Perdidos
      </a>
      <a href="<%= adminPath %>/tags" class="admin-nav-item <%= p === '/tags' ? 'active' : '' %>">
        <i class="fa-solid fa-tag"></i> Tags NFC
      </a>

      <div class="admin-nav-section">Operacao</div>
      <a href="<%= adminPath %>/pedidos" class="admin-nav-item <%= p === '/pedidos' || p === '/tags-commerce' ? 'active' : '' %>">
        <i class="fa-solid fa-cart-shopping"></i> Pedidos
      </a>
      <a href="<%= adminPath %>/usuarios" class="admin-nav-item <%= p === '/usuarios' ? 'active' : '' %>">
        <i class="fa-solid fa-users"></i> Usuarios
      </a>
      <a href="<%= adminPath %>/pets" class="admin-nav-item <%= (p === '/pets' || (p && String(p).indexOf('/pets/') === 0)) ? 'active' : '' %>">
        <i class="fa-solid fa-dog"></i> Pets
      </a>
      <a href="<%= adminPath %>/petshops/solicitacoes" class="admin-nav-item <%= p === '/petshops/solicitacoes' ? 'active' : '' %>">
        <i class="fa-solid fa-store"></i> Parceiros
      </a>
      <a href="<%= adminPath %>/monitoramento" class="admin-nav-item <%= p === '/monitoramento' ? 'active' : '' %>">
        <i class="fa-solid fa-gauge-high"></i> Monitoramento
      </a>
      <a href="<%= adminPath %>/configuracoes" class="admin-nav-item <%= p === '/configuracoes' ? 'active' : '' %>">
        <i class="fa-solid fa-gear"></i> Configuracoes
      </a>
    </nav>

    <div class="admin-modern-sidebar-footer">
      <a href="<%= adminPath %>/logout" class="admin-nav-item">
        <i class="fa-solid fa-right-from-bracket"></i> Sair
      </a>
    </div>
  </aside>

  <section class="admin-modern-main">
    <header class="admin-modern-topbar">
      <div class="admin-topbar-left">
        <button type="button" class="admin-mobile-menu" onclick="document.getElementById('adminSidebar').classList.toggle('open')">
          <i class="fa-solid fa-bars"></i>
        </button>
        <span class="admin-breadcrumb">
          <%= typeof titulo !== 'undefined' ? titulo : 'Painel administrativo' %>
        </span>
      </div>
      <a href="<%= adminPath %>/logout" class="admin-topbar-logout"><i class="fa-solid fa-right-from-bracket"></i> Sair</a>
    </header>
    <%- include('./flash') %>
