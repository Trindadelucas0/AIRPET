<% var isLogado = typeof usuario !== 'undefined' && usuario; %>

  <footer class="mt-auto safe-bottom <%= isLogado ? 'pb-20 md:pb-0' : '' %>" style="background: var(--ink-2); border-top: 1px solid var(--border);">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 py-5">
      <div class="flex flex-col sm:flex-row items-center justify-between gap-3">
        <div class="flex items-center gap-2 text-xs" style="color: var(--text-dim);">
          <i class="fa-solid fa-paw text-primary-500"></i>
          <span>&copy; <%= new Date().getFullYear() %> <strong class="font-brand text-[13px] leading-none" style="color: var(--text);">AIRPET</strong></span>
        </div>
        <div class="flex items-center gap-4 text-xs" style="color: var(--text-dim);">
          <a href="/termos" class="hover:text-primary-500 transition-colors">Termos</a>
          <a href="/privacidade" class="hover:text-primary-500 transition-colors">Privacidade</a>
        </div>
      </div>
    </div>
  </footer>

  <script src="/js/app.js"></script>
  <script src="/js/pwa.js"></script>
  <script src="/js/permissions.js?v=5"></script>

  <% if (isLogado) { %>
  <script src="/socket.io/socket.io.js"></script>
  <script>
  (function () {
    'use strict';

    var usuarioId = <%= usuario && usuario.id ? JSON.stringify(usuario.id) : 'null' %>;

    function atualizarBadges(total) {
      document.querySelectorAll('[data-notif-badge]').forEach(function (el) {
        if (total > 0) {
          el.textContent = total > 9 ? '9+' : total;
          el.classList.remove('hidden');
        } else {
          el.classList.add('hidden');
        }
      });
    }

    var lastBadgeRefreshAt = 0;
    function fetchCount(force) {
      if (!usuarioId && usuarioId !== 0) return;

      var now = Date.now();
      if (!force && now - lastBadgeRefreshAt < 10000) return; // evita spam mesmo sem socket
      lastBadgeRefreshAt = now;

      if (typeof swrFetchGet === 'function') {
        var key = 'notifCount:' + usuarioId;
        var staleTimeMs = force ? 0 : 120000; // 2 min
        var cacheTimeMs = 1800000; // 30 min

        swrFetchGet({
          key: key,
          url: '/notificacoes/api/count',
          priority: window.AIRPET_REQ_COORDINATOR && window.AIRPET_REQ_COORDINATOR.PRIORITY
            ? window.AIRPET_REQ_COORDINATOR.PRIORITY.MEDIUM
            : 'MEDIUM',
          staleTimeMs: staleTimeMs,
          cacheTimeMs: cacheTimeMs,
          group: 'notifBadge',
          onUpdate: function (data) {
            if (!data) return;
            atualizarBadges(data.total || 0);
          }
        }).then(function (res) {
          var data = res && res.data ? res.data : res;
          atualizarBadges((data && data.total) ? data.total : 0);
        }).catch(function () {});

        return;
      }

      // fallback (caso SWR-like não carregou)
      fetch('/notificacoes/api/count', { headers: { 'Accept': 'application/json' }, credentials: 'same-origin' })
        .then(function (r) { return r.json(); })
        .then(function (data) { atualizarBadges(data.total); })
        .catch(function () {});
    }

    var socketOk = false;
    try {
      if (typeof io !== 'undefined') {
        var notifSocket = io('/notificacoes', { transports: ['websocket', 'polling'] });
        notifSocket.on('connect', function () { socketOk = true; });
        notifSocket.on('nova_notificacao', function (data) {
          fetchCount(true);
          if ('Notification' in window && Notification.permission === 'granted' && document.hidden) {
            try {
              new Notification(data.tipo === 'alerta' ? 'Pet Perdido!' : 'AIRPET', {
                body: data.mensagem, icon: '/images/icons/icon-192.svg', tag: 'airpet-' + (data.id || Date.now()),
              });
            } catch (e) {}
          }
        });
        notifSocket.on('disconnect', function () { socketOk = false; });
      }
    } catch (e) {}

    setInterval(function () { if (!socketOk) fetchCount(false); }, 300000); // 5 min
    fetchCount(false);
  })();
  </script>
  <% } %>

  <%# Ver comentario em header.ejs sobre extraScripts e XSS. %>
  <% if (typeof extraScripts !== 'undefined') { %>
    <%- extraScripts %>
  <% } %>
</body>
</html>
