<% locals.titulo = titulo || 'Galeria' %>
<% var meusPets = typeof meusPets !== 'undefined' ? meusPets : []; %>
<% var galeria = typeof galeria !== 'undefined' ? galeria : []; %>
<%- include('../partials/header') %>
<%- include('../partials/flash') %>

<main class="flex-1 pb-24 md:pb-6">
  <%- include('../partials/settings-route-loader') %>
  <%- include('../partials/settings-subpage-header') %>

  <div class="settings-layout">
    <div class="section-card anim-3">
      <div class="section-card-header">
        <div>
          <div class="section-card-title">
            <div class="section-card-title-icon" style="background:rgba(167,139,250,0.1);border-color:rgba(167,139,250,0.15);color:#a78bfa;"><i class="fa-solid fa-photo-film"></i></div>
            Galeria dos pets
          </div>
          <p class="section-card-subtitle">Fotos públicas organizadas por pet. Selecione o pet e adicione ou remova imagens.</p>
        </div>
      </div>
      <div class="section-card-body">
        <% if (meusPets && meusPets.length > 0) { %>
        <div class="field-group" style="margin-bottom:16px;">
          <label class="field-label-soft" for="galeriaPetSelect">Pet</label>
          <div class="settings-select-wrap">
            <select id="galeriaPetSelect" class="field-input">
              <% meusPets.forEach(function(p) { %><option value="<%= p.id %>"><%= p.nome %></option><% }); %>
            </select>
          </div>
        </div>
        <% } else { %>
        <p class="galeria-empty-msg" style="margin-bottom:16px;">Cadastre um pet para adicionar fotos à galeria.</p>
        <% } %>
        <div id="galeriaLoading" class="galeria-skeleton-grid hidden" aria-hidden="true">
          <div class="galeria-skeleton-cell"></div>
          <div class="galeria-skeleton-cell"></div>
          <div class="galeria-skeleton-cell"></div>
          <div class="galeria-skeleton-cell"></div>
        </div>
        <div id="galeriaPorPetContainer" class="">
          <% if (!galeria || galeria.length === 0) { %>
            <p class="galeria-empty-msg">Nenhuma foto ainda. Escolha um pet acima e toque em <strong>Adicionar foto</strong>.</p>
          <% } else { %>
            <% galeria.forEach(function(item) { %>
              <div class="galeria-pet-block" data-pet-id="<%= item.pet_id %>">
                <div class="galeria-block-title"><%= item.pet_nome || 'Pet' %></div>
                <div class="galeria-grid">
                  <% (item.fotos || []).forEach(function(f) { %>
                    <div class="galeria-thumb-wrap galeria-item-wrap">
                      <img src="<%= f.foto %>" alt="">
                      <button type="button" class="galeria-thumb-remove btn-remover-foto-galeria" data-id="<%= f.id %>" aria-label="Remover foto">
                        <i class="fa-solid fa-xmark"></i>
                      </button>
                    </div>
                  <% }); %>
                </div>
              </div>
            <% }); %>
          <% } %>
        </div>
        <% if (meusPets && meusPets.length > 0) { %>
        <div class="btn-row-actions" style="margin-top:0;">
          <button type="button" id="btnAdicionarFotoGaleria" class="btn-ghost">
            <i class="fa-solid fa-plus"></i>Adicionar foto
          </button>
        </div>
        <input type="file" id="galeriaFileInput" accept="image/jpeg,image/png,image/gif,image/webp" class="hidden">
        <% } %>
      </div>
    </div>
  </div>
</main>

<script src="/js/perfil-settings-pages.js"></script>
<%- include('../partials/footer') %>
