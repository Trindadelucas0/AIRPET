  var bounds = [];
  petshops.forEach(function(p) {
    if (!p.latitude||!p.longitude) return;
    L.marker([parseFloat(p.latitude),parseFloat(p.longitude)],{icon:orangeIcon}).addTo(map)
      .bindPopup('<strong>'+(p.nome||'Petshop')+'</strong><br>'+(p.endereco?'<small>'+p.endereco+'</small><br>':'')+'<a href="/petshops/'+(p.slug||p.id)+'">Ver perfil →</a>');
    bounds.push([parseFloat(p.latitude),parseFloat(p.longitude)]);
  });
  if (bounds.length) map.fitBounds(bounds,{padding:[40,40]});
