<% locals.titulo = 'Mapa' %>
<% locals.extraHead = `
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="">
<link rel="stylesheet" href="https://unpkg.com/leaflet.markercluster@1.5.3/dist/MarkerCluster.css">
<link rel="stylesheet" href="https://unpkg.com/leaflet.markercluster@1.5.3/dist/MarkerCluster.Default.css">
<style>
  #mapaFull { position: absolute; inset: 0; z-index: 0; }
  .mapa-wrapper { position: relative; flex: 1; display: flex; flex-direction: column; }
  .layer-btn { transition: background-color .15s ease, color .15s ease, border-color .15s ease, transform .15s ease; }
  .layer-btn.active { background-color: var(--color-primary); color: white; border-color: var(--color-primary); box-shadow: 0 10px 25px rgba(242,96,32,0.18); }
  .layer-btn:not(.active):hover { color: var(--color-primary); border-color: color-mix(in srgb, var(--color-primary) 35%, transparent); background: color-mix(in srgb, var(--color-primary) 10%, transparent); transform: translateY(-1px); }
  .painel-localizar { max-height: 20rem; transition: max-height 0.25s ease-out, opacity 0.2s; }
  .painel-localizar.collapsed { max-height: 0; overflow: hidden; opacity: 0; pointer-events: none; }
  @media (min-width: 768px) { .painel-localizar.collapsed { max-height: 20rem; overflow: visible; opacity: 1; pointer-events: auto; } }

  /* ── Bottom Sheet ── */
  .mapa-bottom-sheet {
    position: fixed;
    bottom: 0; left: 0; right: 0;
    z-index: 2000;
    background: transparent;
    display: flex;
    align-items: flex-end;
    justify-content: center;
    pointer-events: none;
  }
  .mapa-bottom-sheet.active { pointer-events: auto; }
  .mapa-bottom-sheet__backdrop {
    position: fixed;
    inset: 0;
    background: rgba(15,23,42,0.45);
    backdrop-filter: blur(2px);
    opacity: 0;
    transition: opacity 0.25s ease;
    z-index: 1;
  }
  .mapa-bottom-sheet.active .mapa-bottom-sheet__backdrop { opacity: 1; }
  .mapa-bottom-sheet__panel {
    position: relative;
    z-index: 2;
    width: 100%;
    max-width: 520px;
    background: #fff;
    border-radius: 1.25rem 1.25rem 0 0;
    box-shadow: 0 -12px 40px rgba(15,23,42,.18);
    padding: 1rem 1.25rem calc(1.25rem + env(safe-area-inset-bottom));
    transform: translateY(100%);
    transition: transform 0.28s cubic-bezier(.32,0,.67,0);
    max-height: 72dvh;
    overflow-y: auto;
  }
  .mapa-bottom-sheet.active .mapa-bottom-sheet__panel {
    transform: translateY(0);
  }
  @media (min-width: 640px) {
    .mapa-bottom-sheet__panel {
      border-radius: 1.25rem;
      margin-bottom: 1.5rem;
    }
  }
  .mapa-bs-handle {
    width: 40px; height: 4px; border-radius: 999px;
    background: #e5e7eb; margin: 0 auto 1rem;
  }
  .mapa-bs-close {
    position: absolute; top: .85rem; right: 1rem;
    width: 2rem; height: 2rem;
    border: 1px solid #e5e7eb; border-radius: 50%;
    background: #fff; color: #6b7280;
    display: flex; align-items: center; justify-content: center;
    cursor: pointer; font-size: 13px;
    transition: background .15s, color .15s;
  }
  .mapa-bs-close:hover { background: #f3f4f6; color: #111827; }

  /* ── Pin de pet com foto ── */
  .pet-photo-pin { background: transparent !important; border: none !important; }
  @keyframes petPinRing {
    0%, 100% { box-shadow: 0 0 0 0 rgba(220,38,38,0.4); }
    50%       { box-shadow: 0 0 0 7px rgba(220,38,38,0); }
  }
</style>
` %>
<%- include('../partials/header') %>

<div class="mapa-wrapper">

  <div class="absolute top-3 left-3 right-3 z-[1000] flex flex-col gap-2">
    <div class="bg-white/95 backdrop-blur-sm rounded-2xl shadow-lg p-2 flex items-center gap-2 overflow-x-auto">
      <%- include('../partials/map-layer-button', { layer: 'petshops', icon: 'fa-solid fa-store', label: 'Petshops', isActive: true }) %>
      <%- include('../partials/map-layer-button', { layer: 'perdidos', icon: 'fa-solid fa-triangle-exclamation', label: 'Perdidos', isActive: true }) %>
      <%- include('../partials/map-layer-button', { layer: 'avistamentos', icon: 'fa-solid fa-eye', label: 'Avistamentos', isActive: true }) %>
      <%- include('../partials/map-layer-button', { layer: 'pontos', icon: 'fa-solid fa-map-pin', label: 'Pontos', isActive: false }) %>
      <%- include('../partials/map-layer-button', { layer: 'pet_scans', icon: 'fa-solid fa-paw', label: 'Pets no mapa', isActive: true }) %>
      <% if (locals.usuario) { %>
        <%- include('../partials/map-layer-button', { layer: 'social', icon: 'fa-solid fa-heart', label: 'Seguindo', isActive: false }) %>
      <% } %>
      <button type="button" id="btnToggleLocalizar" class="ml-auto flex items-center gap-1.5 px-3 py-2 rounded-xl text-xs font-semibold border border-gray-200 whitespace-nowrap transition-all text-gray-600 hover:bg-gray-50 md:hidden">
        <i class="fa-solid fa-magnifying-glass-location"></i> Localizar regiao
      </button>
    </div>
    <div id="painelLocalizar" class="painel-localizar bg-white/95 backdrop-blur-sm rounded-2xl shadow-lg p-3">
      <p class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-2">Localizar no mapa</p>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-2 items-end">
        <div>
          <label for="mapaEstado" class="block text-xs font-medium text-gray-600 mb-0.5">Estado</label>
          <select id="mapaEstado" class="w-full rounded-lg border border-gray-200 px-3 py-2 text-sm focus:border-primary-500 focus:ring-1 focus:ring-primary-500">
            <option value="">Selecione o estado</option>
          </select>
        </div>
        <div>
          <label for="mapaCidade" class="block text-xs font-medium text-gray-600 mb-0.5">Cidade</label>
          <select id="mapaCidade" class="w-full rounded-lg border border-gray-200 px-3 py-2 text-sm focus:border-primary-500 focus:ring-1 focus:ring-primary-500 disabled:bg-gray-100" disabled>
            <option value="">Selecione a cidade</option>
          </select>
        </div>
        <div>
          <label for="mapaBairro" class="block text-xs font-medium text-gray-600 mb-0.5">Bairro (opcional)</label>
          <input type="text" id="mapaBairro" placeholder="Ex.: Centro" class="w-full rounded-lg border border-gray-200 px-3 py-2 text-sm focus:border-primary-500 focus:ring-1 focus:ring-primary-500">
        </div>
        <div class="flex gap-2">
          <button type="button" id="btnMostrarNoMapa" class="flex-1 btn-primary-inline disabled:opacity-50 disabled:cursor-not-allowed" disabled>
            <i class="fa-solid fa-map-pin"></i> <span id="btnMostrarNoMapaText">Mostrar no mapa</span>
          </button>
        </div>
      </div>
      <p id="mapaLocalizarMsg" class="text-xs text-gray-500 mt-1.5 hidden"></p>
    </div>
  </div>

  <div id="mapaFull"></div>

  <button type="button" id="btnMinhaLocalizacao"
          class="absolute bottom-6 right-4 z-[1000] w-12 h-12 bg-white rounded-full shadow-lg flex items-center justify-center text-primary-500 hover:bg-gray-50 active:scale-95 transition-all">
    <i class="fa-solid fa-location-crosshairs text-lg"></i>
  </button>

</div>

<!-- Bottom Sheet do Mapa -->
<div id="mapaBottomSheet" class="mapa-bottom-sheet hidden" role="dialog" aria-modal="true" aria-label="Detalhes do local">
  <div class="mapa-bottom-sheet__backdrop"></div>
  <div class="mapa-bottom-sheet__panel">
    <div class="mapa-bs-handle"></div>
    <button type="button" id="mapaBottomSheetClose" class="mapa-bs-close" aria-label="Fechar">
      <i class="fa-solid fa-times"></i>
    </button>
    <div id="mapaBottomSheetContent"></div>
  </div>
</div>

<% locals.extraScripts = `
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
<script src="https://unpkg.com/leaflet.markercluster@1.5.3/dist/leaflet.markercluster.js"></script>
<script src="/js/mapa.js"></script>
` %>

<%- include('../partials/footer') %>
