<% locals.titulo = 'Notificações' %>
<%
  var naoLidas = 0;
  if (typeof notificacoes !== 'undefined' && notificacoes.length > 0) {
    notificacoes.forEach(function(n) { if (!n.lida) naoLidas++; });
  }

  var currentTab = typeof tab !== 'undefined' ? tab : 'todas';
  var pets = typeof pets !== 'undefined' ? pets : [];
  var petFiltro = typeof petFiltro !== 'undefined' ? petFiltro : null;
  var temFiltroPet = pets.length > 1;
  function urlNotif(t, p) {
    var base = '/notificacoes?tab=' + (t || currentTab);
    if (p !== undefined && p !== null && p !== '') base += '&pet=' + p;
    return base;
  }

  var tipoConfig = {
    curtida:    { icon: 'fa-heart',              iconColor: 'text-red-500',     bg: 'bg-red-50' },
    comentario: { icon: 'fa-comment',            iconColor: 'text-blue-500',    bg: 'bg-blue-50' },
    repost:     { icon: 'fa-retweet',            iconColor: 'text-emerald-500', bg: 'bg-emerald-50' },
    seguidor:   { icon: 'fa-user-plus',          iconColor: 'text-primary-500', bg: 'bg-primary-50' },
    mencao:     { icon: 'fa-at',                 iconColor: 'text-indigo-500',  bg: 'bg-indigo-50' },
    alerta:     { icon: 'fa-triangle-exclamation',iconColor: 'text-red-500',    bg: 'bg-red-50' },
    scan:       { icon: 'fa-nfc',                iconColor: 'text-blue-500',    bg: 'bg-blue-50' },
    sistema:    { icon: 'fa-bell',               iconColor: 'text-gray-500',    bg: 'bg-gray-50' },
    chat:       { icon: 'fa-comment-dots',       iconColor: 'text-green-500',   bg: 'bg-green-50' },
    encontrado: { icon: 'fa-location-dot',       iconColor: 'text-emerald-500', bg: 'bg-emerald-50' }
  };
  var tipoDefault = { icon: 'fa-bell', iconColor: 'text-gray-400', bg: 'bg-gray-50' };

  function agruparPorData(lista) {
    var hoje = new Date();
    hoje.setHours(0, 0, 0, 0);
    var ontem = new Date(hoje); ontem.setDate(ontem.getDate() - 1);
    var semana = new Date(hoje); semana.setDate(semana.getDate() - 7);

    var grupos = { hoje: [], ontem: [], semana: [], anteriores: [] };
    lista.forEach(function(n) {
      var d = new Date(n.data_criacao || n.data);
      d.setHours(0, 0, 0, 0);
      if (d.getTime() >= hoje.getTime()) grupos.hoje.push(n);
      else if (d.getTime() >= ontem.getTime()) grupos.ontem.push(n);
      else if (d.getTime() >= semana.getTime()) grupos.semana.push(n);
      else grupos.anteriores.push(n);
    });
    return grupos;
  }

  var grupos = (typeof notificacoes !== 'undefined' && notificacoes.length > 0)
    ? agruparPorData(notificacoes)
    : { hoje: [], ontem: [], semana: [], anteriores: [] };

  var secoes = [
    { chave: 'hoje', label: 'Hoje', items: grupos.hoje },
    { chave: 'ontem', label: 'Ontem', items: grupos.ontem },
    { chave: 'semana', label: 'Esta semana', items: grupos.semana },
    { chave: 'anteriores', label: 'Anteriores', items: grupos.anteriores }
  ];
%>
<% locals.extraHead = `
<style>
  @keyframes slideUp {
    from { opacity: 0; transform: translateY(16px); }
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes fadeOut {
    to { opacity: 0; transform: translateY(-8px); height: 0; margin: 0; padding: 0; overflow: hidden; }
  }
  @keyframes pulse-dot {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.6; transform: scale(0.8); }
  }
  .notif-card { animation: slideUp 0.4s ease-out both; }
  .notif-card:nth-child(1) { animation-delay: 0.03s; }
  .notif-card:nth-child(2) { animation-delay: 0.06s; }
  .notif-card:nth-child(3) { animation-delay: 0.09s; }
  .notif-card:nth-child(4) { animation-delay: 0.12s; }
  .notif-card:nth-child(5) { animation-delay: 0.15s; }
  .notif-read-out {
    animation: fadeOut 0.4s ease-out forwards;
  }
  .dot-unread {
    animation: pulse-dot 2s ease-in-out infinite;
  }
  .tab-notif { position:relative; flex:1; text-align:center; padding:12px 0; font-size:14px; font-weight:600; color:#9ca3af; transition:color .2s; cursor:pointer; }
  .tab-notif.active { color:#111827; }
  .tab-notif:hover { color:#6b7280; }
  .tab-notif-indicator { position:absolute; bottom:0; height:3px; background:linear-gradient(90deg,#ec5a1c,#f17a42); border-radius:3px 3px 0 0; transition:left .3s ease,width .3s ease; }
</style>
` %>
<%- include('../partials/header') %>
<%- include('../partials/flash') %>

<main class="flex-1 pb-24 md:pb-0">
  <div class="max-w-2xl mx-auto px-4 sm:px-6 py-6">

    <!-- Header -->
    <div class="flex items-center justify-between mb-2 animate-slideUp">
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 rounded-2xl bg-gradient-to-br from-primary-500 to-primary-600 flex items-center justify-center shadow-lg shadow-primary-500/20">
          <i class="fa-solid fa-bell text-white text-sm"></i>
        </div>
        <div>
          <h1 class="text-2xl font-extrabold text-gray-900 tracking-tight">Notificações</h1>
          <% if (naoLidas > 0) { %>
            <p class="text-xs text-gray-500 mt-0.5"><%= naoLidas %> não lida<%= naoLidas > 1 ? 's' : '' %></p>
          <% } %>
        </div>
      </div>
      <div class="flex items-center gap-2">
        <% if (naoLidas > 0) { %>
          <button type="button" id="btnMarcarTodasLidas"
                  class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-xl text-xs font-semibold text-primary-500 hover:bg-primary-50 transition-colors">
            <i class="fa-solid fa-check-double text-[10px]"></i> Marcar todas
          </button>
          <span class="inline-flex items-center justify-center min-w-[28px] h-7 px-2 rounded-full bg-red-500 text-white text-xs font-bold shadow-sm shadow-red-500/20">
            <%= naoLidas %>
          </span>
        <% } %>
      </div>
    </div>

    <!-- Tabs -->
    <div class="sticky top-14 z-40 bg-white/90 backdrop-blur-xl border-b border-gray-100 rounded-t-xl mb-4">
      <div class="flex relative">
        <a href="<%= urlNotif('todas', petFiltro) %>"
           class="tab-notif <%= currentTab === 'todas' ? 'active' : '' %>"
           data-tab="todas">
          Todas
        </a>
        <a href="<%= urlNotif('mencoes', petFiltro) %>"
           class="tab-notif <%= currentTab === 'mencoes' ? 'active' : '' %>"
           data-tab="mencoes">
          Menções
        </a>
        <div class="tab-notif-indicator"
             style="left:<%= currentTab === 'mencoes' ? '50%' : '0' %>;width:50%"></div>
      </div>
      <% if (temFiltroPet) { %>
      <div class="flex flex-wrap gap-2 px-2 py-3 border-t border-gray-100">
        <span class="text-xs font-semibold text-gray-500 self-center">Ver por pet:</span>
        <a href="<%= urlNotif(currentTab, '') %>"
           class="px-3 py-1.5 rounded-full text-xs font-semibold transition-colors <%= !petFiltro ? 'bg-primary-500 text-white' : 'bg-gray-100 text-gray-600 hover:bg-gray-200' %>">
          Todas
        </a>
        <% pets.forEach(function(pet) { %>
        <a href="<%= urlNotif(currentTab, pet.id) %>"
           class="px-3 py-1.5 rounded-full text-xs font-semibold transition-colors <%= petFiltro === pet.id ? 'bg-primary-500 text-white' : 'bg-gray-100 text-gray-600 hover:bg-gray-200' %>">
          <%= pet.nome %>
        </a>
        <% }); %>
      </div>
      <% } %>
    </div>

    <% if (typeof notificacoes !== 'undefined' && notificacoes.length > 0) { %>

      <div id="listaNotificacoes" class="space-y-6">
        <% secoes.forEach(function(secao) { %>
          <% if (secao.items.length > 0) { %>

            <div>
              <h2 class="text-xs font-bold uppercase tracking-widest text-gray-400 mb-3 px-1"><%= secao.label %></h2>
              <div class="space-y-1.5">
                <% secao.items.forEach(function(n) { %>
                  <% var cfg = tipoConfig[n.tipo] || tipoDefault; %>
                  <% var isAlerta = n.tipo === 'alerta' && n.pet_id; %>
                  <div class="notif-card relative group" data-notif-id="<%= n.id %>">
                    <a href="<%= n.link || '#' %>"
                       class="notif-link flex items-start gap-3 p-3.5 rounded-2xl transition-all duration-200
                         <%= !n.lida ? 'bg-primary-50/40 hover:bg-primary-50/70' : 'bg-white hover:bg-gray-50' %>
                         border <%= !n.lida ? 'border-primary-100/50' : 'border-gray-100/80' %>"
                       data-notif-id="<%= n.id %>"
                       data-link="<%= (n.link || '#') %>"
                       <%= isAlerta ? ' data-tipo="alerta" data-pet-id="' + n.pet_id + '"' : '' %>>

                      <!-- Avatar ou Icone -->
                      <div class="relative shrink-0">
                        <% if (n.remetente_foto) { %>
                          <img src="<%= n.remetente_foto %>" alt="" class="w-10 h-10 rounded-full object-cover">
                        <% } else if (n.remetente_nome) { %>
                          <span class="w-10 h-10 rounded-full flex items-center justify-center text-sm font-bold text-white"
                                style="background:<%= n.remetente_cor || '#ec5a1c' %>">
                            <%= n.remetente_nome.charAt(0).toUpperCase() %>
                          </span>
                        <% } else { %>
                          <div class="w-10 h-10 rounded-full <%= cfg.bg %> flex items-center justify-center">
                            <i class="fa-solid <%= cfg.icon %> <%= cfg.iconColor %>"></i>
                          </div>
                        <% } %>
                        <% if (n.remetente_nome) { %>
                          <div class="absolute -bottom-1 -right-1 w-5 h-5 rounded-full <%= cfg.bg %> flex items-center justify-center ring-2 ring-white">
                            <i class="fa-solid <%= cfg.icon %> <%= cfg.iconColor %> text-[8px]"></i>
                          </div>
                        <% } %>
                      </div>

                      <!-- Content -->
                      <div class="flex-1 min-w-0">
                        <p class="text-sm text-gray-800 leading-snug line-clamp-2 <%= !n.lida ? 'font-medium' : '' %>">
                          <% if (n.remetente_nome) { %>
                            <strong class="font-semibold text-gray-900"><%= n.remetente_nome %></strong>
                            <%
                              var msgSemNome = (n.mensagem || '').replace(n.remetente_nome, '').trim();
                            %>
                            <%= msgSemNome %>
                          <% } else { %>
                            <%= n.mensagem %>
                          <% } %>
                        </p>
                        <p class="text-[11px] text-gray-400 mt-1" data-time="<%= n.data_criacao || n.data %>"></p>
                      </div>

                      <!-- Unread dot + Actions -->
                      <div class="flex items-center gap-2 shrink-0 mt-1">
                        <% if (!n.lida) { %>
                          <span class="dot-unread w-2.5 h-2.5 rounded-full bg-accent-500 shadow-sm shadow-accent-500/40" data-dot="<%= n.id %>"></span>
                        <% } %>
                        <% if (n.link) { %>
                          <i class="fa-solid fa-chevron-right text-[10px] text-gray-300 group-hover:text-primary-400 transition-colors"></i>
                        <% } %>
                      </div>
                    </a>
                  </div>
                <% }); %>
              </div>
            </div>

          <% } %>
        <% }); %>
      </div>

    <% } else { %>

      <div class="flex flex-col items-center justify-center text-center py-24 animate-slideUp">
        <div class="relative mb-8">
          <div class="w-24 h-24 rounded-full bg-gradient-to-br from-emerald-50 to-green-50 flex items-center justify-center shadow-inner">
            <i class="fa-solid fa-bell text-4xl text-emerald-300"></i>
          </div>
          <div class="absolute -bottom-1 -right-1 w-9 h-9 rounded-full bg-emerald-100 flex items-center justify-center shadow-sm">
            <i class="fa-solid fa-check text-emerald-500 text-sm"></i>
          </div>
        </div>
        <h2 class="text-xl font-bold text-gray-800 mb-2">Tudo em dia!</h2>
        <p class="text-gray-500 text-sm max-w-xs leading-relaxed">
          <% if (currentTab === 'mencoes') { %>
            Nenhuma menção ainda. Quando alguém mencionar você em um comentário, aparecerá aqui.
          <% } else { %>
            Nenhuma notificação. Você receberá alertas de curtidas, comentários, novos seguidores e mais.
          <% } %>
        </p>
      </div>

    <% } %>

  </div>
</main>

<!-- Modal: pet perdido (alerta) -->
<div id="modalAlertaPerdido" class="fixed inset-0 z-[9999] hidden items-center justify-center p-4 bg-black/50" aria-hidden="true">
  <div class="bg-white rounded-3xl shadow-2xl max-w-sm w-full overflow-hidden animate-scaleIn" role="dialog" aria-labelledby="modalAlertaTitulo">
    <div id="modalAlertaFoto" class="h-48 bg-gray-100 flex items-center justify-center">
      <i class="fa-solid fa-paw text-5xl text-gray-300"></i>
    </div>
    <div class="p-5">
      <h2 id="modalAlertaTitulo" class="text-lg font-bold text-gray-900 mb-1">Pet perdido</h2>
      <p id="modalAlertaNome" class="text-gray-600 font-medium mb-2"></p>
      <p id="modalAlertaTexto" class="text-sm text-gray-600 mb-3">Este pet está perdido. Qualquer informação pode ajudar a reunir o pet com o tutor.</p>
      <p id="modalAlertaRecompensa" class="text-sm font-semibold text-amber-600 mb-4 hidden"></p>
      <p id="modalAlertaDescricao" class="text-xs text-gray-500 mb-4 hidden"></p>
      <div class="flex gap-3">
        <button type="button" id="modalAlertaFechar" class="flex-1 py-3 rounded-xl font-medium text-gray-600 bg-gray-100 hover:bg-gray-200 transition-colors">Fechar</button>
        <a id="modalAlertaVerPerfil" href="#" class="flex-1 py-3 rounded-xl font-bold text-white bg-[#ec5a1c] hover:bg-[#d4500f] text-center transition-colors">Ver perfil</a>
      </div>
    </div>
  </div>
</div>

<!-- Modal: notificacao generica (scan, sistema, etc.) -->
<div id="modalNotificacao" class="fixed inset-0 z-[9999] hidden items-center justify-center p-4 bg-black/50" aria-hidden="true">
  <div class="bg-white rounded-3xl shadow-2xl max-w-sm w-full overflow-hidden animate-scaleIn" role="dialog">
    <div class="p-5">
      <h2 class="text-lg font-bold text-gray-900 mb-2">Notificação</h2>
      <p id="modalNotifMensagem" class="text-sm text-gray-600 mb-4"></p>
      <div class="flex gap-3">
        <button type="button" id="modalNotifFechar" class="flex-1 py-3 rounded-xl font-medium text-gray-600 bg-gray-100 hover:bg-gray-200 transition-colors">Fechar</button>
        <a id="modalNotifVer" href="#" class="flex-1 py-3 rounded-xl font-bold text-white bg-[#ec5a1c] hover:bg-[#d4500f] text-center transition-colors">Ver</a>
      </div>
    </div>
  </div>
</div>

<script>
(function () {
  'use strict';

  function tempoRelativo(dataStr) {
    var agora = Date.now();
    var data = new Date(dataStr).getTime();
    var diff = agora - data;
    if (isNaN(diff) || diff < 0) return '';
    var seg = Math.floor(diff / 1000);
    if (seg < 60) return 'agora';
    var min = Math.floor(seg / 60);
    if (min < 60) return 'há ' + min + 'min';
    var hr = Math.floor(min / 60);
    if (hr < 24) return 'há ' + hr + 'h';
    var dias = Math.floor(hr / 24);
    if (dias === 1) return 'há 1 dia';
    if (dias < 7) return 'há ' + dias + 'd';
    var semanas = Math.floor(dias / 7);
    if (semanas < 5) return 'há ' + semanas + ' sem';
    var meses = Math.floor(dias / 30);
    return 'há ' + meses + (meses === 1 ? ' mês' : ' meses');
  }

  document.querySelectorAll('[data-time]').forEach(function (el) {
    var t = el.getAttribute('data-time');
    if (t) el.textContent = tempoRelativo(t);
  });

  window.marcarLida = function (id, btn) {
    fetch('/notificacoes/' + id + '/lida', {
      method: 'POST',
      headers: { 'Accept': 'application/json' },
      credentials: 'same-origin'
    })
    .then(function () {
      var card = document.querySelector('[data-notif-id="' + id + '"]');
      if (card) {
        var link = card.querySelector('a');
        if (link) {
          link.classList.remove('bg-primary-50/40', 'border-primary-100/50');
          link.classList.add('bg-white', 'border-gray-100/80');
        }
        var p = card.querySelector('p.font-medium');
        if (p) p.classList.remove('font-medium');
        var dot = card.querySelector('[data-dot="' + id + '"]');
        if (dot) dot.remove();
      }
      atualizarBadgeGlobal();
    })
    .catch(function () {});
  };

  window.marcarLidaNav = function (id, event) {
    fetch('/notificacoes/' + id + '/lida', {
      method: 'POST',
      headers: { 'Accept': 'application/json' },
      credentials: 'same-origin'
    }).then(function () {
      atualizarBadgeGlobal();
    }).catch(function () {});
  };

  var btnMarcarTodas = document.getElementById('btnMarcarTodasLidas');
  if (btnMarcarTodas) {
    btnMarcarTodas.addEventListener('click', function () {
      fetch('/notificacoes/marcar-todas-lidas', {
        method: 'POST',
        headers: { 'Accept': 'application/json' },
        credentials: 'same-origin'
      })
      .then(function (r) { return r.json(); })
      .then(function (data) {
        if (data.sucesso) {
          document.querySelectorAll('.dot-unread').forEach(function (dot) { dot.remove(); });
          document.querySelectorAll('[data-notif-id] a').forEach(function (link) {
            link.classList.remove('bg-primary-50/40', 'border-primary-100/50');
            link.classList.add('bg-white', 'border-gray-100/80');
          });
          document.querySelectorAll('.notif-card p.font-medium').forEach(function (p) {
            p.classList.remove('font-medium');
          });
          btnMarcarTodas.closest('.flex').innerHTML = '<span class="text-xs text-emerald-500 font-semibold"><i class="fa-solid fa-check mr-1"></i>Todas lidas</span>';
          atualizarBadgeGlobal();
        }
      })
      .catch(function () {});
    });
  }

  function atualizarBadgeGlobal() {
    fetch('/notificacoes/api/count', {
      headers: { 'Accept': 'application/json' },
      credentials: 'same-origin'
    })
    .then(function (r) { return r.json(); })
    .then(function (data) {
      document.querySelectorAll('[data-notif-badge]').forEach(function (el) {
        if (data.total > 0) {
          el.textContent = data.total > 9 ? '9+' : data.total;
          el.classList.remove('hidden');
        } else {
          el.classList.add('hidden');
        }
      });
    })
    .catch(function () {});
  }

  var modalAlerta = document.getElementById('modalAlertaPerdido');
  var modalAlertaFoto = document.getElementById('modalAlertaFoto');
  var modalAlertaNome = document.getElementById('modalAlertaNome');
  var modalAlertaRecompensa = document.getElementById('modalAlertaRecompensa');
  var modalAlertaDescricao = document.getElementById('modalAlertaDescricao');
  var modalAlertaVerPerfil = document.getElementById('modalAlertaVerPerfil');
  var modalAlertaFechar = document.getElementById('modalAlertaFechar');

  function abrirModalAlerta(dados, link) {
    modalAlertaNome.textContent = dados.pet_nome || 'Pet';
    if (dados.pet_foto) {
      modalAlertaFoto.innerHTML = '<img src="' + dados.pet_foto + '" alt="" class="w-full h-full object-cover">';
    } else {
      modalAlertaFoto.innerHTML = '<i class="fa-solid fa-paw text-5xl text-gray-300"></i>';
    }
    if (dados.recompensa != null && String(dados.recompensa).trim() !== '') {
      var val = String(dados.recompensa).trim();
      modalAlertaRecompensa.textContent = /^\d+(\.\d+)?$/.test(val)
        ? 'Recompensa: R$ ' + parseFloat(val).toFixed(2).replace('.', ',')
        : 'Recompensa: ' + val;
      modalAlertaRecompensa.classList.remove('hidden');
    } else {
      modalAlertaRecompensa.classList.add('hidden');
    }
    if (dados.descricao != null && String(dados.descricao).trim() !== '') {
      modalAlertaDescricao.textContent = dados.descricao;
      modalAlertaDescricao.classList.remove('hidden');
    } else {
      modalAlertaDescricao.classList.add('hidden');
    }
    modalAlertaVerPerfil.href = link || ('/pets/' + dados.pet_id);
    modalAlerta.classList.remove('hidden');
    modalAlerta.classList.add('flex');
  }

  function fecharModalAlerta() {
    modalAlerta.classList.add('hidden');
    modalAlerta.classList.remove('flex');
  }

  if (modalAlertaFechar) modalAlertaFechar.addEventListener('click', fecharModalAlerta);
  modalAlerta.addEventListener('click', function (e) {
    if (e.target === modalAlerta) fecharModalAlerta();
  });

  var modalNotif = document.getElementById('modalNotificacao');
  var modalNotifMensagem = document.getElementById('modalNotifMensagem');
  var modalNotifVer = document.getElementById('modalNotifVer');
  var modalNotifFechar = document.getElementById('modalNotifFechar');

  function abrirModalNotificacao(mensagem, link) {
    if (modalNotifMensagem) modalNotifMensagem.textContent = mensagem || '';
    if (modalNotifVer) {
      modalNotifVer.href = link && link !== '#' ? link : '/notificacoes';
      modalNotifVer.style.display = link && link !== '#' ? '' : 'none';
    }
    if (modalNotif) {
      modalNotif.classList.remove('hidden');
      modalNotif.classList.add('flex');
    }
  }
  function fecharModalNotificacao() {
    if (modalNotif) {
      modalNotif.classList.add('hidden');
      modalNotif.classList.remove('flex');
    }
  }
  if (modalNotifFechar) modalNotifFechar.addEventListener('click', fecharModalNotificacao);
  if (modalNotif) modalNotif.addEventListener('click', function (e) { if (e.target === modalNotif) fecharModalNotificacao(); });

  document.body.addEventListener('click', function (e) {
    var a = e.target.closest('a.notif-link');
    if (!a) return;
    var notifId = a.getAttribute('data-notif-id');
    var link = a.getAttribute('data-link') || '#';
    var isAlerta = a.getAttribute('data-tipo') === 'alerta';
    var petId = a.getAttribute('data-pet-id');

    if (isAlerta && petId) {
      e.preventDefault();
      fetch('/api/pets/' + petId + '/alerta-ativo', { headers: { 'Accept': 'application/json' }, credentials: 'same-origin' })
        .then(function (r) { return r.json(); })
        .then(function (data) {
          if (data.ativo && data.pet_nome != null) {
            if (notifId && typeof marcarLida === 'function') marcarLida(parseInt(notifId, 10));
            abrirModalAlerta(data, link);
          } else {
            window.location.href = link;
          }
        })
        .catch(function () { window.location.href = link; });
      return;
    }

    e.preventDefault();
    var msgEl = a.querySelector('.flex-1.min-w-0 p');
    var mensagem = msgEl ? msgEl.textContent.trim() : '';
    if (notifId && typeof marcarLida === 'function') marcarLida(parseInt(notifId, 10));
    abrirModalNotificacao(mensagem, link);
  });
})();
</script>

