<% locals.titulo = 'Horários de Atendimento' %>
<%
  const dias = [
    { id: 0, label: 'Domingo' },
    { id: 1, label: 'Segunda' },
    { id: 2, label: 'Terça' },
    { id: 3, label: 'Quarta' },
    { id: 4, label: 'Quinta' },
    { id: 5, label: 'Sexta' },
    { id: 6, label: 'Sábado' },
  ];
  function valorHora(rule, field, fallback) {
    if (!rule || !rule[field]) return fallback;
    return String(rule[field]).slice(0, 5);
  }
  locals.extraHead = `
  <link rel="stylesheet" href="/css/partner-ui.css">
  <style>
    .partner-app { max-width: 1080px; }
    .partner-card { background: var(--ink-2); border:1px solid var(--border); border-radius: 18px; padding: 16px; }
    .row-dia { border: 1px solid var(--border); border-radius: 14px; padding: 12px; background: var(--ink-3); }
    .label-col { color: var(--text); font-weight: 700; }
  </style>
  `;
%>
<%- include('../partials/header') %>
<%- include('../partials/flash') %>

<main class="flex-1 container mx-auto partner-app px-4 py-8 space-y-5 app-shell">
  <%- include('../partials/petshop-panel-nav', { activeTab: 'horarios' }) %>

  <section class="partner-card">
    <h1 class="text-xl font-bold text-[color:var(--text)]">Configuração semanal</h1>
    <p class="text-sm text-[color:var(--text-dim)] mt-1">
      Defina apenas os períodos em que você atende. Dias desmarcados ficam bloqueados.
    </p>
  </section>

  <form action="/petshop-panel/agenda/config" method="POST" class="space-y-3">
    <% dias.forEach(function(dia) { %>
      <% const regra = (regrasMap && regrasMap[String(dia.id)]) || null; %>
      <% const ativo = regra ? regra.ativo !== false : false; %>
      <div class="row-dia">
        <div class="flex flex-wrap items-center justify-between gap-3">
          <label class="inline-flex items-center gap-2 label-col">
            <input type="checkbox" name="dia_<%= dia.id %>_ativo" value="1" <%= ativo ? 'checked' : '' %>>
            <span><%= dia.label %></span>
          </label>
          <span class="text-xs text-[color:var(--text-dim)]">Dia <%= dia.id %></span>
        </div>

        <div class="grid md:grid-cols-4 gap-3 mt-3">
          <label class="text-xs text-[color:var(--text-dim)]">
            Abre
            <input class="input w-full mt-1" type="time" name="dia_<%= dia.id %>_abre" value="<%= valorHora(regra, 'abre', '08:00') %>">
          </label>
          <label class="text-xs text-[color:var(--text-dim)]">
            Fecha
            <input class="input w-full mt-1" type="time" name="dia_<%= dia.id %>_fecha" value="<%= valorHora(regra, 'fecha', '18:00') %>">
          </label>
          <label class="text-xs text-[color:var(--text-dim)]">
            Intervalo início (opcional)
            <input class="input w-full mt-1" type="time" name="dia_<%= dia.id %>_intervalo_inicio" value="<%= valorHora(regra, 'intervalo_inicio', '') %>">
          </label>
          <label class="text-xs text-[color:var(--text-dim)]">
            Intervalo fim (opcional)
            <input class="input w-full mt-1" type="time" name="dia_<%= dia.id %>_intervalo_fim" value="<%= valorHora(regra, 'intervalo_fim', '') %>">
          </label>
        </div>
      </div>
    <% }) %>

    <div class="pt-1">
      <button class="btn-primary-inline">Salvar horários</button>
    </div>
  </form>

  <section class="partner-card mt-6">
    <h2 class="font-bold mb-2">Bloquear horários específicos</h2>
    <p class="text-xs text-[color:var(--text-dim)] mb-3">Use para feriados, pausas extras ou horários indisponíveis por serviço.</p>
    <form action="/petshop-panel/agenda/config/bloqueios" method="POST" class="grid md:grid-cols-4 gap-3">
      <select class="input w-full" name="service_id">
        <option value="">Todos os serviços</option>
        <% (services || []).forEach(function(s) { %>
          <option value="<%= s.id %>"><%= s.nome %></option>
        <% }) %>
      </select>
      <input class="input w-full" type="datetime-local" name="inicio" required>
      <input class="input w-full" type="datetime-local" name="fim" required>
      <input class="input w-full" name="motivo" placeholder="Motivo (opcional)">
      <div class="md:col-span-4">
        <button class="btn-primary-inline">Adicionar bloqueio</button>
      </div>
    </form>
  </section>

  <section class="partner-card mt-4">
    <div class="flex items-center justify-between mb-3">
      <h2 class="font-bold">Próximos bloqueios</h2>
      <span class="text-xs text-[color:var(--text-dim)]"><%= (bloqueios || []).length %> ativo(s)</span>
    </div>
    <% if (!(bloqueios || []).length) { %>
      <p class="text-sm text-[color:var(--text-dim)]">Sem bloqueios cadastrados.</p>
    <% } else { %>
      <div class="space-y-2">
        <% (bloqueios || []).forEach(function(b) { %>
          <article class="row-dia flex flex-wrap items-center justify-between gap-3">
            <div class="text-xs">
              <p><strong><%= b.servico_nome || 'Todos os serviços' %></strong></p>
              <p><%= new Date(b.inicio).toLocaleString('pt-BR') %> até <%= new Date(b.fim).toLocaleString('pt-BR') %></p>
              <p class="text-[color:var(--text-dim)]"><%= b.motivo || 'Sem motivo' %></p>
            </div>
            <form method="POST" action="/petshop-panel/agenda/config/bloqueios/<%= b.id %>/remover">
              <button class="px-3 py-2 rounded-lg border border-red-200 bg-red-50 text-red-600 text-xs font-semibold">Remover</button>
            </form>
          </article>
        <% }) %>
      </div>
    <% } %>
  </section>
</main>

<%- include('../partials/footer') %>
