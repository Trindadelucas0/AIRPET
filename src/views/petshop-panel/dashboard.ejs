<% locals.titulo = 'Dashboard do Petshop' %>
<%
  locals.extraHead = `
  <link rel="stylesheet" href="/css/partner-ui.css">
  <style>
    .partner-app { max-width: 1200px; }
    .partner-card { background: var(--ink-2); border:1px solid var(--border); border-radius: 18px; padding: 16px; }
    .partner-kpis { display:grid; grid-template-columns: repeat(4, minmax(0,1fr)); gap: 12px; }
    .partner-kpi { background: var(--ink-3); border:1px solid var(--border); border-radius: 14px; padding: 12px; }
    .partner-kpi .label { color: var(--text-dim); font-size: 11px; text-transform: uppercase; letter-spacing: .08em; font-weight:700; }
    .partner-kpi .value { color: var(--text); font-size: 1.4rem; font-weight: 900; margin-top: 4px; }
    .partner-list-item { border: 1px solid var(--border); border-radius: 14px; padding: 12px; background: var(--ink-3); }
    @media (max-width: 980px) { .partner-kpis { grid-template-columns: repeat(2, minmax(0,1fr)); } }
    @media (max-width: 640px) { .partner-kpis { grid-template-columns: 1fr; } }
  </style>
  `;
%>
<%- include('../partials/header') %>
<%- include('../partials/flash') %>

<main class="flex-1 container mx-auto partner-app px-4 py-8 space-y-6 app-shell">
  <%- include('../partials/petshop-panel-nav', { activeTab: 'dashboard' }) %>
  <% const statusAtual = (solicitacao && solicitacao.status) || (accountStatus === 'ativo' ? 'aprovado' : 'pendente'); %>
  <% const postsComFoto = (posts || []).filter(function(p) { return p && p.foto_url && String(p.foto_url).trim(); }); %>
  <% const promocoes = (products || []).filter(function(p) { return p && p.is_promocao; }); %>

  <section class="partner-card">
    <div class="flex items-start justify-between gap-3">
      <div>
        <h1 class="text-2xl font-black text-[color:var(--text)]">Painel profissional do parceiro</h1>
        <p class="text-sm text-[color:var(--text-dim)] mt-1">Controle agenda, serviços, perfil público e pets vinculados em um só lugar.</p>
      </div>
      <a href="/petshop-panel/auth/logout" class="text-xs text-[color:var(--text-dim)] hover:text-[color:var(--text)]">Sair</a>
    </div>
    <div class="mt-3 text-xs">
      <span class="px-2 py-1 rounded-full bg-[color:var(--secondary)] text-[color:var(--text-dim)]">Status da parceria: <strong><%= statusAtual %></strong></span>
    </div>
  </section>

  <section class="partner-kpis">
    <div class="partner-kpi"><p class="label">Serviços</p><p class="value"><%= (services || []).length %></p></div>
    <div class="partner-kpi"><p class="label">Agendamentos</p><p class="value"><%= (appointments || []).length %></p></div>
    <div class="partner-kpi"><p class="label">Pets vinculados</p><p class="value"><%= (petsVinculadosDetalhados || []).length %></p></div>
    <div class="partner-kpi"><p class="label">Fotos e promoções</p><p class="value"><%= postsComFoto.length %>/<%= promocoes.length %></p></div>
  </section>

  <section class="grid lg:grid-cols-[minmax(0,1.2fr)_minmax(0,1fr)] gap-6">
    <%- include('../partials/petshop-calendar-card') %>
    <%- include('../partials/petshop-public-profile-preview', { petshop: petshop || {}, profile: profile || {}, postsComFoto: postsComFoto, promocoes: promocoes, followerCount: followerCount || 0 }) %>
  </section>

  <section class="partner-card">
    <div class="flex items-center justify-between mb-3">
      <h2 class="font-bold">Solicitações de vínculo pendentes</h2>
      <span class="text-xs text-[color:var(--text-dim)]"><%= (solicitacoesVinculo || []).length %> pendentes</span>
    </div>
    <% if (!(solicitacoesVinculo || []).length) { %>
      <p class="text-sm text-[color:var(--text-dim)]">Nenhuma solicitação pendente no momento.</p>
    <% } else { %>
      <div class="space-y-3">
        <% (solicitacoesVinculo || []).forEach(function(s) { %>
          <article class="partner-list-item flex flex-col md:flex-row md:items-center md:justify-between gap-3">
            <div>
              <p class="font-semibold"><%= s.pet_nome %> • Tutor: <%= s.tutor_nome %></p>
              <p class="text-xs text-[color:var(--text-dim)] mt-1"><%= s.mensagem || 'Sem mensagem.' %></p>
            </div>
            <div class="flex gap-2">
              <form action="/petshop-panel/vinculos/solicitacoes/<%= s.id %>/recusar" method="POST">
                <button class="px-3 py-2 rounded-lg border border-red-200 bg-red-50 text-red-600 text-xs font-semibold">Recusar</button>
              </form>
              <form action="/petshop-panel/vinculos/solicitacoes/<%= s.id %>/aprovar" method="POST">
                <button class="btn-primary-inline text-xs !px-3 !py-2">Aprovar vínculo</button>
              </form>
            </div>
          </article>
        <% }) %>
      </div>
    <% } %>
  </section>

  <%- include('../partials/petshop-linked-pets-card', { petsVinculadosDetalhados: petsVinculadosDetalhados || [] }) %>

  <section class="partner-card">
    <div class="flex items-center justify-between mb-3">
      <h2 class="font-bold">Agendamentos recebidos</h2>
      <a href="/petshop-panel/agenda" class="btn-ghost border border-[color:var(--border)] rounded-xl px-3 py-2 text-xs">Abrir agenda completa</a>
    </div>
    <% if (!(appointmentsPreview || []).length) { %>
      <p class="text-sm text-[color:var(--text-dim)]">Nenhum agendamento recebido ainda.</p>
    <% } else { %>
      <div class="space-y-3">
        <% (appointmentsPreview || []).forEach(function(a) { %>
          <article class="partner-list-item flex flex-col md:flex-row md:items-center gap-3 md:justify-between">
            <div>
              <p class="font-semibold"><%= a.pet_nome %> • <%= a.servico_nome || 'Serviço' %></p>
              <p class="text-sm text-[color:var(--text-dim)]"><%= a.usuario_nome %> • <%= new Date(a.data_agendada).toLocaleString('pt-BR') %></p>
            </div>
            <form action="/petshop-panel/agenda/<%= a.id %>/status" method="POST" class="flex gap-2">
              <select name="status" class="input">
                <option value="aceito" <%= a.status === 'aceito' ? 'selected' : '' %>>Confirmar</option>
                <option value="recusado" <%= a.status === 'recusado' ? 'selected' : '' %>>Recusar</option>
                <option value="concluido" <%= a.status === 'concluido' ? 'selected' : '' %>>Concluir</option>
              </select>
              <button class="btn-primary-inline">Atualizar</button>
            </form>
          </article>
        <% }) %>
      </div>
    <% } %>
  </section>
</main>

<script>
  window.__agendaDiasResumo = <%- JSON.stringify(typeof agendaDiasResumo !== 'undefined' ? agendaDiasResumo : {}) %>;
</script>
<script src="/js/petshop-calendar.js" defer></script>

<%- include('../partials/footer') %>
