<% locals.titulo = 'Dashboard do Petshop' %>
<% locals.extraHead = '<link rel="stylesheet" href="/css/partner-ui.css">'; %>
<%- include('../partials/header') %>
<%- include('../partials/flash') %>

<main class="flex-1 container mx-auto max-w-7xl px-4 py-8 space-y-6 app-shell">
  <%- include('../partials/petshop-panel-nav', { activeTab: 'dashboard' }) %>

  <section class="surface-card p-6 md:p-7">
    <div class="flex flex-col gap-4 md:flex-row md:items-start md:justify-between">
      <div>
        <p class="text-xs font-bold uppercase tracking-[0.08em] text-primary-600">PetParceiro AIRPET</p>
        <h1 class="mt-1 text-2xl md:text-3xl font-black text-[color:var(--text)]">Painel profissional do parceiro</h1>
        <p class="mt-2 text-sm text-[color:var(--text-dim)]">Controle agenda, serviços, perfil público e pets vinculados em um só lugar.</p>
        <div class="mt-4 inline-flex items-center gap-2 rounded-full border border-emerald-200 bg-emerald-50 px-3 py-1.5 text-xs font-semibold text-emerald-700">
          <i class="fa-solid fa-badge-check"></i>
          Status da parceria: <%= statusAtual %>
        </div>
      </div>
      <div class="flex items-center gap-2">
        <a href="/petshop-panel/perfil" class="btn-ghost !px-3 !py-2 !text-xs">
          <i class="fa-solid fa-pen-to-square"></i> Editar perfil
        </a>
        <a href="/petshop-panel/auth/logout" class="btn-ghost !px-3 !py-2 !text-xs">
          <i class="fa-solid fa-right-from-bracket"></i> Sair
        </a>
      </div>
    </div>

    <div class="mt-6 kpi-grid">
      <article class="kpi-card">
        <p class="kpi-label">Serviços ativos</p>
        <p class="kpi-value"><%= dashboardResumo.totalServicos %></p>
      </article>
      <article class="kpi-card">
        <p class="kpi-label">Agendamentos</p>
        <p class="kpi-value"><%= dashboardResumo.totalAgendamentos %></p>
      </article>
      <article class="kpi-card">
        <p class="kpi-label">Pets vinculados</p>
        <p class="kpi-value"><%= dashboardResumo.totalPetsVinculados %></p>
      </article>
      <article class="kpi-card">
        <p class="kpi-label">Fotos / Promoções</p>
        <p class="kpi-value"><%= dashboardResumo.totalPostsComFoto %>/<%= dashboardResumo.totalPromocoes %></p>
      </article>
    </div>
  </section>

  <section class="surface-card p-6">
    <div class="flex flex-wrap items-center justify-between gap-3 mb-3">
      <h2 class="text-lg font-bold text-[color:var(--text)]">Métricas do PetParceiro</h2>
      <div class="flex items-center gap-2">
        <a href="/petshop-panel/dashboard?period=7" class="rounded-full border px-3 py-1.5 text-xs font-semibold <%= periodAtivo === 7 ? 'border-primary-300 bg-primary-100 text-primary-700' : 'border-[color:var(--border)] text-[color:var(--text-dim)] hover:bg-[color:var(--ink-3)]' %>">7 dias</a>
        <a href="/petshop-panel/dashboard?period=30" class="rounded-full border px-3 py-1.5 text-xs font-semibold <%= periodAtivo === 30 ? 'border-primary-300 bg-primary-100 text-primary-700' : 'border-[color:var(--border)] text-[color:var(--text-dim)] hover:bg-[color:var(--ink-3)]' %>">30 dias</a>
        <a href="/petshop-panel/dashboard?period=90" class="rounded-full border px-3 py-1.5 text-xs font-semibold <%= periodAtivo === 90 ? 'border-primary-300 bg-primary-100 text-primary-700' : 'border-[color:var(--border)] text-[color:var(--text-dim)] hover:bg-[color:var(--ink-3)]' %>">90 dias</a>
      </div>
    </div>
    <section class="kpi-grid">
      <div class="kpi-card"><p class="kpi-label">Views</p><p class="kpi-value"><%= (metricas && metricas.views) || 0 %></p></div>
      <div class="kpi-card"><p class="kpi-label">Curtidas</p><p class="kpi-value"><%= (metricas && metricas.likes) || 0 %></p></div>
      <div class="kpi-card"><p class="kpi-label">Novos seguidores</p><p class="kpi-value"><%= (metricas && metricas.novosSeguidores) || 0 %></p></div>
      <div class="kpi-card"><p class="kpi-label">Engajamento total</p><p class="kpi-value"><%= (metricas && metricas.engajamentoTotal) || 0 %></p></div>
    </section>
    <p class="text-xs text-[color:var(--text-dim)] mt-4">
      Taxa de engajamento no período: <strong><%= ((metricas && metricas.taxaEngajamento) || 0).toFixed(1).replace('.', ',') %>%</strong>
      · Comentários: <strong><%= (metricas && metricas.comments) || 0 %></strong>
    </p>
  </section>

  <section class="grid lg:grid-cols-[minmax(0,1.2fr)_minmax(0,1fr)] gap-6">
    <%- include('../partials/petshop-calendar-card') %>
    <%- include('../partials/petshop-public-profile-preview', { petshop: petshop || {}, profile: profile || {}, postsComFoto: postsComFoto, promocoes: promocoes, followerCount: followerCount || 0 }) %>
  </section>

  <section class="surface-card p-6">
    <div class="flex items-center justify-between mb-3">
      <h2 class="font-bold">Solicitações de vínculo pendentes</h2>
      <span class="text-xs text-[color:var(--text-dim)]"><%= (solicitacoesVinculo || []).length %> pendentes</span>
    </div>
    <% if (!(solicitacoesVinculo || []).length) { %>
      <p class="text-sm text-[color:var(--text-dim)]">Nenhuma solicitação pendente no momento.</p>
    <% } else { %>
      <div class="space-y-3">
        <% (solicitacoesVinculo || []).forEach(function(s) { %>
          <article class="surface-subtle p-3 flex flex-col md:flex-row md:items-center md:justify-between gap-3">
            <div>
              <p class="font-semibold"><%= s.pet_nome %> • Tutor: <%= s.tutor_nome %></p>
              <p class="text-xs text-[color:var(--text-dim)] mt-1"><%= s.mensagem || 'Sem mensagem.' %></p>
            </div>
            <div class="flex gap-2">
              <form action="/petshop-panel/vinculos/solicitacoes/<%= s.id %>/recusar" method="POST">
                <button class="px-3 py-2 rounded-lg border border-red-200 bg-red-50 text-red-600 text-xs font-semibold">Recusar</button>
              </form>
              <form action="/petshop-panel/vinculos/solicitacoes/<%= s.id %>/aprovar" method="POST">
                <button class="btn-primary-inline text-xs !px-3 !py-2">Aprovar vínculo</button>
              </form>
            </div>
          </article>
        <% }) %>
      </div>
    <% } %>
  </section>

  <section class="surface-card p-6">
    <div class="flex items-center justify-between mb-3">
      <h2 class="font-bold">Pets vinculados</h2>
      <a href="/petshop-panel/pets-vinculados" class="btn-ghost border border-[color:var(--border)] rounded-xl px-3 py-2 text-xs">Ver lista completa</a>
    </div>
    <p class="text-sm text-[color:var(--text-dim)]">Total de pets vinculados: <strong><%= (petsVinculadosDetalhados || []).length %></strong>.</p>
  </section>

  <section class="surface-card p-6">
    <div class="flex items-center justify-between mb-3">
      <h2 class="font-bold">Agendamentos recebidos</h2>
      <a href="/petshop-panel/agendamentos-recebidos" class="btn-ghost border border-[color:var(--border)] rounded-xl px-3 py-2 text-xs">Ver todos</a>
    </div>
    <% if (!(appointmentsPreview || []).length) { %>
      <p class="text-sm text-[color:var(--text-dim)]">Nenhum agendamento recebido ainda.</p>
    <% } else { %>
      <div class="space-y-3">
        <% (appointmentsPreview || []).forEach(function(a) { %>
          <article class="surface-subtle p-3 flex flex-col md:flex-row md:items-center gap-3 md:justify-between">
            <div>
              <p class="font-semibold"><%= a.pet_nome %> • <%= a.servico_nome || 'Serviço' %></p>
              <p class="text-sm text-[color:var(--text-dim)]"><%= a.usuario_nome %> • <%= new Date(a.data_agendada).toLocaleString('pt-BR') %></p>
            </div>
            <form action="/petshop-panel/agenda/<%= a.id %>/status" method="POST" class="flex gap-2">
              <select name="status" class="input">
                <option value="aceito" <%= a.status === 'aceito' ? 'selected' : '' %>>Confirmar</option>
                <option value="recusado" <%= a.status === 'recusado' ? 'selected' : '' %>>Recusar</option>
                <option value="concluido" <%= a.status === 'concluido' ? 'selected' : '' %>>Concluir</option>
              </select>
              <button class="btn-primary-inline">Atualizar</button>
            </form>
          </article>
        <% }) %>
      </div>
      <div class="mt-3">
        <a href="/petshop-panel/agendamentos-recebidos" class="text-xs text-[color:var(--accent)]">Abrir lista completa de agendamentos</a>
      </div>
    <% } %>
  </section>
</main>

<script>
  window.__agendaDiasResumo = <%- safeJson(typeof agendaDiasResumo !== 'undefined' ? agendaDiasResumo : {}) %>;
</script>
<script src="/js/petshop-calendar.js" defer></script>

<%- include('../partials/footer') %>
