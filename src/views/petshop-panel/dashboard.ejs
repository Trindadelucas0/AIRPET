<% locals.titulo = 'Dashboard do Petshop' %>
<%
  locals.extraHead = `
  <style>
    .partner-app { max-width: 1200px; }
    .partner-top {
      background: linear-gradient(135deg, color-mix(in srgb, var(--accent) 18%, transparent), transparent 45%), var(--ink-2);
      border: 1px solid var(--border);
      border-radius: 20px;
      padding: 18px 20px;
    }
    .partner-top h1 { color: var(--text); font-size: 1.65rem; font-weight: 900; letter-spacing: -.02em; }
    .partner-top p { color: var(--text-dim); }
    .partner-kpis { display:grid; grid-template-columns: repeat(4, minmax(0,1fr)); gap: 12px; }
    .partner-kpi {
      background: var(--ink-2); border:1px solid var(--border); border-radius: 16px; padding: 14px;
      transition: transform .2s ease, border-color .2s ease;
    }
    .partner-kpi:hover { transform: translateY(-2px); border-color: var(--border-hover); }
    .partner-kpi .label { color: var(--text-dim); font-size: 12px; text-transform: uppercase; letter-spacing: .08em; font-weight:700; }
    .partner-kpi .value { color: var(--text); font-size: 1.6rem; font-weight: 900; margin-top: 4px; }
    .partner-card {
      background: var(--ink-2); border:1px solid var(--border); border-radius: 18px; padding: 16px;
    }
    .partner-card h2 { color: var(--text); font-weight: 800; }
    .partner-card .hint { color: var(--text-dim); font-size: 12px; }
    .partner-card .input { border-radius: 12px; }
    .partner-card .btn-primary-inline { border-radius: 12px; }
    .partner-status { border-radius: 16px; padding: 14px; background: var(--ink-2); border:1px solid var(--border); }
    .partner-status p, .partner-status .text-gray-600, .partner-status .text-gray-500 { color: var(--text-dim) !important; }
    .partner-list-item { border: 1px solid var(--border); border-radius: 14px; padding: 12px; background: var(--ink-3); }
    @media (max-width: 980px) {
      .partner-kpis { grid-template-columns: repeat(2, minmax(0,1fr)); }
    }
    @media (max-width: 640px) {
      .partner-kpis { grid-template-columns: 1fr; }
      .partner-top { padding: 14px; }
      .partner-top h1 { font-size: 1.35rem; }
    }
  </style>
  `;
%>
<%- include('../partials/header') %>
<%- include('../partials/flash') %>

<main class="flex-1 container mx-auto partner-app px-4 py-8 space-y-6 app-shell">
  <% const statusAtual = (solicitacao && solicitacao.status) || (accountStatus === 'ativo' ? 'aprovado' : 'pendente'); %>
  <% const statusClasses = statusAtual === 'aprovado'
    ? 'bg-emerald-100 text-emerald-700'
    : statusAtual === 'rejeitado'
      ? 'bg-red-100 text-red-700'
      : statusAtual === 'em_analise'
        ? 'bg-amber-100 text-amber-700'
        : 'bg-blue-100 text-blue-700'; %>
  <div class="partner-top flex items-center justify-between flex-wrap gap-3">
    <div>
      <h1>Dashboard do Parceiro</h1>
      <p class="text-sm mt-1">Layout social premium para gerenciar perfil, vitrine e agenda.</p>
    </div>
    <div class="flex items-center gap-3">
      <% if (typeof usuario !== 'undefined' && usuario) { %>
      <a href="/feed" class="text-sm font-medium text-primary-600 hover:text-primary-700">
        <i class="fa-solid fa-paw mr-1"></i> Área do usuário
      </a>
      <% } %>
      <a href="/petshop-panel/auth/logout" class="text-sm text-gray-500 hover:text-gray-800">Sair</a>
    </div>
  </div>

  <section class="partner-status space-y-3">
    <div class="flex items-center justify-between">
      <h2 class="font-bold text-gray-900">Status da parceria</h2>
      <span class="px-3 py-1 rounded-full text-xs font-semibold uppercase <%= statusClasses %>"><%= statusAtual.replace('_', ' ') %></span>
    </div>
    <p class="text-sm text-gray-600">
      <% if (statusAtual === 'aprovado') { %>
        Seu perfil está aprovado e os recursos públicos estão liberados.
      <% } else if (statusAtual === 'rejeitado') { %>
        Sua solicitação foi rejeitada. Ajuste os dados e envie nova solicitação.
      <% } else if (statusAtual === 'em_analise') { %>
        Seu cadastro está em análise pelo time AIRPET.
      <% } else { %>
        Cadastro recebido. Você já pode organizar o perfil no painel restrito.
      <% } %>
    </p>
    <% if (solicitacao && solicitacao.motivo_rejeicao) { %>
      <div class="rounded-xl border border-red-200 bg-red-50 p-3 text-sm text-red-700">
        Motivo informado pela moderação: <strong><%= solicitacao.motivo_rejeicao %></strong>
      </div>
    <% } %>
    <% if (statusAtual !== 'aprovado') { %>
      <p class="text-xs text-gray-500">Recursos públicos bloqueados até aprovação: posts públicos, promoções e agenda aberta.</p>
    <% } %>
  </section>

  <section class="partner-kpis">
    <div class="partner-kpi"><p class="label">Serviços</p><p class="value"><%= (services || []).length %></p></div>
    <div class="partner-kpi"><p class="label">Produtos</p><p class="value"><%= (products || []).length %><span class="text-base font-semibold">/15</span></p></div>
    <div class="partner-kpi"><p class="label">Posts</p><p class="value"><%= (posts || []).length %></p></div>
    <div class="partner-kpi"><p class="label">Agendamentos</p><p class="value"><%= (appointments || []).length %></p></div>
  </section>

  <section class="grid lg:grid-cols-[minmax(0,1.4fr)_minmax(0,1.2fr)] gap-6">
    <%- include('../partials/petshop-calendar-card') %>

    <div class="partner-card">
      <h2 class="font-bold mb-3">Atualizar perfil público</h2>
      <p class="hint mb-3">Deixe seu perfil com cara de feed: slogan curto, descrição objetiva e links sociais.</p>
      <form action="/petshop-panel/perfil" method="POST" class="space-y-3">
        <input class="input w-full" name="slogan" placeholder="Slogan" value="<%= profile?.slogan || '' %>">
        <input class="input w-full" name="descricao_curta" placeholder="Descrição curta" value="<%= profile?.descricao_curta || '' %>">
        <textarea class="input w-full min-h-20" name="descricao_longa" placeholder="Descrição completa"><%= profile?.descricao_longa || '' %></textarea>
        <input class="input w-full" name="instagram_url" placeholder="Instagram URL" value="<%= profile?.instagram_url || '' %>">
        <input class="input w-full" name="facebook_url" placeholder="Facebook URL" value="<%= profile?.facebook_url || '' %>">
        <button class="btn-primary-inline">Salvar perfil</button>
      </form>
    </div>

    <div class="partner-card">
      <h2 class="font-bold mb-3">Novo serviço</h2>
      <form action="/petshop-panel/servicos" method="POST" class="space-y-3">
        <input class="input w-full" name="nome" placeholder="Nome do serviço" required>
        <input class="input w-full" type="number" name="duracao_minutos" placeholder="Duração (min)" required>
        <input class="input w-full" type="number" step="0.01" name="preco_base" placeholder="Preço base">
        <textarea class="input w-full min-h-20" name="descricao" placeholder="Descrição"></textarea>
        <button class="btn-primary-inline">Salvar serviço</button>
      </form>
    </div>
  </section>

  <section class="grid lg:grid-cols-2 gap-6">
    <div class="partner-card">
      <h2 class="font-bold mb-3">Nova postagem/produto</h2>
      <p class="hint mb-3">Use título curto e imagem forte para parecer uma vitrine tipo Instagram.</p>
      <form action="/petshop-panel/posts" method="POST" enctype="multipart/form-data" class="space-y-3">
        <select class="input w-full" name="post_type">
          <option value="normal">Post normal (feed)</option>
          <option value="produto">Produto (catálogo)</option>
          <option value="promocao">Promoção (com moderação)</option>
        </select>
        <input class="input w-full" name="titulo" placeholder="Título" required>
        <textarea class="input w-full min-h-20" name="texto" placeholder="Texto"></textarea>

        <select class="input w-full" name="service_id">
          <option value="">Vincular a um serviço (opcional)</option>
          <% (services || []).forEach(function(s) { %>
            <option value="<%= s.id %>"><%= s.nome %></option>
          <% }) %>
        </select>

        <div class="grid md:grid-cols-2 gap-3">
          <label class="flex items-center gap-2 text-sm text-gray-700 bg-gray-50 rounded-xl p-3 border border-gray-200">
            <input type="checkbox" name="is_highlighted" value="1">
            Marcar como Destaque
          </label>
          <input class="input w-full" type="number" name="highlight_rank" placeholder="Rank (maior = melhor)" value="0">
        </div>

        <input class="input w-full" name="nome_produto" placeholder="Nome do produto (se aplicável)">
        <input class="input w-full" type="number" step="0.01" name="preco" placeholder="Preço (se aplicável)">
        <input class="input w-full" name="contato_link" placeholder="Link de contato">
        <input class="input w-full" type="file" name="foto" accept="image/*">
        <button class="btn-primary-inline">Publicar</button>
      </form>
    </div>

    <div class="partner-card">
      <h2 class="font-bold mb-3">Agendamento (teste interno)</h2>
      <form action="/petshop-panel/agenda" method="POST" class="space-y-3">
        <input class="input w-full" name="usuario_id" placeholder="ID do usuário" required>
        <input class="input w-full" name="pet_id" placeholder="ID do pet" required>
        <input class="input w-full" name="service_id" placeholder="ID do serviço">
        <input class="input w-full" type="datetime-local" name="data_agendada" required>
        <textarea class="input w-full min-h-20" name="observacoes" placeholder="Observações"></textarea>
        <button class="btn-primary-inline">Criar agendamento</button>
      </form>
    </div>
  </section>

  <section class="partner-card">
    <h2 class="font-bold mb-3">Agendamentos recebidos</h2>
    <div class="space-y-3">
      <% (appointments || []).forEach(function(a) { %>
        <div class="partner-list-item flex flex-col md:flex-row md:items-center gap-3 md:justify-between">
          <div>
            <p class="font-semibold"><%= a.pet_nome %> • <%= a.servico_nome || 'Serviço' %></p>
            <p class="text-sm text-gray-500"><%= a.usuario_nome %> • <%= new Date(a.data_agendada).toLocaleString('pt-BR') %></p>
          </div>
          <form action="/petshop-panel/agenda/<%= a.id %>/status" method="POST" class="flex gap-2">
            <select name="status" class="input">
              <option value="aceito">Aceitar</option>
              <option value="recusado">Recusar</option>
              <option value="concluido">Concluir</option>
            </select>
            <button class="btn-primary-inline">Atualizar</button>
          </form>
        </div>
      <% }) %>
    </div>
  </section>
</main>

<script>
  window.__agendaDiasResumo = <%- JSON.stringify(typeof agendaDiasResumo !== 'undefined' ? agendaDiasResumo : {}) %>;
</script>
<script src="/js/petshop-calendar.js" defer></script>

<%- include('../partials/footer') %>
