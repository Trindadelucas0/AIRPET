<% locals.titulo = 'Meu perfil público' %>
<%
  locals.extraHead = `
  <link rel="stylesheet" href="/css/partner-ui.css">
  <style>
    .partner-app { max-width: 1180px; }
    .partner-card { background: var(--ink-2); border:1px solid var(--border); border-radius: 18px; padding: 16px; }
    .partner-list-item { border: 1px solid var(--border); border-radius: 14px; padding: 12px; background: var(--ink-3); }
  </style>
  `;
%>
<%- include('../partials/header') %>
<%- include('../partials/flash') %>

<main class="flex-1 container mx-auto partner-app px-4 py-8 space-y-6 app-shell">
  <%- include('../partials/petshop-panel-nav', { activeTab: 'perfil' }) %>

  <%- include('../partials/mobile-screen-header', {
    badge: 'Painel parceiro',
    title: 'Controle do perfil público',
    subtitle: 'Fluxo reorganizado por contexto: dados, publicação e gestão.',
    slotHtml: `
      <div class="grid grid-cols-3 gap-2 text-xs">
        <a href="#dadosPublicos" class="px-3 py-2 rounded-xl bg-[color:var(--ink-3)] text-center font-semibold">Dados</a>
        <a href="#publicacoes" class="px-3 py-2 rounded-xl bg-[color:var(--ink-3)] text-center font-semibold">Publicar</a>
        <a href="#gerenciar" class="px-3 py-2 rounded-xl bg-[color:var(--ink-3)] text-center font-semibold">Gerenciar</a>
      </div>
    `
  }) %>

  <section id="dadosPublicos" class="grid lg:grid-cols-[minmax(0,1.1fr)_minmax(0,1fr)] gap-6">
    <div class="partner-card">
      <h2 class="font-bold mb-3">Dados públicos</h2>
      <form action="/petshop-panel/perfil" method="POST" class="space-y-3">
        <p class="text-xs text-[color:var(--text-dim)]">Atualize os dados essenciais primeiro para manter a página clara.</p>
        <input class="input w-full" name="petshop_nome" placeholder="Nome público do petshop" value="<%= petshop?.nome || '' %>">
        <input class="input w-full" name="petshop_telefone" placeholder="Telefone público" value="<%= petshop?.telefone || '' %>">
        <input class="input w-full" name="petshop_endereco" placeholder="Endereço público" value="<%= petshop?.endereco || '' %>">
        <textarea class="input w-full min-h-20" name="petshop_descricao" placeholder="Descrição geral"><%= petshop?.descricao || '' %></textarea>

        <input class="input w-full" name="slogan" placeholder="Slogan" value="<%= profile?.slogan || '' %>">
        <input class="input w-full" name="descricao_curta" placeholder="Descrição curta" value="<%= profile?.descricao_curta || '' %>">
        <textarea class="input w-full min-h-20" name="descricao_longa" placeholder="Descrição completa"><%= profile?.descricao_longa || '' %></textarea>
        <input class="input w-full" name="whatsapp_publico" placeholder="WhatsApp público" value="<%= profile?.whatsapp_publico || '' %>">
        <input class="input w-full" name="instagram_url" placeholder="Instagram URL" value="<%= profile?.instagram_url || '' %>">
        <input class="input w-full" name="facebook_url" placeholder="Facebook URL" value="<%= profile?.facebook_url || '' %>">
        <input class="input w-full" name="website_url" placeholder="Website URL" value="<%= profile?.website_url || '' %>">
        <button class="btn-primary-inline">Salvar alterações</button>
      </form>
    </div>

    <%- include('../partials/petshop-public-profile-preview', { petshop: petshop, profile: profile, postsComFoto: postsComFoto, promocoes: promocoes, followerCount: followerCount }) %>
  </section>

  <section class="partner-card">
    <div class="flex items-center justify-between gap-3">
      <h2 class="font-bold">Pets vinculados</h2>
      <a href="/petshop-panel/pets-vinculados" class="text-xs text-[color:var(--accent)]">Abrir view completa</a>
    </div>
    <p class="text-sm text-[color:var(--text-dim)] mt-1">Você possui <strong><%= (petsVinculadosDetalhados || []).length %></strong> pets vinculados.</p>
  </section>

  <section id="publicacoes" class="grid lg:grid-cols-2 gap-6">
    <div class="partner-card">
      <h2 class="font-bold mb-3">Publicar foto no feed</h2>
      <form action="/petshop-panel/posts" method="POST" enctype="multipart/form-data" class="space-y-3">
        <input type="hidden" name="post_type" value="normal">
        <input class="input w-full" name="titulo" placeholder="Título">
        <textarea class="input w-full min-h-20" name="texto" placeholder="Legenda opcional"></textarea>
        <input class="input w-full" type="file" name="foto" accept="image/*" required>
        <button class="btn-primary-inline">Publicar no feed</button>
      </form>
    </div>
    <div class="partner-card">
      <h2 class="font-bold mb-3">Publicar promoção</h2>
      <form action="/petshop-panel/posts" method="POST" enctype="multipart/form-data" class="space-y-3">
        <input type="hidden" name="post_type" value="promocao">
        <input class="input w-full" name="titulo" placeholder="Título da promoção" required>
        <input class="input w-full" type="number" step="0.01" name="preco" placeholder="Preço" required>
        <textarea class="input w-full min-h-20" name="texto" placeholder="Descrição curta"></textarea>
        <input class="input w-full" type="file" name="foto" accept="image/*">
        <button class="btn-primary-inline">Publicar promoção</button>
      </form>
    </div>
  </section>

  <section class="partner-card">
    <h2 class="font-bold mb-3">Publicar serviço marketplace</h2>
    <form action="/petshop-panel/posts" method="POST" enctype="multipart/form-data" class="grid lg:grid-cols-2 gap-3">
      <input type="hidden" name="post_type" value="produto">
      <input class="input w-full" name="nome_produto" placeholder="Nome da oferta/serviço" required>
      <input class="input w-full" type="number" step="0.01" name="preco" placeholder="Preço" required>
      <select class="input w-full" name="service_id">
        <option value="">Vincular a serviço cadastrado (opcional)</option>
        <% (services || []).forEach(function(s) { %>
          <option value="<%= s.id %>"><%= s.nome %></option>
        <% }) %>
      </select>
      <input class="input w-full" name="contato_link" placeholder="Link de contato (opcional)">
      <textarea class="input w-full lg:col-span-2 min-h-20" name="descricao_produto" placeholder="Descrição completa da oferta"></textarea>
      <input class="input w-full lg:col-span-2" type="file" name="foto" accept="image/*">
      <div class="lg:col-span-2">
        <button class="btn-primary-inline">Publicar serviço no marketplace</button>
      </div>
    </form>
  </section>

  <section id="gerenciar" class="grid lg:grid-cols-2 gap-6">
    <div class="partner-card">
      <h2 class="font-bold mb-3">Gerenciar posts</h2>
      <% if (!(postsNormais || []).length) { %>
        <p class="text-sm text-[color:var(--text-dim)]">Sem posts para editar.</p>
      <% } else { %>
        <div class="space-y-3">
          <% (postsNormais || []).forEach(function(post) { %>
            <article class="partner-list-item">
              <form action="/petshop-panel/posts/<%= post.id %>/editar" method="POST" enctype="multipart/form-data" class="space-y-2">
                <input class="input w-full" name="titulo" value="<%= post.titulo || '' %>" placeholder="Título">
                <textarea class="input w-full min-h-20" name="texto" placeholder="Legenda"><%= post.texto || '' %></textarea>
                <input class="input w-full" type="file" name="foto" accept="image/*">
                <button class="btn-primary-inline text-sm">Salvar post</button>
              </form>
              <form action="/petshop-panel/posts/<%= post.id %>/remover" method="POST" class="mt-2">
                <button class="px-3 py-2 rounded-xl border border-red-200 bg-red-50 text-red-600 text-xs font-semibold">Excluir post</button>
              </form>
            </article>
          <% }) %>
        </div>
      <% } %>
    </div>

    <div class="partner-card">
      <h2 class="font-bold mb-3">Gerenciar promoções e serviços</h2>
      <% if (!((promocoes || []).length || (produtos || []).length)) { %>
        <p class="text-sm text-[color:var(--text-dim)]">Sem itens comerciais para editar.</p>
      <% } else { %>
        <div class="space-y-3">
          <% (promocoes || []).concat(produtos || []).forEach(function(item) { %>
            <article class="partner-list-item">
              <form action="/petshop-panel/produtos/<%= item.id %>/editar" method="POST" enctype="multipart/form-data" class="space-y-2">
                <input class="input w-full" name="nome" value="<%= item.nome || '' %>" placeholder="Nome" required>
                <input class="input w-full" type="number" step="0.01" name="preco" value="<%= item.preco != null ? item.preco : '' %>" placeholder="Preço">
                <textarea class="input w-full min-h-20" name="descricao" placeholder="Descrição"><%= item.descricao || '' %></textarea>
                <input class="input w-full" name="contato_link" value="<%= item.contato_link || '' %>" placeholder="Link de contato">
                <select class="input w-full" name="service_id">
                  <option value="">Sem vínculo com serviço</option>
                  <% (services || []).forEach(function(s) { %>
                    <option value="<%= s.id %>" <%= Number(item.service_id) === Number(s.id) ? 'selected' : '' %>><%= s.nome %></option>
                  <% }) %>
                </select>
                <input class="input w-full" type="file" name="foto" accept="image/*">
                <button class="btn-primary-inline text-sm">Salvar item</button>
              </form>
              <form action="/petshop-panel/produtos/<%= item.id %>/remover" method="POST" class="mt-2">
                <button class="px-3 py-2 rounded-xl border border-red-200 bg-red-50 text-red-600 text-xs font-semibold">Excluir item</button>
              </form>
            </article>
          <% }) %>
        </div>
      <% } %>
    </div>
  </section>
</main>

<%- include('../partials/footer') %>
