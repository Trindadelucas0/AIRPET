<% locals.titulo = 'Login do Parceiro' %>
<%- include('../partials/header') %>
<%- include('../partials/flash') %>

<main class="flex-1 container mx-auto max-w-md px-4 py-12">
  <div class="card">
    <h1 class="text-2xl font-bold text-gray-900 mb-2">Painel do Petshop Parceiro</h1>
    <p class="text-sm text-gray-500 mb-6">Acesse com o e-mail aprovado na parceria.</p>

    <form action="/petshop-panel/auth/login" method="POST" class="space-y-4">
      <input class="input w-full" type="email" name="email" placeholder="E-mail" required />
      <input class="input w-full" type="password" name="senha" placeholder="Senha" required />
      <button class="btn btn-primary w-full">Entrar</button>
    </form>
  </div>
</main>

<%- include('../partials/footer') %>
