<% locals.titulo = 'Chat' %>
<% locals.extraHead = '<style>.chat-container{display:flex;flex-direction:column;height:calc(100vh - 4rem);max-height:calc(100dvh - 4rem);}.msgs-scroll{flex:1;overflow-y:auto;-webkit-overflow-scrolling:touch;}</style>' %>
<%- include('../partials/header') %>

<div class="chat-container bg-gray-50">

  <div class="bg-white border-b border-gray-200 px-4 py-3 flex items-center gap-3 flex-shrink-0">
    <a href="/chat" class="w-9 h-9 rounded-full bg-gray-100 flex items-center justify-center text-gray-500 hover:bg-gray-200 transition-colors flex-shrink-0">
      <i class="fa-solid fa-arrow-left text-sm"></i>
    </a>
    <% if (pet) { %>
      <div class="w-10 h-10 rounded-full overflow-hidden bg-gray-100 flex-shrink-0">
        <% if (pet.foto) { %>
          <img src="<%= pet.foto %>" alt="<%= pet.nome %>" class="w-full h-full object-cover">
        <% } else { %>
          <div class="w-full h-full flex items-center justify-center">
            <i class="fa-solid fa-paw text-gray-300"></i>
          </div>
        <% } %>
      </div>
      <div class="min-w-0 flex-1">
        <p class="text-sm font-bold text-gray-900 truncate"><%= pet.nome %></p>
        <p class="text-xs text-gray-500">
          <% if (conversa.status === 'ativa') { %>
            <span class="inline-block w-1.5 h-1.5 rounded-full bg-emerald-400 mr-1"></span>Ativo
          <% } else { %>
            <span class="inline-block w-1.5 h-1.5 rounded-full bg-gray-300 mr-1"></span>Encerrado
          <% } %>
        </p>
      </div>
    <% } %>
  </div>

  <div class="msgs-scroll px-4 py-4 space-y-3" id="mensagensContainer">
    <% if (typeof mensagens !== 'undefined' && mensagens.length > 0) { %>
      <% mensagens.forEach(function(msg) { %>
        <%
          var isOwner = (typeof usuario !== 'undefined' && usuario && msg.remetente_id === usuario.id);
          var pendente = msg.status === 'pendente';
        %>
        <div class="flex <%= isOwner ? 'justify-end' : 'justify-start' %>">
          <div class="max-w-[80%] sm:max-w-[70%]">
            <div class="<%= isOwner
              ? 'bg-[#ec5a1c] text-white rounded-2xl rounded-br-md'
              : 'bg-white text-gray-800 rounded-2xl rounded-bl-md shadow-sm border border-gray-100' %> px-4 py-2.5">

              <% if (msg.tipo === 'imagem' && msg.arquivo) { %>
                <img src="/images/chat/<%= msg.arquivo %>" alt="Foto"
                     class="rounded-lg max-w-full mb-1 cursor-pointer"
                     onclick="window.open(this.src, '_blank')">
              <% } %>

              <% if (msg.conteudo) { %>
                <p class="text-sm leading-relaxed whitespace-pre-wrap"><%= msg.conteudo %></p>
              <% } %>
            </div>

            <div class="flex items-center gap-2 mt-1 px-1 <%= isOwner ? 'justify-end' : 'justify-start' %>">
              <span class="text-[10px] text-gray-400">
                <%= new Date(msg.createdAt).toLocaleTimeString('pt-BR', { hour: '2-digit', minute: '2-digit' }) %>
              </span>
              <% if (isOwner && msg.lida) { %>
                <i class="fa-solid fa-check-double text-[10px] text-blue-400"></i>
              <% } else if (isOwner) { %>
                <i class="fa-solid fa-check text-[10px] text-gray-300"></i>
              <% } %>
              <% if (pendente) { %>
                <span class="text-[10px] text-amber-500 font-medium">
                  <i class="fa-solid fa-clock mr-0.5"></i>Aguardando moderacao
                </span>
              <% } %>
            </div>
          </div>
        </div>
      <% }); %>
    <% } else { %>
      <div class="text-center py-12">
        <i class="fa-solid fa-comments text-4xl text-gray-200 mb-3"></i>
        <p class="text-sm text-gray-400">Nenhuma mensagem ainda. Comece a conversa!</p>
      </div>
    <% } %>
  </div>

  <% if (conversa.status === 'ativa') { %>
    <% if (typeof usuarioAtualId !== 'undefined' && usuarioAtualId === conversa.iniciador_id) { %>
      <div class="bg-amber-50 border-t border-amber-200 px-4 py-3 flex-shrink-0">
        <p class="text-xs text-amber-800 leading-relaxed flex items-start gap-2">
          <i class="fa-solid fa-circle-info mt-0.5 flex-shrink-0"></i>
          Para o tutor poder entrar em contato caso voce nao responda, informe seu e-mail e telefone em uma das mensagens.
        </p>
      </div>
    <% } %>
    <div class="bg-white border-t border-gray-200 px-4 py-3 flex-shrink-0">
      <form id="formMsg" class="flex items-end gap-2" action="/chat/<%= conversa.id %>/enviar" method="POST" enctype="multipart/form-data">

        <label class="w-10 h-10 rounded-full bg-gray-100 flex items-center justify-center text-gray-500 hover:bg-gray-200 transition-colors cursor-pointer flex-shrink-0">
          <i class="fa-solid fa-camera"></i>
          <input type="file" name="foto" accept="image/*" class="hidden" id="inputFoto"
                 onchange="if(this.files.length){document.getElementById('formMsg').submit();}">
        </label>

        <div class="flex-1 relative">
          <input type="text" name="conteudo" id="inputMsg" autocomplete="off"
                 placeholder="Digite sua mensagem..."
                 class="w-full px-4 py-2.5 rounded-2xl border border-gray-200 text-sm
                        focus:ring-2 focus:ring-[#ec5a1c]/30 focus:border-[#ec5a1c] transition-colors
                        placeholder:text-gray-400">
        </div>

        <button type="submit"
                class="w-10 h-10 rounded-full bg-[#ec5a1c] text-white flex items-center justify-center hover:bg-[#d4500f] active:scale-95 transition-all flex-shrink-0">
          <i class="fa-solid fa-paper-plane text-sm"></i>
        </button>
      </form>
    </div>
  <% } else { %>
    <div class="bg-gray-100 border-t border-gray-200 px-4 py-4 text-center flex-shrink-0">
      <p class="text-sm text-gray-500">
        <i class="fa-solid fa-lock mr-1"></i>
        Esta conversa foi encerrada.
      </p>
    </div>
  <% } %>

</div>

<% locals.extraScripts = `
<script src="/socket.io/socket.io.js"></script>
<script>
(function() {
  var container = document.getElementById('mensagensContainer');
  if (container) container.scrollTop = container.scrollHeight;

  var conversaId = ${conversa.id};
  var socket = io();
  socket.emit('entrar_conversa', conversaId);

  socket.on('nova_mensagem', function(msg) {
    if (!container) return;
    var isOwner = msg.remetente_id === ${typeof usuario !== 'undefined' && usuario ? usuario.id : 0};
    var div = document.createElement('div');
    div.className = 'flex ' + (isOwner ? 'justify-end' : 'justify-start');

    var bubbleClass = isOwner
      ? 'bg-[#ec5a1c] text-white rounded-2xl rounded-br-md'
      : 'bg-white text-gray-800 rounded-2xl rounded-bl-md shadow-sm border border-gray-100';

    var html = '<div class="max-w-[80%] sm:max-w-[70%]">';
    html += '<div class="' + bubbleClass + ' px-4 py-2.5">';
    if (msg.conteudo) html += '<p class="text-sm leading-relaxed whitespace-pre-wrap">' + msg.conteudo.replace(/</g, '&lt;') + '</p>';
    html += '</div>';
    html += '<div class="flex items-center gap-2 mt-1 px-1 ' + (isOwner ? 'justify-end' : 'justify-start') + '">';
    html += '<span class="text-[10px] text-gray-400">' + new Date().toLocaleTimeString('pt-BR', { hour: '2-digit', minute: '2-digit' }) + '</span>';
    if (msg.status === 'pendente') {
      html += '<span class="text-[10px] text-amber-500 font-medium"><i class="fa-solid fa-clock mr-0.5"></i>Aguardando moderacao</span>';
    }
    html += '</div></div>';

    div.innerHTML = html;
    container.appendChild(div);
    container.scrollTop = container.scrollHeight;
  });

  var form = document.getElementById('formMsg');
  var input = document.getElementById('inputMsg');
  if (form && input) {
    form.addEventListener('submit', function(e) {
      var texto = input.value.trim();
      if (!texto) { e.preventDefault(); return; }
      if (socket.connected) {
        e.preventDefault();
        socket.emit('enviar_mensagem', { conversa_id: conversaId, conteudo: texto });
        input.value = '';
        input.focus();
      }
    });
  }
})();
</script>
` %>

<%- include('../partials/footer') %>
