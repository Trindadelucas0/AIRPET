<%- include('../partials/header') %>
<%- include('../partials/flash') %>

<main class="flex-1 py-4 px-3 sm:px-4">
  <section class="air-mobile-screen">
    <%- include('../partials/mobile-screen-header', {
      badge: 'Conta AIRPET',
      title: 'Crie sua conta',
      subtitle: 'Primeiro o essencial, depois os dados opcionais.',
      slotHtml: `
        <div class="grid grid-cols-2 gap-2" aria-hidden="true">
          <span id="registroStep1Badge" class="inline-flex items-center justify-center rounded-full px-3 py-2 text-xs font-semibold bg-[color:var(--accent)]/15 text-[color:var(--accent)]">1. Conta</span>
          <span id="registroStep2Badge" class="inline-flex items-center justify-center rounded-full px-3 py-2 text-xs font-semibold bg-[color:var(--ink-3)] text-[color:var(--text-dim)]">2. Perfil opcional</span>
        </div>
      `
    }) %>

    <form action="/auth/registro" method="POST" class="air-card mt-4 air-form-stack" id="registroForm">
      <section data-step="1" class="air-form-stack">
        <div>
          <label for="nome" class="air-form-label">Nome completo</label>
          <input type="text" id="nome" name="nome" required autocomplete="name" placeholder="Seu nome" class="input-field w-full">
        </div>
        <div class="air-form-row">
          <div>
            <label for="email" class="air-form-label">E-mail</label>
            <input type="email" id="email" name="email" required autocomplete="email" placeholder="seu@email.com" class="input-field w-full">
          </div>
          <div>
            <label for="telefone" class="air-form-label">Telefone</label>
            <input type="tel" id="telefone" name="telefone" autocomplete="tel" placeholder="(00) 00000-0000" class="input-field w-full">
          </div>
        </div>
        <div>
          <label for="senha" class="air-form-label">Senha</label>
          <div class="relative">
            <input type="password" id="senha" name="senha" required minlength="6" autocomplete="new-password" placeholder="Mínimo 6 caracteres" class="input-field w-full pr-12">
            <button type="button" id="toggleSenha" class="absolute right-3 top-1/2 -translate-y-1/2 text-[color:var(--text-dim)]" aria-label="Mostrar ou ocultar senha">
              <i class="fa-solid fa-eye text-sm" id="eyeIcon"></i>
            </button>
          </div>
          <div class="mt-2 flex items-center gap-2">
            <div class="flex-1 h-1.5 bg-gray-100 rounded-full overflow-hidden">
              <div id="strengthBar" class="h-full rounded-full transition-all duration-500 ease-out w-0 bg-gray-300"></div>
            </div>
            <span id="strengthText" class="text-[10px] font-semibold text-gray-400 uppercase tracking-wider min-w-[50px] text-right"></span>
          </div>
        </div>
        <div>
          <label for="confirmarSenha" class="air-form-label">Confirmar senha</label>
          <div class="relative">
            <input type="password" id="confirmarSenha" name="confirmarSenha" required minlength="6" autocomplete="new-password" placeholder="Repita a senha" class="input-field w-full pr-12">
            <button type="button" id="toggleConfirmar" class="absolute right-3 top-1/2 -translate-y-1/2 text-[color:var(--text-dim)]" aria-label="Mostrar ou ocultar confirmação de senha">
              <i class="fa-solid fa-eye text-sm" id="eyeIconConfirmar"></i>
            </button>
          </div>
          <p id="senhaMatch" class="hidden air-feedback-inline"></p>
        </div>
        <div>
          <label class="flex items-start gap-2.5 cursor-pointer select-none">
            <input type="checkbox" name="termos" value="1" required class="w-4 h-4 mt-0.5 rounded border-gray-300 text-primary-500 focus:ring-primary-500/30">
            <span class="text-xs text-[color:var(--text-dim)] leading-relaxed">
              Li e aceito os
              <a href="/termos" class="font-semibold text-[color:var(--accent)] hover:underline" target="_blank">Termos de Uso</a>
              e a
              <a href="/privacidade" class="font-semibold text-[color:var(--accent)] hover:underline" target="_blank">Política de Privacidade</a>.
            </span>
          </label>
        </div>
        <button type="button" id="goStep2" class="btn-primary">Continuar</button>
      </section>

      <section data-step="2" class="air-form-stack hidden">
        <p class="text-xs text-[color:var(--text-dim)]">Preenchimento opcional para personalizar seu perfil.</p>
        <div class="air-form-row">
          <div>
            <label for="cep" class="air-form-label">CEP</label>
            <input type="text" id="cep" name="cep" maxlength="9" placeholder="00000-000" class="input-field w-full">
          </div>
          <div>
            <label for="estado" class="air-form-label">Estado</label>
            <input type="text" id="estado" name="estado" maxlength="2" placeholder="UF" class="input-field w-full uppercase">
          </div>
        </div>
        <div>
          <label for="endereco" class="air-form-label">Endereço</label>
          <input type="text" id="endereco" name="endereco" placeholder="Rua, número" class="input-field w-full">
        </div>
        <div class="air-form-row">
          <div>
            <label for="bairro" class="air-form-label">Bairro</label>
            <input type="text" id="bairro" name="bairro" placeholder="Bairro" class="input-field w-full">
          </div>
          <div>
            <label for="cidade" class="air-form-label">Cidade</label>
            <input type="text" id="cidade" name="cidade" placeholder="Cidade" class="input-field w-full">
          </div>
        </div>
        <div>
          <label for="bio" class="air-form-label">Sobre você</label>
          <textarea id="bio" name="bio" maxlength="160" rows="3" placeholder="Conte um pouco sobre você e seus pets..." class="input-field w-full resize-none"></textarea>
          <p class="text-xs text-[color:var(--text-dim)] mt-1"><span id="bioCount">0</span>/160</p>
        </div>
        <div class="grid grid-cols-2 gap-2">
          <button type="button" id="backStep1" class="btn-ghost">Voltar</button>
          <button type="submit" id="btnRegistro" class="btn-primary flex items-center justify-center gap-2">
            <span id="btnRegistroText">Criar conta</span>
            <svg id="btnRegistroSpinner" class="hidden animate-spin h-4 w-4 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
              <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
              <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
            </svg>
          </button>
        </div>
      </section>
    </form>

    <p class="text-center text-sm text-[color:var(--text-dim)] mt-4">
      Já tem conta?
      <a href="/auth/login" class="font-semibold text-[color:var(--accent)] hover:underline">Entrar</a>
    </p>
  </section>
    </div>
</main>

<script>
(function () {
  var currentStep = 1;
  var stepOne = document.querySelector('[data-step="1"]');
  var stepTwo = document.querySelector('[data-step="2"]');
  var goStep2 = document.getElementById('goStep2');
  var backStep1 = document.getElementById('backStep1');
  var step1Badge = document.getElementById('registroStep1Badge');
  var step2Badge = document.getElementById('registroStep2Badge');

  function setStep(step) {
    currentStep = step;
    var oneActive = step === 1;
    if (stepOne) stepOne.classList.toggle('hidden', !oneActive);
    if (stepTwo) stepTwo.classList.toggle('hidden', oneActive);
    if (step1Badge) step1Badge.className = oneActive
      ? 'inline-flex items-center justify-center rounded-full px-3 py-2 text-xs font-semibold bg-[color:var(--accent)]/15 text-[color:var(--accent)]'
      : 'inline-flex items-center justify-center rounded-full px-3 py-2 text-xs font-semibold bg-[color:var(--ink-3)] text-[color:var(--text-dim)]';
    if (step2Badge) step2Badge.className = !oneActive
      ? 'inline-flex items-center justify-center rounded-full px-3 py-2 text-xs font-semibold bg-[color:var(--accent)]/15 text-[color:var(--accent)]'
      : 'inline-flex items-center justify-center rounded-full px-3 py-2 text-xs font-semibold bg-[color:var(--ink-3)] text-[color:var(--text-dim)]';
  }

  if (goStep2) {
    goStep2.addEventListener('click', function () {
      var required = ['nome', 'email', 'senha', 'confirmarSenha'];
      var allValid = required.every(function (id) {
        var el = document.getElementById(id);
        return el && el.value.trim().length > 0;
      });
      if (!allValid) return;
      var senhaEl = document.getElementById('senha');
      var confirmarEl = document.getElementById('confirmarSenha');
      if (senhaEl && confirmarEl && senhaEl.value !== confirmarEl.value) return;
      setStep(2);
    });
  }
  if (backStep1) {
    backStep1.addEventListener('click', function () { setStep(1); });
  }

  // Toggle password visibility — main password
  var toggle = document.getElementById('toggleSenha');
  var senhaInput = document.getElementById('senha');
  var eyeIcon = document.getElementById('eyeIcon');
  if (toggle && senhaInput && eyeIcon) {
    toggle.addEventListener('click', function () {
      var show = senhaInput.type === 'password';
      senhaInput.type = show ? 'text' : 'password';
      eyeIcon.className = show ? 'fa-solid fa-eye-slash text-sm' : 'fa-solid fa-eye text-sm';
    });
  }

  // Toggle password visibility — confirm password
  var toggleC = document.getElementById('toggleConfirmar');
  var confirmarInput = document.getElementById('confirmarSenha');
  var eyeIconC = document.getElementById('eyeIconConfirmar');
  if (toggleC && confirmarInput && eyeIconC) {
    toggleC.addEventListener('click', function () {
      var show = confirmarInput.type === 'password';
      confirmarInput.type = show ? 'text' : 'password';
      eyeIconC.className = show ? 'fa-solid fa-eye-slash text-sm' : 'fa-solid fa-eye text-sm';
    });
  }

  // Password strength indicator
  var strengthBar = document.getElementById('strengthBar');
  var strengthText = document.getElementById('strengthText');
  if (senhaInput && strengthBar && strengthText) {
    senhaInput.addEventListener('input', function () {
      var val = senhaInput.value;
      var score = 0;
      if (val.length >= 4) score++;
      if (val.length >= 6) score++;
      if (val.length >= 8) score++;
      if (/[A-Z]/.test(val)) score++;
      if (/[0-9]/.test(val)) score++;
      if (/[^A-Za-z0-9]/.test(val)) score++;

      var levels = [
        { w: '0%',   color: 'bg-gray-300',    label: '' },
        { w: '16%',  color: 'bg-red-400',     label: 'Fraca' },
        { w: '33%',  color: 'bg-orange-400',  label: 'Fraca' },
        { w: '50%',  color: 'bg-amber-400',   label: 'Média' },
        { w: '70%',  color: 'bg-emerald-400', label: 'Boa' },
        { w: '85%',  color: 'bg-emerald-500', label: 'Forte' },
        { w: '100%', color: 'bg-emerald-600', label: 'Ótima' }
      ];

      var level = levels[Math.min(score, levels.length - 1)];
      strengthBar.style.width = level.w;
      strengthBar.className = 'h-full rounded-full transition-all duration-500 ease-out ' + level.color;
      strengthText.textContent = val.length > 0 ? level.label : '';

      var textColors = { Fraca: 'text-red-400', Média: 'text-amber-500', Boa: 'text-emerald-500', Forte: 'text-emerald-600', 'Ótima': 'text-emerald-700' };
      strengthText.className = 'text-[10px] font-semibold uppercase tracking-wider min-w-[50px] text-right ' + (textColors[level.label] || 'text-gray-400');

      checkMatch();
    });
  }

  // Password match checker
  var matchEl = document.getElementById('senhaMatch');
  function checkMatch() {
    if (!confirmarInput || !senhaInput || !matchEl) return;
    var cv = confirmarInput.value;
    if (cv.length === 0) { matchEl.classList.add('hidden'); return; }
    matchEl.classList.remove('hidden');
    if (cv === senhaInput.value) {
      matchEl.innerHTML = '<i class="fa-solid fa-circle-check text-emerald-500"></i> <span class="text-emerald-600">Senhas conferem</span>';
    } else {
      matchEl.innerHTML = '<i class="fa-solid fa-circle-xmark text-red-400"></i> <span class="text-red-500">Senhas não conferem</span>';
    }
  }
  if (confirmarInput) confirmarInput.addEventListener('input', checkMatch);

  // Phone mask
  var telefoneInput = document.getElementById('telefone');
  if (telefoneInput) {
    telefoneInput.addEventListener('input', function () {
      var v = telefoneInput.value.replace(/\D/g, '').substring(0, 11);
      if (v.length > 6) {
        v = '(' + v.substring(0, 2) + ') ' + v.substring(2, 7) + '-' + v.substring(7);
      } else if (v.length > 2) {
        v = '(' + v.substring(0, 2) + ') ' + v.substring(2);
      } else if (v.length > 0) {
        v = '(' + v;
      }
      telefoneInput.value = v;
    });
  }

  // Form submit loading state
  var form = document.getElementById('registroForm');
  var btn = document.getElementById('btnRegistro');
  var btnText = document.getElementById('btnRegistroText');
  var spinner = document.getElementById('btnRegistroSpinner');
  if (form && btn) {
    form.addEventListener('submit', function (e) {
      if (senhaInput && confirmarInput && senhaInput.value !== confirmarInput.value) {
        e.preventDefault();
        if (matchEl) { matchEl.classList.remove('hidden'); matchEl.innerHTML = '<i class="fa-solid fa-circle-xmark text-red-400"></i> <span class="text-red-500">Senhas não conferem</span>'; }
        confirmarInput.focus();
        return;
      }
      if (currentStep === 1) {
        e.preventDefault();
        setStep(2);
        return;
      }
      btn.disabled = true;
      if (btnText) btnText.textContent = 'Criando conta...';
      if (spinner) spinner.classList.remove('hidden');
      var arrow = btn.querySelector('.fa-arrow-right');
      if (arrow) arrow.classList.add('hidden');
    });
  }
})();
</script>

<%- include('../partials/footer') %>
