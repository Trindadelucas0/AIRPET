<%- include('../partials/header') %>

<%- include('../partials/flash') %>

<main class="flex-1 flex items-center justify-center py-6 px-4 sm:px-6">
  <div class="w-full max-w-5xl animate-slideUp">
    <div class="flex rounded-3xl shadow-2xl overflow-hidden bg-white min-h-[540px]">

      <!-- Left Panel — decorative (hidden on mobile) -->
      <div class="hidden lg:flex lg:w-1/2 relative overflow-hidden bg-gradient-to-br from-primary-500 to-orange-700">
        <!-- Animated background shapes -->
        <div class="absolute inset-0 overflow-hidden">
          <div class="absolute -top-20 -left-20 w-72 h-72 bg-white/10 rounded-full blur-2xl" style="animation: floatA 8s ease-in-out infinite;"></div>
          <div class="absolute bottom-10 -right-16 w-64 h-64 bg-white/10 rounded-full blur-2xl" style="animation: floatB 10s ease-in-out infinite;"></div>
          <div class="absolute top-1/2 left-1/3 w-40 h-40 bg-white/5 rounded-full blur-xl" style="animation: floatA 12s ease-in-out infinite reverse;"></div>

          <!-- Decorative paw prints -->
          <i class="fa-solid fa-paw absolute top-12 right-16 text-white/10 text-6xl rotate-[-20deg]"></i>
          <i class="fa-solid fa-paw absolute bottom-20 left-10 text-white/10 text-5xl rotate-[15deg]"></i>
          <i class="fa-solid fa-paw absolute top-1/3 left-12 text-white/10 text-4xl rotate-[-35deg]"></i>
          <i class="fa-solid fa-paw absolute bottom-1/3 right-20 text-white/8 text-3xl rotate-[25deg]"></i>

          <!-- Grid pattern -->
          <div class="absolute inset-0" style="background-image: radial-gradient(circle, rgba(255,255,255,0.06) 1px, transparent 1px); background-size: 30px 30px;"></div>
        </div>

        <!-- Content -->
        <div class="relative z-10 flex flex-col items-center justify-center w-full px-10 text-center">
          <!-- Logo icon -->
          <div class="w-20 h-20 bg-white/20 backdrop-blur-sm rounded-3xl flex items-center justify-center mb-6 shadow-lg" style="animation: floatB 6s ease-in-out infinite;">
            <i class="fa-solid fa-paw text-white text-3xl"></i>
          </div>

          <h2 class="text-white text-3xl font-black tracking-tight mb-3">AIRPET</h2>
          <div class="w-12 h-1 bg-white/40 rounded-full mb-6"></div>

          <p class="text-white/90 text-lg font-medium leading-relaxed mb-4">
            Proteja quem você ama.
          </p>
          <p class="text-white/70 text-sm leading-relaxed max-w-xs">
            Identificação inteligente via NFC, rede de proteção e comunidade unida
            para garantir a segurança do seu pet.
          </p>

          <!-- Feature pills -->
          <div class="flex flex-wrap justify-center gap-2 mt-8">
            <span class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-white/15 backdrop-blur-sm rounded-full text-white/90 text-xs font-medium">
              <i class="fa-solid fa-shield-dog text-[10px]"></i> NFC Tag
            </span>
            <span class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-white/15 backdrop-blur-sm rounded-full text-white/90 text-xs font-medium">
              <i class="fa-solid fa-map-location-dot text-[10px]"></i> Geolocalização
            </span>
            <span class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-white/15 backdrop-blur-sm rounded-full text-white/90 text-xs font-medium">
              <i class="fa-solid fa-bell text-[10px]"></i> Alertas
            </span>
          </div>
        </div>
      </div>

      <!-- Right Panel — login form -->
      <div class="w-full lg:w-1/2 flex flex-col justify-center px-6 sm:px-10 lg:px-14 py-10">

        <!-- Mobile logo -->
        <div class="flex items-center gap-2.5 mb-8 lg:mb-10 animate-fadeIn">
          <span class="bg-gradient-to-br from-primary-500 to-primary-600 text-white w-10 h-10 rounded-2xl flex items-center justify-center shadow-lg shadow-primary-500/20">
            <i class="fa-solid fa-paw text-base"></i>
          </span>
          <span class="text-xl font-black tracking-tight bg-gradient-to-r from-primary-500 to-primary-600 bg-clip-text text-transparent">AIRPET</span>
        </div>

        <h1 class="text-2xl sm:text-3xl font-extrabold text-gray-900 tracking-tight mb-1 animate-fadeIn" style="animation-delay: .05s">
          Bem-vindo de volta
        </h1>
        <p class="text-gray-400 text-sm mb-8 animate-fadeIn" style="animation-delay: .1s">
          Entre para continuar cuidando do seu pet
        </p>

        <!-- Form -->
        <form action="/auth/login" method="POST" class="space-y-5" id="loginForm">

          <!-- Email -->
          <div class="animate-fadeIn" style="animation-delay: .15s">
            <label for="email" class="block text-xs font-semibold text-gray-600 mb-1.5 uppercase tracking-wide">E-mail</label>
            <div class="relative">
              <span class="absolute left-3.5 top-1/2 -translate-y-1/2 text-gray-400">
                <i class="fa-solid fa-envelope text-sm"></i>
              </span>
              <input type="email" id="email" name="email" required autocomplete="email"
                     placeholder="seu@email.com"
                     class="w-full pl-10 pr-4 py-3 rounded-xl border border-gray-200 bg-gray-50/60 text-sm
                            placeholder:text-gray-300
                            focus:outline-none focus:border-primary-500 focus:ring-2 focus:ring-primary-500/20 focus:bg-white
                            transition-all duration-200">
            </div>
          </div>

          <!-- Password -->
          <div class="animate-fadeIn" style="animation-delay: .2s">
            <label for="senha" class="block text-xs font-semibold text-gray-600 mb-1.5 uppercase tracking-wide">Senha</label>
            <div class="relative">
              <span class="absolute left-3.5 top-1/2 -translate-y-1/2 text-gray-400">
                <i class="fa-solid fa-lock text-sm"></i>
              </span>
              <input type="password" id="senha" name="senha" required autocomplete="current-password"
                     placeholder="••••••••"
                     class="w-full pl-10 pr-11 py-3 rounded-xl border border-gray-200 bg-gray-50/60 text-sm
                            placeholder:text-gray-300
                            focus:outline-none focus:border-primary-500 focus:ring-2 focus:ring-primary-500/20 focus:bg-white
                            transition-all duration-200">
              <button type="button" id="toggleSenha"
                      class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 hover:text-gray-600 transition-colors p-1"
                      aria-label="Mostrar/ocultar senha">
                <i class="fa-solid fa-eye text-sm" id="eyeIcon"></i>
              </button>
            </div>
          </div>

          <!-- Remember + Forgot -->
          <div class="flex items-center justify-between animate-fadeIn" style="animation-delay: .25s">
            <label class="flex items-center gap-2 cursor-pointer select-none group">
              <input type="checkbox" name="lembrar" value="1"
                     class="w-4 h-4 rounded border-gray-300 text-primary-500 focus:ring-primary-500/30 transition">
              <span class="text-xs text-gray-500 group-hover:text-gray-700 transition-colors">Lembrar de mim</span>
            </label>
            <a href="/auth/esqueci-senha" class="text-xs font-medium text-primary-500 hover:text-primary-600 transition-colors hover:underline">
              Esqueci minha senha
            </a>
          </div>

          <!-- Submit -->
          <div class="animate-fadeIn" style="animation-delay: .3s">
            <button type="submit" id="btnLogin"
                    class="w-full py-3.5 rounded-xl text-sm font-bold text-white
                           bg-gradient-to-r from-primary-500 to-primary-600
                           hover:shadow-lg hover:shadow-primary-500/25 hover:-translate-y-0.5
                           active:scale-[0.98] active:shadow-none
                           focus:outline-none focus:ring-2 focus:ring-primary-500/40 focus:ring-offset-2
                           transition-all duration-300
                           disabled:opacity-40 disabled:cursor-not-allowed
                           flex items-center justify-center gap-2">
              <span id="btnLoginText">Entrar</span>
              <i class="fa-solid fa-arrow-right text-xs"></i>
              <svg id="btnLoginSpinner" class="hidden animate-spin h-4 w-4 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
              </svg>
            </button>
          </div>
        </form>

        <!-- Divider -->
        <div class="flex items-center gap-3 my-6 animate-fadeIn" style="animation-delay: .35s">
          <div class="flex-1 h-px bg-gray-200"></div>
          <span class="text-xs text-gray-400 font-medium">ou</span>
          <div class="flex-1 h-px bg-gray-200"></div>
        </div>

        <!-- Register link -->
        <p class="text-center text-sm text-gray-500 animate-fadeIn" style="animation-delay: .4s">
          Não tem conta?
          <a href="/auth/registro" class="font-semibold text-primary-500 hover:text-primary-600 transition-colors hover:underline">
            Criar conta
          </a>
        </p>

      </div>
    </div>
  </div>
</main>

<style>
  @keyframes floatA {
    0%, 100% { transform: translateY(0) translateX(0); }
    50% { transform: translateY(-20px) translateX(10px); }
  }
  @keyframes floatB {
    0%, 100% { transform: translateY(0) translateX(0); }
    50% { transform: translateY(15px) translateX(-10px); }
  }
</style>

<script>
(function () {
  var toggle = document.getElementById('toggleSenha');
  var senhaInput = document.getElementById('senha');
  var eyeIcon = document.getElementById('eyeIcon');
  if (toggle && senhaInput && eyeIcon) {
    toggle.addEventListener('click', function () {
      var show = senhaInput.type === 'password';
      senhaInput.type = show ? 'text' : 'password';
      eyeIcon.className = show ? 'fa-solid fa-eye-slash text-sm' : 'fa-solid fa-eye text-sm';
    });
  }

  var form = document.getElementById('loginForm');
  var btn = document.getElementById('btnLogin');
  var btnText = document.getElementById('btnLoginText');
  var spinner = document.getElementById('btnLoginSpinner');
  if (form && btn) {
    form.addEventListener('submit', function () {
      btn.disabled = true;
      if (btnText) btnText.textContent = 'Entrando...';
      if (spinner) spinner.classList.remove('hidden');
      var arrow = btn.querySelector('.fa-arrow-right');
      if (arrow) arrow.classList.add('hidden');
    });
  }
})();
</script>

<%- include('../partials/footer') %>
