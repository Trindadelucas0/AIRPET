<% locals.titulo = 'Redefinir Senha' %>
<%- include('../partials/header') %>
<%- include('../partials/flash') %>

<main class="flex-1 container mx-auto px-4 py-6 flex items-center justify-center">
  <div class="w-full max-w-md">

    <div class="text-center mb-8">
      <div class="inline-flex items-center justify-center w-16 h-16 rounded-2xl bg-primary-50 text-primary-500 mb-4">
        <i class="fa-solid fa-key text-3xl"></i>
      </div>
      <h1 class="text-2xl font-bold text-gray-900">Redefinir Senha</h1>
      <p class="text-gray-500 mt-1 text-sm">Crie uma nova senha para acessar sua conta.</p>
    </div>

    <form action="/auth/redefinir-senha" method="POST" class="card space-y-5">

      <input type="hidden" name="token" value="<%= typeof token !== 'undefined' ? token : '' %>">

      <div>
        <label for="senha" class="block text-sm font-medium text-gray-700 mb-1">Nova senha</label>
        <div class="relative">
          <input type="password" id="senha" name="senha" required minlength="6"
                 placeholder="Mínimo 6 caracteres"
                 class="input-field pr-11">
          <button type="button" onclick="toggleSenha(this, 'senha')"
                  class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 hover:text-gray-600 transition-colors">
            <i class="fa-solid fa-eye"></i>
          </button>
        </div>
      </div>

      <div>
        <label for="confirmarSenha" class="block text-sm font-medium text-gray-700 mb-1">Confirmar nova senha</label>
        <div class="relative">
          <input type="password" id="confirmarSenha" name="confirmarSenha" required minlength="6"
                 placeholder="Repita a nova senha"
                 class="input-field pr-11">
          <button type="button" onclick="toggleSenha(this, 'confirmarSenha')"
                  class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 hover:text-gray-600 transition-colors">
            <i class="fa-solid fa-eye"></i>
          </button>
        </div>
      </div>

      <button type="submit" class="btn-primary">
        <i class="fa-solid fa-lock mr-2"></i>Redefinir Senha
      </button>
    </form>

    <p class="text-center text-sm text-gray-500 mt-6">
      <a href="/auth/login" class="text-primary-500 hover:text-primary-600 font-semibold">
        <i class="fa-solid fa-arrow-left mr-1"></i>Voltar ao login
      </a>
    </p>

  </div>
</main>

<script>
function toggleSenha(btn, id) {
  var input = document.getElementById(id);
  var icon = btn.querySelector('i');
  if (input.type === 'password') {
    input.type = 'text';
    icon.className = 'fa-solid fa-eye-slash';
  } else {
    input.type = 'password';
    icon.className = 'fa-solid fa-eye';
  }
}
</script>

<%- include('../partials/footer') %>
