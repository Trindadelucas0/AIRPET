<% locals.titulo = titulo || 'Cadastro temporariamente indisponível' %>
<%- include('../partials/header') %>

<main class="flex-1 flex items-center justify-center py-12 px-4 sm:px-6">
  <div class="w-full max-w-md animate-slideUp">
    <div class="bg-white rounded-2xl shadow-xl border border-gray-100 p-8 sm:p-10 text-center">
      <div class="w-16 h-16 mx-auto mb-6 rounded-2xl bg-amber-50 text-amber-500 flex items-center justify-center">
        <i class="fa-solid fa-users-slash text-2xl"></i>
      </div>
      <h1 class="text-xl font-bold text-gray-900 mb-3">Cadastro temporariamente indisponível</h1>
      <p class="text-gray-600 text-sm leading-relaxed mb-8">
        No momento atingimos o número máximo de usuários na sua região. Tente novamente em algumas horas.
      </p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a href="/" class="inline-flex items-center justify-center gap-2 px-5 py-2.5 rounded-xl text-sm font-semibold text-gray-700 bg-gray-100 hover:bg-gray-200 transition-colors">
          <i class="fa-solid fa-house text-xs"></i> Voltar ao início
        </a>
        <a href="/auth/login" class="inline-flex items-center justify-center gap-2 px-5 py-2.5 rounded-xl text-sm font-semibold text-white bg-primary-500 hover:bg-primary-600 transition-colors">
          <i class="fa-solid fa-right-to-bracket text-xs"></i> Fazer login
        </a>
      </div>
    </div>
  </div>
</main>

<%- include('../partials/footer') %>
