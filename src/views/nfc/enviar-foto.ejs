<% locals.titulo = 'Enviar Foto do Pet' %>
<%- include('../partials/header') %>
<%- include('../partials/flash') %>

<main class="flex-1 container mx-auto px-4 py-8 max-w-lg">
  <%- include('../partials/page-header', { backHref: '/tag/' + tag_code, backLabel: 'Voltar', sticky: false }) %>

  <div class="text-center mb-8 mt-6">
    <div class="flex justify-center mb-4">
      <div class="w-28 h-28 rounded-full ring-4 ring-primary-500/20 shadow-xl overflow-hidden bg-white">
        <% if (pet.foto) { %>
          <img src="<%= pet.foto %>" alt="<%= pet.nome %>" class="w-full h-full object-cover">
        <% } else { %>
          <div class="w-full h-full flex items-center justify-center bg-orange-50">
            <i class="fa-solid fa-paw text-4xl text-orange-300"></i>
          </div>
        <% } %>
      </div>
    </div>
    <h1 class="text-2xl font-bold text-gray-900"><%= pet.nome %></h1>
    <p class="text-gray-500 text-sm mt-1">Envie uma foto de como o pet esta agora</p>
  </div>

  <div class="card">
    <form action="/tag/<%= tag_code %>/enviar-foto" method="POST" enctype="multipart/form-data" class="space-y-5" id="formFoto">

      <div>
        <label for="foto"
               class="flex flex-col items-center justify-center gap-3 w-full py-10 border-2 border-dashed border-gray-300 rounded-2xl cursor-pointer
                      hover:border-primary-500/40 hover:bg-primary-50/50 transition-colors"
               id="uploadArea">
          <div class="w-16 h-16 rounded-full bg-primary-500/10 flex items-center justify-center" id="uploadIconWrap">
            <i class="fa-solid fa-camera text-2xl text-primary-500" id="uploadIcon"></i>
          </div>
          <div class="text-center">
            <p class="text-sm font-semibold text-gray-700" id="uploadTitle">Toque para tirar ou escolher uma foto</p>
            <p class="text-xs text-gray-400 mt-1" id="uploadHint">JPG, PNG — ate 5MB</p>
          </div>
          <input type="file" id="foto" name="foto" accept="image/*" class="hidden" required>
        </label>
      </div>

      <div id="previewContainer" class="hidden">
        <div class="relative rounded-2xl overflow-hidden shadow-sm">
          <img id="previewImg" class="w-full max-h-64 object-cover" alt="Preview da foto">
          <button type="button" id="btnRemover"
                  class="absolute top-3 right-3 w-8 h-8 rounded-full bg-black/50 text-white flex items-center justify-center hover:bg-black/70 transition-colors">
            <i class="fa-solid fa-xmark text-sm"></i>
          </button>
        </div>
      </div>

      <input type="hidden" name="pet_id" value="<%= pet.id %>">

      <button type="submit" id="btnEnviar" disabled
              class="btn-primary text-lg disabled:opacity-40 disabled:cursor-not-allowed">
        <i class="fa-solid fa-paper-plane mr-2"></i>Enviar Foto
      </button>
    </form>

    <div class="mt-6 bg-emerald-50 border border-emerald-200 rounded-xl p-4">
      <div class="flex items-start gap-2.5">
        <i class="fa-solid fa-heart text-emerald-400 mt-0.5 flex-shrink-0"></i>
        <p class="text-sm text-emerald-700 leading-relaxed">
          Obrigado por ajudar! Sua foto sera enviada diretamente ao dono de <strong><%= pet.nome %></strong> e pode fazer toda a diferenca.
        </p>
      </div>
    </div>
  </div>

</main>

<% locals.extraScripts = `
<script>
(function() {
  var inputFoto = document.getElementById('foto');
  var previewContainer = document.getElementById('previewContainer');
  var previewImg = document.getElementById('previewImg');
  var uploadArea = document.getElementById('uploadArea');
  var uploadIcon = document.getElementById('uploadIcon');
  var uploadTitle = document.getElementById('uploadTitle');
  var uploadHint = document.getElementById('uploadHint');
  var btnEnviar = document.getElementById('btnEnviar');
  var btnRemover = document.getElementById('btnRemover');

  function mostrarPreview(file) {
    var reader = new FileReader();
    reader.onload = function(e) {
      previewImg.src = e.target.result;
      previewContainer.classList.remove('hidden');
      uploadIcon.className = 'fa-solid fa-check text-2xl text-emerald-500';
      uploadTitle.textContent = 'Foto selecionada';
      uploadHint.textContent = 'Toque para trocar';
      btnEnviar.disabled = false;
    };
    reader.readAsDataURL(file);
  }

  function limparPreview() {
    inputFoto.value = '';
    previewContainer.classList.add('hidden');
    previewImg.src = '';
    uploadIcon.className = 'fa-solid fa-camera text-2xl text-primary-500';
    uploadTitle.textContent = 'Toque para tirar ou escolher uma foto';
    uploadHint.textContent = 'JPG, PNG — ate 5MB';
    btnEnviar.disabled = true;
  }

  if (uploadArea) {
    uploadArea.addEventListener('click', function (ev) {
      var PS = window.airpetPermissionSheet;
      if (!PS || typeof PS.prepareFilePickerWithCameraHint !== 'function') return;
      ev.preventDefault();
      ev.stopPropagation();
      PS.prepareFilePickerWithCameraHint(inputFoto).then(function () { inputFoto.click(); });
    }, true);
  }

  if (inputFoto) {
    inputFoto.addEventListener('change', function() {
      if (this.files && this.files[0]) {
        mostrarPreview(this.files[0]);
      }
    });
  }

  if (btnRemover) {
    btnRemover.addEventListener('click', function(e) {
      e.preventDefault();
      e.stopPropagation();
      limparPreview();
    });
  }
})();
</script>
` %>

<%- include('../partials/footer') %>
