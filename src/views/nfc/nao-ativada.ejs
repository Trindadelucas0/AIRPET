<% locals.titulo = 'Tag Nao Ativada' %>
<%- include('../partials/header') %>
<%- include('../partials/flash') %>

<main class="flex-1 container mx-auto px-4 py-10 max-w-lg">

  <div class="card text-center py-12 px-6">

    <div class="inline-flex items-center justify-center w-24 h-24 rounded-full bg-gray-100 mb-6">
      <div class="relative">
        <i class="fa-solid fa-nfc-magnifying-glass text-4xl text-gray-300"></i>
        <span class="absolute -bottom-1 -right-1 w-8 h-8 rounded-full bg-amber-100 flex items-center justify-center">
          <i class="fa-solid fa-lock text-amber-500 text-sm"></i>
        </span>
      </div>
    </div>

    <h1 class="text-2xl font-bold text-gray-900 mb-3">Tag nao ativada</h1>

    <% if (tag.status === 'sent') { %>
      <div class="bg-emerald-50 border border-emerald-200 rounded-xl p-4 mb-6">
        <div class="flex items-center justify-center gap-2 text-emerald-700 font-semibold mb-1">
          <i class="fa-solid fa-truck-fast"></i>
          Sua tag esta pronta!
        </div>
        <p class="text-emerald-600 text-sm">
          Sua tag foi enviada e esta pronta para ser ativada. Clique no botao abaixo para comecar.
        </p>
      </div>
    <% } else { %>
      <p class="text-gray-500 leading-relaxed mb-6">
        Esta tag ainda nao esta protegendo nenhum pet.
        <br>Se voce comprou esta tag, ative agora e comece a proteger seu companheiro.
      </p>
    <% } %>

    <div class="bg-gray-50 rounded-xl p-5 mb-8">
      <p class="text-xs text-gray-400 uppercase font-semibold tracking-wider mb-2">Codigo da tag</p>
      <p class="text-lg font-mono font-bold text-gray-800 tracking-widest"><%= tag.codigo %></p>
    </div>

    <a href="/tags/<%= tag.codigo %>/ativar"
       class="btn-primary text-lg">
      <i class="fa-solid fa-bolt"></i>
      ATIVAR MINHA TAG
    </a>

    <p class="text-xs text-gray-400 mt-6">
      <i class="fa-solid fa-circle-info mr-1"></i>
      Voce precisara estar logado e ter o codigo de ativacao que veio na embalagem.
    </p>
  </div>

</main>

<%- include('../partials/footer') %>
