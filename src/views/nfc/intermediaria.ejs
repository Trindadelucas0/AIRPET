<% locals.titulo = 'Pet Encontrado - ' + pet.nome %>
<%- include('../partials/header') %>

<main class="flex-1 min-h-screen bg-slate-100">
  <%- include('../partials/flash') %>
  <% var perdido = (typeof pet !== 'undefined' && pet && pet.status === 'perdido') || (typeof petPerdido !== 'undefined' && petPerdido && petPerdido.status === 'aprovado'); %>
  <% var telefone = (dono && dono.telefone) || pet.telefone_contato; %>
  <% var ultimaCidade = (ultimaLocalizacao && ultimaLocalizacao.cidade) || (petPerdido && petPerdido.cidade) || null; %>

  <% if (perdido) { %>
    <div class="bg-red-600 text-white text-center px-4 py-3">
      <strong><i class="fa-solid fa-triangle-exclamation mr-1"></i> ESTE PET ESTA PERDIDO</strong>
      <p class="text-red-100 text-sm mt-1">O tutor esta procurando. Ajude com qualquer informacao.</p>
    </div>
  <% } %>

  <div class="max-w-2xl mx-auto px-4 py-6 md:py-8 space-y-4">
    <section class="bg-white rounded-3xl shadow-md border border-slate-200 p-5 md:p-6">
      <div class="flex flex-col sm:flex-row gap-4 items-center sm:items-start">
        <div class="w-28 h-28 rounded-2xl overflow-hidden bg-slate-100 border border-slate-200 shrink-0">
          <% if (pet.foto) { %>
            <img src="<%= pet.foto %>" alt="<%= pet.nome %>" class="w-full h-full object-cover">
          <% } else { %>
            <div class="w-full h-full flex items-center justify-center text-slate-400"><i class="fa-solid fa-paw text-4xl"></i></div>
          <% } %>
        </div>
        <div class="flex-1 text-center sm:text-left">
          <div class="inline-flex items-center gap-2 text-xs font-bold uppercase tracking-wide px-3 py-1 rounded-full <%= perdido ? 'bg-red-100 text-red-700' : 'bg-emerald-100 text-emerald-700' %>">
            <i class="fa-solid <%= perdido ? 'fa-triangle-exclamation' : 'fa-shield-check' %>"></i>
            <%= perdido ? 'Perdido' : 'Tag ativa' %>
          </div>
          <h1 class="text-3xl font-extrabold text-slate-900 mt-2"><%= pet.nome %></h1>
          <p class="text-slate-600 text-sm mt-1">
            <%= pet.tipo ? (pet.tipo.charAt(0).toUpperCase() + pet.tipo.slice(1)) : 'Pet' %>
            <% if (pet.raca) { %> • <%= pet.raca %><% } %>
            <% if (pet.porte) { %> • <%= pet.porte %><% } %>
          </p>
          <% if (pet.descricao_emocional) { %>
            <p class="text-slate-700 italic mt-3">"<%= pet.descricao_emocional %>"</p>
          <% } %>
        </div>
      </div>
    </section>

    <% if (perdido && petPerdido && petPerdido.recompensa) { %>
      <section class="bg-amber-100 text-amber-900 rounded-2xl border border-amber-300 p-4 text-center">
        <div class="font-semibold"><i class="fa-solid fa-gift mr-1"></i> Recompensa oferecida</div>
        <p class="text-2xl font-extrabold">R$ <%= parseFloat(petPerdido.recompensa).toFixed(2).replace('.', ',') %></p>
      </section>
    <% } %>

    <section class="bg-white rounded-3xl shadow-sm border border-slate-200 p-5">
      <h2 class="text-sm font-bold text-slate-500 uppercase tracking-wide mb-3">Contato rapido</h2>
      <div class="space-y-3">
        <% if (telefone) { %>
          <a href="tel:<%= telefone %>" class="flex items-center gap-3 w-full bg-emerald-500 hover:bg-emerald-600 text-white rounded-2xl px-4 py-4 transition">
            <i class="fa-solid fa-phone text-xl"></i>
            <span class="font-semibold">Ligar para <%= (dono && dono.nome) || 'o tutor' %></span>
          </a>
        <% } %>
        <button type="button" id="btnLocalizacao" class="flex items-center gap-3 w-full bg-blue-500 hover:bg-blue-600 text-white rounded-2xl px-4 py-4 transition">
          <i class="fa-solid fa-location-dot text-xl"></i>
          <span class="font-semibold text-lg">Enviar minha localizacao</span>
        </button>
        <a href="/tag/<%= tag.tag_code %>/encontrei" class="flex items-center gap-3 w-full bg-rose-500 hover:bg-rose-600 text-white rounded-2xl px-4 py-4 transition">
          <i class="fa-solid fa-hand-holding-heart text-xl"></i>
          <span class="font-semibold">Encontrei este pet</span>
        </a>
      </div>
    </section>

    <section class="bg-white rounded-3xl shadow-sm border border-slate-200 p-5">
      <h2 class="text-sm font-bold text-slate-500 uppercase tracking-wide mb-3">Mais informacoes do pet</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 text-sm">
        <div class="rounded-xl bg-slate-50 p-3"><strong class="block text-slate-700">Saude</strong><span class="text-slate-600"><%= pet.alergias_medicacoes || 'Sem informacoes de alergias/medicacoes' %></span></div>
        <div class="rounded-xl bg-slate-50 p-3"><strong class="block text-slate-700">Comportamento</strong><span class="text-slate-600"><%= pet.observacoes || pet.descricao_emocional || 'Sem observacoes comportamentais' %></span></div>
        <div class="rounded-xl bg-slate-50 p-3"><strong class="block text-slate-700">Contato alternativo</strong><span class="text-slate-600"><%= pet.telefone_contato || (dono && dono.telefone) || 'Nao informado' %></span></div>
        <div class="rounded-xl bg-slate-50 p-3"><strong class="block text-slate-700">Ultima localizacao</strong><span class="text-slate-600"><%= ultimaCidade || 'Nao informada' %></span></div>
      </div>
      <% if (petPerdido && petPerdido.descricao) { %>
        <div class="rounded-xl bg-red-50 border border-red-100 p-3 mt-3 text-sm text-red-700">
          <strong class="block">Observacao do tutor sobre o desaparecimento</strong>
          <span><%= petPerdido.descricao %></span>
        </div>
      <% } %>
    </section>

    <a href="<%= petshopMaisProximo ? ('/petshops/' + (petshopMaisProximo.slug || petshopMaisProximo.id)) : '/petshops?apoio=1' %>"
       class="flex items-center gap-3 w-full bg-violet-600 hover:bg-violet-700 text-white rounded-2xl px-4 py-4 transition">
      <i class="fa-solid fa-store text-xl"></i>
      <span class="font-semibold">
        Levar ao petshop parceiro
        <% if (petshopMaisProximo && petshopMaisProximo.nome) { %>
          - <%= petshopMaisProximo.nome %>
        <% } %>
      </span>
    </a>

    <% if (perdido) { %>
      <section class="bg-white rounded-3xl shadow-sm border border-slate-200 p-5 space-y-3">
        <h3 class="text-sm font-bold text-slate-500 uppercase tracking-wide">Acoes extras</h3>
        <a href="/chat/novo/<%= pet.id %>" target="_blank" rel="noopener" class="block w-full rounded-2xl border border-slate-300 px-4 py-3 text-slate-700 hover:bg-slate-50">
          <i class="fa-solid fa-comments mr-2"></i> Conversar com o tutor
        </a>
        <a href="/tag/<%= tag.tag_code %>/enviar-foto" class="block w-full rounded-2xl border border-slate-300 px-4 py-3 text-slate-700 hover:bg-slate-50">
          <i class="fa-solid fa-camera mr-2"></i> Enviar foto do pet agora
        </a>
      </section>
    <% } %>

    <p class="text-center text-slate-500 text-xs leading-relaxed px-2">
      <i class="fa-solid fa-lock mr-1"></i>
      Sua localizacao pode ser compartilhada para ajudar no resgate. Nenhum dado sensivel e exibido publicamente.
    </p>
  </div>
</main>

<% locals.extraScripts = `
<script>
(function() {
  var tagCode = '${tag.tag_code}';

  function enviarLocalizacao(lat, lng, manual) {
    var doFetch = function () {
      return fetch('/tag/' + tagCode + '/localizacao', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        credentials: 'same-origin',
        body: JSON.stringify({
          latitude: lat,
          longitude: lng,
          tipo: manual ? 'encontrador_manual' : 'encontrador_auto'
        })
      });
    };
    if (manual) {
      var L = window.AIRPET_LOADING;
      if (L && typeof L.withDeferredOverlay === 'function') {
        L.withDeferredOverlay(doFetch, { message: 'A enviar localização…' }).catch(function () {});
        return;
      }
    }
    doFetch().catch(function () {});
  }

  if (navigator.geolocation) {
    navigator.geolocation.getCurrentPosition(
      function(pos) {
        enviarLocalizacao(pos.coords.latitude, pos.coords.longitude, false);
      },
      function(err) {
        console.warn('[NFC] Geoloc auto falhou:', err.code, err.message);
      },
      { enableHighAccuracy: true, timeout: 12000 }
    );
  }

  var btn = document.getElementById('btnLocalizacao');
  if (btn) {
    btn.addEventListener('click', function() {
      var icon = btn.querySelector('.fa-location-dot');
      var label = btn.querySelector('.text-lg');
      if (navigator.geolocation) {
        label.textContent = 'Obtendo localizacao...';
        if (icon) icon.className = 'fa-solid fa-spinner fa-spin text-2xl';
        navigator.geolocation.getCurrentPosition(
          function(pos) {
            enviarLocalizacao(pos.coords.latitude, pos.coords.longitude, true);
            label.textContent = 'Localizacao enviada!';
            if (icon) icon.className = 'fa-solid fa-check text-2xl';
            btn.classList.remove('bg-blue-500', 'hover:bg-blue-600');
            btn.classList.add('bg-emerald-500');
          },
          function(err) {
            var msg = (window.airpetGeo && window.airpetGeo.getErrorMessage)
              ? window.airpetGeo.getErrorMessage(err)
              : 'Nao foi possivel obter localizacao';
            label.textContent = msg.length > 40 ? 'Localizacao bloqueada' : msg;
            if (icon) icon.className = 'fa-solid fa-xmark text-2xl';
            if (window.airpetGeo && window.airpetGeo.isIOS && err.code === 1) {
              alert(window.airpetGeo.getErrorMessage(err));
            }
          },
          { enableHighAccuracy: true, timeout: 15000 }
        );
      } else {
        label.textContent = 'Navegador sem suporte';
      }
    });
  }
})();
</script>
` %>

<%- include('../partials/footer') %>
