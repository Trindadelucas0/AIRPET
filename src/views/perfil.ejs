<% locals.titulo = 'Configurações' %>
<%- include('partials/header') %>
<%- include('partials/flash') %>

<main class="flex-1 pb-24 md:pb-6">
  <div class="max-w-2xl mx-auto px-4 py-6">

    <h1 class="text-2xl font-black text-gray-900 mb-6 animate-slideUp">
      <i class="fa-solid fa-gear text-primary-500 mr-2"></i>Configurações
    </h1>

    <!-- Profile Card -->
    <div class="card card-hover mb-6 overflow-hidden animate-slideUp" style="animation-delay: 0.05s">
      <div class="h-20 rounded-t-3xl bg-gradient-to-r from-primary-500 to-primary-600 -m-6 mb-0"></div>
      <div class="px-2 pb-2 -mt-8 relative">
        <div class="flex items-end gap-4">
          <% if (perfil.foto_perfil) { %>
            <img src="<%= perfil.foto_perfil %>" alt="" class="w-20 h-20 rounded-2xl object-cover border-4 border-white shadow-lg">
          <% } else { %>
            <div class="w-20 h-20 rounded-2xl border-4 border-white shadow-lg flex items-center justify-center text-2xl font-bold text-white"
                 style="background: <%= perfil.cor_perfil || '#ec5a1c' %>">
              <%= perfil.nome ? perfil.nome.charAt(0).toUpperCase() : 'U' %>
            </div>
          <% } %>
          <div class="pb-1">
            <h2 class="text-xl font-bold text-gray-900"><%= perfil.nome %></h2>
            <p class="text-sm text-gray-500"><%= perfil.email %></p>
          </div>
        </div>
        <a href="/explorar/perfil/<%= perfil.id %>" class="mt-4 inline-flex items-center gap-2 text-sm text-primary-500 font-medium hover:underline">
          <i class="fa-solid fa-eye"></i> Ver meu perfil público
        </a>
      </div>
    </div>

    <!-- Pets -->
    <div class="card card-hover mb-6 animate-slideUp" style="animation-delay: 0.1s">
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-lg font-bold text-gray-900"><i class="fa-solid fa-paw mr-2 text-primary-500"></i>Meus Pets</h2>
        <a href="/pets" class="text-sm text-primary-500 font-medium hover:underline">Ver todos</a>
      </div>
      <% if (pets && pets.length > 0) { %>
        <div class="flex gap-3 overflow-x-auto scrollbar-hide pb-2">
          <% pets.slice(0, 8).forEach(function(pet) { %>
            <a href="/pets/<%= pet.id %>" class="flex-shrink-0 flex flex-col items-center w-20 p-2 rounded-2xl hover:bg-primary-50 transition-colors">
              <% if (pet.foto) { %>
                <img src="<%= pet.foto %>" alt="<%= pet.nome %>" class="w-14 h-14 rounded-full object-cover ring-2 ring-primary-100">
              <% } else { %>
                <div class="w-14 h-14 rounded-full bg-gray-100 flex items-center justify-center">
                  <i class="fa-solid fa-paw text-gray-400"></i>
                </div>
              <% } %>
              <span class="text-xs font-semibold text-gray-800 mt-1.5 truncate w-full text-center"><%= pet.nome %></span>
            </a>
          <% }) %>
        </div>
      <% } else { %>
        <div class="text-center py-6 text-gray-400">
          <i class="fa-solid fa-dog text-3xl mb-2 opacity-40"></i>
          <p class="text-sm">Nenhum pet cadastrado.</p>
          <a href="/pets/cadastro" class="text-sm text-primary-500 font-medium hover:underline mt-1 inline-block">Cadastrar pet</a>
        </div>
      <% } %>
    </div>

    <!-- Edit Form -->
    <div class="card animate-slideUp" style="animation-delay: 0.15s">
      <h2 class="text-lg font-bold text-gray-900 mb-5"><i class="fa-solid fa-user-pen mr-2 text-primary-500"></i>Editar Perfil</h2>

      <form action="/perfil?_method=PUT" method="POST">
        <input type="hidden" name="_method" value="PUT">

        <div class="space-y-5">
          <div>
            <label for="nome" class="block text-sm font-semibold text-gray-700 mb-1.5">Nome</label>
            <input type="text" id="nome" name="nome" value="<%= perfil.nome %>" required class="input-field">
          </div>

          <div>
            <label for="telefone" class="block text-sm font-semibold text-gray-700 mb-1.5">Telefone</label>
            <input type="tel" id="telefone" name="telefone" value="<%= perfil.telefone || '' %>" placeholder="(00) 00000-0000" class="input-field">
          </div>

          <div>
            <label class="block text-sm font-semibold text-gray-700 mb-2">Cor do Perfil</label>
            <div class="flex flex-wrap gap-2" id="colorPicker">
              <% var cores = ['#ec5a1c','#e74c3c','#e91e63','#9b59b6','#673ab7','#3f51b5','#2196f3','#03a9f4','#00bcd4','#009688','#4caf50','#8bc34a','#ff9800','#ff5722','#795548','#607d8b','#000000']; %>
              <% cores.forEach(function(cor) { %>
                <button type="button" onclick="selecionarCor('<%= cor %>')"
                        class="w-9 h-9 rounded-full border-2 transition-all duration-200 hover:scale-110 active:scale-95 <%= (perfil.cor_perfil || '#ec5a1c') === cor ? 'border-gray-900 ring-2 ring-offset-2 ring-gray-400 scale-110' : 'border-transparent' %>"
                        style="background: <%= cor %>" data-cor="<%= cor %>">
                </button>
              <% }) %>
            </div>
            <input type="hidden" name="cor_perfil" id="cor_perfil" value="<%= perfil.cor_perfil || '#ec5a1c' %>">
          </div>

          <div class="pt-1">
            <button type="submit" class="btn-primary">
              <i class="fa-solid fa-check mr-2"></i>Salvar Alterações
            </button>
          </div>
        </div>
      </form>
    </div>

    <!-- Danger Zone -->
    <div class="mt-6 text-center">
      <a href="/auth/logout" class="inline-flex items-center gap-2 text-sm text-red-500 hover:text-red-600 font-medium transition-colors">
        <i class="fa-solid fa-right-from-bracket"></i> Sair da conta
      </a>
    </div>

  </div>
</main>

<script>
function selecionarCor(cor) {
  document.getElementById('cor_perfil').value = cor;
  document.querySelectorAll('#colorPicker button').forEach(function(btn) {
    btn.classList.remove('border-gray-900', 'ring-2', 'ring-offset-2', 'ring-gray-400', 'scale-110');
    btn.classList.add('border-transparent');
  });
  var btn = document.querySelector('#colorPicker button[data-cor="' + cor + '"]');
  if (btn) {
    btn.classList.remove('border-transparent');
    btn.classList.add('border-gray-900', 'ring-2', 'ring-offset-2', 'ring-gray-400', 'scale-110');
  }
}
</script>

<%- include('partials/footer') %>
