function toggleSecao(secao) {
  var view = document.querySelector('.secao-' + secao + '-view');
  var edit = document.querySelector('.secao-' + secao + '-edit');
  var btns = document.querySelectorAll('.secao-' + secao);
  if (!view || !edit) return;
  if (edit.classList.contains('hidden')) {
    view.classList.add('hidden');
    edit.classList.remove('hidden');
    btns.forEach(function(b) { if (b.classList.contains('perfil-btn-editar')) b.classList.add('hidden'); });
  } else {
    edit.classList.add('hidden');
    view.classList.remove('hidden');
    btns.forEach(function(b) { if (b.classList.contains('perfil-btn-editar')) b.classList.remove('hidden'); });
  }
}

