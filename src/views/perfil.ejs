function tryOpenCropModal(dataUrl, options, fallbackFile) {
  function doOpen() {
    if (typeof openCropModal === 'function' && typeof Cropper !== 'undefined') {
      openCropModal(options);
      return true;
    }
    return false;
  }
  if (doOpen()) return;
  var attempts = 0;
  var maxAttempts = 15;
  var interval = setInterval(function() {
    attempts++;
    if (doOpen()) { clearInterval(interval); return; }
    if (attempts >= maxAttempts) {
      clearInterval(interval);
      if (fallbackFile && options.onConfirm) {
        fetch(dataUrl).then(function(r) { return r.blob(); }).then(function(blob) {
          options.onConfirm(blob);
        }).catch(function() {
          alert('Não foi possível carregar o editor de fotos. Tente recarregar a página ou use outra rede.');
        });
      } else {
        alert('Não foi possível carregar o editor de fotos. Tente recarregar a página ou use outra rede.');
      }
    }
  }, 200);
}

