document.getElementById('btnBuscarCep').addEventListener('click', function() {
  var cep = cepInput.value.replace(/\D/g, '');
  if (cep.length !== 8) return;
  var btn = this;
  btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin text-sm"></i>';
  fetch('https://viacep.com.br/ws/' + cep + '/json/')
    .then(function(r) { return r.json(); })
    .then(function(d) {
      if (d.erro) { alert('CEP não encontrado.'); return; }
      if (d.logradouro) document.getElementById('endereco').value = d.logradouro;
      if (d.bairro) document.getElementById('bairro').value = d.bairro;
      if (d.localidade) document.getElementById('cidade').value = d.localidade;
      if (d.uf) document.getElementById('estado').value = d.uf;
    })
    .catch(function() { alert('Erro ao buscar CEP.'); })
    .finally(function() { btn.innerHTML = '<i class="fa-solid fa-magnifying-glass text-sm"></i>'; });
});

document.getElementById('btnGeolocalizacao').addEventListener('click', function() {
  var btn = this;
  if (!navigator.geolocation) { alert('Geolocalização não suportada.'); return; }
  btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin mr-2"></i> Obtendo localização...';
  btn.disabled = true;
  navigator.geolocation.getCurrentPosition(
    function(pos) {
      var lat = pos.coords.latitude;
      var lng = pos.coords.longitude;
      fetch('/api/localizacao/atualizar', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ latitude: lat, longitude: lng })
      }).then(function() {
        fetch('https://nominatim.openstreetmap.org/reverse?lat=' + lat + '&lon=' + lng + '&format=json&accept-language=pt-BR')
          .then(function(r) { return r.json(); })
          .then(function(d) {
            var a = d.address || {};
            if (a.road) document.getElementById('endereco').value = a.road + (a.house_number ? ', ' + a.house_number : '');
            if (a.suburb || a.neighbourhood) document.getElementById('bairro').value = a.suburb || a.neighbourhood;
            if (a.city || a.town || a.municipality) document.getElementById('cidade').value = a.city || a.town || a.municipality;
            var ufMap = {'São Paulo':'SP','Rio de Janeiro':'RJ','Minas Gerais':'MG','Bahia':'BA','Paraná':'PR','Rio Grande do Sul':'RS','Pernambuco':'PE','Ceará':'CE','Pará':'PA','Maranhão':'MA','Santa Catarina':'SC','Goiás':'GO','Paraíba':'PB','Espírito Santo':'ES','Amazonas':'AM','Rio Grande do Norte':'RN','Alagoas':'AL','Piauí':'PI','Mato Grosso':'MT','Distrito Federal':'DF','Mato Grosso do Sul':'MS','Sergipe':'SE','Rondônia':'RO','Tocantins':'TO','Acre':'AC','Amapá':'AP','Roraima':'RR'};
            if (a.state && ufMap[a.state]) document.getElementById('estado').value = ufMap[a.state];
            if (a.postcode) {
              var cepVal = a.postcode.replace(/\D/g, '');
              if (cepVal.length >= 8) {
                cepInput.value = cepVal.slice(0,5) + '-' + cepVal.slice(5,8);
              }
            }
            btn.innerHTML = '<i class="fa-solid fa-check text-green-500 mr-2"></i> Localização obtida!';
            setTimeout(function() { btn.innerHTML = '<i class="fa-solid fa-crosshairs"></i> Usar minha localização atual'; btn.disabled = false; }, 2000);
          });
      });
    },
    function() {
      alert('Não foi possível obter sua localização.');
      btn.innerHTML = '<i class="fa-solid fa-crosshairs"></i> Usar minha localização atual';
      btn.disabled = false;
    },
    { enableHighAccuracy: true, timeout: 10000 }
  );
});

(function galeriaPerfil() {
  var container = document.getElementById('galeriaPorPetContainer');
  var loading = document.getElementById('galeriaLoading');
  var btnAdd = document.getElementById('btnAdicionarFotoGaleria');
  var fileInput = document.getElementById('galeriaFileInput');
  var petSelect = document.getElementById('galeriaPetSelect');
  if (!container || !btnAdd) return;

  function renderGaleria(galeria) {
    if (!galeria || galeria.length === 0) {
      container.innerHTML = '<p class="text-sm text-gray-500 text-center py-4">Nenhuma foto ainda. Escolha um pet e clique em Adicionar foto.</p>';
      return;
    }
    var html = '';
    galeria.forEach(function(item) {
      html += '<div class="border border-gray-100 rounded-xl p-3" data-pet-id="' + item.pet_id + '">';
      html += '<h4 class="text-sm font-bold text-gray-700 mb-2">' + (item.pet_nome || 'Pet') + '</h4>';
      html += '<div class="flex flex-wrap gap-2">';
      (item.fotos || []).forEach(function(f) {
        html += '<div class="relative group"><img src="' + f.foto + '" alt="" class="w-20 h-20 object-cover rounded-lg">';
        html += '<button type="button" class="absolute top-1 right-1 w-6 h-6 rounded-full bg-red-500 text-white text-xs flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity btn-remover-foto-galeria" data-id="' + f.id + '"><i class="fa-solid fa-xmark"></i></button></div>';
      });
      html += '</div></div>';
    });
    container.innerHTML = html;
    container.querySelectorAll('.btn-remover-foto-galeria').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var id = this.getAttribute('data-id');
        if (!confirm('Remover esta foto?')) return;
        fetch('/perfil/galeria/' + id, { method: 'DELETE', credentials: 'same-origin' })
          .then(function(r) { return r.json(); })
          .then(function(data) {
            if (data.sucesso) carregarGaleria();
          });
      });
    });
  }

  function carregarGaleria() {
    fetch('/perfil/galeria', { credentials: 'same-origin' })
      .then(function(r) { return r.json(); })
      .then(function(data) {
        renderGaleria(data.galeria || []);
      })
      .catch(function() {
        container.innerHTML = '<p class="text-sm text-red-500 text-center py-4">Erro ao carregar.</p>';
      });
  }

  btnAdd.addEventListener('click', function() { fileInput.click(); });
  fileInput.addEventListener('change', function() {
    if (!this.files || !this.files[0]) return;
    var file = this.files[0];
    if (!file.type.match(/^image\/(jpeg|png|gif|webp)$/)) { alert('Formato não suportado.'); this.value = ''; return; }
    var reader = new FileReader();
    reader.onload = function(ev) {
      fileInput.value = '';
      if (typeof openCropModal !== 'function') { alert('Recorte não disponível.'); return; }
      var petId = petSelect ? petSelect.value : '';
      if (!petId) { alert('Selecione um pet.'); return; }
      openCropModal({
        src: ev.target.result,
        aspectRatio: 0,
        maxWidth: 1200,
        maxHeight: 1200,
        onConfirm: function(blob) {
          var fd = new FormData();
          fd.append('pet_id', petId);
          fd.append('foto', new File([blob], 'foto.jpg', { type: 'image/jpeg' }));
          fetch('/perfil/galeria', { method: 'POST', body: fd, credentials: 'same-origin' })
            .then(function(r) { return r.json(); })
            .then(function(data) {
              if (data.sucesso) carregarGaleria();
              else alert(data.mensagem || 'Erro.');
            })
            .catch(function() { alert('Erro ao enviar.'); });
        }
      });
    };
    reader.readAsDataURL(file);
  });

  carregarGaleria();
})();
</script>

