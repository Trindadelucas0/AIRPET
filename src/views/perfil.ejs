<% locals.titulo = 'Configurações' %>
<%- include('partials/header') %>
<%- include('partials/flash') %>

<main class="flex-1 pb-24 md:pb-6">
  <div class="max-w-2xl mx-auto px-4 py-6">

    <h1 class="text-2xl font-black text-gray-900 mb-6 animate-slideUp">
      <i class="fa-solid fa-gear text-primary-500 mr-2"></i>Configurações
    </h1>

    <!-- Profile Card -->
    <div class="card card-hover mb-6 overflow-hidden animate-slideUp" style="animation-delay: 0.05s">
      <div class="h-20 rounded-t-3xl bg-gradient-to-r from-primary-500 to-primary-600 -m-6 mb-0"></div>
      <div class="px-2 pb-2 -mt-8 relative">
        <div class="flex items-end gap-4">
          <% var corDestaque = perfil.cor_perfil || '#ec5a1c'; %>
          <% if (perfil.foto_perfil) { %>
            <img src="<%= perfil.foto_perfil %>" alt="" class="w-20 h-20 rounded-2xl object-cover border-4 border-white shadow-lg" style="box-shadow: 0 0 0 2px <%= corDestaque %>">
          <% } else { %>
            <div class="w-20 h-20 rounded-2xl border-4 border-white shadow-lg flex items-center justify-center text-2xl font-bold text-white bg-gray-400"
                 style="box-shadow: 0 0 0 2px <%= corDestaque %>">
              <%= perfil.nome ? perfil.nome.charAt(0).toUpperCase() : 'U' %>
            </div>
          <% } %>
          <div class="pb-1">
            <h2 class="text-xl font-bold text-gray-900"><%= perfil.nome %></h2>
            <p class="text-sm text-gray-500"><%= perfil.email %></p>
            <% if (perfil.cidade) { %>
              <p class="text-xs text-gray-400 mt-0.5"><i class="fa-solid fa-location-dot mr-1"></i><%= perfil.bairro ? perfil.bairro + ', ' : '' %><%= perfil.cidade %><%= perfil.estado ? ' - ' + perfil.estado : '' %></p>
            <% } %>
          </div>
        </div>
        <a href="/explorar/perfil/<%= perfil.id %>" class="mt-4 inline-flex items-center gap-2 text-sm text-primary-500 font-medium hover:underline">
          <i class="fa-solid fa-paw"></i> Ver meus pets no explorar
        </a>
      </div>
    </div>

    <!-- Pets -->
    <div class="card card-hover mb-6 animate-slideUp" style="animation-delay: 0.1s">
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-lg font-bold text-gray-900"><i class="fa-solid fa-paw mr-2 text-primary-500"></i>Meus Pets</h2>
        <a href="/pets" class="text-sm text-primary-500 font-medium hover:underline">Ver todos</a>
      </div>
      <% if (pets && pets.length > 0) { %>
        <div class="flex gap-3 overflow-x-auto scrollbar-hide pb-2">
          <% pets.slice(0, 8).forEach(function(pet) { %>
            <a href="/pets/<%= pet.id %>" class="flex-shrink-0 flex flex-col items-center w-20 p-2 rounded-2xl hover:bg-primary-50 transition-colors">
              <% if (pet.foto) { %>
                <img src="<%= pet.foto %>" alt="<%= pet.nome %>" class="w-14 h-14 rounded-full object-cover ring-2 ring-primary-100">
              <% } else { %>
                <div class="w-14 h-14 rounded-full bg-gray-100 flex items-center justify-center">
                  <i class="fa-solid fa-paw text-gray-400"></i>
                </div>
              <% } %>
              <span class="text-xs font-semibold text-gray-800 mt-1.5 truncate w-full text-center"><%= pet.nome %></span>
            </a>
          <% }) %>
        </div>
      <% } else { %>
        <div class="text-center py-6 text-gray-400">
          <i class="fa-solid fa-dog text-3xl mb-2 opacity-40"></i>
          <p class="text-sm">Nenhum pet cadastrado.</p>
          <a href="/pets/cadastro" class="text-sm text-primary-500 font-medium hover:underline mt-1 inline-block">Cadastrar pet</a>
        </div>
      <% } %>
      <p class="text-xs text-gray-400 mt-2">Gerencie e edite os perfis dos seus pets em <a href="/pets" class="text-primary-500 hover:underline">Meus Pets</a>.</p>
    </div>

    <!-- Seção: Rede social — quantidade de postagem -->
    <div class="card animate-slideUp mb-6" style="animation-delay: 0.13s">
      <div class="flex items-center justify-between mb-2">
        <h2 class="text-lg font-bold text-gray-900"><i class="fa-solid fa-images mr-2 text-primary-500"></i>Publicações</h2>
      </div>
      <p class="text-sm text-gray-600 mb-3">Você pode publicar até 10 fotos no feed. Exclua posts antigos para liberar espaço.</p>
      <div class="flex items-center gap-3 flex-wrap">
        <span class="inline-flex items-center gap-2 px-3 py-1.5 rounded-xl text-sm font-semibold <%= (typeof totalPosts !== 'undefined' ? totalPosts : 0) >= 10 ? 'bg-red-50 text-red-600' : 'bg-gray-100 text-gray-700' %>">
          <i class="fa-solid fa-camera"></i>
          <%= typeof totalPosts !== 'undefined' ? totalPosts : 0 %>/10 publicações
        </span>
        <a href="/feed" class="inline-flex items-center gap-1.5 text-sm font-medium text-primary-500 hover:text-primary-600 hover:underline">
          <i class="fa-solid fa-arrow-right"></i> Ver minhas publicações
        </a>
      </div>
    </div>

    <!-- Seção: Foto de perfil -->
    <div class="card animate-slideUp mb-6" style="animation-delay: 0.12s">
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-lg font-bold text-gray-900"><i class="fa-solid fa-image mr-2 text-primary-500"></i>Foto de perfil</h2>
      </div>
      <div class="perfil-secao-view">
        <div class="flex items-center gap-4">
          <button type="button" id="btnAbrirFotoPerfil" class="relative flex-shrink-0 rounded-full focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2" title="Trocar ou ajustar foto">
            <% if (perfil.foto_perfil) { %>
              <img src="<%= perfil.foto_perfil %>" alt="" id="previewFotoPerfil" class="w-16 h-16 rounded-full object-cover border-2 border-gray-200 block" style="box-shadow: 0 0 0 2px <%= perfil.cor_perfil || '#ec5a1c' %>">
            <% } else { %>
              <div id="previewFotoPerfil" class="w-16 h-16 rounded-full border-2 border-gray-200 flex items-center justify-center text-2xl font-bold text-white bg-gray-400" style="box-shadow: 0 0 0 2px <%= perfil.cor_perfil || '#ec5a1c' %>"><%= (perfil.nome || 'U').charAt(0).toUpperCase() %></div>
            <% } %>
            <span class="absolute bottom-0 right-0 w-6 h-6 rounded-full bg-primary-500 text-white flex items-center justify-center text-xs shadow" title="Ajustar foto"><i class="fa-solid fa-crop"></i></span>
          </button>
          <div>
            <p class="text-sm text-gray-600">Clique na foto para alterar e recortar.</p>
            <div id="fotoPerfilAcoes" class="mt-2 hidden">
              <button type="button" id="btnSalvarFotoPerfil" class="btn-primary text-sm py-1.5 px-3 mr-2"><i class="fa-solid fa-check mr-1"></i>Salvar foto</button>
              <button type="button" id="btnCancelarFotoPerfil" class="text-sm text-gray-500 hover:text-gray-700">Cancelar</button>
            </div>
          </div>
        </div>
      </div>
      <input type="file" id="foto_perfil" accept="image/*" class="hidden">
    </div>

    <!-- Seção: Capa -->
    <div class="card animate-slideUp mb-6" style="animation-delay: 0.14s">
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-lg font-bold text-gray-900"><i class="fa-solid fa-image mr-2 text-primary-500"></i>Capa do perfil</h2>
      </div>
      <div class="perfil-secao-view">
        <p class="text-xs text-gray-500 mb-2">Banner exibido no topo do seu perfil.</p>
        <button type="button" id="btnAbrirCapa" class="block w-full rounded-xl border-2 border-dashed border-gray-200 hover:border-primary-300 hover:bg-primary-50/30 transition-all overflow-hidden">
          <div id="previewCapa" class="h-24 sm:h-28 bg-gray-100 flex items-center justify-center" style="<%= perfil.foto_capa ? 'background-image:url(' + perfil.foto_capa + '); background-size:cover; background-position:center' : '' %>">
            <% if (!perfil.foto_capa) { %>
              <span class="text-gray-400 text-sm font-medium"><i class="fa-solid fa-image mr-1"></i> Clique para escolher capa</span>
            <% } else { %>
              <span class="text-white/90 text-sm font-medium drop-shadow">Clique para trocar</span>
            <% } %>
          </div>
        </button>
        <input type="file" id="foto_capa" accept="image/*" class="hidden">
        <div id="capaAcoes" class="mt-2 hidden">
          <button type="button" id="btnSalvarCapa" class="btn-primary text-sm py-1.5 px-3 mr-2"><i class="fa-solid fa-check mr-1"></i>Salvar capa</button>
          <button type="button" id="btnCancelarCapa" class="text-sm text-gray-500 hover:text-gray-700">Cancelar</button>
        </div>
      </div>
    </div>

    <!-- Seção: Dados pessoais -->
    <div class="card animate-slideUp mb-6" style="animation-delay: 0.16s">
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-lg font-bold text-gray-900"><i class="fa-solid fa-user mr-2 text-primary-500"></i>Dados pessoais</h2>
        <button type="button" class="perfil-btn-editar secao-dados text-sm text-primary-500 font-medium hover:underline"><i class="fa-solid fa-pen-to-square mr-1"></i>Editar</button>
      </div>
      <div class="perfil-secao-view secao-dados-view">
        <dl class="space-y-2 text-sm">
          <div><dt class="text-gray-500 font-medium">Nome</dt><dd class="text-gray-900" id="viewNome"><%= perfil.nome %></dd></div>
          <div><dt class="text-gray-500 font-medium">Telefone</dt><dd class="text-gray-900" id="viewTelefone"><%= perfil.telefone || '—' %></dd></div>
          <div><dt class="text-gray-500 font-medium">Data de nascimento</dt><dd class="text-gray-900" id="viewDataNascimento"><%= perfil.data_nascimento ? new Date(perfil.data_nascimento).toISOString().split('T')[0] : '—' %></dd></div>
          <div><dt class="text-gray-500 font-medium">Contato extra</dt><dd class="text-gray-900" id="viewContatoExtra"><%= perfil.contato_extra || '—' %></dd></div>
          <div><dt class="text-gray-500 font-medium">Bio</dt><dd class="text-gray-900 whitespace-pre-wrap" id="viewBio"><%= perfil.bio || '—' %></dd></div>
        </dl>
      </div>
      <div class="perfil-secao-edit secao-dados-edit hidden">
        <div class="space-y-4">
          <div>
            <label for="nome" class="block text-sm font-semibold text-gray-700 mb-1">Nome</label>
            <input type="text" id="nome" value="<%= perfil.nome %>" required class="input-field">
          </div>
          <div>
            <label for="telefone" class="block text-sm font-semibold text-gray-700 mb-1">Telefone</label>
            <input type="tel" id="telefone" value="<%= perfil.telefone || '' %>" placeholder="(00) 00000-0000" class="input-field">
          </div>
          <div>
            <label for="data_nascimento" class="block text-sm font-semibold text-gray-700 mb-1">Data de nascimento</label>
            <input type="date" id="data_nascimento" value="<%= perfil.data_nascimento ? new Date(perfil.data_nascimento).toISOString().split('T')[0] : '' %>" class="input-field">
          </div>
          <div>
            <label for="contato_extra" class="block text-sm font-semibold text-gray-700 mb-1">Contato extra</label>
            <input type="text" id="contato_extra" value="<%= perfil.contato_extra || '' %>" placeholder="Ex: @usuario ou link" class="input-field">
          </div>
          <div>
            <label for="bio" class="block text-sm font-semibold text-gray-700 mb-1">Bio</label>
            <textarea id="bio" maxlength="160" rows="2" placeholder="Conte sobre você e seus pets..." class="input-field resize-none"><%= perfil.bio || '' %></textarea>
            <p class="text-xs text-gray-400 mt-1"><span id="bioCount"><%= (perfil.bio || '').length %></span>/160</p>
          </div>
          <div class="flex gap-2">
            <button type="button" id="btnSalvarDados" class="btn-primary text-sm py-2 px-4"><i class="fa-solid fa-check mr-1"></i>Salvar</button>
            <button type="button" id="btnCancelarDados" class="text-sm text-gray-500 hover:text-gray-700 py-2">Cancelar</button>
          </div>
        </div>
      </div>
    </div>

    <!-- Seção: Recuperar senha -->
    <div class="card animate-slideUp mb-6" style="animation-delay: 0.17s">
      <div class="flex items-center justify-between mb-2">
        <h2 class="text-lg font-bold text-gray-900"><i class="fa-solid fa-key mr-2 text-primary-500"></i>Conta e segurança</h2>
      </div>
      <p class="text-sm text-gray-600 mb-3">Altere sua senha de acesso caso tenha esquecido ou queira atualizá-la.</p>
      <a href="/auth/esqueci-senha" class="inline-flex items-center gap-2 text-sm font-medium text-primary-500 hover:text-primary-600 hover:underline">
        <i class="fa-solid fa-lock"></i> Recuperar ou alterar senha
      </a>
    </div>

    <!-- Seção: Endereço -->
    <div class="card animate-slideUp mb-6" style="animation-delay: 0.18s">
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-lg font-bold text-gray-900"><i class="fa-solid fa-location-dot mr-2 text-primary-500"></i>Endereço</h2>
        <button type="button" class="perfil-btn-editar secao-endereco text-sm text-primary-500 font-medium hover:underline"><i class="fa-solid fa-pen-to-square mr-1"></i>Editar</button>
      </div>
      <div class="perfil-secao-view secao-endereco-view">
        <dl class="space-y-2 text-sm">
          <div><dt class="text-gray-500 font-medium">CEP</dt><dd class="text-gray-900" id="viewCep"><%= perfil.cep || '—' %></dd></div>
          <div><dt class="text-gray-500 font-medium">Endereço</dt><dd class="text-gray-900" id="viewEndereco"><%= perfil.endereco || '—' %></dd></div>
          <div><dt class="text-gray-500 font-medium">Bairro, cidade, estado</dt><dd class="text-gray-900" id="viewBairroCidadeEstado"><%= [perfil.bairro, perfil.cidade, perfil.estado].filter(Boolean).join(', ') || '—' %></dd></div>
        </dl>
      </div>
      <div class="perfil-secao-edit secao-endereco-edit hidden">
        <p class="text-xs text-gray-400 mb-4">Usado para recomendar tutores e pets próximos.</p>
        <div class="space-y-4">
          <div>
            <label for="cep" class="block text-sm font-semibold text-gray-700 mb-1">CEP</label>
            <div class="relative">
              <input type="text" id="cep" value="<%= perfil.cep || '' %>" placeholder="00000-000" maxlength="9" class="input-field pr-10">
              <button type="button" id="btnBuscarCep" class="absolute right-2 top-1/2 -translate-y-1/2 p-1.5 text-primary-500 hover:bg-primary-50 rounded-lg transition-colors" title="Buscar CEP"><i class="fa-solid fa-magnifying-glass text-sm"></i></button>
            </div>
          </div>
          <div>
            <label for="endereco" class="block text-sm font-semibold text-gray-700 mb-1">Endereço</label>
            <input type="text" id="endereco" value="<%= perfil.endereco || '' %>" placeholder="Rua, número" class="input-field">
          </div>
          <div class="grid grid-cols-2 gap-3">
            <div>
              <label for="bairro" class="block text-sm font-semibold text-gray-700 mb-1">Bairro</label>
              <input type="text" id="bairro" value="<%= perfil.bairro || '' %>" class="input-field">
            </div>
            <div>
              <label for="cidade" class="block text-sm font-semibold text-gray-700 mb-1">Cidade</label>
              <input type="text" id="cidade" value="<%= perfil.cidade || '' %>" class="input-field">
            </div>
          </div>
          <div>
            <label for="estado" class="block text-sm font-semibold text-gray-700 mb-1">Estado</label>
            <select id="estado" class="input-field">
              <option value="">Selecione</option>
              <% var estados = [{s:'AC',n:'Acre'},{s:'AL',n:'Alagoas'},{s:'AP',n:'Amapá'},{s:'AM',n:'Amazonas'},{s:'BA',n:'Bahia'},{s:'CE',n:'Ceará'},{s:'DF',n:'Distrito Federal'},{s:'ES',n:'Espírito Santo'},{s:'GO',n:'Goiás'},{s:'MA',n:'Maranhão'},{s:'MT',n:'Mato Grosso'},{s:'MS',n:'Mato Grosso do Sul'},{s:'MG',n:'Minas Gerais'},{s:'PA',n:'Pará'},{s:'PB',n:'Paraíba'},{s:'PR',n:'Paraná'},{s:'PE',n:'Pernambuco'},{s:'PI',n:'Piauí'},{s:'RJ',n:'Rio de Janeiro'},{s:'RN',n:'Rio Grande do Norte'},{s:'RS',n:'Rio Grande do Sul'},{s:'RO',n:'Rondônia'},{s:'RR',n:'Roraima'},{s:'SC',n:'Santa Catarina'},{s:'SP',n:'São Paulo'},{s:'SE',n:'Sergipe'},{s:'TO',n:'Tocantins'}]; %>
              <% estados.forEach(function(e) { %>
                <option value="<%= e.s %>" <%= (perfil.estado || '') === e.s ? 'selected' : '' %>><%= e.n %></option>
              <% }) %>
            </select>
          </div>
          <button type="button" id="btnGeolocalizacao" class="w-full flex items-center justify-center gap-2 py-2.5 px-4 border-2 border-dashed border-primary-200 rounded-2xl text-sm font-semibold text-primary-500 hover:bg-primary-50 hover:border-primary-300 transition-all">
            <i class="fa-solid fa-crosshairs"></i> Usar minha localização atual
          </button>
          <div class="flex gap-2">
            <button type="button" id="btnSalvarEndereco" class="btn-primary text-sm py-2 px-4"><i class="fa-solid fa-check mr-1"></i>Salvar</button>
            <button type="button" id="btnCancelarEndereco" class="text-sm text-gray-500 hover:text-gray-700 py-2">Cancelar</button>
          </div>
        </div>
      </div>
    </div>

    <!-- Seção: Cor de destaque -->
    <div class="card animate-slideUp mb-6" style="animation-delay: 0.2s">
      <div class="flex items-center justify-between mb-2">
        <h2 class="text-lg font-bold text-gray-900"><i class="fa-solid fa-palette mr-2 text-primary-500"></i>Cor de destaque</h2>
        <button type="button" class="perfil-btn-editar secao-cor text-sm text-primary-500 font-medium hover:underline"><i class="fa-solid fa-pen-to-square mr-1"></i>Editar</button>
      </div>
      <p class="text-sm text-gray-500 mb-3">Define a cor das bordas do seu avatar e dos destaques no seu perfil (estilo Twitter).</p>
      <div class="perfil-secao-view secao-cor-view">
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 rounded-full bg-gray-400 flex items-center justify-center text-white text-xs font-bold" id="viewCorSwatch" style="box-shadow: 0 0 0 3px <%= perfil.cor_perfil || '#ec5a1c' %>">U</div>
          <span class="text-sm text-gray-600" id="viewCorHex"><%= perfil.cor_perfil || '#ec5a1c' %></span>
        </div>
      </div>
      <div class="perfil-secao-edit secao-cor-edit hidden">
        <div class="flex flex-wrap gap-2 mb-4" id="colorPicker">
          <% var cores = ['#ec5a1c','#e74c3c','#e91e63','#9b59b6','#673ab7','#3f51b5','#2196f3','#03a9f4','#00bcd4','#009688','#4caf50','#8bc34a','#ff9800','#ff5722','#795548','#607d8b','#000000']; %>
          <% cores.forEach(function(cor) { %>
            <button type="button" class="cor-picker-btn w-9 h-9 rounded-full border-2 transition-all duration-200 hover:scale-110 active:scale-95 <%= (perfil.cor_perfil || '#ec5a1c') === cor ? 'border-gray-900 ring-2 ring-offset-2 ring-gray-400 scale-110' : 'border-transparent' %>" style="background: <%= cor %>" data-cor="<%= cor %>"></button>
          <% }) %>
        </div>
        <input type="hidden" id="cor_perfil" value="<%= perfil.cor_perfil || '#ec5a1c' %>">
        <div class="flex gap-2">
          <button type="button" id="btnSalvarCor" class="btn-primary text-sm py-2 px-4"><i class="fa-solid fa-check mr-1"></i>Salvar</button>
          <button type="button" id="btnCancelarCor" class="text-sm text-gray-500 hover:text-gray-700 py-2">Cancelar</button>
        </div>
      </div>
    </div>

    <!-- Fotos dos pets no perfil -->
    <% if (pets && pets.length > 0) { %>
    <div class="card animate-slideUp mt-6" style="animation-delay: 0.2s">
      <h2 class="text-lg font-bold text-gray-900 mb-4"><i class="fa-solid fa-images mr-2 text-primary-500"></i>Fotos dos pets no seu perfil</h2>
      <p class="text-sm text-gray-500 mb-4">Adicione fotos que aparecerão no seu perfil público, organizadas por pet.</p>
      <div class="flex flex-wrap gap-3 items-end mb-4">
        <div class="flex-1 min-w-[140px]">
          <label class="block text-xs font-semibold text-gray-500 mb-1">Pet</label>
          <select id="galeriaPetSelect" class="input-field py-2">
            <% pets.forEach(function(p) { %>
              <option value="<%= p.id %>"><%= p.nome %></option>
            <% }); %>
          </select>
        </div>
        <button type="button" id="btnAdicionarFotoGaleria" class="px-4 py-2 rounded-xl bg-primary-500 text-white text-sm font-semibold hover:bg-primary-600 transition-colors">
          <i class="fa-solid fa-plus mr-1"></i> Adicionar foto
        </button>
      </div>
      <input type="file" id="galeriaFileInput" accept="image/*" class="hidden">
      <div id="galeriaPorPetContainer" class="space-y-4">
        <div class="text-center py-6 text-gray-400" id="galeriaLoading"><i class="fa-solid fa-spinner fa-spin"></i> Carregando…</div>
      </div>
    </div>
    <% } %>

    <!-- Central de ajuda -->
    <div class="card animate-slideUp mb-6" style="animation-delay: 0.22s">
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-lg font-bold text-gray-900"><i class="fa-solid fa-circle-question mr-2 text-primary-500"></i>Central de ajuda</h2>
      </div>
      <p class="text-sm text-gray-600 mb-4">Documentos e informações importantes do AIRPET.</p>
      <ul class="space-y-2">
        <li>
          <a href="/termos" class="flex items-center gap-3 py-2.5 px-3 rounded-xl hover:bg-gray-50 transition-colors text-gray-700">
            <i class="fa-solid fa-file-lines w-5 text-center text-gray-400"></i>
            <span class="font-medium">Termos de uso</span>
            <i class="fa-solid fa-chevron-right text-xs text-gray-300 ml-auto"></i>
          </a>
        </li>
        <li>
          <a href="/privacidade" class="flex items-center gap-3 py-2.5 px-3 rounded-xl hover:bg-gray-50 transition-colors text-gray-700">
            <i class="fa-solid fa-shield-halved w-5 text-center text-gray-400"></i>
            <span class="font-medium">Política de privacidade</span>
            <i class="fa-solid fa-chevron-right text-xs text-gray-300 ml-auto"></i>
          </a>
        </li>
      </ul>
    </div>

    <!-- Sair -->
    <div class="mt-6 text-center">
      <a href="/auth/logout" class="inline-flex items-center gap-2 text-sm text-red-500 hover:text-red-600 font-medium transition-colors">
