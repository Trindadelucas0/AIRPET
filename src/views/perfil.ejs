<% locals.titulo = 'Configurações' %>
<%- include('partials/header') %>
<%- include('partials/flash') %>

<main class="flex-1 pb-24 md:pb-6">
  <div class="max-w-2xl mx-auto px-4 py-6">

    <h1 class="text-2xl font-black text-gray-900 mb-6 animate-slideUp">
      <i class="fa-solid fa-gear text-primary-500 mr-2"></i>Configurações
    </h1>

    <!-- Profile Card -->
    <div class="card card-hover mb-6 overflow-hidden animate-slideUp" style="animation-delay: 0.05s">
      <div class="h-20 rounded-t-3xl bg-gradient-to-r from-primary-500 to-primary-600 -m-6 mb-0"></div>
      <div class="px-2 pb-2 -mt-8 relative">
        <div class="flex items-end gap-4">
          <% if (perfil.foto_perfil) { %>
            <img src="<%= perfil.foto_perfil %>" alt="" class="w-20 h-20 rounded-2xl object-cover border-4 border-white shadow-lg">
          <% } else { %>
            <div class="w-20 h-20 rounded-2xl border-4 border-white shadow-lg flex items-center justify-center text-2xl font-bold text-white"
                 style="background: <%= perfil.cor_perfil || '#ec5a1c' %>">
              <%= perfil.nome ? perfil.nome.charAt(0).toUpperCase() : 'U' %>
            </div>
          <% } %>
          <div class="pb-1">
            <h2 class="text-xl font-bold text-gray-900"><%= perfil.nome %></h2>
            <p class="text-sm text-gray-500"><%= perfil.email %></p>
            <% if (perfil.cidade) { %>
              <p class="text-xs text-gray-400 mt-0.5"><i class="fa-solid fa-location-dot mr-1"></i><%= perfil.bairro ? perfil.bairro + ', ' : '' %><%= perfil.cidade %><%= perfil.estado ? ' - ' + perfil.estado : '' %></p>
            <% } %>
          </div>
        </div>
        <a href="/explorar/perfil/<%= perfil.id %>" class="mt-4 inline-flex items-center gap-2 text-sm text-primary-500 font-medium hover:underline">
          <i class="fa-solid fa-paw"></i> Ver meus pets no explorar
        </a>
      </div>
    </div>

    <!-- Pets -->
    <div class="card card-hover mb-6 animate-slideUp" style="animation-delay: 0.1s">
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-lg font-bold text-gray-900"><i class="fa-solid fa-paw mr-2 text-primary-500"></i>Meus Pets</h2>
        <a href="/pets" class="text-sm text-primary-500 font-medium hover:underline">Ver todos</a>
      </div>
      <% if (pets && pets.length > 0) { %>
        <div class="flex gap-3 overflow-x-auto scrollbar-hide pb-2">
          <% pets.slice(0, 8).forEach(function(pet) { %>
            <a href="/pets/<%= pet.id %>" class="flex-shrink-0 flex flex-col items-center w-20 p-2 rounded-2xl hover:bg-primary-50 transition-colors">
              <% if (pet.foto) { %>
                <img src="<%= pet.foto %>" alt="<%= pet.nome %>" class="w-14 h-14 rounded-full object-cover ring-2 ring-primary-100">
              <% } else { %>
                <div class="w-14 h-14 rounded-full bg-gray-100 flex items-center justify-center">
                  <i class="fa-solid fa-paw text-gray-400"></i>
                </div>
              <% } %>
              <span class="text-xs font-semibold text-gray-800 mt-1.5 truncate w-full text-center"><%= pet.nome %></span>
            </a>
          <% }) %>
        </div>
      <% } else { %>
        <div class="text-center py-6 text-gray-400">
          <i class="fa-solid fa-dog text-3xl mb-2 opacity-40"></i>
          <p class="text-sm">Nenhum pet cadastrado.</p>
          <a href="/pets/cadastro" class="text-sm text-primary-500 font-medium hover:underline mt-1 inline-block">Cadastrar pet</a>
        </div>
      <% } %>
    </div>

    <!-- Edit Form -->
    <div class="card animate-slideUp" style="animation-delay: 0.15s">
      <h2 class="text-lg font-bold text-gray-900 mb-5"><i class="fa-solid fa-user-pen mr-2 text-primary-500"></i>Editar Perfil</h2>

      <form action="/perfil?_method=PUT" method="POST" enctype="multipart/form-data">
        <input type="hidden" name="_method" value="PUT">

        <div class="space-y-5">

          <!-- Dados pessoais -->
          <div class="pb-2 border-b border-gray-100">
            <h3 class="text-sm font-bold text-gray-500 uppercase tracking-wider mb-4"><i class="fa-solid fa-user mr-1.5"></i>Dados Pessoais</h3>

            <div class="space-y-4">
              <div>
                <label for="foto_perfil" class="block text-sm font-semibold text-gray-700 mb-1.5">Foto de perfil</label>
                <div class="flex items-center gap-4">
                  <button type="button" id="btnAbrirFotoPerfil" class="relative flex-shrink-0 rounded-full focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2" title="Trocar ou ajustar foto">
                    <% if (perfil.foto_perfil) { %>
                      <img src="<%= perfil.foto_perfil %>" alt="" id="previewFotoPerfil" class="w-16 h-16 rounded-full object-cover border-2 border-gray-200 block">
                    <% } else { %>
                      <div id="previewFotoPerfil" class="w-16 h-16 rounded-full border-2 border-gray-200 flex items-center justify-center text-2xl font-bold text-white" style="background:<%= perfil.cor_perfil || '#ec5a1c' %>"><%= (perfil.nome || 'U').charAt(0).toUpperCase() %></div>
                    <% } %>
                    <span class="absolute bottom-0 right-0 w-6 h-6 rounded-full bg-primary-500 text-white flex items-center justify-center text-xs shadow" title="Ajustar foto"><i class="fa-solid fa-crop"></i></span>
                  </button>
                  <div class="flex-1 min-w-0">
                    <input type="file" id="foto_perfil" name="foto_perfil" accept="image/*" class="input-field text-sm">
                    <p class="text-xs text-gray-500 mt-1">Escolha uma imagem e ajuste o recorte antes de salvar.</p>
                  </div>
                </div>
              </div>

              <div>
                <label class="block text-sm font-semibold text-gray-700 mb-1.5">Capa do perfil</label>
                <p class="text-xs text-gray-500 mb-2">Banner exibido no topo do seu perfil (estilo Twitter).</p>
                <button type="button" id="btnAbrirCapa" class="block w-full rounded-xl border-2 border-dashed border-gray-200 hover:border-primary-300 hover:bg-primary-50/30 transition-all overflow-hidden">
                  <div id="previewCapa" class="h-24 sm:h-28 bg-gray-100 flex items-center justify-center" style="<%= perfil.foto_capa ? 'background-image:url(' + perfil.foto_capa + '); background-size:cover; background-position:center' : '' %>">
                    <% if (!perfil.foto_capa) { %>
                      <span class="text-gray-400 text-sm font-medium"><i class="fa-solid fa-image mr-1"></i> Clique para escolher capa</span>
                    <% } else { %>
                      <span class="text-white/90 text-sm font-medium drop-shadow">Clique para trocar</span>
                    <% } %>
                  </div>
                </button>
                <input type="file" id="foto_capa" name="foto_capa" accept="image/*" class="hidden">
              </div>

              <div>
                <label for="nome" class="block text-sm font-semibold text-gray-700 mb-1.5">Nome</label>
                <input type="text" id="nome" name="nome" value="<%= perfil.nome %>" required class="input-field">
              </div>

              <div>
                <label for="telefone" class="block text-sm font-semibold text-gray-700 mb-1.5">Telefone</label>
                <input type="tel" id="telefone" name="telefone" value="<%= perfil.telefone || '' %>" placeholder="(00) 00000-0000" class="input-field">
              </div>

              <div>
                <label for="data_nascimento" class="block text-sm font-semibold text-gray-700 mb-1.5">Data de nascimento</label>
                <input type="date" id="data_nascimento" name="data_nascimento" value="<%= perfil.data_nascimento ? new Date(perfil.data_nascimento).toISOString().split('T')[0] : '' %>" class="input-field">
              </div>

              <div>
                <label for="contato_extra" class="block text-sm font-semibold text-gray-700 mb-1.5">Contato extra (redes sociais, WhatsApp)</label>
                <input type="text" id="contato_extra" name="contato_extra" value="<%= perfil.contato_extra || '' %>" placeholder="Ex: @usuario ou link" class="input-field">
              </div>

              <div>
                <label for="bio" class="block text-sm font-semibold text-gray-700 mb-1.5">Bio</label>
                <textarea id="bio" name="bio" maxlength="160" rows="2" placeholder="Conte sobre você e seus pets..." class="input-field resize-none"><%= perfil.bio || '' %></textarea>
                <p class="text-xs text-gray-400 mt-1"><span id="bioCount"><%= (perfil.bio || '').length %></span>/160</p>
              </div>
            </div>
          </div>

          <!-- Endereço -->
          <div class="pb-2 border-b border-gray-100">
            <h3 class="text-sm font-bold text-gray-500 uppercase tracking-wider mb-1"><i class="fa-solid fa-location-dot mr-1.5"></i>Endereço / Região</h3>
            <p class="text-xs text-gray-400 mb-4">Usado para recomendar tutores e pets próximos a você</p>

            <div class="space-y-4">
              <div>
                <label for="cep" class="block text-sm font-semibold text-gray-700 mb-1.5">CEP</label>
                <div class="relative">
                  <input type="text" id="cep" name="cep" value="<%= perfil.cep || '' %>" placeholder="00000-000" maxlength="9" class="input-field pr-10">
                  <button type="button" id="btnBuscarCep" class="absolute right-2 top-1/2 -translate-y-1/2 p-1.5 text-primary-500 hover:bg-primary-50 rounded-lg transition-colors" title="Buscar CEP">
                    <i class="fa-solid fa-magnifying-glass text-sm"></i>
                  </button>
                </div>
              </div>

              <div>
                <label for="endereco" class="block text-sm font-semibold text-gray-700 mb-1.5">Endereço</label>
                <input type="text" id="endereco" name="endereco" value="<%= perfil.endereco || '' %>" placeholder="Rua, número" class="input-field">
              </div>

              <div class="grid grid-cols-2 gap-3">
                <div>
                  <label for="bairro" class="block text-sm font-semibold text-gray-700 mb-1.5">Bairro</label>
                  <input type="text" id="bairro" name="bairro" value="<%= perfil.bairro || '' %>" placeholder="Bairro" class="input-field">
                </div>
                <div>
                  <label for="cidade" class="block text-sm font-semibold text-gray-700 mb-1.5">Cidade</label>
                  <input type="text" id="cidade" name="cidade" value="<%= perfil.cidade || '' %>" placeholder="Cidade" class="input-field">
                </div>
              </div>

              <div>
                <label for="estado" class="block text-sm font-semibold text-gray-700 mb-1.5">Estado</label>
                <select id="estado" name="estado" class="input-field">
                  <option value="">Selecione</option>
                  <% var estados = [{s:'AC',n:'Acre'},{s:'AL',n:'Alagoas'},{s:'AP',n:'Amapá'},{s:'AM',n:'Amazonas'},{s:'BA',n:'Bahia'},{s:'CE',n:'Ceará'},{s:'DF',n:'Distrito Federal'},{s:'ES',n:'Espírito Santo'},{s:'GO',n:'Goiás'},{s:'MA',n:'Maranhão'},{s:'MT',n:'Mato Grosso'},{s:'MS',n:'Mato Grosso do Sul'},{s:'MG',n:'Minas Gerais'},{s:'PA',n:'Pará'},{s:'PB',n:'Paraíba'},{s:'PR',n:'Paraná'},{s:'PE',n:'Pernambuco'},{s:'PI',n:'Piauí'},{s:'RJ',n:'Rio de Janeiro'},{s:'RN',n:'Rio Grande do Norte'},{s:'RS',n:'Rio Grande do Sul'},{s:'RO',n:'Rondônia'},{s:'RR',n:'Roraima'},{s:'SC',n:'Santa Catarina'},{s:'SP',n:'São Paulo'},{s:'SE',n:'Sergipe'},{s:'TO',n:'Tocantins'}]; %>
                  <% estados.forEach(function(e) { %>
                    <option value="<%= e.s %>" <%= (perfil.estado || '') === e.s ? 'selected' : '' %>><%= e.n %></option>
                  <% }) %>
                </select>
              </div>

              <button type="button" id="btnGeolocalizacao" class="w-full flex items-center justify-center gap-2 py-2.5 px-4 border-2 border-dashed border-primary-200 rounded-2xl text-sm font-semibold text-primary-500 hover:bg-primary-50 hover:border-primary-300 transition-all">
                <i class="fa-solid fa-crosshairs"></i> Usar minha localização atual
              </button>
            </div>
          </div>

          <!-- Cor do Perfil -->
          <div>
            <label class="block text-sm font-semibold text-gray-700 mb-2">Cor do Perfil</label>
            <div class="flex flex-wrap gap-2" id="colorPicker">
              <% var cores = ['#ec5a1c','#e74c3c','#e91e63','#9b59b6','#673ab7','#3f51b5','#2196f3','#03a9f4','#00bcd4','#009688','#4caf50','#8bc34a','#ff9800','#ff5722','#795548','#607d8b','#000000']; %>
              <% cores.forEach(function(cor) { %>
                <button type="button" onclick="selecionarCor('<%= cor %>')"
                        class="w-9 h-9 rounded-full border-2 transition-all duration-200 hover:scale-110 active:scale-95 <%= (perfil.cor_perfil || '#ec5a1c') === cor ? 'border-gray-900 ring-2 ring-offset-2 ring-gray-400 scale-110' : 'border-transparent' %>"
                        style="background: <%= cor %>" data-cor="<%= cor %>">
                </button>
              <% }) %>
            </div>
            <input type="hidden" name="cor_perfil" id="cor_perfil" value="<%= perfil.cor_perfil || '#ec5a1c' %>">
          </div>

          <div class="pt-1">
            <button type="submit" class="btn-primary w-full">
              <i class="fa-solid fa-check mr-2"></i>Salvar Alterações
            </button>
          </div>
        </div>
      </form>
    </div>

    <!-- Fotos dos pets no perfil -->
    <% if (pets && pets.length > 0) { %>
    <div class="card animate-slideUp mt-6" style="animation-delay: 0.2s">
      <h2 class="text-lg font-bold text-gray-900 mb-4"><i class="fa-solid fa-images mr-2 text-primary-500"></i>Fotos dos pets no seu perfil</h2>
      <p class="text-sm text-gray-500 mb-4">Adicione fotos que aparecerão no seu perfil público, organizadas por pet.</p>
      <div class="flex flex-wrap gap-3 items-end mb-4">
        <div class="flex-1 min-w-[140px]">
          <label class="block text-xs font-semibold text-gray-500 mb-1">Pet</label>
          <select id="galeriaPetSelect" class="input-field py-2">
            <% pets.forEach(function(p) { %>
              <option value="<%= p.id %>"><%= p.nome %></option>
            <% }); %>
          </select>
        </div>
        <button type="button" id="btnAdicionarFotoGaleria" class="px-4 py-2 rounded-xl bg-primary-500 text-white text-sm font-semibold hover:bg-primary-600 transition-colors">
          <i class="fa-solid fa-plus mr-1"></i> Adicionar foto
        </button>
      </div>
      <input type="file" id="galeriaFileInput" accept="image/*" class="hidden">
      <div id="galeriaPorPetContainer" class="space-y-4">
        <div class="text-center py-6 text-gray-400" id="galeriaLoading"><i class="fa-solid fa-spinner fa-spin"></i> Carregando…</div>
      </div>
    </div>
    <% } %>

    <!-- Danger Zone -->
    <div class="mt-6 text-center">
      <a href="/auth/logout" class="inline-flex items-center gap-2 text-sm text-red-500 hover:text-red-600 font-medium transition-colors">
        <i class="fa-solid fa-right-from-bracket"></i> Sair da conta
      </a>
    </div>

  </div>
</main>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.1/cropper.min.css"
      integrity="sha512-0x6JxdTnmQSFJb7g8+YovV0OXFWVQlpnYbJwY9FpZ0P4B+GacePAfjxqRgJ0hnW50Omh2kHh2k9nN1F4b0q1Sw=="
      crossorigin="anonymous" referrerpolicy="no-referrer">
<%- include('partials/modal-crop') %>
<script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.1/cropper.min.js"
        integrity="sha512-9KkIqdfN7ipE6L4oF4lF0W5f+Yk3nN7+E2n1Q0Y1kHjAPiVnJjOVT1fE2YTYL4e1kCwTxmU1nPqkRIKO1pV4Eg=="
        crossorigin="anonymous" referrerpolicy="no-referrer"></script>
<script src="/js/crop-modal.js"></script>
<script>
var croppedProfileFile = null;
var croppedCapaFile = null;

document.getElementById('btnAbrirFotoPerfil').addEventListener('click', function() {
  document.getElementById('foto_perfil').click();
});

document.getElementById('btnAbrirCapa').addEventListener('click', function() {
  document.getElementById('foto_capa').click();
});
document.getElementById('foto_capa').addEventListener('change', function() {
  var input = this;
  if (!input.files || !input.files[0]) return;
  var file = input.files[0];
  if (!file.type.match(/^image\/(jpeg|png|gif|webp)$/)) { alert('Formato não suportado.'); input.value = ''; return; }
  if (file.size > 5 * 1024 * 1024) { alert('Imagem muito grande (máx. 5MB).'); input.value = ''; return; }
  var reader = new FileReader();
  reader.onload = function(ev) {
    if (typeof openCropModal !== 'function') { alert('Recorte não disponível.'); return; }
    openCropModal({
      src: ev.target.result,
      aspectRatio: 3 / 1,
      maxWidth: 1200,
      maxHeight: 400,
      onConfirm: function(blob) {
        croppedCapaFile = new File([blob], 'capa.jpg', { type: 'image/jpeg' });
        input.value = '';
        var url = URL.createObjectURL(blob);
        var preview = document.getElementById('previewCapa');
        preview.style.backgroundImage = 'url(' + url + ')';
        preview.style.backgroundSize = 'cover';
        preview.style.backgroundPosition = 'center';
        var span = preview.querySelector('span');
        if (span) span.textContent = 'Clique para trocar';
      }
    });
  };
  reader.readAsDataURL(file);
});

document.getElementById('foto_perfil').addEventListener('change', function() {
  var input = this;
  if (!input.files || !input.files[0]) return;
  var file = input.files[0];
  if (!file.type.match(/^image\/(jpeg|png|gif|webp)$/)) { alert('Formato não suportado.'); input.value = ''; return; }
  if (file.size > 5 * 1024 * 1024) { alert('Imagem muito grande (máx. 5MB).'); input.value = ''; return; }
  var reader = new FileReader();
  reader.onload = function(ev) {
    if (typeof openCropModal !== 'function') { alert('Recorte não disponível.'); return; }
    openCropModal({
      src: ev.target.result,
      aspectRatio: 1,
      maxWidth: 500,
      maxHeight: 500,
      onConfirm: function(blob) {
        croppedProfileFile = new File([blob], 'foto-perfil.jpg', { type: 'image/jpeg' });
        input.value = '';
        var url = URL.createObjectURL(blob);
        var preview = document.getElementById('previewFotoPerfil');
        if (preview.tagName === 'IMG') {
          preview.src = url;
        } else {
          var img = document.createElement('img');
          img.id = 'previewFotoPerfil';
          img.alt = '';
          img.className = 'w-16 h-16 rounded-full object-cover border-2 border-gray-200';
          img.src = url;
          preview.parentNode.replaceChild(img, preview);
        }
      }
    });
  };
  reader.readAsDataURL(file);
});

document.querySelector('form[action*="/perfil"]').addEventListener('submit', function(e) {
  if (!croppedProfileFile && !croppedCapaFile) return;
  e.preventDefault();
  var form = this;
  var formData = new FormData(form);
  formData.delete('foto_perfil');
  formData.delete('foto_capa');
  if (croppedProfileFile) formData.append('foto_perfil', croppedProfileFile);
  if (croppedCapaFile) formData.append('foto_capa', croppedCapaFile);
  var btn = form.querySelector('button[type="submit"]');
  var origHtml = btn.innerHTML;
  btn.disabled = true;
  btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin mr-2"></i>Salvando…';
  fetch(form.action, { method: 'POST', body: formData, credentials: 'same-origin' })
    .then(function(r) {
      if (r.ok) {
        window.location.href = '/perfil';
        return;
      }
      return r.text().then(function() {
        alert('Não foi possível salvar. Tamanho ou formato da imagem podem estar incorretos.');
        btn.disabled = false;
        btn.innerHTML = origHtml;
      });
    })
    .catch(function() {
      alert('Erro ao salvar. Tente novamente.');
      btn.disabled = false;
      btn.innerHTML = origHtml;
    });
});

function selecionarCor(cor) {
  document.getElementById('cor_perfil').value = cor;
  document.querySelectorAll('#colorPicker button').forEach(function(btn) {
    btn.classList.remove('border-gray-900', 'ring-2', 'ring-offset-2', 'ring-gray-400', 'scale-110');
    btn.classList.add('border-transparent');
  });
  var btn = document.querySelector('#colorPicker button[data-cor="' + cor + '"]');
  if (btn) {
    btn.classList.remove('border-transparent');
    btn.classList.add('border-gray-900', 'ring-2', 'ring-offset-2', 'ring-gray-400', 'scale-110');
  }
}

var bioEl = document.getElementById('bio');
var bioCount = document.getElementById('bioCount');
if (bioEl) {
  bioEl.addEventListener('input', function() {
    bioCount.textContent = this.value.length;
  });
}

var cepInput = document.getElementById('cep');
if (cepInput) {
  cepInput.addEventListener('input', function() {
    var v = this.value.replace(/\D/g, '');
    if (v.length > 5) v = v.slice(0,5) + '-' + v.slice(5,8);
    this.value = v;
  });
}

document.getElementById('btnBuscarCep').addEventListener('click', function() {
  var cep = cepInput.value.replace(/\D/g, '');
  if (cep.length !== 8) return;
  var btn = this;
  btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin text-sm"></i>';
  fetch('https://viacep.com.br/ws/' + cep + '/json/')
    .then(function(r) { return r.json(); })
    .then(function(d) {
      if (d.erro) { alert('CEP não encontrado.'); return; }
      if (d.logradouro) document.getElementById('endereco').value = d.logradouro;
      if (d.bairro) document.getElementById('bairro').value = d.bairro;
      if (d.localidade) document.getElementById('cidade').value = d.localidade;
      if (d.uf) document.getElementById('estado').value = d.uf;
    })
    .catch(function() { alert('Erro ao buscar CEP.'); })
    .finally(function() { btn.innerHTML = '<i class="fa-solid fa-magnifying-glass text-sm"></i>'; });
});

document.getElementById('btnGeolocalizacao').addEventListener('click', function() {
  var btn = this;
  if (!navigator.geolocation) { alert('Geolocalização não suportada.'); return; }
  btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin mr-2"></i> Obtendo localização...';
  btn.disabled = true;
  navigator.geolocation.getCurrentPosition(
    function(pos) {
      var lat = pos.coords.latitude;
      var lng = pos.coords.longitude;
      fetch('/api/localizacao/atualizar', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ latitude: lat, longitude: lng })
      }).then(function() {
        fetch('https://nominatim.openstreetmap.org/reverse?lat=' + lat + '&lon=' + lng + '&format=json&accept-language=pt-BR')
          .then(function(r) { return r.json(); })
          .then(function(d) {
            var a = d.address || {};
            if (a.road) document.getElementById('endereco').value = a.road + (a.house_number ? ', ' + a.house_number : '');
            if (a.suburb || a.neighbourhood) document.getElementById('bairro').value = a.suburb || a.neighbourhood;
            if (a.city || a.town || a.municipality) document.getElementById('cidade').value = a.city || a.town || a.municipality;
            var ufMap = {'São Paulo':'SP','Rio de Janeiro':'RJ','Minas Gerais':'MG','Bahia':'BA','Paraná':'PR','Rio Grande do Sul':'RS','Pernambuco':'PE','Ceará':'CE','Pará':'PA','Maranhão':'MA','Santa Catarina':'SC','Goiás':'GO','Paraíba':'PB','Espírito Santo':'ES','Amazonas':'AM','Rio Grande do Norte':'RN','Alagoas':'AL','Piauí':'PI','Mato Grosso':'MT','Distrito Federal':'DF','Mato Grosso do Sul':'MS','Sergipe':'SE','Rondônia':'RO','Tocantins':'TO','Acre':'AC','Amapá':'AP','Roraima':'RR'};
            if (a.state && ufMap[a.state]) document.getElementById('estado').value = ufMap[a.state];
            if (a.postcode) {
              var cepVal = a.postcode.replace(/\D/g, '');
              if (cepVal.length >= 8) {
                cepInput.value = cepVal.slice(0,5) + '-' + cepVal.slice(5,8);
              }
            }
            btn.innerHTML = '<i class="fa-solid fa-check text-green-500 mr-2"></i> Localização obtida!';
            setTimeout(function() { btn.innerHTML = '<i class="fa-solid fa-crosshairs"></i> Usar minha localização atual'; btn.disabled = false; }, 2000);
          });
      });
    },
    function() {
      alert('Não foi possível obter sua localização.');
      btn.innerHTML = '<i class="fa-solid fa-crosshairs"></i> Usar minha localização atual';
      btn.disabled = false;
    },
    { enableHighAccuracy: true, timeout: 10000 }
  );
});

(function galeriaPerfil() {
  var container = document.getElementById('galeriaPorPetContainer');
  var loading = document.getElementById('galeriaLoading');
  var btnAdd = document.getElementById('btnAdicionarFotoGaleria');
  var fileInput = document.getElementById('galeriaFileInput');
  var petSelect = document.getElementById('galeriaPetSelect');
  if (!container || !btnAdd) return;

  function renderGaleria(galeria) {
    if (!galeria || galeria.length === 0) {
      container.innerHTML = '<p class="text-sm text-gray-500 text-center py-4">Nenhuma foto ainda. Escolha um pet e clique em Adicionar foto.</p>';
      return;
    }
    var html = '';
    galeria.forEach(function(item) {
      html += '<div class="border border-gray-100 rounded-xl p-3" data-pet-id="' + item.pet_id + '">';
      html += '<h4 class="text-sm font-bold text-gray-700 mb-2">' + (item.pet_nome || 'Pet') + '</h4>';
      html += '<div class="flex flex-wrap gap-2">';
      (item.fotos || []).forEach(function(f) {
        html += '<div class="relative group"><img src="' + f.foto + '" alt="" class="w-20 h-20 object-cover rounded-lg">';
        html += '<button type="button" class="absolute top-1 right-1 w-6 h-6 rounded-full bg-red-500 text-white text-xs flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity btn-remover-foto-galeria" data-id="' + f.id + '"><i class="fa-solid fa-xmark"></i></button></div>';
      });
      html += '</div></div>';
    });
    container.innerHTML = html;
    container.querySelectorAll('.btn-remover-foto-galeria').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var id = this.getAttribute('data-id');
        if (!confirm('Remover esta foto?')) return;
        fetch('/perfil/galeria/' + id, { method: 'DELETE', credentials: 'same-origin' })
          .then(function(r) { return r.json(); })
          .then(function(data) {
            if (data.sucesso) carregarGaleria();
          });
      });
    });
  }

  function carregarGaleria() {
    fetch('/perfil/galeria', { credentials: 'same-origin' })
      .then(function(r) { return r.json(); })
      .then(function(data) {
        renderGaleria(data.galeria || []);
      })
      .catch(function() {
        container.innerHTML = '<p class="text-sm text-red-500 text-center py-4">Erro ao carregar.</p>';
      });
  }

  btnAdd.addEventListener('click', function() { fileInput.click(); });
  fileInput.addEventListener('change', function() {
    if (!this.files || !this.files[0]) return;
    var file = this.files[0];
    if (!file.type.match(/^image\/(jpeg|png|gif|webp)$/)) { alert('Formato não suportado.'); this.value = ''; return; }
    var reader = new FileReader();
    reader.onload = function(ev) {
      fileInput.value = '';
      if (typeof openCropModal !== 'function') { alert('Recorte não disponível.'); return; }
      var petId = petSelect ? petSelect.value : '';
      if (!petId) { alert('Selecione um pet.'); return; }
      openCropModal({
        src: ev.target.result,
        aspectRatio: 0,
        maxWidth: 1200,
        maxHeight: 1200,
        onConfirm: function(blob) {
          var fd = new FormData();
          fd.append('pet_id', petId);
          fd.append('foto', new File([blob], 'foto.jpg', { type: 'image/jpeg' }));
          fetch('/perfil/galeria', { method: 'POST', body: fd, credentials: 'same-origin' })
            .then(function(r) { return r.json(); })
            .then(function(data) {
              if (data.sucesso) carregarGaleria();
              else alert(data.mensagem || 'Erro.');
            })
            .catch(function() { alert('Erro ao enviar.'); });
        }
      });
    };
    reader.readAsDataURL(file);
  });

  carregarGaleria();
})();
</script>

