<% locals.titulo = 'Configurações' %>
<%- include('partials/header') %>
<%- include('partials/flash') %>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Syne:wght@400;700;800&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,700;1,9..40,400&display=swap');

  :root {
    --font-display: 'Syne', sans-serif;
    --font-body: 'DM Sans', sans-serif;
  }

  /* ── PAGE HEADER ── */
  .page-header {
    position: sticky; top: 56px; z-index: 40;
    background: rgba(255,255,255,0.78);
    backdrop-filter: blur(20px);
    border-bottom: 1px solid var(--border);
    padding: 14px 0;
  }

  .page-header-inner {
    max-width: 720px; margin: 0 auto; padding: 0 20px;
    display: flex; align-items: center; gap: 12px;
  }

  .page-header h1 {
    font-family: var(--font-display);
    font-size: 18px; font-weight: 800; color: var(--text); letter-spacing: -0.01em;
  }

  .page-header-icon {
    width: 32px; height: 32px;
    border-radius: 9px;
    background: var(--accent-glow);
    border: 1px solid rgba(242,96,32,0.2);
    display: flex; align-items: center; justify-content: center;
    color: var(--accent); font-size: 14px;
  }

  /* ── MAIN LAYOUT ── */
  .settings-layout {
    max-width: 720px;
    margin: 0 auto;
    padding: 24px 20px 80px;
  }

  /* ── PROFILE HERO CARD ── */
  .profile-hero {
    background: var(--ink-2);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    margin-bottom: 14px;
  }

  .profile-hero-banner {
    height: 100px;
    background: linear-gradient(135deg, #1a1018 0%, #2d1a10 50%, #1a1018 100%);
    position: relative;
    overflow: hidden;
  }

  .profile-hero-banner-img {
    width: 100%; height: 100%;
    object-fit: cover;
    display: block;
  }

  .profile-hero-banner-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(to bottom, transparent 40%, rgba(19,19,26,0.6) 100%);
  }

  .profile-hero-banner-edit {
    position: absolute; bottom: 8px; right: 8px;
    display: inline-flex; align-items: center; gap: 6px;
    padding: 5px 12px;
    background: rgba(255,255,255,0.78);
    backdrop-filter: blur(8px);
    border: 1px solid rgba(31,41,55,0.12);
    border-radius: 8px;
    font-size: 11px; font-weight: 600; color: rgba(31,41,55,0.85);
    cursor: pointer; transition: all 0.15s;
  }
  .profile-hero-banner-edit:hover { border-color: rgba(31,41,55,0.28); color: var(--text); }

  .profile-hero-body {
    padding: 0 20px 20px;
  }

  .profile-hero-avatar-row {
    display: flex; align-items: flex-end; justify-content: space-between;
    margin-top: -36px; margin-bottom: 14px;
  }

  .profile-avatar-wrap {
    position: relative; display: inline-block;
  }

  .profile-avatar {
    width: 72px; height: 72px; border-radius: 50%;
    object-fit: cover;
    border: 3px solid var(--ink-2);
    display: block;
  }

  .profile-avatar-initial {
    width: 72px; height: 72px; border-radius: 50%;
    border: 3px solid var(--ink-2);
    display: flex; align-items: center; justify-content: center;
    font-size: 26px; font-weight: 700; color: var(--text);
    background: var(--ink-3);
  }

  .profile-avatar-edit-btn {
    position: absolute; bottom: 0; right: 0;
    width: 26px; height: 26px; border-radius: 50%;
    background: var(--accent); border: 2px solid var(--ink-2);
    display: flex; align-items: center; justify-content: center;
    color: #fff; font-size: 11px; cursor: pointer; border: none;
    transition: background 0.15s;
  }
  .profile-avatar-edit-btn:hover { background: var(--accent-light); }

  .profile-hero-name {
    font-family: var(--font-display);
    font-size: 20px; font-weight: 700; color: var(--text);
    margin-bottom: 2px;
  }

  .profile-hero-email {
    font-size: 13px; color: var(--text-dim);
  }

  .profile-hero-location {
    font-size: 12px; color: var(--text-dim); margin-top: 3px;
  }

  .profile-view-link {
    display: inline-flex; align-items: center; gap: 6px;
    margin-top: 10px;
    padding: 7px 16px;
    background: transparent;
    border: 1px solid var(--border);
    border-radius: 9px;
    font-size: 12px; font-weight: 600; color: var(--text-dim);
    text-decoration: none; transition: all 0.15s;
  }
  .profile-view-link:hover { border-color: var(--border-hover); color: var(--text); text-decoration: none; background: var(--ink-3); }

  /* ── SECTION CARD ── */
  .section-card {
    background: var(--ink-2);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    margin-bottom: 14px;
    overflow: hidden;
  }

  .section-card-header {
    display: flex; align-items: center; justify-content: space-between;
    padding: 18px 20px 14px;
    border-bottom: 1px solid var(--border);
  }

  .section-card-title {
    display: flex; align-items: center; gap: 10px;
    font-family: var(--font-display);
    font-size: 14px; font-weight: 700; color: var(--text);
    letter-spacing: 0.01em;
  }

  .section-card-title-icon {
    width: 28px; height: 28px;
    border-radius: 8px;
    background: var(--accent-glow);
    border: 1px solid rgba(242,96,32,0.15);
    display: flex; align-items: center; justify-content: center;
    color: var(--accent); font-size: 12px;
  }

  .section-card-link {
    font-size: 12px; font-weight: 600; color: var(--accent);
    text-decoration: none; letter-spacing: 0.03em;
  }
  .section-card-link:hover { color: var(--accent-light); text-decoration: none; }

  .section-card-body { padding: 18px 20px; }

  /* ── PETS CAROUSEL ── */
  .pets-scroll {
    display: flex; gap: 10px;
    overflow-x: auto;
    padding-bottom: 4px;
    scrollbar-width: none;
  }
  .pets-scroll::-webkit-scrollbar { display: none; }

  .pet-chip {
    flex-shrink: 0;
    display: flex; flex-direction: column; align-items: center;
    width: 72px; padding: 8px 4px;
    border-radius: 14px;
    border: 1px solid var(--border);
    background: var(--ink-3);
    text-decoration: none;
    transition: all 0.15s;
    gap: 6px;
  }
  .pet-chip:hover { border-color: var(--accent); background: var(--ink-3); text-decoration: none; }

  .pet-chip-avatar {
    width: 48px; height: 48px; border-radius: 50%;
    object-fit: cover;
    border: 2px solid rgba(242,96,32,0.3);
  }

  .pet-chip-avatar-empty {
    width: 48px; height: 48px; border-radius: 50%;
    background: var(--ink-4);
    border: 2px solid var(--border);
    display: flex; align-items: center; justify-content: center;
    font-size: 18px; color: var(--text-muted);
  }

  .pet-chip-name {
    font-size: 10px; font-weight: 600; color: var(--text);
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    width: 100%; text-align: center;
  }

  .pets-empty {
    text-align: center; padding: 28px 16px;
    color: var(--text-dim);
  }

  .pets-empty-icon { font-size: 32px; opacity: 0.25; margin-bottom: 10px; display: block; }

  /* ── POST COUNTER ── */
  .posts-counter {
    display: flex; align-items: center; gap: 12px; flex-wrap: wrap;
  }

  .posts-badge {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 8px 16px;
    border-radius: 10px;
    font-size: 14px; font-weight: 700;
  }

  .posts-badge.ok { background: rgba(34,197,94,0.08); color: var(--green); border: 1px solid rgba(34,197,94,0.15); }
  .posts-badge.warn { background: rgba(242,96,32,0.08); color: var(--accent); border: 1px solid rgba(242,96,32,0.15); }
  .posts-badge.danger { background: rgba(239,68,68,0.08); color: #f87171; border: 1px solid rgba(239,68,68,0.15); }

  .posts-progress {
    width: 100%; height: 4px;
    background: var(--ink-3);
    border-radius: 2px;
    overflow: hidden;
    margin-top: 10px;
  }

  .posts-progress-fill {
    height: 100%;
    border-radius: 2px;
    transition: width 0.6s ease;
  }

  /* ── FORM FIELDS ── */
  .field-group { margin-bottom: 18px; }

  .field-label {
    display: block;
    font-size: 12px; font-weight: 600; color: var(--text-dim);
    letter-spacing: 0.05em; text-transform: uppercase;
    margin-bottom: 7px;
  }

  .field-input {
    width: 100%;
    background: var(--ink-3);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 11px 14px;
    color: var(--text);
    font-family: var(--font-body);
    font-size: 14px;
    outline: none;
    transition: border-color 0.15s, box-shadow 0.15s;
  }
  .field-input:focus { border-color: rgba(242,96,32,0.5); box-shadow: 0 0 0 3px rgba(242,96,32,0.06); }
  .field-input::placeholder { color: var(--text-muted); }

  .field-row {
    display: grid; grid-template-columns: 1fr 1fr; gap: 12px;
  }

  @media (max-width: 500px) { .field-row { grid-template-columns: 1fr; } }

  .field-hint { font-size: 11px; color: var(--text-dim); margin-top: 5px; }

  .field-input-row {
    display: flex; gap: 8px;
  }

  .field-input-row .field-input { flex: 1; }

  /* ── COLOR PICKER ── */
  .color-row {
    display: flex; align-items: center; gap: 10px; flex-wrap: wrap;
    margin-bottom: 18px;
  }

  .color-swatch {
    width: 34px; height: 34px; border-radius: 50%; cursor: pointer;
    border: 2px solid transparent;
    transition: all 0.15s; position: relative;
    flex-shrink: 0;
  }
  .color-swatch:hover { transform: scale(1.12); }
  .color-swatch.active {
    border-color: var(--accent);
    box-shadow: 0 0 0 2px color-mix(in srgb, var(--accent) 30%, transparent);
  }

  .color-custom-input {
    display: flex; align-items: center; gap: 8px;
    background: var(--ink-3); border: 1px solid var(--border); border-radius: 10px;
    padding: 6px 12px;
  }

  .color-preview {
    width: 22px; height: 22px; border-radius: 50%;
    border: 2px solid var(--border);
    flex-shrink: 0;
  }

  /* ── BUTTONS ── */
  .btn-primary {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 11px 22px;
    background: var(--accent); color: #fff;
    border: none; border-radius: 10px;
    font-family: var(--font-body);
    font-size: 14px; font-weight: 700;
    cursor: pointer; transition: all 0.2s;
  }
  .btn-primary:hover { background: var(--accent-light); transform: translateY(-1px); }
  .btn-primary:disabled { opacity: 0.5; cursor: not-allowed; transform: none; }

  .btn-ghost {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 11px 22px;
    background: transparent; color: var(--text-dim);
    border: 1px solid var(--border); border-radius: 10px;
    font-family: var(--font-body);
    font-size: 14px; font-weight: 600;
    cursor: pointer; transition: all 0.15s;
  }
  .btn-ghost:hover { border-color: var(--border-hover); color: var(--text); background: var(--ink-3); }

  .btn-danger {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 11px 22px;
    background: rgba(239,68,68,0.08); color: #f87171;
    border: 1px solid rgba(239,68,68,0.2); border-radius: 10px;
    font-family: var(--font-body);
    font-size: 14px; font-weight: 600;
    cursor: pointer; transition: all 0.15s;
  }
  .btn-danger:hover { background: rgba(239,68,68,0.15); border-color: rgba(239,68,68,0.35); }

  .btn-row { display: flex; gap: 10px; flex-wrap: wrap; align-items: center; margin-top: 20px; }

  /* ── DANGER ZONE ── */
  .danger-zone {
    background: rgba(239,68,68,0.04);
    border: 1px solid rgba(239,68,68,0.15);
    border-radius: var(--radius);
    padding: 18px 20px;
    margin-bottom: 14px;
  }

  .danger-zone-title {
    font-size: 13px; font-weight: 700; color: #f87171; margin-bottom: 6px;
    display: flex; align-items: center; gap: 7px;
  }

  .danger-zone-desc { font-size: 13px; color: var(--text-dim); line-height: 1.6; margin-bottom: 14px; }

  /* ── ANIMATE ── */
  @keyframes slide-up { from { opacity:0; transform:translateY(16px); } to { opacity:1; transform:none; } }
  .anim-1 { animation: slide-up 0.4s 0.05s both; }
  .anim-2 { animation: slide-up 0.4s 0.1s both; }
  .anim-3 { animation: slide-up 0.4s 0.15s both; }
  .anim-4 { animation: slide-up 0.4s 0.2s both; }
  .anim-5 { animation: slide-up 0.4s 0.25s both; }
  .anim-6 { animation: slide-up 0.4s 0.3s both; }
</style>

<% var meusPets = typeof meusPets !== 'undefined' ? meusPets : (typeof pets !== 'undefined' ? pets : []); %>

<main class="flex-1 pb-24 md:pb-6">

  <!-- Page header -->
  <div class="page-header">
    <div class="page-header-inner">
      <div class="page-header-icon"><i class="fa-solid fa-gear"></i></div>
      <h1>Configurações</h1>
    </div>
  </div>

  <div class="settings-layout">

    <!-- ═══ PROFILE HERO ═══ -->
    <div class="profile-hero anim-1">
      <% var corDestaque = perfil.cor_perfil || '#ec5a1c'; %>

      <!-- Banner -->
      <div class="profile-hero-banner" id="bannerPreviewWrap" style="<%= perfil.foto_capa ? 'padding:0' : '' %>">
        <% if (perfil.foto_capa) { %>
          <img src="<%= perfil.foto_capa %>" class="profile-hero-banner-img" id="bannerImg" alt="">
          <div class="profile-hero-banner-overlay"></div>
        <% } else { %>
          <!-- Pattern decoration -->
          <svg style="position:absolute;inset:0;width:100%;height:100%;opacity:0.04" viewBox="0 0 100 100" preserveAspectRatio="none">
            <defs><pattern id="grid" width="10" height="10" patternUnits="userSpaceOnUse"><path d="M 10 0 L 0 0 0 10" fill="none" stroke="white" stroke-width="0.5"/></pattern></defs>
            <rect width="100%" height="100%" fill="url(#grid)"/>
          </svg>
          <div style="position:absolute;top:20px;left:50%;transform:translateX(-50%);font-size:28px;opacity:0.1;">🐾</div>
        <% } %>
        <button type="button" class="profile-hero-banner-edit" id="btnAbrirCapa">
          <i class="fa-solid fa-image"></i>
          <% if (perfil.foto_capa) { %>Trocar capa<% } else { %>Adicionar capa<% } %>
        </button>
      </div>

      <!-- Body -->
      <div class="profile-hero-body">
        <div class="profile-hero-avatar-row">
          <div class="profile-avatar-wrap" id="btnAbrirFotoPerfilWrap">
            <% if (perfil.foto_perfil) { %>
              <img src="<%= perfil.foto_perfil %>" id="previewFotoPerfil" class="profile-avatar" style="box-shadow:0 0 0 3px <%= corDestaque %>40;" alt="">
            <% } else { %>
              <div class="profile-avatar-initial" id="previewFotoPerfil" style="box-shadow:0 0 0 3px <%= corDestaque %>40;"><%= perfil.nome ? perfil.nome.charAt(0).toUpperCase() : 'U' %></div>
            <% } %>
            <button type="button" class="profile-avatar-edit-btn" id="btnAbrirFotoPerfil" title="Trocar foto">
              <i class="fa-solid fa-camera"></i>
            </button>
          </div>
          <div id="fotoPerfilAcoes" class="hidden" style="display:flex;gap:8px;align-items:center;">
            <button type="button" id="btnSalvarFotoPerfil" class="btn-primary" style="padding:8px 16px;font-size:13px;">
              <i class="fa-solid fa-check"></i>Salvar
            </button>
            <button type="button" id="btnCancelarFotoPerfil" class="btn-ghost" style="padding:8px 14px;font-size:13px;">Cancelar</button>
          </div>
        </div>

        <div class="profile-hero-name"><%= perfil.nome %></div>
        <div class="profile-hero-email"><%= perfil.email %></div>
        <% if (perfil.cidade) { %>
          <div class="profile-hero-location">
            <i class="fa-solid fa-location-dot" style="margin-right:4px;color:var(--accent);font-size:11px;"></i>
            <%= perfil.bairro ? perfil.bairro + ', ' : '' %><%= perfil.cidade %><%= perfil.estado ? ' — ' + perfil.estado : '' %>
          </div>
        <% } %>
        <a href="/explorar/perfil/<%= perfil.id %>" class="profile-view-link">
          <i class="fa-solid fa-arrow-up-right-from-square" style="font-size:11px;"></i>
          Ver perfil público
        </a>
      </div>

      <input type="file" id="foto_perfil" accept="image/*" class="hidden">
      <input type="file" id="foto_capa" accept="image/*" class="hidden">
    </div>

    <!-- Banner save actions -->
    <div id="capaAcoes" class="hidden anim-1" style="background:var(--ink-2);border:1px solid var(--border);border-radius:var(--radius);padding:14px 20px;display:flex;gap:10px;align-items:center;margin-bottom:14px;">
      <button type="button" id="btnSalvarCapa" class="btn-primary" style="font-size:13px;padding:9px 18px;">
        <i class="fa-solid fa-check"></i>Salvar capa
      </button>
      <button type="button" id="btnCancelarCapa" class="btn-ghost" style="font-size:13px;padding:9px 14px;">Cancelar</button>
    </div>

    <!-- ═══ PETS ═══ -->
    <div class="section-card anim-2">
      <div class="section-card-header">
        <div class="section-card-title">
          <div class="section-card-title-icon"><i class="fa-solid fa-paw"></i></div>
          Meus Pets
        </div>
        <a href="/pets" class="section-card-link">Ver todos →</a>
      </div>
      <div class="section-card-body">
        <% if (pets && pets.length > 0) { %>
        <div class="pets-scroll">
          <% pets.slice(0, 8).forEach(function(pet) { %>
          <a href="/pets/<%= pet.id %>" class="pet-chip">
            <% if (pet.foto) { %>
              <img src="<%= pet.foto %>" class="pet-chip-avatar" alt="<%= pet.nome %>">
            <% } else { %>
              <div class="pet-chip-avatar-empty">🐾</div>
            <% } %>
            <span class="pet-chip-name"><%= pet.nome %></span>
          </a>
          <% }); %>
          <a href="/pets/cadastro" class="pet-chip" style="border-style:dashed;border-color:rgba(242,96,32,0.3);">
            <div class="pet-chip-avatar-empty" style="border-color:rgba(242,96,32,0.3);color:var(--accent);font-size:22px;">+</div>
            <span class="pet-chip-name" style="color:var(--accent);">Novo pet</span>
          </a>
        </div>
        <% } else { %>
        <div class="pets-empty">
          <span class="pets-empty-icon">🐾</span>
          <p style="font-size:14px;font-weight:600;color:var(--text);margin-bottom:6px;">Nenhum pet cadastrado</p>
          <p style="font-size:13px;margin-bottom:14px;">Adicione seu primeiro pet para começar.</p>
          <a href="/pets/cadastro" class="btn-primary" style="font-size:13px;padding:9px 20px;">
            <i class="fa-solid fa-plus"></i>Cadastrar pet
          </a>
        </div>
        <% } %>
        <p style="font-size:11px;color:var(--text-dim);margin-top:10px;">Gerencie em <a href="/pets" style="color:var(--accent);text-decoration:none;">Meus Pets</a></p>
      </div>
    </div>

    <!-- ═══ PUBLICAÇÕES ═══ -->
    <div class="section-card anim-2">
      <div class="section-card-header">
        <div class="section-card-title">
          <div class="section-card-title-icon"><i class="fa-solid fa-images"></i></div>
          Publicações
        </div>
        <a href="/feed" class="section-card-link">Ver feed →</a>
      </div>
      <div class="section-card-body">
        <%
          var total = typeof totalPosts !== 'undefined' ? totalPosts : 0;
          var pct = Math.min(Math.round((total / 10) * 100), 100);
          var badgeClass = total >= 10 ? 'danger' : total >= 7 ? 'warn' : 'ok';
        %>
        <div class="posts-counter">
          <div class="posts-badge <%= badgeClass %>">
            <i class="fa-solid fa-camera"></i>
            <%= total %>/10 publicações
          </div>
          <% if (total >= 10) { %>
            <span style="font-size:13px;color:#f87171;">Limite atingido — exclua posts para publicar mais.</span>
          <% } %>
        </div>
        <div class="posts-progress" style="margin-top:12px;">
          <div class="posts-progress-fill" style="width:<%= pct %>%;background:<%= total >= 10 ? '#ef4444' : total >= 7 ? 'var(--accent)' : 'var(--green)' %>"></div>
        </div>
      </div>
    </div>

    <!-- ═══ DADOS PESSOAIS ═══ -->
    <form id="formDadosPessoais" action="/perfil?_method=PUT" method="POST" autocomplete="off">
      <div class="section-card anim-3">
        <div class="section-card-header">
          <div class="section-card-title">
            <div class="section-card-title-icon"><i class="fa-solid fa-user"></i></div>
            Dados pessoais
          </div>
        </div>
        <div class="section-card-body">
          <div class="field-row">
            <div class="field-group" style="margin-bottom:0">
              <label class="field-label" for="nome">Nome</label>
              <input type="text" id="nome" name="nome" class="field-input" value="<%= perfil.nome || '' %>" maxlength="80" required>
            </div>
            <div class="field-group" style="margin-bottom:0">
              <label class="field-label" for="apelido">Apelido / Username</label>
              <input type="text" id="apelido" name="apelido" class="field-input" value="<%= perfil.apelido || '' %>" maxlength="40" placeholder="Opcional">
            </div>
          </div>

          <div class="field-group" style="margin-top:14px;">
            <label class="field-label" for="bio">Bio</label>
            <textarea id="bio" name="bio" class="field-input" rows="3" maxlength="160" placeholder="Conte um pouco sobre você e seus pets..."><%= perfil.bio || '' %></textarea>
            <div class="field-hint"><span id="bioCount"><%= (perfil.bio || '').length %></span>/160</div>
          </div>

          <!-- Cor do perfil -->
          <div class="field-group">
            <label class="field-label">Cor de destaque</label>
            <div class="color-row" id="colorSwatches">
              <% var cores = ['#f26020','#ef4444','#a855f7','#3b82f6','#22c55e','#eab308','#ec4899','#14b8a6']; %>
              <% cores.forEach(function(c) { %>
                <div class="color-swatch <%= perfil.cor_perfil === c ? 'active' : '' %>"
                     style="background:<%= c %>;" data-cor="<%= c %>" title="<%= c %>"></div>
              <% }); %>
              <div class="color-custom-input">
                <div class="color-preview" id="corPreview" style="background:<%= corDestaque %>;"></div>
                <input type="color" id="inputCor" name="cor_perfil" value="<%= corDestaque %>"
                       style="background:transparent;border:none;width:24px;height:24px;cursor:pointer;padding:0;outline:none;">
              </div>
            </div>
          </div>

          <div class="btn-row">
            <button type="submit" class="btn-primary">
              <i class="fa-solid fa-floppy-disk"></i>Salvar dados
            </button>
          </div>
        </div>
      </div>
    </form>

    <!-- ═══ LOCALIZAÇÃO ═══ -->
    <form id="formLocalizacao" action="/perfil?_method=PUT" method="POST" autocomplete="off">
      <div class="section-card anim-4">
        <div class="section-card-header">
          <div class="section-card-title">
            <div class="section-card-title-icon"><i class="fa-solid fa-location-dot"></i></div>
            Localização
          </div>
        </div>
        <div class="section-card-body">
          <div class="field-group">
            <label class="field-label" for="cep">CEP</label>
            <div class="field-input-row">
              <input type="text" id="cep" name="cep" class="field-input" value="<%= perfil.cep || '' %>" maxlength="9" placeholder="00000-000">
              <button type="button" id="btnBuscarCep" class="btn-ghost" style="flex-shrink:0;padding:11px 16px;font-size:13px;">
                <i class="fa-solid fa-magnifying-glass"></i>
              </button>
            </div>
          </div>
          <div class="field-row">
            <div class="field-group" style="margin-bottom:0;">
              <label class="field-label" for="endereco">Endereço</label>
              <input type="text" id="endereco" name="endereco" class="field-input" value="<%= perfil.endereco || '' %>" maxlength="100">
            </div>
            <div class="field-group" style="margin-bottom:0;">
              <label class="field-label" for="bairro">Bairro</label>
              <input type="text" id="bairro" name="bairro" class="field-input" value="<%= perfil.bairro || '' %>" maxlength="60">
            </div>
          </div>
          <div class="field-row" style="margin-top:14px;">
            <div class="field-group" style="margin-bottom:0;">
              <label class="field-label" for="cidade">Cidade</label>
              <input type="text" id="cidade" name="cidade" class="field-input" value="<%= perfil.cidade || '' %>" maxlength="80">
            </div>
            <div class="field-group" style="margin-bottom:0;">
              <label class="field-label" for="estado">Estado</label>
              <input type="text" id="estado" name="estado" class="field-input" value="<%= perfil.estado || '' %>" maxlength="2" placeholder="SP">
            </div>
          </div>
          <div class="btn-row">
            <button type="submit" class="btn-primary">
              <i class="fa-solid fa-floppy-disk"></i>Salvar localização
            </button>
            <button type="button" id="btnGeolocalizacao" class="btn-ghost">
              <i class="fa-solid fa-crosshairs"></i>Usar localização atual
            </button>
          </div>
        </div>
      </div>
    </form>

    <!-- ═══ ALTERAR SENHA ═══ -->
    <div class="section-card anim-5">
      <div class="section-card-header">
        <div class="section-card-title">
          <div class="section-card-title-icon"><i class="fa-solid fa-lock"></i></div>
          Segurança da conta
        </div>
      </div>
      <div class="section-card-body">
        <p style="font-size:13px;color:var(--text-dim);line-height:1.6;margin-bottom:14px;">
          Para alterar sua senha, use o fluxo de recuperação seguro do sistema.
        </p>
        <a href="/auth/esqueci-senha" class="btn-primary" style="text-decoration:none;">
          <i class="fa-solid fa-key"></i>Recuperar/alterar senha
        </a>
      </div>
    </div>

    <!-- ═══ GALERIA ═══ -->
    <div class="section-card anim-5">
      <div class="section-card-header">
        <div class="section-card-title">
          <div class="section-card-title-icon" style="background:rgba(167,139,250,0.1);border-color:rgba(167,139,250,0.15);color:#a78bfa;"><i class="fa-solid fa-photo-film"></i></div>
          Galeria dos pets
        </div>
      </div>
      <div class="section-card-body">
        <% if (typeof meusPets !== 'undefined' && meusPets && meusPets.length > 0) { %>
        <div class="field-group">
          <label class="field-label" for="galeriaPetSelect">Pet</label>
          <select id="galeriaPetSelect" class="field-input" style="cursor:pointer;">
            <% meusPets.forEach(function(p) { %><option value="<%= p.id %>"><%= p.nome %></option><% }); %>
          </select>
        </div>
        <% } %>
        <div id="galeriaLoading" style="text-align:center;padding:24px;color:var(--text-dim);font-size:13px;">
          <i class="fa-solid fa-spinner fa-spin mr-2"></i>Carregando galeria...
        </div>
        <div id="galeriaPorPetContainer" class="hidden"></div>
        <div class="btn-row">
          <button type="button" id="btnAdicionarFotoGaleria" class="btn-primary">
            <i class="fa-solid fa-plus"></i>Adicionar foto
          </button>
        </div>
        <input type="file" id="galeriaFileInput" accept="image/jpeg,image/png,image/gif,image/webp" class="hidden">
      </div>
    </div>

    <!-- ═══ DANGER ZONE ═══ -->
    <div class="danger-zone anim-6">
      <div class="danger-zone-title">
        <i class="fa-solid fa-triangle-exclamation"></i>
        Zona de perigo
      </div>
      <div class="danger-zone-desc">
        A exclusão de conta não está disponível nesta área. Para sua segurança, finalize sua sessão quando estiver em dispositivo compartilhado.
      </div>
      <a href="/auth/logout" class="btn-danger" style="text-decoration:none;">
        <i class="fa-solid fa-right-from-bracket"></i>
        Sair da conta
      </a>
    </div>

  </div>
</main>

<script>
(function () {
  'use strict';

  // ── Bio counter ──
  var bioEl = document.getElementById('bio');
  var bioCount = document.getElementById('bioCount');
  if (bioEl && bioCount) {
    bioEl.addEventListener('input', function() { bioCount.textContent = this.value.length; });
  }

  // ── Color swatches ──
  var swatches = document.querySelectorAll('.color-swatch');
  var inputCor = document.getElementById('inputCor');
  var corPreview = document.getElementById('corPreview');

  swatches.forEach(function(s) {
    s.addEventListener('click', function() {
      swatches.forEach(function(x) { x.classList.remove('active'); });
      s.classList.add('active');
      var c = s.getAttribute('data-cor');
      inputCor.value = c;
      corPreview.style.background = c;
    });
  });

  if (inputCor) {
    inputCor.addEventListener('input', function() {
      corPreview.style.background = this.value;
      swatches.forEach(function(x) { x.classList.remove('active'); });
    });
  }

  // ── Avatar crop ──
  var btnAbrirFoto = document.getElementById('btnAbrirFotoPerfil');
  var inputFoto = document.getElementById('foto_perfil');
  var fotoAcoes = document.getElementById('fotoPerfilAcoes');
  var previewFoto = document.getElementById('previewFotoPerfil');
  var btnSalvarFoto = document.getElementById('btnSalvarFotoPerfil');
  var btnCancelarFoto = document.getElementById('btnCancelarFotoPerfil');
  var fotoBlob = null;
  var fotoOrigSrc = previewFoto ? (previewFoto.src || '') : '';

  if (btnAbrirFoto) {
    btnAbrirFoto.addEventListener('click', function() { inputFoto.click(); });
  }

  if (inputFoto) {
    inputFoto.addEventListener('change', function() {
      var file = this.files[0];
      if (!file) return;
      var reader = new FileReader();
      reader.onload = function(ev) {
        if (typeof openCropModal === 'function') {
          openCropModal({
            src: ev.target.result, aspectRatio: 1, maxWidth: 600, maxHeight: 600,
            onConfirm: function(blob) {
              fotoBlob = blob;
              var url = URL.createObjectURL(blob);
              if (previewFoto.tagName === 'IMG') { previewFoto.src = url; }
              else { var img = document.createElement('img'); img.src = url; img.id = 'previewFotoPerfil'; img.className = previewFoto.className; img.style.cssText = previewFoto.style.cssText; previewFoto.parentNode.replaceChild(img, previewFoto); previewFoto = img; }
              fotoAcoes.classList.remove('hidden');
            }
          });
        } else {
          fotoBlob = file;
          if (previewFoto.tagName === 'IMG') { previewFoto.src = ev.target.result; }
          fotoAcoes.classList.remove('hidden');
        }
      };
      reader.readAsDataURL(file);
      this.value = '';
    });
  }

  if (btnCancelarFoto) {
    btnCancelarFoto.addEventListener('click', function() {
      fotoAcoes.classList.add('hidden');
      fotoBlob = null;
      if (previewFoto.tagName === 'IMG' && fotoOrigSrc) previewFoto.src = fotoOrigSrc;
    });
  }

  if (btnSalvarFoto) {
    btnSalvarFoto.addEventListener('click', function() {
      if (!fotoBlob) return;
      btnSalvarFoto.disabled = true;
      btnSalvarFoto.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i>Salvando...';
      var fd = new FormData();
      fd.append('foto_perfil', new File([fotoBlob], 'foto.jpg', { type: 'image/jpeg' }));
      fetch('/perfil?_method=PUT', { method: 'POST', body: fd, headers: { 'Accept': 'application/json' }, credentials: 'same-origin' })
        .then(function(r) { return r.json(); })
        .then(function(d) {
          if (d.sucesso) {
            fotoAcoes.classList.add('hidden');
            fotoBlob = null;
            btnSalvarFoto.innerHTML = '<i class="fa-solid fa-check"></i>Salvo!';
            setTimeout(function() { btnSalvarFoto.innerHTML = '<i class="fa-solid fa-check"></i>Salvar'; btnSalvarFoto.disabled = false; }, 1500);
          } else {
            alert(d.mensagem || 'Erro ao salvar.');
            btnSalvarFoto.disabled = false;
            btnSalvarFoto.innerHTML = '<i class="fa-solid fa-check"></i>Salvar';
          }
        });
    });
  }

  // ── Banner ──
  var btnAbrirCapa = document.getElementById('btnAbrirCapa');
  var inputCapa = document.getElementById('foto_capa');
  var capaAcoes = document.getElementById('capaAcoes');
  var btnSalvarCapa = document.getElementById('btnSalvarCapa');
  var btnCancelarCapa = document.getElementById('btnCancelarCapa');
  var capaBlob = null;
  var bannerWrap = document.getElementById('bannerPreviewWrap');

  if (btnAbrirCapa) btnAbrirCapa.addEventListener('click', function() { inputCapa.click(); });

  if (inputCapa) {
    inputCapa.addEventListener('change', function() {
      var file = this.files[0];
      if (!file) return;
      var reader = new FileReader();
      reader.onload = function(ev) {
        capaBlob = file;
        bannerWrap.style.backgroundImage = 'url(' + ev.target.result + ')';
        bannerWrap.style.backgroundSize = 'cover';
        bannerWrap.style.backgroundPosition = 'center';
        capaAcoes.classList.remove('hidden');
        var img = bannerWrap.querySelector('img');
        if (img) { img.src = ev.target.result; }
      };
      reader.readAsDataURL(file);
      this.value = '';
    });
  }

  if (btnCancelarCapa) {
    btnCancelarCapa.addEventListener('click', function() {
      capaAcoes.classList.add('hidden');
      capaBlob = null;
    });
  }

  if (btnSalvarCapa) {
    btnSalvarCapa.addEventListener('click', function() {
      if (!capaBlob) return;
      btnSalvarCapa.disabled = true;
      btnSalvarCapa.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i>Salvando...';
      var fd = new FormData();
      fd.append('foto_capa', new File([capaBlob], 'capa.jpg', { type: 'image/jpeg' }));
      fetch('/perfil?_method=PUT', { method: 'POST', body: fd, headers: { 'Accept': 'application/json' }, credentials: 'same-origin' })
        .then(function(r) { return r.json(); })
        .then(function(d) {
          if (d.sucesso) {
            capaAcoes.classList.add('hidden');
            capaBlob = null;
            btnSalvarCapa.innerHTML = '<i class="fa-solid fa-check"></i>Salvo!';
            setTimeout(function() { btnSalvarCapa.innerHTML = '<i class="fa-solid fa-check"></i>Salvar capa'; btnSalvarCapa.disabled = false; }, 1500);
          } else {
            alert(d.mensagem || 'Erro.');
            btnSalvarCapa.disabled = false;
            btnSalvarCapa.innerHTML = '<i class="fa-solid fa-check"></i>Salvar capa';
          }
        });
    });
  }

  // ── CEP lookup ──
  var cepInput = document.getElementById('cep');
  if (cepInput) {
    cepInput.addEventListener('input', function() {
      var v = this.value.replace(/\D/g, '');
      if (v.length > 5) v = v.slice(0,5) + '-' + v.slice(5,8);
      this.value = v;
    });
  }

  var btnBuscarCep = document.getElementById('btnBuscarCep');
  if (btnBuscarCep) {
    btnBuscarCep.addEventListener('click', function() {
      var btn = this;
      var cep = (cepInput.value || '').replace(/\D/g,'');
      if (cep.length !== 8) { alert('CEP inválido.'); return; }
      btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i>';
      fetch('https://viacep.com.br/ws/' + cep + '/json/')
        .then(function(r) { return r.json(); })
        .then(function(d) {
          if (d.erro) { alert('CEP não encontrado.'); return; }
          if (d.logradouro) document.getElementById('endereco').value = d.logradouro;
          if (d.bairro) document.getElementById('bairro').value = d.bairro;
          if (d.localidade) document.getElementById('cidade').value = d.localidade;
          if (d.uf) document.getElementById('estado').value = d.uf;
        })
        .catch(function() { alert('Erro ao buscar CEP.'); })
        .finally(function() { btn.innerHTML = '<i class="fa-solid fa-magnifying-glass"></i>'; });
    });
  }

  // ── Geolocation ──
  var btnGeo = document.getElementById('btnGeolocalizacao');
  if (btnGeo) {
    btnGeo.addEventListener('click', function() {
      if (!navigator.geolocation) { alert('Geolocalização não suportada.'); return; }
      var btn = this;
      btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i>Obtendo localização...';
      btn.disabled = true;
      navigator.geolocation.getCurrentPosition(
        function(pos) {
          fetch('https://nominatim.openstreetmap.org/reverse?lat=' + pos.coords.latitude + '&lon=' + pos.coords.longitude + '&format=json&accept-language=pt-BR')
            .then(function(r) { return r.json(); })
            .then(function(d) {
              var a = d.address || {};
              if (a.road) document.getElementById('endereco').value = a.road + (a.house_number ? ', ' + a.house_number : '');
              if (a.suburb || a.neighbourhood) document.getElementById('bairro').value = a.suburb || a.neighbourhood;
              if (a.city || a.town || a.municipality) document.getElementById('cidade').value = a.city || a.town || a.municipality;
              btn.innerHTML = '<i class="fa-solid fa-check"></i>Localização obtida!';
              setTimeout(function() { btn.innerHTML = '<i class="fa-solid fa-crosshairs"></i>Usar localização atual'; btn.disabled = false; }, 2000);
            });
        },
        function() {
          alert('Não foi possível obter localização.');
          btn.innerHTML = '<i class="fa-solid fa-crosshairs"></i>Usar localização atual';
          btn.disabled = false;
        },
        { enableHighAccuracy: true, timeout: 10000 }
      );
    });
  }

  // ── Galeria ──
  (function galeria() {
    var container = document.getElementById('galeriaPorPetContainer');
    var loading = document.getElementById('galeriaLoading');
    var btnAdd = document.getElementById('btnAdicionarFotoGaleria');
    var fileInput = document.getElementById('galeriaFileInput');
    var petSelect = document.getElementById('galeriaPetSelect');
    if (!container || !btnAdd) return;

    function renderGaleria(data) {
      loading.classList.add('hidden');
      container.classList.remove('hidden');
      if (!data || data.length === 0) {
        container.innerHTML = '<p style="font-size:13px;color:var(--text-dim);text-align:center;padding:16px 0;">Nenhuma foto ainda. Selecione um pet e adicione fotos.</p>';
        return;
      }
      var html = '';
      data.forEach(function(item) {
        html += '<div style="margin-bottom:16px;" data-pet-id="' + item.pet_id + '">';
        html += '<h4 style="font-size:12px;font-weight:700;color:var(--text-dim);text-transform:uppercase;letter-spacing:0.08em;margin-bottom:10px;">' + (item.pet_nome || 'Pet') + '</h4>';
        html += '<div style="display:flex;flex-wrap:wrap;gap:8px;">';
        (item.fotos || []).forEach(function(f) {
          html += '<div style="position:relative;" class="galeria-item-wrap">';
          html += '<img src="' + f.foto + '" alt="" style="width:80px;height:80px;object-fit:cover;border-radius:10px;display:block;border:1px solid var(--border);">';
          html += '<button type="button" class="btn-remover-foto-galeria" data-id="' + f.id + '" style="position:absolute;top:4px;right:4px;width:22px;height:22px;border-radius:50%;background:rgba(0,0,0,0.7);backdrop-filter:blur(4px);border:none;color:#fff;cursor:pointer;font-size:10px;display:flex;align-items:center;justify-content:center;opacity:0;transition:opacity 0.15s;">';
          html += '<i class="fa-solid fa-xmark"></i></button></div>';
        });
        html += '</div></div>';
      });
      container.innerHTML = html;
      container.querySelectorAll('.galeria-item-wrap').forEach(function(w) {
        w.addEventListener('mouseenter', function() { w.querySelector('.btn-remover-foto-galeria').style.opacity = '1'; });
        w.addEventListener('mouseleave', function() { w.querySelector('.btn-remover-foto-galeria').style.opacity = '0'; });
      });
      container.querySelectorAll('.btn-remover-foto-galeria').forEach(function(btn) {
        btn.addEventListener('click', function() {
          if (!confirm('Remover esta foto?')) return;
          fetch('/perfil/galeria/' + this.getAttribute('data-id'), { method: 'DELETE', credentials: 'same-origin' })
            .then(function(r) { return r.json(); })
            .then(function(d) { if (d.sucesso) carregarGaleria(); });
        });
      });
    }

    function carregarGaleria() {
      loading.classList.remove('hidden');
      container.classList.add('hidden');
      fetch('/perfil/galeria', { credentials: 'same-origin' })
        .then(function(r) { return r.json(); })
        .then(function(d) { renderGaleria(d.galeria || []); })
        .catch(function() {
          loading.classList.add('hidden');
          container.classList.remove('hidden');
          container.innerHTML = '<p style="color:#f87171;font-size:13px;">Erro ao carregar galeria.</p>';
        });
    }

    btnAdd.addEventListener('click', function() { fileInput.click(); });
    fileInput.addEventListener('change', function() {
      var file = this.files[0];
      if (!file) return;
      if (!file.type.match(/^image\//)) { alert('Formato não suportado.'); this.value = ''; return; }
      var reader = new FileReader();
      reader.onload = function(ev) {
        fileInput.value = '';
        var petId = petSelect ? petSelect.value : '';
        if (!petId) { alert('Selecione um pet.'); return; }
        if (typeof openCropModal === 'function') {
          openCropModal({
            src: ev.target.result, aspectRatio: 0, maxWidth: 1200, maxHeight: 1200,
            onConfirm: function(blob) {
              var fd = new FormData();
              fd.append('pet_id', petId);
              fd.append('foto', new File([blob], 'foto.jpg', { type: 'image/jpeg' }));
              fetch('/perfil/galeria', { method: 'POST', body: fd, credentials: 'same-origin' })
                .then(function(r) { return r.json(); })
                .then(function(d) { if (d.sucesso) carregarGaleria(); else alert(d.mensagem || 'Erro.'); })
                .catch(function() { alert('Erro ao enviar.'); });
            }
          });
        } else {
          var fd = new FormData();
          fd.append('pet_id', petId);
          fd.append('foto', file);
          fetch('/perfil/galeria', { method: 'POST', body: fd, credentials: 'same-origin' })
            .then(function(r) { return r.json(); })
            .then(function(d) { if (d.sucesso) carregarGaleria(); else alert(d.mensagem || 'Erro.'); });
        }
      };
      reader.readAsDataURL(file);
    });

    carregarGaleria();
  })();

})();
</script>

<%- include('partials/footer') %>
