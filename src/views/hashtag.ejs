<%- include('partials/header') %>
<%- include('partials/flash') %>
<main class="flex-1 max-w-lg mx-auto px-4 py-6 pb-24">
  <h1 class="text-2xl font-extrabold text-slate-800">#<%= tag.slug %></h1>
  <p class="text-sm text-slate-500 mt-1"><%= totalSeguidores %> seguem · <%= posts.length %> posts recentes</p>
  <% if (uid) { %>
    <div class="mt-4 flex gap-2">
      <% if (seguindo) { %>
        <button type="button" id="btnHash" data-slug="<%= tag.slug %>" data-following="1"
          class="px-4 py-2 rounded-xl border border-slate-200 text-sm font-semibold text-slate-700">Seguindo</button>
      <% } else { %>
        <button type="button" id="btnHash" data-slug="<%= tag.slug %>" data-following="0"
          class="px-4 py-2 rounded-xl bg-orange-500 text-white text-sm font-semibold">Seguir hashtag</button>
      <% } %>
    </div>
  <% } else { %>
    <p class="mt-3 text-sm"><a href="/auth/login?return_to=/h/<%= tag.slug %>" class="text-orange-600 font-semibold">Entrar</a> para seguir esta hashtag.</p>
  <% } %>

  <div class="mt-8 space-y-4">
    <% (posts || []).forEach(function(p) { %>
      <article class="rounded-2xl border border-slate-200 overflow-hidden bg-white shadow-sm">
        <% if (p.foto) { %><img src="<%= p.foto %>" alt="" class="w-full max-h-64 object-cover"><% } %>
        <div class="p-3">
          <a href="/p/<%= p.pet_slug || '' %>" class="font-bold text-slate-800"><%= p.pet_nome || 'Pet' %></a>
          <p class="text-sm text-slate-600 mt-1"><%= (p.texto || p.legenda || '').slice(0, 200) %></p>
          <a href="/explorar#post-<%= p.id %>" class="text-xs text-orange-600 font-semibold mt-2 inline-block">Ver no feed</a>
        </div>
      </article>
    <% }); %>
  </div>
</main>
<% if (uid) { %>
<script>
(function(){
  var btn = document.getElementById('btnHash');
  if (!btn) return;
  btn.addEventListener('click', function(){
    var slug = btn.getAttribute('data-slug');
    var f = btn.getAttribute('data-following') === '1';
    var url = '/h/' + encodeURIComponent(slug) + '/seguir';
    var method = f ? 'DELETE' : 'POST';
    var headers = {
      'Accept': 'application/json',
      'X-Requested-With': 'XMLHttpRequest',
    };
    if (method === 'POST') headers['Content-Type'] = 'application/json';
    fetch(url, {
      method: method,
      credentials: 'same-origin',
      headers: headers,
      body: method === 'POST' ? '{}' : undefined,
    }).then(function (r) {
      if (r.status === 401) {
        window.location.href = '/auth/login?return_to=/h/' + encodeURIComponent(slug);
        return null;
      }
      return r.json().catch(function () { return { sucesso: false, mensagem: 'Resposta inválida.' }; });
    }).then(function (j) {
      if (!j || !j.sucesso) {
        alert((j && j.mensagem) || 'Não foi possível atualizar. Tente de novo.');
        return;
      }
      btn.setAttribute('data-following', f ? '0' : '1');
      btn.textContent = f ? 'Seguir hashtag' : 'Seguindo';
      btn.className = f ? 'px-4 py-2 rounded-xl bg-orange-500 text-white text-sm font-semibold' : 'px-4 py-2 rounded-xl border border-slate-200 text-sm font-semibold text-slate-700';
    });
  });
})();
</script>
<% } %>
<%- include('partials/footer') %>
